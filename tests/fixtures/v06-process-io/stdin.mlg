import "std/io"

func main() {
    match io.readStdin() {
        case Ok(text) {
            match io.writeStdout(con text) {
                case Ok(_) {
                }
                case Err(error) {
                    print(error)
                }
            }
        }
        case Err(error) {
            print(error)
        }
    }
}
