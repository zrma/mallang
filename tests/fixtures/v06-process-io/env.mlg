import "std/os"

func main() {
    present_name := "MALLANG_P149_TEST"
    match os.env(con present_name) {
        case Ok(Some(value)) {
            print(value)
        }
        case Ok(None) {
            missing := "missing-present"
            print(missing)
        }
        case Err(error) {
            print(error)
        }
    }

    missing_name := "MALLANG_P149_MISSING"
    match os.env(con missing_name) {
        case Ok(Some(value)) {
            print(value)
        }
        case Ok(None) {
            missing := "missing"
            print(missing)
        }
        case Err(error) {
            print(error)
        }
    }
}
