func optionValue(input Option[int]) int {
    return match input {
        case Some(value) { value }
        case None { 0 }
    }
}

func resultValue(input Result[int, bool]) int {
    return match input {
        case Ok(value) { value }
        case Err(failed) { if failed { 1 } else { 0 } }
    }
}

func optionOrZero(input Option[int]) int {
    return match input {
        case Some(value) { value }
        case _ { 0 }
    }
}

func main() {}
