func main() {
    base := 10
    total := add(base, 20)
    print(total)
    print(isPositive(total))
    print(-base)
    print(total / 3)
    print(total % 7)
    print(isPositive(total) && total == 30)
    print(total == 0 || isPositive(total))
}

func add(left int, right int) int {
    return left + right
}

func isPositive(value int) bool {
    return !(value <= 0
    )
}
