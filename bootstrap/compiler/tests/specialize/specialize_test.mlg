package specialize

import "bootstrap_compiler/frontend/lexer"
import "bootstrap_compiler/frontend/parser"
import "bootstrap_compiler/semantic"

test SpecializesGenericStructsFunctionsAndReceivers() {
    source := "type Box[T] struct { value T } func (mut box Box[T]) replace(value T) { box.value = value } func Identity[T](value T) T { return value } func main() { mut box := Box[string]{value: Identity[string](\"before\")}; box.replace(\"after\") }"
    match lexer.Lex(source) {
        case Ok(tokens) {
            match parser.Parse(tokens) {
                case Ok(program) {
                    match Specialize(con program) {
                        case Ok(concrete) {
                            match semantic.Check(con concrete) {
                                case Ok(checked) {
                                    expected := "CHECKED|1|0|2|1\nSTRUCT|__mlg_spec_type_426f785b737472696e675d|1\nFIELD|__mlg_spec_type_426f785b737472696e675d|value|string\nFUNC|main|unit|0\nFUNC|__mlg_spec_func_4964656e746974795b737472696e675d|string|1\nPARAM|__mlg_spec_func_4964656e746974795b737472696e675d|owned|value|string\nMETHOD|__mlg_spec_type_426f785b737472696e675d|replace|mut|box|unit|1\nMPARAM|__mlg_spec_type_426f785b737472696e675d|replace|owned|value|string"
                                    assert(semantic.Normalize(con checked) == expected)
                                }
                                case Err(_) {
                                    assert(false)
                                }
                            }
                        }
                        case Err(_) {
                            assert(false)
                        }
                    }
                }
                case Err(_) {
                    assert(false)
                }
            }
        }
        case Err(_) {
            assert(false)
        }
    }
}

test SpecializesGenericEnumsAndPreservesPatternOrigins() {
    source := "type Maybe[T] enum { None; Some(T) } func number(value Maybe[int]) int { return match value { case Maybe.Some(item) { item } case Maybe.None { 0 } } } func text(value Maybe[string]) string { return match value { case Maybe.Some(item) { item } case Maybe.None { \"\" } } } func main() {}"
    match lexer.Lex(source) {
        case Ok(tokens) {
            match parser.Parse(tokens) {
                case Ok(program) {
                    match Specialize(con program) {
                        case Ok(concrete) {
                            match semantic.Check(con concrete) {
                                case Ok(checked) {
                                    expected := "CHECKED|0|2|3|0\nENUM|__mlg_spec_enum_4d617962655b696e745d|2\nVARIANT|__mlg_spec_enum_4d617962655b696e745d|None|0\nVARIANT|__mlg_spec_enum_4d617962655b696e745d|Some|1|int\nENUM|__mlg_spec_enum_4d617962655b737472696e675d|2\nVARIANT|__mlg_spec_enum_4d617962655b737472696e675d|None|0\nVARIANT|__mlg_spec_enum_4d617962655b737472696e675d|Some|1|string\nFUNC|number|int|1\nPARAM|number|owned|value|__mlg_spec_enum_4d617962655b696e745d\nFUNC|text|string|1\nPARAM|text|owned|value|__mlg_spec_enum_4d617962655b737472696e675d\nFUNC|main|unit|0"
                                    assert(semantic.Normalize(con checked) == expected)
                                }
                                case Err(_) {
                                    assert(false)
                                }
                            }
                        }
                        case Err(_) {
                            assert(false)
                        }
                    }
                }
                case Err(_) {
                    assert(false)
                }
            }
        }
        case Err(_) {
            assert(false)
        }
    }
}

test RestoresSymbolicGenericBodyDiagnostics() {
    source := "type Box[T] struct { value T } func Debug[T](value Box[T]) { print(value) } func main() {}"
    match lexer.Lex(source) {
        case Ok(tokens) {
            match parser.Parse(tokens) {
                case Ok(program) {
                    match SpecializeForValidation(con program) {
                        case Ok(symbolic) {
                            validationProgram := Program(con symbolic)
                            match semantic.Check(con validationProgram) {
                                case Ok(_) {
                                    assert(false)
                                }
                                case Err(error) {
                                    message := semantic.ErrorMessage(con error)
                                    assert(RestoreMessage(con symbolic, con message) == "cannot print value of type `Box[T]` in v0")
                                }
                            }
                        }
                        case Err(_) {
                            assert(false)
                        }
                    }
                }
                case Err(_) {
                    assert(false)
                }
            }
        }
        case Err(_) {
            assert(false)
        }
    }
}
