                                    assert(lowered.nodes[lowered.nodes[fixedDrop].children[0]].value == "unused")
                                    assert(lowered.nodes[lowered.functions[0].body[2]].kind == "Stmt.Return")

                                    assert(len(lowered.functions[1].body) == 2)
                                    discardLet := lowered.functions[1].body[0]
                                    discardLiteral := lowered.nodes[discardLet].children[0]
                                    assert(lowered.nodes[discardLiteral].kind == "Expr.ArrayLiteral")
                                    assert(lowered.nodes[discardLiteral].ty == "[]string")
                                    discardDrop := lowered.functions[1].body[1]
                                    assert(lowered.nodes[discardDrop].kind == "Stmt.Drop")
                                    assert(lowered.nodes[lowered.nodes[discardDrop].children[0]].value == "values")

                                    assert(len(lowered.functions[2].body) == 1)
                                    collectReturn := lowered.functions[2].body[0]
                                    collectLiteral := lowered.nodes[collectReturn].children[0]
                                    assert(lowered.nodes[collectLiteral].kind == "Expr.ArrayLiteral")
                                    assert(lowered.nodes[collectLiteral].ty == "[]Entry")
                                    assert(lowered.nodes[lowered.nodes[collectLiteral].children[0]].value == "entry")
                                }
                                case Err(_) {
                                    assert(false)
                                }
                            }
                        }
                        case Err(_) {
                            assert(false)
                        }
                    }
                }
                case Err(_) {
                    assert(false)
                }
            }
        }
        case Err(_) {
            assert(false)
        }
    }
}

test LowersBuiltinConstructorCleanup() {
    source := "func some(value string, unused string) Option[string] { return Some(value) } func none(unused string) Option[string] { return None } func ok(value string, unused string) Result[string, string] { return Ok(value) } func err(value string) Result[int, string] { return Err(value) } func discard(value string) { option := Some(value) } func main() {}"
    match lexer.Lex(source) {
        case Ok(tokens) {
            match parser.Parse(tokens) {
                case Ok(program) {
                    match semantic.Check(con program) {
                        case Ok(checked) {
                            match Lower(con program, con checked) {
                                case Ok(lowered) {
                                    assert(len(lowered.functions[0].body) == 3)
                                    someTemp := lowered.functions[0].body[0]
                                    someConstructor := lowered.nodes[someTemp].children[0]
                                    assert(lowered.nodes[someConstructor].kind == "Expr.VariantConstructor.Inline")
                                    assert(lowered.nodes[someConstructor].value == "Some")
                                    assert(lowered.nodes[someConstructor].ty == "Option[string]")
                                    assert(lowered.nodes[lowered.nodes[someConstructor].children[0]].value == "value")
                                    someDrop := lowered.functions[0].body[1]
                                    assert(lowered.nodes[lowered.nodes[someDrop].children[0]].value == "unused")

                                    assert(len(lowered.functions[1].body) == 3)
                                    noneTemp := lowered.functions[1].body[0]
                                    noneConstructor := lowered.nodes[noneTemp].children[0]
                                    assert(lowered.nodes[noneConstructor].kind == "Expr.VariantConstructor.Inline")
                                    assert(lowered.nodes[noneConstructor].value == "None")
                                    assert(len(lowered.nodes[noneConstructor].children) == 0)
                                    noneDrop := lowered.functions[1].body[1]
                                    assert(lowered.nodes[lowered.nodes[noneDrop].children[0]].value == "unused")

                                    okConstructor := lowered.nodes[lowered.functions[2].body[0]].children[0]
                                    assert(lowered.nodes[okConstructor].value == "Ok")
                                    assert(lowered.nodes[okConstructor].ty == "Result[string, string]")
                                    errConstructor := lowered.nodes[lowered.functions[3].body[0]].children[0]
                                    assert(lowered.nodes[errConstructor].value == "Err")
                                    assert(lowered.nodes[errConstructor].ty == "Result[int, string]")

                                    assert(len(lowered.functions[4].body) == 2)
                                    discardLet := lowered.functions[4].body[0]
                                    discardConstructor := lowered.nodes[discardLet].children[0]
                                    assert(lowered.nodes[discardConstructor].value == "Some")
                                    discardDrop := lowered.functions[4].body[1]
                                    assert(lowered.nodes[discardDrop].kind == "Stmt.Drop")
                                    assert(lowered.nodes[lowered.nodes[discardDrop].children[0]].value == "option")
                                }
                                case Err(_) {
                                    assert(false)
                                }
                            }
                        }
                        case Err(_) {
                            assert(false)
                        }
                    }
                }
                case Err(_) {
                    assert(false)
                }
            }
        }
        case Err(_) {
            assert(false)
        }
    }
}

test LowersUserEnumConstructorStorageAndCleanup() {
    source := "type Message enum { Quit Text(string) Pair(string, int) } type Chain enum { End Link(string, Chain) } type Wrapped enum { Empty More(Option[Wrapped]) } type Through struct { next ThroughEnum } type ThroughEnum enum { End Box(Through) } func quit(unused string) Message { return Message.Quit } func text(value string, unused string) Message { return Message.Text(value) } func pair(value string) Message { return Message.Pair(value, 1) } func end(unused string) Chain { return Chain.End } func link(value string, tail Chain) Chain { return Chain.Link(value, tail) } func discard(value string) { chain := Chain.Link(value, Chain.End) } func wrappedEmpty(unused string) Wrapped { return Wrapped.Empty } func main() {}"
    match lexer.Lex(source) {
        case Ok(tokens) {
            match parser.Parse(tokens) {
                case Ok(program) {
                    match semantic.Check(con program) {
                        case Ok(checked) {
                            assert(semantic.EnumStorage(con checked, con "Message") == "inline")
                            assert(semantic.EnumStorage(con checked, con "Chain") == "owned")
                            assert(semantic.EnumStorage(con checked, con "Wrapped") == "owned")
                            assert(semantic.EnumStorage(con checked, con "ThroughEnum") == "owned")
                            match Lower(con program, con checked) {
                                case Ok(lowered) {
                                    assert(len(lowered.functions[0].body) == 3)
                                    quitConstructor := lowered.nodes[lowered.functions[0].body[0]].children[0]
                                    assert(lowered.nodes[quitConstructor].kind == "Expr.VariantConstructor.Inline")
                                    assert(lowered.nodes[quitConstructor].value == "Quit")
                                    assert(len(lowered.nodes[quitConstructor].children) == 0)
                                    quitDrop := lowered.functions[0].body[1]
                                    assert(lowered.nodes[lowered.nodes[quitDrop].children[0]].value == "unused")

                                    textConstructor := lowered.nodes[lowered.functions[1].body[0]].children[0]
                                    assert(lowered.nodes[textConstructor].kind == "Expr.VariantConstructor.Inline")
                                    assert(lowered.nodes[textConstructor].value == "Text")
                                    assert(lowered.nodes[lowered.nodes[textConstructor].children[0]].value == "value")
                                    textDrop := lowered.functions[1].body[1]
                                    assert(lowered.nodes[lowered.nodes[textDrop].children[0]].value == "unused")

                                    pairConstructor := lowered.nodes[lowered.functions[2].body[0]].children[0]
                                    assert(lowered.nodes[pairConstructor].value == "Pair")
                                    assert(len(lowered.nodes[pairConstructor].children) == 2)

                                    endConstructor := lowered.nodes[lowered.functions[3].body[0]].children[0]
                                    assert(lowered.nodes[endConstructor].kind == "Expr.VariantConstructor.Owned")
                                    assert(lowered.nodes[endConstructor].value == "End")
                                    linkConstructor := lowered.nodes[lowered.functions[4].body[0]].children[0]
                                    assert(lowered.nodes[linkConstructor].kind == "Expr.VariantConstructor.Owned")
                                    assert(lowered.nodes[linkConstructor].value == "Link")
                                    assert(len(lowered.nodes[linkConstructor].children) == 2)

                                    assert(len(lowered.functions[5].body) == 2)
                                    discardLet := lowered.functions[5].body[0]
                                    discardConstructor := lowered.nodes[discardLet].children[0]
                                    assert(lowered.nodes[discardConstructor].kind == "Expr.VariantConstructor.Owned")
                                    nestedEnd := lowered.nodes[discardConstructor].children[1]
                                    assert(lowered.nodes[nestedEnd].kind == "Expr.VariantConstructor.Owned")
                                    discardDrop := lowered.functions[5].body[1]
                                    assert(lowered.nodes[discardDrop].kind == "Stmt.Drop")
                                    assert(lowered.nodes[lowered.nodes[discardDrop].children[0]].value == "chain")

                                    assert(len(lowered.functions[6].body) == 3)
                                    wrappedConstructor := lowered.nodes[lowered.functions[6].body[0]].children[0]
                                    assert(lowered.nodes[wrappedConstructor].kind == "Expr.VariantConstructor.Owned")
                                    assert(lowered.nodes[wrappedConstructor].value == "Empty")
                                    wrappedDrop := lowered.functions[6].body[1]
                                    assert(lowered.nodes[lowered.nodes[wrappedDrop].children[0]].value == "unused")
                                }
                                case Err(_) {
                                    assert(false)
                                }
                            }
                        }
                        case Err(_) {
                            assert(false)
                        }
                    }
                }
                case Err(_) {
                    assert(false)
                }
            }
        }
        case Err(_) {
            assert(false)
        }
    }
}

test LowersCopyBuiltinMatchExpressions() {
    source := "func optionValue(input Option[int]) int { return match input { case Some(value) { value } case None { 0 } } } func resultValue(input Result[int, bool]) int { return match input { case Ok(value) { value } case Err(failed) { if failed { 1 } else { 0 } } } } func optionOrZero(input Option[int]) int { return match input { case Some(value) { value } case _ { 0 } } } func main() {}"
    match lexer.Lex(source) {
        case Ok(tokens) {
            match parser.Parse(tokens) {
                case Ok(program) {
                    match semantic.Check(con program) {
                        case Ok(checked) {
                            match Lower(con program, con checked) {
                                case Ok(lowered) {
                                    optionMatch := lowered.nodes[lowered.functions[0].body[0]].children[0]
                                    assert(lowered.nodes[optionMatch].kind == "Expr.Match")
                                    assert(len(lowered.nodes[optionMatch].children) == 3)
                                    someArm := lowered.nodes[optionMatch].children[1]
                                    assert(lowered.nodes[someArm].kind == "Match.Arm")
                                    somePattern := lowered.nodes[someArm].children[0]
                                    assert(lowered.nodes[somePattern].kind == "Pattern.Variant.Inline")
                                    assert(lowered.nodes[somePattern].value == "Some")
                                    someBinding := lowered.nodes[somePattern].children[0]
                                    assert(lowered.nodes[someBinding].kind == "Pattern.Binding")
                                    assert(lowered.nodes[someBinding].value == "value")
                                    assert(lowered.nodes[someBinding].ty == "int")
                                    nonePattern := lowered.nodes[lowered.nodes[optionMatch].children[2]].children[0]
                                    assert(lowered.nodes[nonePattern].value == "None")

                                    resultMatch := lowered.nodes[lowered.functions[1].body[0]].children[0]
                                    assert(lowered.nodes[resultMatch].kind == "Expr.Match")
                                    errPattern := lowered.nodes[lowered.nodes[resultMatch].children[2]].children[0]
                                    assert(lowered.nodes[errPattern].value == "Err")
                                    errBinding := lowered.nodes[errPattern].children[0]
                                    assert(lowered.nodes[errBinding].ty == "bool")

                                    wildcardMatch := lowered.nodes[lowered.functions[2].body[0]].children[0]
                                    wildcardPattern := lowered.nodes[lowered.nodes[wildcardMatch].children[2]].children[0]
                                    assert(lowered.nodes[wildcardPattern].kind == "Pattern.Wildcard")
                                    assert(lowered.nodes[wildcardPattern].ty == "Option[int]")
                                }
                                case Err(_) {
                                    assert(false)
                                }
                            }
                        }
                        case Err(_) {
                            assert(false)
                        }
                    }
                }
                case Err(_) {
                    assert(false)
                }
            }
        }
        case Err(_) {
            assert(false)
        }
    }
}

test LowersCleanupBuiltinMatchExpressions() {
    source := "func unwrap(input Option[string], unused string) string { return match input { case Some(value) { value } case None { \"fallback\" } } } func inspect(input Option[string]) int { return match input { case Some(value) { if value == \"\" { 1 } else { 2 } } case None { 0 } } } func ignore(input Option[string]) int { return match input { case _ { 0 } } } func main() {}"
    match lexer.Lex(source) {
        case Ok(tokens) {
            match parser.Parse(tokens) {
                case Ok(program) {
                    match semantic.Check(con program) {
                        case Ok(checked) {
                            match Lower(con program, con checked) {
                                case Ok(lowered) {
                                    assert(len(lowered.functions[0].body) == 3)
                                    unwrapTemp := lowered.functions[0].body[0]
                                    unwrapMatch := lowered.nodes[unwrapTemp].children[0]
                                    assert(lowered.nodes[unwrapMatch].kind == "Expr.Match")
                                    someArm := lowered.nodes[unwrapMatch].children[1]
                                    assert(len(lowered.nodes[someArm].children) == 2)
                                    someBranch := lowered.nodes[someArm].children[1]
                                    assert(lowered.nodes[someBranch].kind == "Expr.Var")
                                    assert(lowered.nodes[someBranch].value == "value")
                                    unwrapDrop := lowered.functions[0].body[1]
                                    assert(lowered.nodes[unwrapDrop].kind == "Stmt.Drop")
                                    assert(lowered.nodes[lowered.nodes[unwrapDrop].children[0]].value == "unused")
                                    assert(lowered.nodes[lowered.functions[0].body[2]].kind == "Stmt.Return")

                                    assert(len(lowered.functions[1].body) == 1)
                                    inspectMatch := lowered.nodes[lowered.functions[1].body[0]].children[0]
                                    inspectSomeArm := lowered.nodes[inspectMatch].children[1]
                                    assert(len(lowered.nodes[inspectSomeArm].children) == 3)
                                    inspectBranch := lowered.nodes[inspectSomeArm].children[1]
                                    equality := lowered.nodes[inspectBranch].children[0]
                                    equalityRight := lowered.nodes[equality].children[1]
                                    assert(lowered.nodes[equalityRight].kind == "Expr.FullExprTemporary")
                                    bindingDrop := lowered.nodes[inspectSomeArm].children[2]
                                    assert(lowered.nodes[bindingDrop].kind == "Stmt.Drop")
                                    assert(lowered.nodes[lowered.nodes[bindingDrop].children[0]].value == "value")

                                    assert(len(lowered.functions[2].body) == 1)
                                    ignoreMatch := lowered.nodes[lowered.functions[2].body[0]].children[0]
                                    ignoreArm := lowered.nodes[ignoreMatch].children[1]
                                    assert(len(lowered.nodes[ignoreArm].children) == 3)
                                    ignorePattern := lowered.nodes[ignoreArm].children[0]
                                    assert(lowered.nodes[ignorePattern].kind == "Pattern.Binding")
                                    ignoreDrop := lowered.nodes[ignoreArm].children[2]
                                    assert(lowered.nodes[ignoreDrop].kind == "Stmt.Drop")
                                    ignoreDropValue := lowered.nodes[ignoreDrop].children[0]
                                    assert(lowered.nodes[ignoreDropValue].value == lowered.nodes[ignorePattern].value)
                                }
                                case Err(_) {
                                    assert(false)
                                }
                            }
                        }
                        case Err(_) {
                            assert(false)
                        }
                    }
                }
                case Err(_) {
                    assert(false)
                }
            }
        }
        case Err(_) {
            assert(false)
        }
    }
}

test LowersFieldAndIndexReads() {
    source := "type User struct { age int } func readAge(con user User) int { return user.age } func readArray(con values [2]int) int { return values[0] + values[1] } func main() {}"
    match lexer.Lex(source) {
        case Ok(tokens) {
            match parser.Parse(tokens) {
                case Ok(program) {
                    match semantic.Check(con program) {
                        case Ok(checked) {
                            match Lower(con program, con checked) {
                                case Ok(lowered) {
                                    mut fields := 0
                                    mut indexes := 0
                                    for mut node := 0; node < len(lowered.nodes); node = node + 1 {
                                        if lowered.nodes[node].kind == "Expr.FieldAccess" {
                                            fields = fields + 1
                                        } else if lowered.nodes[node].kind == "Expr.Index" {
                                            indexes = indexes + 1
                                        }
                                    }
                                    assert(fields == 1)
                                    assert(indexes == 2)
                                }
                                case Err(_) {
                                    assert(false)
                                }
                            }
                        }
                        case Err(_) {
                            assert(false)
                        }
                    }
                }
                case Err(_) {
                    assert(false)
                }
            }
        }
        case Err(_) {
            assert(false)
        }
    }
}

test LowersFieldAndIndexAssignments() {
    source := "type User struct { age int } func updateUser(mut user User) int { user.age = 31; return user.age } func updateArray(mut values [2]int) int { values[1] = 7; return values[1] } func main() {}"
    match lexer.Lex(source) {
        case Ok(tokens) {
            match parser.Parse(tokens) {
