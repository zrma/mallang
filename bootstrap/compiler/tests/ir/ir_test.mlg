package ir

import "bootstrap_compiler/frontend/ast"
import "bootstrap_compiler/frontend/lexer"
import "bootstrap_compiler/frontend/parser"
import "bootstrap_compiler/semantic"

test LowersPrimitiveTypedNodes() {
    source := "func compute(left int, right int) int { mut total := left + right * 2; total = total - 1; return total } func main() {}"
    match lexer.Lex(source) {
        case Ok(tokens) {
            match parser.Parse(tokens) {
                case Ok(program) {
                    match semantic.Check(con program) {
                        case Ok(checked) {
                            match Lower(con program, con checked) {
                                case Ok(lowered) {
                                    assert(len(lowered.functions) == 2)
                                    assert(len(lowered.nodes) == 12)
                                    assert(lowered.nodes[11].kind == "Stmt.Return")
                                }
                                case Err(_) {
                                    assert(false)
                                }
                            }
                        }
                        case Err(_) {
                            assert(false)
                        }
                    }
                }
                case Err(_) {
                    assert(false)
                }
            }
        }
        case Err(_) {
            assert(false)
        }
    }
}

test LowersFunctionValuesAndCalls() {
    source := "func add(left int, right int) int { return left + right } func select() func(int, int) int { return add } func apply(con operation func(int, int) int, left int, right int) int { return operation(left, right) } func compute() int { return add(1, 2) } func main() {}"
    match lexer.Lex(source) {
        case Ok(tokens) {
            match parser.Parse(tokens) {
                case Ok(program) {
                    match semantic.Check(con program) {
                        case Ok(checked) {
                            match Lower(con program, con checked) {
                                case Ok(lowered) {
                                    mut functionValues := 0
                                    mut directCalls := 0
                                    mut indirectCalls := 0
                                    for mut node := 0; node < len(lowered.nodes); node = node + 1 {
                                        if lowered.nodes[node].kind == "Expr.FunctionValue" {
                                            functionValues = functionValues + 1
                                        } else if lowered.nodes[node].kind == "Expr.Call" {
                                            directCalls = directCalls + 1
                                        } else if lowered.nodes[node].kind == "Expr.IndirectCall" {
                                            indirectCalls = indirectCalls + 1
                                        }
                                    }
                                    assert(functionValues == 1)
                                    assert(directCalls == 1)
                                    assert(indirectCalls == 1)
                                }
                                case Err(_) {
                                    assert(false)
                                }
                            }
                        }
                        case Err(_) {
                            assert(false)
                        }
                    }
                }
                case Err(_) {
                    assert(false)
                }
            }
        }
        case Err(_) {
            assert(false)
        }
    }
}

test LowersClosureDefinitionsAndCaptureValues() {
    source := "func make(offset int) func(int) int { return func(value int) int { return value + offset } } func main() {}"
    match lexer.Lex(source) {
        case Ok(tokens) {
            match parser.Parse(tokens) {
                case Ok(program) {
                    match semantic.Check(con program) {
                        case Ok(checked) {
                            match Lower(con program, con checked) {
                                case Ok(lowered) {
                                    assert(len(lowered.closures) == 1)
                                    assert(!lowered.closures[0].mutable)
                                    assert(len(lowered.closures[0].captures) == 1)
                                    assert(lowered.closures[0].captures[0].name == "offset")
                                    assert(lowered.closures[0].captures[0].ty == "int")
                                    assert(!lowered.closures[0].captures[0].mutable)
                                    assert(len(lowered.closures[0].params) == 1)
                                    assert(lowered.closures[0].params[0].name == "value")
                                    assert(lowered.closures[0].params[0].mode == "owned")
                                    assert(lowered.closures[0].params[0].ty == "int")
                                    assert(lowered.closures[0].returnType == "int")
                                    assert(len(lowered.closures[0].body) == 1)

                                    mut closureValues := 0
                                    mut captureValues := 0
                                    for mut node := 0; node < len(lowered.nodes); node = node + 1 {
                                        if lowered.nodes[node].kind == "Expr.ClosureValue" {
                                            closureValues = closureValues + 1
                                            assert(lowered.nodes[node].value == lowered.closures[0].name)
                                        } else if lowered.nodes[node].kind == "Closure.Capture" {
                                            captureValues = captureValues + 1
                                            assert(lowered.nodes[node].value == "offset")
                                            assert(lowered.nodes[node].ty == "int")
                                        }
                                    }
                                    assert(closureValues == 1)
                                    assert(captureValues == 1)
                                }
                                case Err(_) {
                                    assert(false)
                                }
                            }
                        }
                        case Err(_) {
                            assert(false)
                        }
                    }
                }
                case Err(_) {
                    assert(false)
                }
            }
        }
        case Err(_) {
            assert(false)
        }
    }
}

test LowersMutableNestedClosureMetadata() {
    source := "func make() func mut() func mut() int { mut count := 0; return func mut() func mut() int { return func mut() int { count = count + 1; return count } } } func main() {}"
    match lexer.Lex(source) {
        case Ok(tokens) {
            match parser.Parse(tokens) {
                case Ok(program) {
                    match semantic.Check(con program) {
                        case Ok(checked) {
                            match Lower(con program, con checked) {
                                case Ok(lowered) {
                                    assert(len(lowered.closures) == 2)
                                    assert(lowered.closures[0].mutable)
                                    assert(lowered.closures[1].mutable)
                                    assert(len(lowered.closures[0].captures) == 1)
                                    assert(len(lowered.closures[1].captures) == 1)
                                    assert(lowered.closures[0].captures[0].name == "count")
                                    assert(lowered.closures[1].captures[0].name == "count")
                                    assert(lowered.closures[0].captures[0].mutable)
                                    assert(lowered.closures[1].captures[0].mutable)

                                    mut closureValues := 0
                                    mut captureValues := 0
                                    for mut node := 0; node < len(lowered.nodes); node = node + 1 {
                                        if lowered.nodes[node].kind == "Expr.ClosureValue" {
                                            closureValues = closureValues + 1
                                        } else if lowered.nodes[node].kind == "Closure.Capture" {
                                            captureValues = captureValues + 1
                                        }
                                    }
                                    assert(closureValues == 2)
                                    assert(captureValues == 2)
                                }
                                case Err(_) {
                                    assert(false)
                                }
                            }
                        }
                        case Err(_) {
                            assert(false)
                        }
                    }
                }
                case Err(_) {
                    assert(false)
                }
            }
        }
        case Err(_) {
            assert(false)
        }
    }
}

test InsertsStraightLineCleanupDrops() {
    source := "func dropParam(name string) {} func dropLocal() { name := \"kim\" } func moveReturn(name string) string { return name } func dropBeforeReturn(name string) int { return 1 } func take(name string) {} func moveCall(name string) { take(name) } func main() {}"
    match lexer.Lex(source) {
        case Ok(tokens) {
            match parser.Parse(tokens) {
                case Ok(program) {
                    match semantic.Check(con program) {
                        case Ok(checked) {
                            match Lower(con program, con checked) {
                                case Ok(lowered) {
                                    assert(len(lowered.functions) == 7)
                                    assert(len(lowered.functions[0].body) == 1)
                                    assert(lowered.nodes[lowered.functions[0].body[0]].kind == "Stmt.Drop")
                                    assert(len(lowered.functions[1].body) == 2)
                                    assert(lowered.nodes[lowered.functions[1].body[1]].kind == "Stmt.Drop")
                                    assert(len(lowered.functions[2].body) == 1)
                                    assert(lowered.nodes[lowered.functions[2].body[0]].kind == "Stmt.Return")
                                    assert(len(lowered.functions[3].body) == 3)
                                    assert(lowered.nodes[lowered.functions[3].body[0]].kind == "Stmt.Let.Immutable")
                                    assert(lowered.nodes[lowered.functions[3].body[0]].value != "")
                                    assert(lowered.nodes[lowered.functions[3].body[1]].kind == "Stmt.Drop")
                                    assert(lowered.nodes[lowered.functions[3].body[2]].kind == "Stmt.Return")
                                    assert(len(lowered.functions[5].body) == 1)
                                    assert(lowered.nodes[lowered.functions[5].body[0]].kind == "Stmt.Expr")
                                }
                                case Err(_) {
                                    assert(false)
                                }
                            }
                        }
                        case Err(_) {
                            assert(false)
                        }
                    }
                }
                case Err(_) {
                    assert(false)
                }
            }
        }
        case Err(_) {
            assert(false)
        }
    }
}

test InsertsBranchLocalCleanupDrops() {
    source := "func branch(flag bool) { if flag { name := \"yes\" } else { name := \"no\" } } func branchReturn(flag bool) int { if flag { name := \"yes\"; return 1 } else { name := \"no\"; return 2 } } func main() {}"
    match lexer.Lex(source) {
        case Ok(tokens) {
            match parser.Parse(tokens) {
                case Ok(program) {
                    match semantic.Check(con program) {
                        case Ok(checked) {
                            match Lower(con program, con checked) {
                                case Ok(lowered) {
                                    firstIf := lowered.functions[0].body[0]
                                    firstThen := lowered.nodes[firstIf].children[1]
                                    firstElse := lowered.nodes[firstIf].children[2]
                                    assert(len(lowered.nodes[firstThen].children) == 2)
                                    assert(len(lowered.nodes[firstElse].children) == 2)
                                    assert(lowered.nodes[lowered.nodes[firstThen].children[1]].kind == "Stmt.Drop")
                                    assert(lowered.nodes[lowered.nodes[firstElse].children[1]].kind == "Stmt.Drop")

                                    secondIf := lowered.functions[1].body[0]
                                    secondThen := lowered.nodes[secondIf].children[1]
                                    secondElse := lowered.nodes[secondIf].children[2]
                                    assert(len(lowered.nodes[secondThen].children) == 4)
                                    assert(len(lowered.nodes[secondElse].children) == 4)
                                    assert(lowered.nodes[lowered.nodes[secondThen].children[2]].kind == "Stmt.Drop")
                                    assert(lowered.nodes[lowered.nodes[secondElse].children[2]].kind == "Stmt.Drop")
                                }
                                case Err(_) {
                                    assert(false)
                                }
                            }
                        }
                        case Err(_) {
                            assert(false)
                        }
                    }
                }
                case Err(_) {
                    assert(false)
                }
            }
        }
        case Err(_) {
            assert(false)
        }
    }
}

test JoinsOuterCleanupAcrossBranches() {
    source := "func take(name string) {} func keep(flag bool, name string) { if flag {} else {} } func moveThen(flag bool, name string) { if flag { take(name) } else {} } func moveElse(flag bool, name string) { if flag {} else { take(name) } } func moveBoth(flag bool, name string) { if flag { take(name) } else { take(name) } } func returnBoth(flag bool, name string) int { if flag { return 1 } else { return 2 } } func nested(outer bool, inner bool, name string) { if outer { if inner { take(name) } else {} } else {} } func main() {}"
    match lexer.Lex(source) {
        case Ok(tokens) {
            match parser.Parse(tokens) {
                case Ok(program) {
                    match semantic.Check(con program) {
                        case Ok(checked) {
                            match Lower(con program, con checked) {
                                case Ok(lowered) {
                                    assert(len(lowered.functions[1].body) == 2)
                                    assert(lowered.nodes[lowered.functions[1].body[1]].kind == "Stmt.Drop")

                                    thenIf := lowered.functions[2].body[0]
                                    thenBranch := lowered.nodes[thenIf].children[1]
                                    thenElse := lowered.nodes[thenIf].children[2]
                                    assert(len(lowered.nodes[thenBranch].children) == 1)
                                    assert(len(lowered.nodes[thenElse].children) == 1)
                                    assert(lowered.nodes[lowered.nodes[thenElse].children[0]].kind == "Stmt.Drop")
                                    assert(len(lowered.functions[2].body) == 1)

                                    elseIf := lowered.functions[3].body[0]
                                    elseThen := lowered.nodes[elseIf].children[1]
                                    elseBranch := lowered.nodes[elseIf].children[2]
                                    assert(len(lowered.nodes[elseThen].children) == 1)
                                    assert(lowered.nodes[lowered.nodes[elseThen].children[0]].kind == "Stmt.Drop")
                                    assert(len(lowered.nodes[elseBranch].children) == 1)
                                    assert(len(lowered.functions[3].body) == 1)

                                    assert(len(lowered.functions[4].body) == 1)
                                    assert(len(lowered.functions[5].body) == 2)
                                    assert(lowered.nodes[lowered.functions[5].body[1]].kind == "Stmt.Drop")
                                    returningIf := lowered.functions[5].body[0]
                                    returningThen := lowered.nodes[returningIf].children[1]
                                    returningElse := lowered.nodes[returningIf].children[2]
                                    assert(len(lowered.nodes[returningThen].children) == 3)
                                    assert(len(lowered.nodes[returningElse].children) == 3)
                                    assert(lowered.nodes[lowered.nodes[returningThen].children[1]].kind == "Stmt.Drop")
                                    assert(lowered.nodes[lowered.nodes[returningElse].children[1]].kind == "Stmt.Drop")

                                    nestedIf := lowered.functions[6].body[0]
                                    nestedThen := lowered.nodes[nestedIf].children[1]
                                    nestedElse := lowered.nodes[nestedIf].children[2]
                                    assert(len(lowered.nodes[nestedThen].children) == 1)
                                    assert(len(lowered.nodes[nestedElse].children) == 1)
                                    assert(lowered.nodes[lowered.nodes[nestedElse].children[0]].kind == "Stmt.Drop")
                                }
                                case Err(_) {
                                    assert(false)
                                }
                            }
                        }
                        case Err(_) {
                            assert(false)
                        }
                    }
                }
                case Err(_) {
                    assert(false)
                }
            }
        }
        case Err(_) {
            assert(false)
        }
    }
}

test LowersFieldAndIndexReads() {
    source := "type User struct { age int } func readAge(con user User) int { return user.age } func readArray(con values [2]int) int { return values[0] + values[1] } func main() {}"
    match lexer.Lex(source) {
        case Ok(tokens) {
            match parser.Parse(tokens) {
                case Ok(program) {
                    match semantic.Check(con program) {
                        case Ok(checked) {
                            match Lower(con program, con checked) {
                                case Ok(lowered) {
                                    mut fields := 0
                                    mut indexes := 0
                                    for mut node := 0; node < len(lowered.nodes); node = node + 1 {
                                        if lowered.nodes[node].kind == "Expr.FieldAccess" {
                                            fields = fields + 1
                                        } else if lowered.nodes[node].kind == "Expr.Index" {
                                            indexes = indexes + 1
                                        }
                                    }
                                    assert(fields == 1)
                                    assert(indexes == 2)
                                }
                                case Err(_) {
                                    assert(false)
                                }
                            }
                        }
                        case Err(_) {
                            assert(false)
                        }
                    }
                }
                case Err(_) {
                    assert(false)
                }
            }
        }
        case Err(_) {
            assert(false)
        }
    }
}

test LowersFieldAndIndexAssignments() {
    source := "type User struct { age int } func updateUser(mut user User) int { user.age = 31; return user.age } func updateArray(mut values [2]int) int { values[1] = 7; return values[1] } func main() {}"
    match lexer.Lex(source) {
        case Ok(tokens) {
            match parser.Parse(tokens) {
                case Ok(program) {
                    match semantic.Check(con program) {
                        case Ok(checked) {
                            match Lower(con program, con checked) {
                                case Ok(lowered) {
                                    mut fieldAssignments := 0
                                    mut indexAssignments := 0
                                    for mut node := 0; node < len(lowered.nodes); node = node + 1 {
                                        if lowered.nodes[node].kind == "Stmt.FieldAssign" {
                                            fieldAssignments = fieldAssignments + 1
                                        } else if lowered.nodes[node].kind == "Stmt.IndexAssign" {
                                            indexAssignments = indexAssignments + 1
                                        }
                                    }
                                    assert(fieldAssignments == 1)
                                    assert(indexAssignments == 1)
                                }
                                case Err(_) {
                                    assert(false)
                                }
                            }
                        }
                        case Err(_) {
                            assert(false)
                        }
                    }
                }
                case Err(_) {
                    assert(false)
                }
            }
        }
        case Err(_) {
            assert(false)
        }
    }
}

test LowersNestedIfStatements() {
    source := "func choose(flag bool, nested bool) int { value := 1; if flag { value := 2; if nested { return value } else { return 3 } } else { return value } } func main() {}"
    match lexer.Lex(source) {
        case Ok(tokens) {
            match parser.Parse(tokens) {
                case Ok(program) {
                    match semantic.Check(con program) {
                        case Ok(checked) {
                            match Lower(con program, con checked) {
                                case Ok(lowered) {
                                    mut statements := 0
                                    mut thenBlocks := 0
                                    mut elseBlocks := 0
                                    for mut node := 0; node < len(lowered.nodes); node = node + 1 {
                                        if lowered.nodes[node].kind == "Stmt.If" {
                                            statements = statements + 1
                                        } else if lowered.nodes[node].kind == "Block.Then" {
                                            thenBlocks = thenBlocks + 1
                                        } else if lowered.nodes[node].kind == "Block.Else" {
                                            elseBlocks = elseBlocks + 1
                                        }
                                    }
                                    assert(statements == 2)
                                    assert(thenBlocks == 2)
                                    assert(elseBlocks == 2)
                                }
                                case Err(_) {
                                    assert(false)
                                }
                            }
                        }
                        case Err(_) {
                            assert(false)
                        }
                    }
                }
                case Err(_) {
                    assert(false)
                }
            }
        }
        case Err(_) {
            assert(false)
        }
    }
}

test LowersNestedIfExpressions() {
    source := "func choose(flag bool, nested bool) int { return if flag { 1 } else if nested { 2 } else { 3 } } func main() {}"
    match lexer.Lex(source) {
        case Ok(tokens) {
            match parser.Parse(tokens) {
                case Ok(program) {
                    match semantic.Check(con program) {
                        case Ok(checked) {
                            match Lower(con program, con checked) {
                                case Ok(lowered) {
                                    mut expressions := 0
                                    for mut node := 0; node < len(lowered.nodes); node = node + 1 {
                                        if lowered.nodes[node].kind == "Expr.If" {
                                            expressions = expressions + 1
                                        }
                                    }
                                    assert(expressions == 2)
                                }
                                case Err(_) {
                                    assert(false)
                                }
                            }
                        }
                        case Err(_) {
                            assert(false)
                        }
                    }
                }
                case Err(_) {
                    assert(false)
                }
            }
        }
        case Err(_) {
            assert(false)
        }
    }
}
