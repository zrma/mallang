                    assert(false)
                }
            }
        }
        case Err(_) {
            assert(false)
        }
    }
}

test LowersNestedIfStatements() {
    source := "func choose(flag bool, nested bool) int { value := 1; if flag { value := 2; if nested { return value } else { return 3 } } else { return value } } func main() {}"
    match lexer.Lex(source) {
        case Ok(tokens) {
            match parser.Parse(tokens) {
                case Ok(program) {
                    match semantic.Check(con program) {
                        case Ok(checked) {
                            match Lower(con program, con checked) {
                                case Ok(lowered) {
                                    mut statements := 0
                                    mut thenBlocks := 0
                                    mut elseBlocks := 0
                                    for mut node := 0; node < len(lowered.nodes); node = node + 1 {
                                        if lowered.nodes[node].kind == "Stmt.If" {
                                            statements = statements + 1
                                        } else if lowered.nodes[node].kind == "Block.Then" {
                                            thenBlocks = thenBlocks + 1
                                        } else if lowered.nodes[node].kind == "Block.Else" {
                                            elseBlocks = elseBlocks + 1
                                        }
                                    }
                                    assert(statements == 2)
                                    assert(thenBlocks == 2)
                                    assert(elseBlocks == 2)
                                }
                                case Err(_) {
                                    assert(false)
                                }
                            }
                        }
                        case Err(_) {
                            assert(false)
                        }
                    }
                }
                case Err(_) {
                    assert(false)
                }
            }
        }
        case Err(_) {
            assert(false)
        }
    }
}

test LowersNestedIfExpressions() {
    source := "func choose(flag bool, nested bool) int { return if flag { 1 } else if nested { 2 } else { 3 } } func main() {}"
    match lexer.Lex(source) {
        case Ok(tokens) {
            match parser.Parse(tokens) {
                case Ok(program) {
                    match semantic.Check(con program) {
                        case Ok(checked) {
                            match Lower(con program, con checked) {
                                case Ok(lowered) {
                                    mut expressions := 0
                                    for mut node := 0; node < len(lowered.nodes); node = node + 1 {
                                        if lowered.nodes[node].kind == "Expr.If" {
                                            expressions = expressions + 1
                                        }
                                    }
                                    assert(expressions == 2)
                                }
                                case Err(_) {
                                    assert(false)
                                }
                            }
                        }
                        case Err(_) {
                            assert(false)
                        }
                    }
                }
                case Err(_) {
                    assert(false)
                }
            }
        }
        case Err(_) {
            assert(false)
        }
    }
}
