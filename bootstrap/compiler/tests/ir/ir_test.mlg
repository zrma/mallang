package ir

import "bootstrap_compiler/frontend/ast"
import "bootstrap_compiler/frontend/lexer"
import "bootstrap_compiler/frontend/parser"
import "bootstrap_compiler/semantic"

test LowersPrimitiveTypedNodes() {
    source := "func compute(left int, right int) int { mut total := left + right * 2; total = total - 1; return total } func main() {}"
    match lexer.Lex(source) {
        case Ok(tokens) {
            match parser.Parse(tokens) {
                case Ok(program) {
                    match semantic.Check(con program) {
                        case Ok(checked) {
                            match Lower(con program, con checked) {
                                case Ok(lowered) {
                                    assert(len(lowered.functions) == 2)
                                    assert(len(lowered.nodes) == 12)
                                    assert(lowered.nodes[11].kind == "Stmt.Return")
                                }
                                case Err(_) {
                                    assert(false)
                                }
                            }
                        }
                        case Err(_) {
                            assert(false)
                        }
                    }
                }
                case Err(_) {
                    assert(false)
                }
            }
        }
        case Err(_) {
            assert(false)
        }
    }
}

test LowersFunctionValuesAndCalls() {
    source := "func add(left int, right int) int { return left + right } func select() func(int, int) int { return add } func apply(con operation func(int, int) int, left int, right int) int { return operation(left, right) } func compute() int { return add(1, 2) } func main() {}"
    match lexer.Lex(source) {
        case Ok(tokens) {
            match parser.Parse(tokens) {
                case Ok(program) {
                    match semantic.Check(con program) {
                        case Ok(checked) {
                            match Lower(con program, con checked) {
                                case Ok(lowered) {
                                    mut functionValues := 0
                                    mut directCalls := 0
                                    mut indirectCalls := 0
                                    for mut node := 0; node < len(lowered.nodes); node = node + 1 {
                                        if lowered.nodes[node].kind == "Expr.FunctionValue" {
                                            functionValues = functionValues + 1
                                        } else if lowered.nodes[node].kind == "Expr.Call" {
                                            directCalls = directCalls + 1
                                        } else if lowered.nodes[node].kind == "Expr.IndirectCall" {
                                            indirectCalls = indirectCalls + 1
                                        }
                                    }
                                    assert(functionValues == 1)
                                    assert(directCalls == 1)
                                    assert(indirectCalls == 1)
                                }
                                case Err(_) {
                                    assert(false)
                                }
                            }
                        }
                        case Err(_) {
                            assert(false)
                        }
                    }
                }
                case Err(_) {
                    assert(false)
                }
            }
        }
        case Err(_) {
            assert(false)
        }
    }
}

test LowersFieldAndIndexReads() {
    source := "type User struct { age int } func readAge(con user User) int { return user.age } func readArray(con values [2]int) int { return values[0] + values[1] } func main() {}"
    match lexer.Lex(source) {
        case Ok(tokens) {
            match parser.Parse(tokens) {
                case Ok(program) {
                    match semantic.Check(con program) {
                        case Ok(checked) {
                            match Lower(con program, con checked) {
                                case Ok(lowered) {
                                    mut fields := 0
                                    mut indexes := 0
                                    for mut node := 0; node < len(lowered.nodes); node = node + 1 {
                                        if lowered.nodes[node].kind == "Expr.FieldAccess" {
                                            fields = fields + 1
                                        } else if lowered.nodes[node].kind == "Expr.Index" {
                                            indexes = indexes + 1
                                        }
                                    }
                                    assert(fields == 1)
                                    assert(indexes == 2)
                                }
                                case Err(_) {
                                    assert(false)
                                }
                            }
                        }
                        case Err(_) {
                            assert(false)
                        }
                    }
                }
                case Err(_) {
                    assert(false)
                }
            }
        }
        case Err(_) {
            assert(false)
        }
    }
}

test LowersFieldAndIndexAssignments() {
    source := "type User struct { age int } func updateUser(mut user User) int { user.age = 31; return user.age } func updateArray(mut values [2]int) int { values[1] = 7; return values[1] } func main() {}"
    match lexer.Lex(source) {
        case Ok(tokens) {
            match parser.Parse(tokens) {
                case Ok(program) {
                    match semantic.Check(con program) {
                        case Ok(checked) {
                            match Lower(con program, con checked) {
                                case Ok(lowered) {
                                    mut fieldAssignments := 0
                                    mut indexAssignments := 0
                                    for mut node := 0; node < len(lowered.nodes); node = node + 1 {
                                        if lowered.nodes[node].kind == "Stmt.FieldAssign" {
                                            fieldAssignments = fieldAssignments + 1
                                        } else if lowered.nodes[node].kind == "Stmt.IndexAssign" {
                                            indexAssignments = indexAssignments + 1
                                        }
                                    }
                                    assert(fieldAssignments == 1)
                                    assert(indexAssignments == 1)
                                }
                                case Err(_) {
                                    assert(false)
                                }
                            }
                        }
                        case Err(_) {
                            assert(false)
                        }
                    }
                }
                case Err(_) {
                    assert(false)
                }
            }
        }
        case Err(_) {
            assert(false)
        }
    }
}
