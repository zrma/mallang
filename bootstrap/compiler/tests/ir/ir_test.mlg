}

test TracksSliceAppendMoveAndBorrowCleanup() {
    source := "type Bag struct { values []int } type Entry struct { name string } type EntryBag struct { values []Entry } func grow(input []int, item int) []int { mut values := input; values = append(values, item); return values } func takeField(con bag Bag, item int) []int { grown := append(bag.values, item); return grown } func appendEntry(con bag EntryBag, item Entry) []Entry { grown := append(bag.values, item); return grown } func main() {}"
    match lexer.Lex(source) {
        case Ok(tokens) {
            match parser.Parse(tokens) {
                case Ok(program) {
                    match semantic.Check(con program) {
                        case Ok(checked) {
                            match Lower(con program, con checked) {
                                case Ok(lowered) {
                                    assert(len(lowered.functions[0].body) == 3)
                                    assert(lowered.nodes[lowered.functions[0].body[0]].kind == "Stmt.Let.Mutable")
                                    assignment := lowered.functions[0].body[1]
                                    assert(lowered.nodes[assignment].kind == "Stmt.Assign")
                                    assignmentAppend := lowered.nodes[assignment].children[0]
                                    assert(lowered.nodes[assignmentAppend].kind == "Expr.SliceAppend")
                                    assignmentSource := lowered.nodes[assignmentAppend].children[0]
                                    assert(lowered.nodes[assignmentSource].kind == "Expr.Var")
                                    assert(lowered.nodes[assignmentSource].value == "values")
                                    assert(lowered.nodes[lowered.functions[0].body[2]].kind == "Stmt.Return")

                                    assert(len(lowered.functions[1].body) == 2)
                                    borrowedLet := lowered.functions[1].body[0]
                                    assert(lowered.nodes[borrowedLet].kind == "Stmt.Let.Immutable")
                                    borrowedAppend := lowered.nodes[borrowedLet].children[0]
                                    assert(lowered.nodes[borrowedAppend].kind == "Expr.SliceAppend")
                                    borrowedSource := lowered.nodes[borrowedAppend].children[0]
                                    assert(lowered.nodes[borrowedSource].kind == "Expr.FieldAccess")
                                    assert(lowered.nodes[lowered.functions[1].body[1]].kind == "Stmt.Return")

                                    assert(len(lowered.functions[2].body) == 2)
                                    entryLet := lowered.functions[2].body[0]
                                    assert(lowered.nodes[entryLet].kind == "Stmt.Let.Immutable")
                                    entryAppend := lowered.nodes[entryLet].children[0]
                                    assert(lowered.nodes[entryAppend].kind == "Expr.SliceAppend")
                                    entryItem := lowered.nodes[entryAppend].children[1]
                                    assert(lowered.nodes[entryItem].kind == "Expr.Var")
                                    assert(lowered.nodes[entryItem].value == "item")
                                    assert(lowered.nodes[lowered.functions[2].body[1]].kind == "Stmt.Return")
                                }
                                case Err(_) {
                                    assert(false)
                                }
                            }
                        }
                        case Err(_) {
                            assert(false)
                        }
                    }
                }
                case Err(_) {
                    assert(false)
                }
            }
        }
        case Err(_) {
            assert(false)
        }
    }
}

