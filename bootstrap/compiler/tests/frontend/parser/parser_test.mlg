package parser

import "bootstrap_compiler/frontend/ast"
import "bootstrap_compiler/frontend/lexer"

test ParsesDeclarationsAndTypes() {
    source := "package demo\nimport \"std/strings\"\npub type Box[T] struct { value T }\ntype Outcome[T, E] enum { Empty Value(T) Failure(E) }\npub func (con box Box[T]) Map[U](con transform func(con T) U, values [2][]string) Outcome[U, string] {}\ntest Parses() {}\n"
    match lexer.Lex(source) {
        case Ok(tokens) {
            match Parse(tokens) {
                case Ok(program) {
                    root := ast.Root(con program)
                    assert(ast.Kind(con program, root) == "Program")
                    assert(ast.ChildCount(con program, root) == 5)
                    sourceUnit := ast.Child(con program, root, 0)
                    assert(ast.Kind(con program, sourceUnit) == "SourceUnit")
                    assert(ast.ChildCount(con program, sourceUnit) == 2)
                    structDecl := ast.Child(con program, root, 1)
                    assert(ast.Kind(con program, structDecl) == "StructDecl.Public")
                    assert(ast.Value(con program, structDecl) == "Box")
                    enumDecl := ast.Child(con program, root, 2)
                    assert(ast.Kind(con program, enumDecl) == "EnumDecl.Package")
                    assert(ast.Value(con program, enumDecl) == "Outcome")
                    functionDecl := ast.Child(con program, root, 3)
                    assert(ast.Kind(con program, functionDecl) == "FunctionDecl.Public")
                    assert(ast.Value(con program, functionDecl) == "Map")
                    assert(ast.ChildCount(con program, functionDecl) == 6)
                    testDecl := ast.Child(con program, root, 4)
                    assert(ast.Kind(con program, testDecl) == "TestDecl")
                }
                case Err(_) {
                    assert(false)
                }
            }
        }
        case Err(_) {
            assert(false)
        }
    }
}

test RejectsLatePackageDeclaration() {
    source := "func main() {}\npackage late\n"
    match lexer.Lex(source) {
        case Ok(tokens) {
            match Parse(tokens) {
                case Ok(_) {
                    assert(false)
                }
                case Err(errors) {
                    assert(len(errors) == 1)
                    assert(ast.ErrorMessage(con errors[0]) == "package declaration must appear first")
                }
            }
        }
        case Err(_) {
            assert(false)
        }
    }
}

test ParsesCoreStatementsAndExpressionPrecedence() {
    source := "func main() { mut value := 1 + 2 * 3; value = value - 1; print(value) }"
    match lexer.Lex(source) {
        case Ok(tokens) {
            match Parse(tokens) {
                case Ok(program) {
                    root := ast.Root(con program)
                    functionDecl := ast.Child(con program, root, 1)
                    block := ast.Child(con program, functionDecl, ast.ChildCount(con program, functionDecl) - 1)
                    assert(ast.Kind(con program, block) == "Block")
                    assert(ast.ChildCount(con program, block) == 3)

                    letStatement := ast.Child(con program, block, 0)
                    assert(ast.Kind(con program, letStatement) == "Stmt.Let.Mutable")
                    add := ast.Child(con program, letStatement, 0)
                    assert(ast.Kind(con program, add) == "Expr.Binary.Add")
                    multiply := ast.Child(con program, add, 1)
                    assert(ast.Kind(con program, multiply) == "Expr.Binary.Multiply")

                    assignStatement := ast.Child(con program, block, 1)
                    assert(ast.Kind(con program, assignStatement) == "Stmt.Assign")
                    expressionStatement := ast.Child(con program, block, 2)
                    assert(ast.Kind(con program, expressionStatement) == "Stmt.Expr")
                }
                case Err(_) {
                    assert(false)
                }
            }
        }
        case Err(_) {
            assert(false)
        }
    }
}

test ParsesControlFlowStatements() {
    source := "func run(values []int) int { mut total := 0; if total == 0 { total = 1 } else { total = 2 }; for total < len(values) { total = total + 1; continue }; for index, value := range values { total = total + index + value }; match Some(total) { case Some(value) { return value } case None { return 0 } }; return total }"
    match lexer.Lex(source) {
        case Ok(tokens) {
            match Parse(tokens) {
                case Ok(program) {
                    root := ast.Root(con program)
                    functionDecl := ast.Child(con program, root, 1)
                    block := ast.Child(con program, functionDecl, ast.ChildCount(con program, functionDecl) - 1)
                    assert(ast.ChildCount(con program, block) == 6)
                    assert(ast.Kind(con program, ast.Child(con program, block, 1)) == "Stmt.If")
                    assert(ast.Kind(con program, ast.Child(con program, block, 2)) == "Stmt.For")
                    assert(ast.Kind(con program, ast.Child(con program, block, 3)) == "Stmt.RangeFor")
                    assert(ast.Kind(con program, ast.Child(con program, block, 4)) == "Stmt.Match")
                    matchStatement := ast.Child(con program, block, 4)
                    firstArm := ast.Child(con program, matchStatement, 1)
                    pattern := ast.Child(con program, firstArm, 0)
                    assert(ast.Kind(con program, pattern) == "Pattern.Some")
                    assert(ast.Value(con program, pattern) == "value")
                }
                case Err(_) {
                    assert(false)
                }
            }
        }
        case Err(_) {
            assert(false)
        }
    }
}

test ParsesTestAssertion() {
    source := "test Works() { assert(1 + 1 == 2) }"
    match lexer.Lex(source) {
        case Ok(tokens) {
            match Parse(tokens) {
                case Ok(program) {
                    root := ast.Root(con program)
                    testDecl := ast.Child(con program, root, 1)
                    block := ast.Child(con program, testDecl, 0)
                    statement := ast.Child(con program, block, 0)
                    assert(ast.Kind(con program, statement) == "Stmt.Assert")
                }
                case Err(_) {
                    assert(false)
                }
            }
        }
        case Err(_) {
            assert(false)
        }
    }
}

test ParsesFunctionAndControlExpressions() {
    source := "func run(flag bool, value Option[Result[int, string]]) int { transform := func(con input int) int { return input + 1 }; selected := if flag { transform(con 1) } else { 0 }; decoded := match value { case Some(Ok(inner)) { inner } case Some(Err(message)) { 0 } case None { 0 } }; return selected + decoded }"
    match lexer.Lex(source) {
        case Ok(tokens) {
            match Parse(tokens) {
                case Ok(program) {
                    root := ast.Root(con program)
                    functionDecl := ast.Child(con program, root, 1)
                    block := ast.Child(con program, functionDecl, ast.ChildCount(con program, functionDecl) - 1)

                    closureBinding := ast.Child(con program, block, 0)
                    closure := ast.Child(con program, closureBinding, 0)
                    assert(ast.Kind(con program, closure) == "Expr.FunctionLiteral.Immutable")

                    ifBinding := ast.Child(con program, block, 1)
                    ifExpression := ast.Child(con program, ifBinding, 0)
                    assert(ast.Kind(con program, ifExpression) == "Expr.If")

                    matchBinding := ast.Child(con program, block, 2)
                    matchExpression := ast.Child(con program, matchBinding, 0)
                    assert(ast.Kind(con program, matchExpression) == "Expr.Match")
                    firstArm := ast.Child(con program, matchExpression, 1)
                    pattern := ast.Child(con program, firstArm, 0)
                    assert(ast.Kind(con program, pattern) == "Pattern.NestedBuiltin")
                    assert(ast.Value(con program, pattern) == "Some")
                    nested := ast.Child(con program, pattern, 0)
                    assert(ast.Kind(con program, nested) == "Pattern.Ok")
                    assert(ast.Value(con program, nested) == "inner")
                }
                case Err(_) {
                    assert(false)
                }
            }
        }
        case Err(_) {
            assert(false)
        }
    }
}

test RecoversMultipleParserDiagnostics() {
    source := "func brokenOne(value int {}\nfunc good() {}\nfunc brokenTwo(value bool {}\nfunc main() {}\n"
    match lexer.Lex(source) {
        case Ok(tokens) {
            match Parse(tokens) {
                case Ok(_) {
                    assert(false)
                }
                case Err(errors) {
                    assert(len(errors) == 2)
                    assert(ast.ErrorMessage(con errors[0]) == "expected `)` after function parameters")
                    assert(ast.ErrorMessage(con errors[1]) == "expected `)` after function parameters")
                }
            }
        }
        case Err(_) {
            assert(false)
        }
    }
}

test AbandonsUnclosedBlockAtNamedFunction() {
    source := "func first() {\n    broken := ;\nfunc second(value int {}\nfunc main() {}\n"
    match lexer.Lex(source) {
        case Ok(tokens) {
            match Parse(tokens) {
                case Ok(_) {
                    assert(false)
                }
                case Err(errors) {
                    assert(len(errors) == 3)
                    assert(ast.ErrorMessage(con errors[0]) == "expected expression")
                    assert(ast.ErrorMessage(con errors[1]) == "expected `}` after block")
                    assert(ast.ErrorMessage(con errors[2]) == "expected `)` after function parameters")
                }
            }
        }
        case Err(_) {
            assert(false)
        }
    }
}
