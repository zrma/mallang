package packages

import "bootstrap_compiler/frontend/ast"
import "bootstrap_compiler/frontend/lexer"
import "bootstrap_compiler/frontend/parser"
import "bootstrap_compiler/frontend/token"

func parseLayoutSources(con texts []string) Result[ast.Program, bool] {
    mut programs := []ast.Program{}
    for mut sourceId := 0; sourceId < len(texts); sourceId = sourceId + 1 {
        match lexer.LexWithSource(token.CopyText(con texts[sourceId]), sourceId) {
            case Ok(tokens) {
                match parser.Parse(tokens) {
                    case Ok(program) {
                        programs = append(programs, program)
                    }
                    case Err(_) {
                        return Err(false)
                    }
                }
            }
            case Err(_) {
                return Err(false)
            }
        }
    }
    return match ast.MergePrograms(programs) {
        case Ok(program) {
            Ok(program)
        }
        case Err(_) {
            Err(false)
        }
    }
}

test BuildsSourcePackageIdentity() {
    mut programs := []ast.Program{}
    match lexer.LexWithSource("package main\nimport \"hello/greet\"\nfunc main() {}\n", 0) {
        case Ok(tokens) {
            match parser.Parse(tokens) {
                case Ok(program) {
                    programs = append(programs, program)
                }
                case Err(_) {
                    assert(false)
                }
            }
        }
        case Err(_) {
            assert(false)
        }
    }
    match lexer.LexWithSource("package greet\npub type Message struct {}\npub type State[T] enum { Empty Full(T) }\npub func (con self Message) Show() {}\npub func Print() {}\n", 1) {
        case Ok(tokens) {
            match parser.Parse(tokens) {
                case Ok(program) {
                    programs = append(programs, program)
                }
                case Err(_) {
                    assert(false)
                }
            }
        }
        case Err(_) {
            assert(false)
        }
    }
    match ast.MergePrograms(programs) {
        case Ok(program) {
            paths := []string{"project/src/main.mlg", "project/src/greet/greet.mlg",}
            match Build(con program, con "hello", con "project/src", con paths) {
                case Ok(layout) {
                    assert(Normalize(con layout) == "LAYOUT|2|2\nSOURCE|0|hello|main\nSOURCE|1|hello/greet|greet\nPACKAGE|hello|main|1|1|1|0\nPSOURCE|hello|0\nIMPORT|hello|hello/greet|greet\nDECL|hello|Function|Package|main|0\nPACKAGE|hello/greet|greet|1|0|3|1\nPSOURCE|hello/greet|1\nDECL|hello/greet|Struct|Public|Message|0\nDECL|hello/greet|Function|Public|Print|0\nDECL|hello/greet|Enum|Public|State|1|T\nMETHOD|hello/greet|Message|Method|Public|Show|0\nORDER|2|hello/greet|hello")
                }
                case Err(_) {
                    assert(false)
                }
            }
        }
        case Err(_) {
            assert(false)
        }
    }
}

test BuildsCrossProjectDependencyGraph() {
    texts := []string{"package main\npub func Value() int { return 42 }\n", "package main\nimport \"shared\"\npub func Read() int { return shared.Value() }\n", "package main\nimport \"text\"\nfunc main() {}\n",}
    match parseLayoutSources(con texts) {
        case Ok(program) {
            app := NewProjectUnit(con "app", con "project/src", con []string{"text",})
            text := NewProjectUnit(con "text", con "project/deps/text/src", con []string{"shared",})
            shared := NewProjectUnit(con "shared", con "project/deps/shared/src", con []string{})
            project := NewProject(con []ProjectUnit{app, text, shared})
            paths := []string{"project/deps/shared/src/library.mlg", "project/deps/text/src/library.mlg", "project/src/main.mlg",}
            match BuildProject(con program, con project, con paths) {
                case Ok(layout) {
                    assert(Normalize(con layout) == "LAYOUT|3|3\nSOURCE|0|shared|main\nSOURCE|1|text|main\nSOURCE|2|app|main\nPACKAGE|app|main|1|1|1|0\nPSOURCE|app|2\nIMPORT|app|text|text\nDECL|app|Function|Package|main|0\nPACKAGE|shared|main|1|0|1|0\nPSOURCE|shared|0\nDECL|shared|Function|Public|Value|0\nPACKAGE|text|main|1|1|1|0\nPSOURCE|text|1\nIMPORT|text|shared|shared\nDECL|text|Function|Public|Read|0\nORDER|3|shared|text|app")
                }
                case Err(_) {
                    assert(false)
                }
            }
        }
        case Err(_) {
            assert(false)
        }
    }
}

test RejectsUndeclaredTransitiveProjectImport() {
    texts := []string{"package main\npub func Value() int { return 42 }\n", "package main\nimport \"shared\"\npub func Read() int { return shared.Value() }\n", "package main\nimport \"shared\"\nfunc main() {}\n",}
    match parseLayoutSources(con texts) {
        case Ok(program) {
            app := NewProjectUnit(con "app", con "project/src", con []string{"text",})
            text := NewProjectUnit(con "text", con "project/deps/text/src", con []string{"shared",})
            shared := NewProjectUnit(con "shared", con "project/deps/shared/src", con []string{})
            project := NewProject(con []ProjectUnit{app, text, shared})
            paths := []string{"project/deps/shared/src/library.mlg", "project/deps/text/src/library.mlg", "project/src/main.mlg",}
            match BuildProject(con program, con project, con paths) {
                case Ok(_) {
                    assert(false)
                }
                case Err(error) {
                    assert(ErrorMessage(con error) == "project `app` does not declare dependency `shared`")
                }
            }
        }
        case Err(_) {
            assert(false)
        }
    }
}

test BuildsStandardPackageInventory() {
    match lexer.LexWithSource("package main\nimport \"std/fs\"\nimport \"std/collections\"\nfunc main() {}\n", 0) {
        case Ok(tokens) {
            match parser.Parse(tokens) {
                case Ok(program) {
                    paths := []string{"project/src/main.mlg",}
                    match Build(con program, con "hello", con "project/src", con paths) {
                        case Ok(layout) {
                            assert(Normalize(con layout) == "LAYOUT|1|3\nSOURCE|0|hello|main\nPACKAGE|hello|main|1|2|1|0\nPSOURCE|hello|0\nIMPORT|hello|std/collections|collections\nIMPORT|hello|std/fs|fs\nDECL|hello|Function|Package|main|0\nPACKAGE|std/collections|collections|0|0|7|0\nDECL|std/collections|Opaque|Public|Map|2|K|V\nDECL|std/collections|Function|Public|count|2|K|V\nDECL|std/collections|Function|Public|insert|2|K|V\nDECL|std/collections|Function|Public|newMap|2|K|V\nDECL|std/collections|Function|Public|remove|2|K|V\nDECL|std/collections|Function|Public|update|2|K|V\nDECL|std/collections|Function|Public|with|2|K|V\nPACKAGE|std/fs|fs|0|0|3|0\nDECL|std/fs|Function|Public|forEachLine|2|C|S\nDECL|std/fs|Function|Public|readText|0\nDECL|std/fs|Function|Public|writeText|0\nORDER|3|std/collections|std/fs|hello")
                        }
                        case Err(_) {
                            assert(false)
                        }
                    }
                }
                case Err(_) {
                    assert(false)
                }
            }
        }
        case Err(_) {
            assert(false)
        }
    }
}

test RejectsUnknownStandardPackage() {
    match lexer.LexWithSource("package main\nimport \"std/future\"\nfunc main() {}\n", 0) {
        case Ok(tokens) {
            match parser.Parse(tokens) {
                case Ok(program) {
                    paths := []string{"project/src/main.mlg",}
                    match Build(con program, con "hello", con "project/src", con paths) {
                        case Ok(_) {
                            assert(false)
                        }
                        case Err(error) {
                            assert(ErrorMessage(con error) == "unknown standard package `std/future`")
                        }
                    }
                }
                case Err(_) {
                    assert(false)
                }
            }
        }
        case Err(_) {
            assert(false)
        }
    }
}

test RejectsMismatchedPackageDeclaration() {
    match lexer.LexWithSource("package other\nfunc main() {}\n", 0) {
        case Ok(tokens) {
            match parser.Parse(tokens) {
                case Ok(program) {
                    paths := []string{"project/src/main.mlg",}
                    match Build(con program, con "hello", con "project/src", con paths) {
                        case Ok(_) {
                            assert(false)
                        }
                        case Err(error) {
                            assert(ErrorMessage(con error) == "package `other` does not match source directory package `main`")
                        }
                    }
                }
                case Err(_) {
                    assert(false)
                }
            }
        }
        case Err(_) {
            assert(false)
        }
    }
}

test RejectsPackageImportCycle() {
    mut programs := []ast.Program{}
    match lexer.LexWithSource("package main\nimport \"hello/a\"\nfunc main() {}\n", 0) {
        case Ok(tokens) {
            match parser.Parse(tokens) {
                case Ok(program) {
                    programs = append(programs, program)
                }
                case Err(_) {
                    assert(false)
                }
            }
        }
        case Err(_) {
            assert(false)
        }
    }
    match lexer.LexWithSource("package a\nimport \"hello/b\"\nfunc A() {}\n", 1) {
        case Ok(tokens) {
            match parser.Parse(tokens) {
                case Ok(program) {
                    programs = append(programs, program)
                }
                case Err(_) {
                    assert(false)
                }
            }
        }
        case Err(_) {
            assert(false)
        }
    }
    match lexer.LexWithSource("package b\nimport \"hello/a\"\nfunc B() {}\n", 2) {
        case Ok(tokens) {
            match parser.Parse(tokens) {
                case Ok(program) {
                    programs = append(programs, program)
                }
                case Err(_) {
                    assert(false)
                }
            }
        }
        case Err(_) {
            assert(false)
        }
    }
    match ast.MergePrograms(programs) {
        case Ok(program) {
            paths := []string{"project/src/main.mlg", "project/src/a/a.mlg", "project/src/b/b.mlg",}
            match Build(con program, con "hello", con "project/src", con paths) {
                case Ok(_) {
                    assert(false)
                }
                case Err(error) {
                    assert(ErrorMessage(con error) == "package import cycle: hello/a -> hello/b -> hello/a")
                }
            }
        }
        case Err(_) {
            assert(false)
        }
    }
}

test RejectsInvalidImportPath() {
    match lexer.LexWithSource("package main\nimport \"hello/not-valid\"\nfunc main() {}\n", 0) {
        case Ok(tokens) {
            match parser.Parse(tokens) {
                case Ok(program) {
                    paths := []string{"project/src/main.mlg",}
                    match Build(con program, con "hello", con "project/src", con paths) {
                        case Ok(_) {
                            assert(false)
                        }
                        case Err(error) {
                            assert(ErrorMessage(con error) == "invalid import path `hello/not-valid`")
                        }
                    }
                }
                case Err(_) {
                    assert(false)
                }
            }
        }
        case Err(_) {
            assert(false)
        }
    }
}

test RejectsDuplicatePackageDeclarations() {
    mut programs := []ast.Program{}
    match lexer.LexWithSource("package main\nfunc main() {}\n", 0) {
        case Ok(tokens) {
            match parser.Parse(tokens) {
                case Ok(program) {
                    programs = append(programs, program)
                }
                case Err(_) {
                    assert(false)
                }
            }
        }
        case Err(_) {
            assert(false)
        }
    }
    match lexer.LexWithSource("package a\nfunc Open() {}\n", 1) {
        case Ok(tokens) {
            match parser.Parse(tokens) {
                case Ok(program) {
                    programs = append(programs, program)
                }
                case Err(_) {
                    assert(false)
                }
            }
        }
        case Err(_) {
            assert(false)
        }
    }
    match lexer.LexWithSource("package a\ntype Open struct {}\n", 2) {
        case Ok(tokens) {
            match parser.Parse(tokens) {
                case Ok(program) {
                    programs = append(programs, program)
                }
                case Err(_) {
                    assert(false)
                }
            }
        }
        case Err(_) {
            assert(false)
        }
    }
    match ast.MergePrograms(programs) {
        case Ok(program) {
            paths := []string{"project/src/main.mlg", "project/src/a/first.mlg", "project/src/a/second.mlg",}
            match Build(con program, con "hello", con "project/src", con paths) {
                case Ok(_) {
                    assert(false)
                }
                case Err(error) {
                    assert(ErrorMessage(con error) == "duplicate declaration `Open` in package `hello/a`")
                }
            }
        }
        case Err(_) {
            assert(false)
        }
    }
}
