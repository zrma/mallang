package packages

import "bootstrap_compiler/frontend/ast"
import "bootstrap_compiler/frontend/lexer"
import "bootstrap_compiler/frontend/parser"

test BuildsSourcePackageIdentity() {
    mut programs := []ast.Program{}
    match lexer.LexWithSource("package main\nimport \"hello/greet\"\nfunc main() {}\n", 0) {
        case Ok(tokens) {
            match parser.Parse(tokens) {
                case Ok(program) {
                    programs = append(programs, program)
                }
                case Err(_) {
                    assert(false)
                }
            }
        }
        case Err(_) {
            assert(false)
        }
    }
    match lexer.LexWithSource("package greet\npub type Message struct {}\npub type State[T] enum { Empty Full(T) }\npub func (con self Message) Show() {}\npub func Print() {}\n", 1) {
        case Ok(tokens) {
            match parser.Parse(tokens) {
                case Ok(program) {
                    programs = append(programs, program)
                }
                case Err(_) {
                    assert(false)
                }
            }
        }
        case Err(_) {
            assert(false)
        }
    }
    match ast.MergePrograms(programs) {
        case Ok(program) {
            paths := []string{"project/src/main.mlg", "project/src/greet/greet.mlg",}
            match Build(con program, con "hello", con "project/src", con paths) {
                case Ok(layout) {
                    assert(Normalize(con layout) == "LAYOUT|2|2\nSOURCE|0|hello|main\nSOURCE|1|hello/greet|greet\nPACKAGE|hello|main|1|1|1|0\nPSOURCE|hello|0\nIMPORT|hello|hello/greet|greet\nDECL|hello|Function|Package|main|0\nPACKAGE|hello/greet|greet|1|0|3|1\nPSOURCE|hello/greet|1\nDECL|hello/greet|Struct|Public|Message|0\nDECL|hello/greet|Function|Public|Print|0\nDECL|hello/greet|Enum|Public|State|1|T\nMETHOD|hello/greet|Message|Method|Public|Show|0\nORDER|2|hello/greet|hello")
                }
                case Err(_) {
                    assert(false)
                }
            }
        }
        case Err(_) {
            assert(false)
        }
    }
}

test RejectsMismatchedPackageDeclaration() {
    match lexer.LexWithSource("package other\nfunc main() {}\n", 0) {
        case Ok(tokens) {
            match parser.Parse(tokens) {
                case Ok(program) {
                    paths := []string{"project/src/main.mlg",}
                    match Build(con program, con "hello", con "project/src", con paths) {
                        case Ok(_) {
                            assert(false)
                        }
                        case Err(error) {
                            assert(ErrorMessage(con error) == "package `other` does not match source directory package `main`")
                        }
                    }
                }
                case Err(_) {
                    assert(false)
                }
            }
        }
        case Err(_) {
            assert(false)
        }
    }
}

test RejectsPackageImportCycle() {
    mut programs := []ast.Program{}
    match lexer.LexWithSource("package main\nimport \"hello/a\"\nfunc main() {}\n", 0) {
        case Ok(tokens) {
            match parser.Parse(tokens) {
                case Ok(program) {
                    programs = append(programs, program)
                }
                case Err(_) {
                    assert(false)
                }
            }
        }
        case Err(_) {
            assert(false)
        }
    }
    match lexer.LexWithSource("package a\nimport \"hello/b\"\nfunc A() {}\n", 1) {
        case Ok(tokens) {
            match parser.Parse(tokens) {
                case Ok(program) {
                    programs = append(programs, program)
                }
                case Err(_) {
                    assert(false)
                }
            }
        }
        case Err(_) {
            assert(false)
        }
    }
    match lexer.LexWithSource("package b\nimport \"hello/a\"\nfunc B() {}\n", 2) {
        case Ok(tokens) {
            match parser.Parse(tokens) {
                case Ok(program) {
                    programs = append(programs, program)
                }
                case Err(_) {
                    assert(false)
                }
            }
        }
        case Err(_) {
            assert(false)
        }
    }
    match ast.MergePrograms(programs) {
        case Ok(program) {
            paths := []string{"project/src/main.mlg", "project/src/a/a.mlg", "project/src/b/b.mlg",}
            match Build(con program, con "hello", con "project/src", con paths) {
                case Ok(_) {
                    assert(false)
                }
                case Err(error) {
                    assert(ErrorMessage(con error) == "package import cycle: hello/a -> hello/b -> hello/a")
                }
            }
        }
        case Err(_) {
            assert(false)
        }
    }
}

test RejectsInvalidImportPath() {
    match lexer.LexWithSource("package main\nimport \"hello/not-valid\"\nfunc main() {}\n", 0) {
        case Ok(tokens) {
            match parser.Parse(tokens) {
                case Ok(program) {
                    paths := []string{"project/src/main.mlg",}
                    match Build(con program, con "hello", con "project/src", con paths) {
                        case Ok(_) {
                            assert(false)
                        }
                        case Err(error) {
                            assert(ErrorMessage(con error) == "invalid import path `hello/not-valid`")
                        }
                    }
                }
                case Err(_) {
                    assert(false)
                }
            }
        }
        case Err(_) {
            assert(false)
        }
    }
}

test RejectsDuplicatePackageDeclarations() {
    mut programs := []ast.Program{}
    match lexer.LexWithSource("package main\nfunc main() {}\n", 0) {
        case Ok(tokens) {
            match parser.Parse(tokens) {
                case Ok(program) {
                    programs = append(programs, program)
                }
                case Err(_) {
                    assert(false)
                }
            }
        }
        case Err(_) {
            assert(false)
        }
    }
    match lexer.LexWithSource("package a\nfunc Open() {}\n", 1) {
        case Ok(tokens) {
            match parser.Parse(tokens) {
                case Ok(program) {
                    programs = append(programs, program)
                }
                case Err(_) {
                    assert(false)
                }
            }
        }
        case Err(_) {
            assert(false)
        }
    }
    match lexer.LexWithSource("package a\ntype Open struct {}\n", 2) {
        case Ok(tokens) {
            match parser.Parse(tokens) {
                case Ok(program) {
                    programs = append(programs, program)
                }
                case Err(_) {
                    assert(false)
                }
            }
        }
        case Err(_) {
            assert(false)
        }
    }
    match ast.MergePrograms(programs) {
        case Ok(program) {
            paths := []string{"project/src/main.mlg", "project/src/a/first.mlg", "project/src/a/second.mlg",}
            match Build(con program, con "hello", con "project/src", con paths) {
                case Ok(_) {
                    assert(false)
                }
                case Err(error) {
                    assert(ErrorMessage(con error) == "duplicate declaration `Open` in package `hello/a`")
                }
            }
        }
        case Err(_) {
            assert(false)
        }
    }
}
