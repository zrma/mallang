test PropagatesNestedMutableCaptures() {
    source := "func make() func mut() func mut() int { mut count := 0; return func mut() func mut() int { return func mut() int { count = count + 1; return count } } } func main() {}"
    match lexer.Lex(source) {
        case Ok(tokens) {
            match parser.Parse(tokens) {
                case Ok(program) {
                    match Check(con program) {
                        case Ok(checked) {
                            assert(len(checked.closures) == 2)
                            assert(checked.closures[0].captures[0].mutable)
                            assert(checked.closures[1].captures[0].mutable)
                        }
                        case Err(_) {
                            assert(false)
                        }
                    }
                }
                case Err(_) {
                    assert(false)
                }
            }
        }
        case Err(_) {
            assert(false)
        }
    }
}

test RejectsRecursiveClosureInitializers() {
    source := "func run() int { recurse := func(value int) int { return recurse(value) }; return recurse(1) } func main() {}"
    assert(checkTestSource(source) == "recursive closure `recurse` is not supported in v0.3")
}

test ClosureInitializersCaptureShadowedOuterBindings() {
    source := "func double(value int) int { return value * 2 } func run() { transform := double; if true { transform := func(value int) int { return transform(value) }; result := transform(2) } } func main() {}"
    assert(checkTestSource(source) == "")
}
