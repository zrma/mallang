package semantic

import "bootstrap_compiler/frontend/ast"
import "bootstrap_compiler/frontend/lexer"
import "bootstrap_compiler/frontend/parser"

func checkTestSource(source string) string {
    return match lexer.Lex(source) {
        case Ok(tokens) {
            match parser.Parse(tokens) {
                case Ok(program) {
                    match Check(con program) {
                        case Ok(_) {
                            ""
                        }
                        case Err(error) {
                            ErrorMessage(con error)
                        }
                    }
                }
                case Err(_) {
                    "parser error"
                }
            }
        }
        case Err(_) {
            "lexer error"
        }
    }
}

func firstCaptureMutable(source string) bool {
    return match lexer.Lex(source) {
        case Ok(tokens) {
            match parser.Parse(tokens) {
                case Ok(program) {
                    match Check(con program) {
                        case Ok(checked) {
                            len(checked.closures) > 0 && len(checked.closures[0].captures) > 0 && checked.closures[0].captures[0].mutable
                        }
                        case Err(_) {
                            false
                        }
                    }
                }
                case Err(_) {
                    false
                }
            }
        }
        case Err(_) {
            false
        }
    }
}

test CollectsDeclarationSignatures() {
    source := "type User struct { name string; age int } type Choice enum { Empty; Score(int) } func describe(con value Option[string]) string { return \"ok\" } func (mut user User) rename(con name string) {} func main() {}"
    match lexer.Lex(source) {
        case Ok(tokens) {
            match parser.Parse(tokens) {
                case Ok(program) {
                    match Check(con program) {
                        case Ok(checked) {
                            expected := "CHECKED|1|1|2|1\nSTRUCT|User|2\nFIELD|User|name|string\nFIELD|User|age|int\nENUM|Choice|2\nVARIANT|Choice|Empty|0\nVARIANT|Choice|Score|1|int\nFUNC|describe|string|1\nPARAM|describe|con|value|Option[string]\nFUNC|main|unit|0\nMETHOD|User|rename|mut|user|unit|1\nMPARAM|User|rename|con|name|string"
                            actual := Normalize(con checked)
                            assert(actual == expected)
                        }
                        case Err(_) {
                            assert(false)
                        }
                    }
                }
                case Err(_) {
                    assert(false)
                }
            }
        }
        case Err(_) {
            assert(false)
        }
    }
}

test RejectsUnknownTypes() {
    source := "type User struct { value Missing } func main() {}"
    match lexer.Lex(source) {
        case Ok(tokens) {
            match parser.Parse(tokens) {
                case Ok(program) {
                    match Check(con program) {
                        case Ok(_) {
                            assert(false)
                        }
                        case Err(error) {
                            actual := ErrorMessage(con error)
                            assert(actual == "unknown type `Missing`")
                        }
                    }
                }
                case Err(_) {
                    assert(false)
                }
            }
        }
        case Err(_) {
            assert(false)
        }
    }
}

test ChecksPrimitiveFunctionBodies() {
    source := "func compute(left int, right int) int { mut total := left + right * 2; total = total - 1; return total } func main() {}"
    match lexer.Lex(source) {
        case Ok(tokens) {
            match parser.Parse(tokens) {
                case Ok(program) {
                    match Check(con program) {
                        case Ok(checked) {
                            root := ast.Root(con program)
                            function := ast.Child(con program, root, 1)
                            block := ast.Child(con program, function, ast.ChildCount(con program, function) - 1)
                            binding := ast.Child(con program, block, 0)
                            expression := ast.Child(con program, binding, 0)
                            match NodeType(con checked, expression) {
                                case Ok(ty) {
                                    assert(ty == "int")
                                }
                                case Err(_) {
                                    assert(false)
                                }
                            }
                        }
                        case Err(_) {
                            assert(false)
                        }
                    }
                }
                case Err(_) {
                    assert(false)
                }
            }
        }
        case Err(_) {
            assert(false)
        }
    }
}

