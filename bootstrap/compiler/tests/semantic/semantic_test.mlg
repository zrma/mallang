test PropagatesNestedClosureCaptures() {
    source := "func make(offset int) func(int) func(int) int { return func(base int) func(int) int { return func(value int) int { return offset + base + value } } } func main() {}"
    match lexer.Lex(source) {
        case Ok(tokens) {
            match parser.Parse(tokens) {
                case Ok(program) {
                    match Check(con program) {
                        case Ok(checked) {
                            assert(len(checked.closures) == 2)
                            assert(len(checked.closures[0].captures) == 2)
                            assert(checked.closures[0].captures[0].name == "offset")
                            assert(checked.closures[0].captures[1].name == "base")
                            assert(len(checked.closures[1].captures) == 1)
                            assert(checked.closures[1].captures[0].name == "offset")
                        }
                        case Err(_) {
                            assert(false)
                        }
                    }
                }
                case Err(_) {
                    assert(false)
                }
            }
        }
        case Err(_) {
            assert(false)
        }
    }
}

