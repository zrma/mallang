test ChecksAndRejectsLoopControlByDepth() {
    accepted := "func exercise(flag bool) int { for flag { continue }; for { break }; return 0 } func main() {}"
    match lexer.Lex(accepted) {
        case Ok(tokens) {
            match parser.Parse(tokens) {
                case Ok(program) {
                    match Check(con program) {
                        case Ok(_) {
                            assert(true)
                        }
                        case Err(_) {
                            assert(false)
                        }
                    }
                }
                case Err(_) {
                    assert(false)
                }
            }
        }
        case Err(_) {
            assert(false)
        }
    }

    rejected := "func exercise() int { break; return 0 } func main() {}"
    match lexer.Lex(rejected) {
        case Ok(tokens) {
            match parser.Parse(tokens) {
                case Ok(program) {
                    match Check(con program) {
                        case Ok(_) {
                            assert(false)
                        }
                        case Err(error) {
                            assert(ErrorMessage(con error) == "`break` can only be used inside a loop")
                        }
                    }
                }
                case Err(_) {
                    assert(false)
                }
            }
        }
        case Err(_) {
            assert(false)
        }
    }
}

