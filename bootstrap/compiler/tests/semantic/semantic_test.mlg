test ChecksLocalMoveAndBorrowStates() {
    source := "func inspect(con value string) int { return 1 } func touch(mut value string) int { return 2 } func copyValue(value int) int { return value } func exercise() int { text := \"hello\"; first := inspect(con text); second := inspect(con text); mut changed := \"before\"; third := touch(mut changed); fourth := touch(mut changed); number := 7; fifth := copyValue(number); sixth := copyValue(number); return first + second + third + fourth + fifth + sixth } func main() {}"
    match lexer.Lex(source) {
        case Ok(tokens) {
            match parser.Parse(tokens) {
                case Ok(program) {
                    match Check(con program) {
                        case Ok(_) {
                            assert(true)
                        }
                        case Err(_) {
                            assert(false)
                        }
                    }
                }
                case Err(_) {
                    assert(false)
                }
            }
        }
        case Err(_) {
            assert(false)
        }
    }
}

