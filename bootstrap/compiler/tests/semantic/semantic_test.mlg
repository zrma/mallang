package semantic

import "bootstrap_compiler/frontend/ast"
import "bootstrap_compiler/frontend/lexer"
import "bootstrap_compiler/frontend/parser"

test CollectsDeclarationSignatures() {
    source := "type User struct { name string; age int } type Choice enum { Empty; Score(int) } func describe(con value Option[string]) string { return \"ok\" } func (mut user User) rename(con name string) {} func main() {}"
    match lexer.Lex(source) {
        case Ok(tokens) {
            match parser.Parse(tokens) {
                case Ok(program) {
                    match Check(con program) {
                        case Ok(checked) {
                            expected := "CHECKED|1|1|2|1\nSTRUCT|User|2\nFIELD|User|name|string\nFIELD|User|age|int\nENUM|Choice|2\nVARIANT|Choice|Empty|0\nVARIANT|Choice|Score|1|int\nFUNC|describe|string|1\nPARAM|describe|con|value|Option[string]\nFUNC|main|unit|0\nMETHOD|User|rename|mut|user|unit|1\nMPARAM|User|rename|con|name|string"
                            actual := Normalize(con checked)
                            assert(actual == expected)
                        }
                        case Err(_) {
                            assert(false)
                        }
                    }
                }
                case Err(_) {
                    assert(false)
                }
            }
        }
        case Err(_) {
            assert(false)
        }
    }
}

test RejectsUnknownTypes() {
    source := "type User struct { value Missing } func main() {}"
    match lexer.Lex(source) {
        case Ok(tokens) {
            match parser.Parse(tokens) {
                case Ok(program) {
                    match Check(con program) {
                        case Ok(_) {
                            assert(false)
                        }
                        case Err(error) {
                            actual := ErrorMessage(con error)
                            assert(actual == "unknown type `Missing`")
                        }
                    }
                }
                case Err(_) {
                    assert(false)
                }
            }
        }
        case Err(_) {
            assert(false)
        }
    }
}

test ChecksPrimitiveFunctionBodies() {
    source := "func compute(left int, right int) int { mut total := left + right * 2; total = total - 1; return total } func main() {}"
    match lexer.Lex(source) {
        case Ok(tokens) {
            match parser.Parse(tokens) {
                case Ok(program) {
                    match Check(con program) {
                        case Ok(checked) {
                            root := ast.Root(con program)
                            function := ast.Child(con program, root, 1)
                            block := ast.Child(con program, function, ast.ChildCount(con program, function) - 1)
                            binding := ast.Child(con program, block, 0)
                            expression := ast.Child(con program, binding, 0)
                            match NodeType(con checked, expression) {
                                case Ok(ty) {
                                    assert(ty == "int")
                                }
                                case Err(_) {
                                    assert(false)
                                }
                            }
                        }
                        case Err(_) {
                            assert(false)
                        }
                    }
                }
                case Err(_) {
                    assert(false)
                }
            }
        }
        case Err(_) {
            assert(false)
        }
    }
}

test RejectsImmutableAssignment() {
    source := "func main() { value := 1; value = 2 }"
    match lexer.Lex(source) {
        case Ok(tokens) {
            match parser.Parse(tokens) {
                case Ok(program) {
                    match Check(con program) {
                        case Ok(_) {
                            assert(false)
                        }
                        case Err(error) {
                            assert(ErrorMessage(con error) == "cannot assign to immutable binding `value`")
                        }
                    }
                }
                case Err(_) {
                    assert(false)
                }
            }
        }
        case Err(_) {
            assert(false)
        }
    }
}

test ChecksDirectAndIndirectFunctionCalls() {
    source := "func add(left int, right int) int { return left + right } func compute() int { direct := add(1, 2); operation := add; indirect := operation(3, 4); return direct + indirect } func main() {}"
    match lexer.Lex(source) {
        case Ok(tokens) {
            match parser.Parse(tokens) {
                case Ok(program) {
                    match Check(con program) {
                        case Ok(_) {
                            assert(true)
                        }
                        case Err(_) {
                            assert(false)
                        }
                    }
                }
                case Err(_) {
                    assert(false)
                }
            }
        }
        case Err(_) {
            assert(false)
        }
    }
}

test RejectsIndirectFunctionCallMode() {
    source := "func inspect(con value int) int { return value } func main() { operation := inspect; value := 1; inspected := operation(value) }"
    match lexer.Lex(source) {
        case Ok(tokens) {
            match parser.Parse(tokens) {
                case Ok(program) {
                    match Check(con program) {
                        case Ok(_) {
                            assert(false)
                        }
                        case Err(error) {
                            assert(ErrorMessage(con error) == "parameter `argument 1` expects `con` argument")
                        }
                    }
                }
                case Err(_) {
                    assert(false)
                }
            }
        }
        case Err(_) {
            assert(false)
        }
    }
}

test ChecksFieldAndIndexReads() {
    source := "type User struct { age int } func readAge(con user User) int { return user.age } func readArray(con values [2]int) int { return values[0] + values[1] } func readSlice(con values []int, index int) int { return values[index] } func main() {}"
    match lexer.Lex(source) {
        case Ok(tokens) {
            match parser.Parse(tokens) {
                case Ok(program) {
                    match Check(con program) {
                        case Ok(_) {
                            assert(true)
                        }
                        case Err(_) {
                            assert(false)
                        }
                    }
                }
                case Err(_) {
                    assert(false)
                }
            }
        }
        case Err(_) {
            assert(false)
        }
    }
}

test RejectsArrayIndexOutOfBounds() {
    source := "func read(con values [2]int) int { return values[2] } func main() {}"
    match lexer.Lex(source) {
        case Ok(tokens) {
            match parser.Parse(tokens) {
                case Ok(program) {
                    match Check(con program) {
                        case Ok(_) {
                            assert(false)
                        }
                        case Err(error) {
                            assert(ErrorMessage(con error) == "array index 2 is out of bounds for length 2")
                        }
                    }
                }
                case Err(_) {
                    assert(false)
                }
            }
        }
        case Err(_) {
            assert(false)
        }
    }
}

