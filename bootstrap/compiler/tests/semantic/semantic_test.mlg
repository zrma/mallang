test ChecksNestedIfScopes() {
    source := "func choose(flag bool, nested bool) int { value := 1; if flag { value := 2; if nested { return value } else { return 3 } } else { return value } } func main() {}"
    match lexer.Lex(source) {
        case Ok(tokens) {
            match parser.Parse(tokens) {
                case Ok(program) {
                    match Check(con program) {
                        case Ok(_) {
                            assert(true)
                        }
                        case Err(_) {
                            assert(false)
                        }
                    }
                }
                case Err(_) {
                    assert(false)
                }
            }
        }
        case Err(_) {
            assert(false)
        }
    }
}

test RejectsLeakedIfBinding() {
    source := "func main() { if true { inner := 1 }; leaked := inner }"
    match lexer.Lex(source) {
        case Ok(tokens) {
            match parser.Parse(tokens) {
                case Ok(program) {
                    match Check(con program) {
                        case Ok(_) {
                            assert(false)
                        }
                        case Err(error) {
                            assert(ErrorMessage(con error) == "unknown variable `inner`")
                        }
                    }
                }
                case Err(_) {
                    assert(false)
                }
            }
        }
        case Err(_) {
            assert(false)
        }
    }
}
