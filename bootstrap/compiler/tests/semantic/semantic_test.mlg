test RecordsClosureCaptureMetadata() {
    source := "func run() int { offset := 10; add := func(value int) int { return value + offset }; return add(2) } func main() {}"
    match lexer.Lex(source) {
        case Ok(tokens) {
            match parser.Parse(tokens) {
                case Ok(program) {
                    match Check(con program) {
                        case Ok(checked) {
                            assert(len(checked.closures) == 1)
                            assert(len(checked.closures[0].captures) == 1)
                            assert(checked.closures[0].captures[0].name == "offset")
                            assert(checked.closures[0].captures[0].ty.text == "int")
                            assert(!checked.closures[0].captures[0].mutable)
                        }
                        case Err(_) {
                            assert(false)
                        }
                    }
                }
                case Err(_) {
                    assert(false)
                }
            }
        }
        case Err(_) {
            assert(false)
        }
    }
}

