package ir

import "std/strings"
import "bootstrap_compiler/frontend/ast"
import "bootstrap_compiler/frontend/source"
import "bootstrap_compiler/frontend/token"
import "bootstrap_compiler/semantic"

pub type Node struct {
    category string
    kind string
    value string
    ty string
    span source.Span
    children []int
    cleanup bool
}

pub type Param struct {
    name string
    mode string
    ty string
}

pub type Function struct {
    name string
    params []Param
    returnType string
    body []int
}

pub type Capture struct {
    name string
    ty string
    mutable bool
}

pub type Closure struct {
    name string
    mutable bool
    captures []Capture
    params []Param
    returnType string
    body []int
}

pub type Program struct {
    nodes []Node
    functions []Function
    closures []Closure
}

pub type Error struct {
    message string
    span source.Span
}

type Lowerer struct {
    nodes []Node
    functions []Function
    closures []Closure
}

type CleanupBinding struct {
    key string
    name string
    ty string
    span source.Span
}

type CleanupFlow struct {
    moved []string
    continues bool
}

type LoweredMatchPattern struct {
    node int
    cleanup []CleanupBinding
    nextDiscard int
}

pub func Lower(con syntax ast.Program, con checked semantic.CheckedProgram) Result[Program, Error] {
    mut lowerer := Lowerer{nodes: []Node{}, functions: []Function{}, closures: []Closure{},}
    match lowerer.lowerProgramDeclarations(con syntax, con checked) {
        case Ok(_) {
            return Ok(Program{nodes: lowerer.nodes, functions: lowerer.functions, closures: lowerer.closures})
        }
        case Err(error) {
            return Err(error)
        }
    }
}

pub func LowerTest(con syntax ast.Program, con checked semantic.CheckedProgram, testIndex int) Result[Program, Error] {
    mut lowerer := Lowerer{nodes: []Node{}, functions: []Function{}, closures: []Closure{},}
    match lowerer.lowerProgramDeclarations(con syntax, con checked) {
        case Ok(_) {}
        case Err(error) {
            return Err(error)
        }
    }

    root := ast.Root(con syntax)
    mut selectedTest := -1
    mut seenTests := 0
    for mut child := 0; child < ast.ChildCount(con syntax, root); child = child + 1 {
        declaration := ast.Child(con syntax, root, child)
        if ast.Kind(con syntax, declaration) == "TestDecl" {
            if seenTests == testIndex {
                selectedTest = declaration
            }
            seenTests = seenTests + 1
        }
    }
    if selectedTest < 0 {
        return Err(newError("unknown test index", ast.Span(con syntax, root)))
    }
    block := ast.Child(con syntax, selectedTest, 0)
    mut testBody := []int{}
    match lowerer.lowerBlock(con syntax, block, con checked) {
        case Ok(body) {
            testBody = lowerer.insertStraightLineCleanupDrops(con body, []CleanupBinding{}, []CleanupBinding{}, ast.Span(con syntax, block))
        }
        case Err(error) {
            return Err(error)
        }
    }

    mut functions := []Function{}
    for mut function := 0; function < len(lowerer.functions); function = function + 1 {
        if lowerer.functions[function].name != "main" {
            functions = append(functions, copyFunction(con lowerer.functions[function]))
        }
    }
    functions = append(functions, Function{name: "main", params: []Param{}, returnType: "unit", body: testBody,})
    return Ok(Program{nodes: lowerer.nodes, functions: functions, closures: lowerer.closures})
}

func (mut self Lowerer) lowerProgramDeclarations(con syntax ast.Program, con checked semantic.CheckedProgram) Result[bool, Error] {
    root := ast.Root(con syntax)
    for mut child := 0; child < ast.ChildCount(con syntax, root); child = child + 1 {
        declaration := ast.Child(con syntax, root, child)
        declarationKind := ast.Kind(con syntax, declaration)
        if declarationKind == "FunctionDecl.Package" || declarationKind == "FunctionDecl.Public" {
            match self.lowerFunction(con syntax, declaration, con checked) {
                case Ok(_) {}
                case Err(error) {
                    return Err(error)
                }
            }
        }
    }
    for mut closure := 0; closure < semantic.ClosureCount(con checked); closure = closure + 1 {
        match self.lowerClosure(con syntax, closure, con checked) {
            case Ok(_) {}
            case Err(error) {
                return Err(error)
            }
        }
    }
    return Ok(true)
}

pub func Normalize(con program Program) string {
    mut lines := []string{strings.join(con []string{"IR|", strings.fromInt(len(program.functions)),}, con ""),}
    for mut functionIndex := 0; functionIndex < len(program.functions); functionIndex = functionIndex + 1 {
        lines = append(lines, strings.join(con []string{"FUNCTION|", token.CopyText(con program.functions[functionIndex].name), "|", token.CopyText(con program.functions[functionIndex].returnType), "|", strings.fromInt(len(program.functions[functionIndex].params)), "|", strings.fromInt(len(program.functions[functionIndex].body)),}, con ""))
        for mut paramIndex := 0; paramIndex < len(program.functions[functionIndex].params); paramIndex = paramIndex + 1 {
            lines = append(lines, strings.join(con []string{"IPARAM|", token.CopyText(con program.functions[functionIndex].name), "|", token.CopyText(con program.functions[functionIndex].params[paramIndex].mode), "|", token.CopyText(con program.functions[functionIndex].params[paramIndex].name), "|", token.CopyText(con program.functions[functionIndex].params[paramIndex].ty),}, con ""))
        }
        for mut statementIndex := 0; statementIndex < len(program.functions[functionIndex].body); statementIndex = statementIndex + 1 {
            lines = append(lines, normalizeNode(con program, program.functions[functionIndex].body[statementIndex], 0))
        }
    }
    lines = append(lines, strings.join(con []string{"CLOSURES|", strings.fromInt(len(program.closures)),}, con ""))
    for mut closureIndex := 0; closureIndex < len(program.closures); closureIndex = closureIndex + 1 {
        mut mutable := "false"
        if program.closures[closureIndex].mutable {
            mutable = "true"
        }
        lines = append(lines, strings.join(con []string{"CLOSURE|", token.CopyText(con program.closures[closureIndex].name), "|", mutable, "|", token.CopyText(con program.closures[closureIndex].returnType), "|", strings.fromInt(len(program.closures[closureIndex].params)), "|", strings.fromInt(len(program.closures[closureIndex].captures)), "|", strings.fromInt(len(program.closures[closureIndex].body)),}, con ""))
        for mut captureIndex := 0; captureIndex < len(program.closures[closureIndex].captures); captureIndex = captureIndex + 1 {
            mut captureMutable := "false"
            if program.closures[closureIndex].captures[captureIndex].mutable {
                captureMutable = "true"
            }
            lines = append(lines, strings.join(con []string{"CCAPTURE|", token.CopyText(con program.closures[closureIndex].name), "|", captureMutable, "|", token.CopyText(con program.closures[closureIndex].captures[captureIndex].name), "|", token.CopyText(con program.closures[closureIndex].captures[captureIndex].ty),}, con ""))
        }
        for mut paramIndex := 0; paramIndex < len(program.closures[closureIndex].params); paramIndex = paramIndex + 1 {
            lines = append(lines, strings.join(con []string{"CPARAM|", token.CopyText(con program.closures[closureIndex].name), "|", token.CopyText(con program.closures[closureIndex].params[paramIndex].mode), "|", token.CopyText(con program.closures[closureIndex].params[paramIndex].name), "|", token.CopyText(con program.closures[closureIndex].params[paramIndex].ty),}, con ""))
        }
        for mut statementIndex := 0; statementIndex < len(program.closures[closureIndex].body); statementIndex = statementIndex + 1 {
            lines = append(lines, normalizeNode(con program, program.closures[closureIndex].body[statementIndex], 0))
        }
    }
    return strings.join(con lines, con "\n")
}

pub func NormalizeError(con error Error) string {
    span := source.Copy(con error.span)
    return strings.join(con []string{"IERR|", strings.fromInt(source.Source(con span)), "|", strings.fromInt(source.Start(con span)), "|", strings.fromInt(source.End(con span)), "|", token.EncodeBytes(con error.message),}, con "")
}

func (mut self Lowerer) lowerFunction(con syntax ast.Program, declaration int, con checked semantic.CheckedProgram) Result[bool, Error] {
    name := ast.Value(con syntax, declaration)
    mut block := -1
    mut receiverNode := -1
    for mut child := 0; child < ast.ChildCount(con syntax, declaration); child = child + 1 {
        node := ast.Child(con syntax, declaration, child)
        kind := ast.Kind(con syntax, node)
        if kind == "Receiver" {
            receiverNode = ast.Child(con syntax, node, 0)
        }
        if kind == "Block" {
            block = node
        }
    }

    mut irName := token.CopyText(con name)
    mut returnType := ""
    mut params := []Param{}
    mut paramCleanup := []bool{}
    if receiverNode >= 0 {
        receiverTypeNode := ast.Child(con syntax, receiverNode, 0)
        receiverType := ast.Value(con syntax, receiverTypeNode)
        if !semantic.MethodExists(con checked, con receiverType, con name) {
            return Err(newError("checked method signature is missing", ast.Span(con syntax, declaration)))
        }
        irName = strings.join(con []string{token.CopyText(con receiverType), ".", token.CopyText(con name),}, con "")
        match semantic.MethodReturnType(con checked, con receiverType, con name) {
            case Ok(ty) {
                returnType = ty
            }
            case Err(_) {
                return Err(newError("checked method return type is missing", ast.Span(con syntax, declaration)))
            }
        }
        params = append(params, Param{name: semantic.MethodReceiverName(con checked, con receiverType, con name), mode: semantic.MethodReceiverMode(con checked, con receiverType, con name), ty: semantic.MethodReceiverType(con checked, con receiverType, con name),})
        paramCleanup = append(paramCleanup, semantic.MethodReceiverNeedsCleanup(con checked, con receiverType, con name))
        paramCount := semantic.MethodParamCount(con checked, con receiverType, con name)
        for mut param := 0; param < paramCount; param = param + 1 {
            params = append(params, Param{name: semantic.MethodParamName(con checked, con receiverType, con name, param), mode: semantic.MethodParamMode(con checked, con receiverType, con name, param), ty: semantic.MethodParamType(con checked, con receiverType, con name, param),})
            paramCleanup = append(paramCleanup, semantic.MethodParamNeedsCleanup(con checked, con receiverType, con name, param))
        }
    } else {
        match semantic.FunctionReturnType(con checked, con name) {
            case Ok(ty) {
                returnType = ty
            }
            case Err(_) {
                return Err(newError("checked function return type is missing", ast.Span(con syntax, declaration)))
            }
        }
        paramCount := semantic.FunctionParamCount(con checked, con name)
        for mut param := 0; param < paramCount; param = param + 1 {
            params = append(params, Param{name: semantic.FunctionParamName(con checked, con name, param), mode: semantic.FunctionParamMode(con checked, con name, param), ty: semantic.FunctionParamType(con checked, con name, param),})
            paramCleanup = append(paramCleanup, semantic.FunctionParamNeedsCleanup(con checked, con name, param))
        }
    }

    mut cleanupParams := []CleanupBinding{}
    mut externalCleanupParams := []CleanupBinding{}
    for mut param := 0; param < len(params); param = param + 1 {
        if params[param].mode == "owned" && paramCleanup[param] {
            cleanupParams = append(cleanupParams, newCleanupBinding(con params[param].name, con params[param].ty, ast.Span(con syntax, block)))
        }
        if params[param].mode == "mut" && paramCleanup[param] {
            externalCleanupParams = append(externalCleanupParams, newCleanupBinding(con params[param].name, con params[param].ty, ast.Span(con syntax, block)))
        }
    }

    mut body := []int{}
    for mut statement := 0; statement < ast.ChildCount(con syntax, block); statement = statement + 1 {
        syntaxNode := ast.Child(con syntax, block, statement)
        match self.lowerStatement(con syntax, syntaxNode, con checked) {
            case Ok(irNode) {
                body = append(body, irNode)
            }
            case Err(error) {
                return Err(error)
            }
        }
    }
    body = self.insertStraightLineCleanupDrops(con body, cleanupParams, externalCleanupParams, ast.Span(con syntax, block))
    self.functions = append(self.functions, Function{name: irName, params: params, returnType: returnType, body: body})
    return Ok(true)
}

func (mut self Lowerer) lowerClosure(con syntax ast.Program, closure int, con checked semantic.CheckedProgram) Result[bool, Error] {
    node := semantic.ClosureNode(con checked, closure)
    mut block := -1
    for mut child := 0; child < ast.ChildCount(con syntax, node); child = child + 1 {
        syntaxChild := ast.Child(con syntax, node, child)
        if ast.Kind(con syntax, syntaxChild) == "Block" {
            block = syntaxChild
        }
    }
    if block < 0 {
        return Err(newError("checked closure body is missing", ast.Span(con syntax, node)))
    }

    mut captures := []Capture{}
    mut externalCleanup := []CleanupBinding{}
    for mut capture := 0; capture < semantic.ClosureCaptureCount(con checked, closure); capture = capture + 1 {
        captures = append(captures, Capture{name: semantic.ClosureCaptureName(con checked, closure, capture), ty: semantic.ClosureCaptureType(con checked, closure, capture), mutable: semantic.ClosureCaptureMutable(con checked, closure, capture),})
        if captures[capture].mutable && semantic.ClosureCaptureNeedsCleanup(con checked, closure, capture) {
            externalCleanup = append(externalCleanup, newCleanupBinding(con captures[capture].name, con captures[capture].ty, ast.Span(con syntax, block)))
        }
    }
    mut params := []Param{}
    mut cleanupParams := []CleanupBinding{}
    for mut param := 0; param < semantic.ClosureParamCount(con checked, closure); param = param + 1 {
        params = append(params, Param{name: semantic.ClosureParamName(con checked, closure, param), mode: semantic.ClosureParamMode(con checked, closure, param), ty: semantic.ClosureParamType(con checked, closure, param),})
        if params[param].mode == "owned" && semantic.ClosureParamNeedsCleanup(con checked, closure, param) {
            cleanupParams = append(cleanupParams, newCleanupBinding(con params[param].name, con params[param].ty, ast.Span(con syntax, block)))
        }
        if params[param].mode == "mut" && semantic.ClosureParamNeedsCleanup(con checked, closure, param) {
            externalCleanup = append(externalCleanup, newCleanupBinding(con params[param].name, con params[param].ty, ast.Span(con syntax, block)))
        }
    }
    match self.lowerBlock(con syntax, block, con checked) {
        case Ok(body) {
            cleanedBody := self.insertStraightLineCleanupDrops(con body, cleanupParams, externalCleanup, ast.Span(con syntax, block))
            self.closures = append(self.closures, Closure{name: closureName(ast.Span(con syntax, node)), mutable: semantic.ClosureMutable(con checked, closure), captures: captures, params: params, returnType: semantic.ClosureReturnType(con checked, closure), body: cleanedBody,})
            return Ok(true)
        }
        case Err(error) {
            return Err(error)
        }
    }
}

func (mut self Lowerer) lowerStatement(con syntax ast.Program, statement int, con checked semantic.CheckedProgram) Result[int, Error] {
    kind := ast.Kind(con syntax, statement)
    value := ast.Value(con syntax, statement)
    if kind == "Stmt.Break" || kind == "Stmt.Continue" {
        return Ok(self.addNode("S", token.CopyText(con kind), "", "unit", ast.Span(con syntax, statement), []int{}, false))
    }
    if kind == "Stmt.For" {
        childCount := ast.ChildCount(con syntax, statement)
        if childCount < 1 {
            return Err(newError("checked for statement body is missing", ast.Span(con syntax, statement)))
        }
        body := ast.Child(con syntax, statement, childCount - 1)
        if ast.Kind(con syntax, body) != "Block" {
            return Err(newError("checked for statement body is malformed", ast.Span(con syntax, statement)))
        }
        mut children := []int{}
        for mut child := 0; child < childCount - 1; child = child + 1 {
            control := ast.Child(con syntax, statement, child)
            controlKind := ast.Kind(con syntax, control)
            if controlKind == "ForInit.Let.Immutable" || controlKind == "ForInit.Let.Mutable" {
                if ast.ChildCount(con syntax, control) != 1 {
                    return Err(newError("checked for init is malformed", ast.Span(con syntax, control)))
                }
                expression := ast.Child(con syntax, control, 0)
                match self.lowerExpression(con syntax, expression, con checked) {
                    case Ok(loweredExpression) {
                        match semantic.NodeType(con checked, expression) {
                            case Ok(expressionType) {
                                children = append(children, self.addNode("F", token.CopyText(con controlKind), ast.Value(con syntax, control), expressionType, ast.Span(con syntax, expression), []int{loweredExpression}, semantic.NodeNeedsCleanup(con checked, expression)))
                            }
                            case Err(_) {
                                return Err(newError("checked for init type is missing", ast.Span(con syntax, control)))
                            }
                        }
                    }
                    case Err(error) {
                        return Err(error)
                    }
                }
            } else if controlKind == "ForCondition" {
                if ast.ChildCount(con syntax, control) != 1 {
                    return Err(newError("checked for condition is malformed", ast.Span(con syntax, control)))
                }
                condition := ast.Child(con syntax, control, 0)
                match self.lowerExpression(con syntax, condition, con checked) {
                    case Ok(loweredCondition) {
                        children = append(children, self.addNode("F", "ForCondition", "", "bool", ast.Span(con syntax, condition), []int{loweredCondition}, false))
                    }
                    case Err(error) {
                        return Err(error)
                    }
                }
            } else if controlKind == "ForPost.Assign" {
                if ast.ChildCount(con syntax, control) != 2 {
                    return Err(newError("checked for post is malformed", ast.Span(con syntax, control)))
                }
                mut postChildren := []int{}
                for mut postChild := 0; postChild < 2; postChild = postChild + 1 {
                    match self.lowerExpression(con syntax, ast.Child(con syntax, control, postChild), con checked) {
                        case Ok(loweredPostChild) {
                            postChildren = append(postChildren, loweredPostChild)
                        }
                        case Err(error) {
                            return Err(error)
                        }
                    }
                }
                children = append(children, self.addNode("F", "ForPost.Assign", "", "unit", ast.Span(con syntax, control), postChildren, false))
            } else {
                return Err(newError("checked for control is malformed", ast.Span(con syntax, control)))
            }
        }
        match self.lowerBlock(con syntax, body, con checked) {
            case Ok(loweredBody) {
                children = append(children, self.addNode("B", "Block.For", "", "unit", ast.Span(con syntax, statement), loweredBody, false))
            }
            case Err(error) {
                return Err(error)
            }
        }
        children = append(children, self.addNode("B", "Block.ForCleanup", "", "unit", ast.Span(con syntax, statement), []int{}, false))
        return Ok(self.addNode("S", "Stmt.For", "", "unit", ast.Span(con syntax, statement), children, false))
    }
    if kind == "Stmt.RangeFor" {
        if ast.ChildCount(con syntax, statement) != 2 {
            return Err(newError("checked range statement is malformed", ast.Span(con syntax, statement)))
        }
        rangeSource := ast.Child(con syntax, statement, 0)
        body := ast.Child(con syntax, statement, 1)
        if ast.Kind(con syntax, body) != "Block" {
            return Err(newError("checked range statement body is malformed", ast.Span(con syntax, statement)))
        }
        mut elementType := ""
        match semantic.NodeTypeArgument(con checked, rangeSource, 0) {
            case Ok(resolved) {
                elementType = resolved
            }
            case Err(_) {
                return Err(newError("checked range element type is missing", ast.Span(con syntax, rangeSource)))
            }
        }
        mut children := []int{self.addNode("F", "RangeBindings", token.CopyText(con value), token.CopyText(con elementType), ast.Span(con syntax, statement), []int{}, false),}
        match self.lowerReadExpression(con syntax, rangeSource, con checked) {
            case Ok(loweredSource) {
                children = append(children, loweredSource)
            }
            case Err(error) {
                return Err(error)
            }
        }
        match self.lowerBlock(con syntax, body, con checked) {
            case Ok(loweredBody) {
                children = append(children, self.addNode("B", "Block.RangeFor", "", "unit", ast.Span(con syntax, statement), loweredBody, false))
            }
            case Err(error) {
                return Err(error)
            }
        }
        children = append(children, self.addNode("B", "Block.RangeCleanup", "", "unit", ast.Span(con syntax, statement), []int{}, false))
        return Ok(self.addNode("S", "Stmt.RangeFor", "", "unit", ast.Span(con syntax, statement), children, false))
    }
    if kind == "Stmt.If" {
        condition := ast.Child(con syntax, statement, 0)
        mut children := []int{}
        match self.lowerExpression(con syntax, condition, con checked) {
            case Ok(irCondition) {
                children = append(children, irCondition)
            }
            case Err(error) {
                return Err(error)
            }
        }
        thenBlock := ast.Child(con syntax, statement, 1)
        match self.lowerBlock(con syntax, thenBlock, con checked) {
            case Ok(body) {
                block := self.addNode("B", "Block.Then", "", "unit", ast.Span(con syntax, statement), body, false)
                children = append(children, block)
            }
            case Err(error) {
                return Err(error)
            }
        }
        mut elseBody := []int{}
        if ast.ChildCount(con syntax, statement) > 2 {
            elseBlock := ast.Child(con syntax, statement, 2)
            match self.lowerBlock(con syntax, elseBlock, con checked) {
                case Ok(body) {
                    elseBody = body
                }
                case Err(error) {
                    return Err(error)
                }
            }
        }
        elseBlock := self.addNode("B", "Block.Else", "", "unit", ast.Span(con syntax, statement), elseBody, false)
        children = append(children, elseBlock)
        return Ok(self.addNode("S", "Stmt.If", "", "unit", ast.Span(con syntax, statement), children, false))
    }
    if kind == "Stmt.Match" {
        if ast.ChildCount(con syntax, statement) < 2 {
            return Err(newError("checked match statement has no arms", ast.Span(con syntax, statement)))
        }
        scrutinee := ast.Child(con syntax, statement, 0)
        mut children := []int{}
        match self.lowerExpression(con syntax, scrutinee, con checked) {
            case Ok(loweredScrutinee) {
                children = append(children, loweredScrutinee)
            }
            case Err(error) {
                return Err(error)
            }
        }
        for mut child := 1; child < ast.ChildCount(con syntax, statement); child = child + 1 {
            arm := ast.Child(con syntax, statement, child)
            if ast.Kind(con syntax, arm) != "MatchBlockArm" || ast.ChildCount(con syntax, arm) != 2 {
                return Err(newError("checked match block arm is malformed", ast.Span(con syntax, arm)))
            }
            pattern := ast.Child(con syntax, arm, 0)
            block := ast.Child(con syntax, arm, 1)
            mut loweredPattern := LoweredMatchPattern{node: -1, cleanup: []CleanupBinding{}, nextDiscard: 0,}
            match self.lowerMatchPattern(con syntax, pattern, scrutinee, ast.Span(con syntax, block), ast.Span(con syntax, arm), con checked) {
                case Ok(value) {
                    loweredPattern = value
                }
                case Err(error) {
                    return Err(error)
                }
            }
            match self.lowerBlock(con syntax, block, con checked) {
                case Ok(body) {
                    cleanedBody := self.insertStraightLineCleanupDrops(con body, copyCleanupBindings(con loweredPattern.cleanup), []CleanupBinding{}, ast.Span(con syntax, block))
                    loweredBlock := self.addNode("B", "Block.Match", "", "unit", ast.Span(con syntax, block), cleanedBody, false)
                    children = append(children, self.addNode("M", "Match.BlockArm", "", "unit", ast.Span(con syntax, block), []int{loweredPattern.node, loweredBlock}, false))
                }
                case Err(error) {
                    return Err(error)
                }
            }
        }
        return Ok(self.addNode("S", "Stmt.Match", "", "unit", ast.Span(con syntax, statement), children, false))
    }
    if kind == "Stmt.FieldAssign" {
        base := ast.Child(con syntax, statement, 0)
        expression := ast.Child(con syntax, statement, 1)
        mut children := []int{}
        match self.lowerExpression(con syntax, base, con checked) {
            case Ok(irBase) {
                children = append(children, irBase)
            }
            case Err(error) {
                return Err(error)
            }
        }
        match self.lowerExpression(con syntax, expression, con checked) {
            case Ok(irExpression) {
                children = append(children, irExpression)
            }
            case Err(error) {
                return Err(error)
            }
        }
        return Ok(self.addNode("S", token.CopyText(con kind), token.CopyText(con value), "unit", ast.Span(con syntax, statement), children, false))
    }
    if kind == "Stmt.IndexAssign" {
        mut children := []int{}
        for mut child := 0; child < ast.ChildCount(con syntax, statement); child = child + 1 {
            syntaxChild := ast.Child(con syntax, statement, child)
            match self.lowerExpression(con syntax, syntaxChild, con checked) {
                case Ok(irChild) {
                    children = append(children, irChild)
                }
                case Err(error) {
                    return Err(error)
                }
            }
        }
        return Ok(self.addNode("S", token.CopyText(con kind), "", "unit", ast.Span(con syntax, statement), children, false))
    }
    if kind == "Stmt.Assert" {
        if ast.ChildCount(con syntax, statement) != 1 {
            return Err(newError("checked assertion condition is missing", ast.Span(con syntax, statement)))
        }
        condition := ast.Child(con syntax, statement, 0)
        match self.lowerExpression(con syntax, condition, con checked) {
            case Ok(loweredCondition) {
                return Ok(self.addNode("S", "Stmt.Assert", "", "unit", ast.Span(con syntax, statement), []int{loweredCondition}, false))
            }
            case Err(error) {
                return Err(error)
            }
        }
    }
    if kind == "Stmt.Let.Immutable" || kind == "Stmt.Let.Mutable" || kind == "Stmt.Assign" || kind == "Stmt.Return" || kind == "Stmt.Expr" {
        expression := ast.Child(con syntax, statement, 0)
        match self.lowerExpression(con syntax, expression, con checked) {
            case Ok(child) {
                mut ty := "unit"
                if kind == "Stmt.Let.Immutable" || kind == "Stmt.Let.Mutable" {
                    match semantic.NodeType(con checked, expression) {
                        case Ok(expressionType) {
                            ty = expressionType
                        }
                        case Err(_) {
                            return Err(newError("checked let expression type is missing", ast.Span(con syntax, statement)))
                        }
                    }
                }
                letBinding := kind == "Stmt.Let.Immutable" || kind == "Stmt.Let.Mutable"
                cleanup := letBinding && semantic.NodeNeedsCleanup(con checked, expression)
                return Ok(self.addNode("S", kind, value, ty, ast.Span(con syntax, statement), []int{child}, cleanup))
            }
            case Err(error) {
                return Err(error)
            }
        }
    }
    return Err(newError("B2b typed IR does not yet accept this statement", ast.Span(con syntax, statement)))
}

func (mut self Lowerer) lowerBlock(con syntax ast.Program, block int, con checked semantic.CheckedProgram) Result[[]int, Error] {
    mut body := []int{}
    for mut statement := 0; statement < ast.ChildCount(con syntax, block); statement = statement + 1 {
        syntaxNode := ast.Child(con syntax, block, statement)
        match self.lowerStatement(con syntax, syntaxNode, con checked) {
            case Ok(irNode) {
                body = append(body, irNode)
            }
            case Err(error) {
                return Err(error)
            }
        }
    }
    return Ok(body)
}

func (mut self Lowerer) lowerExpression(con syntax ast.Program, expression int, con checked semantic.CheckedProgram) Result[int, Error] {
    kind := ast.Kind(con syntax, expression)
    value := ast.Value(con syntax, expression)
    mut ty := ""
    match semantic.NodeType(con checked, expression) {
        case Ok(resolved) {
            ty = resolved
        }
        case Err(_) {
            return Err(newError("checked expression type is missing", ast.Span(con syntax, expression)))
        }
    }
    cleanup := semantic.NodeNeedsCleanup(con checked, expression)

    if kind == "Expr.FunctionLiteral.Immutable" || kind == "Expr.FunctionLiteral.Mutable" {
        closure := semantic.ClosureIndexForNode(con checked, expression)
        if closure < 0 {
            return Err(newError("checked closure metadata is missing", ast.Span(con syntax, expression)))
        }
        mut captures := []int{}
        for mut capture := 0; capture < semantic.ClosureCaptureCount(con checked, closure); capture = capture + 1 {
            name := semantic.ClosureCaptureName(con checked, closure, capture)
            captureType := semantic.ClosureCaptureType(con checked, closure, capture)
            captureCleanup := semantic.ClosureCaptureNeedsCleanup(con checked, closure, capture)
            variable := self.addNode("E", "Expr.Var", token.CopyText(con name), token.CopyText(con captureType), ast.Span(con syntax, expression), []int{}, captureCleanup)
            captureValue := self.addNode("C", "Closure.Capture", token.CopyText(con name), token.CopyText(con captureType), ast.Span(con syntax, expression), []int{variable}, captureCleanup)
            captures = append(captures, captureValue)
        }
        return Ok(self.addNode("E", "Expr.ClosureValue", closureName(ast.Span(con syntax, expression)), token.CopyText(con ty), ast.Span(con syntax, expression), captures, cleanup))
    }

    if kind == "Expr.Call" {
        callee := ast.Child(con syntax, expression, 0)
        if ast.Kind(con syntax, callee) == "Expr.FieldAccess" && ast.ChildCount(con syntax, callee) == 1 {
            enumBase := ast.Child(con syntax, callee, 0)
            if ast.Kind(con syntax, enumBase) == "Expr.Var" {
                enumName := ast.Value(con syntax, enumBase)
                variantName := ast.Value(con syntax, callee)
                payloadCount := semantic.EnumVariantPayloadCount(con checked, con enumName, con variantName)
                if payloadCount >= 0 {
                    if ast.ChildCount(con syntax, expression) != payloadCount + 1 {
                        return Err(newError("checked enum constructor argument count is invalid", ast.Span(con syntax, expression)))
                    }
                    mut payloads := []int{}
                    for mut payload := 0; payload < payloadCount; payload = payload + 1 {
                        argument := ast.Child(con syntax, expression, payload + 1)
                        if ast.Kind(con syntax, argument) != "Arg.Owned" || ast.ChildCount(con syntax, argument) != 1 {
                            return Err(newError("checked enum constructor argument mode is invalid", ast.Span(con syntax, argument)))
                        }
                        match self.lowerExpression(con syntax, ast.Child(con syntax, argument, 0), con checked) {
                            case Ok(loweredPayload) {
                                payloads = append(payloads, loweredPayload)
                            }
                            case Err(error) {
                                return Err(error)
                            }
                        }
                    }
                    storage := semantic.EnumStorage(con checked, con enumName)
                    if storage == "" {
                        return Err(newError("checked enum constructor storage is missing", ast.Span(con syntax, expression)))
                    }
                    return Ok(self.addNode("E", variantConstructorKind(con storage), token.CopyText(con variantName), token.CopyText(con ty), ast.Span(con syntax, expression), payloads, cleanup))
                }
            }

            mut receiverType := ""
            match semantic.NodeType(con checked, enumBase) {
                case Ok(resolved) {
                    receiverType = resolved
                }
                case Err(_) {}
            }
            methodName := ast.Value(con syntax, callee)
            if receiverType != "" && semantic.MethodExists(con checked, con receiverType, con methodName) {
                receiverMode := semantic.MethodReceiverMode(con checked, con receiverType, con methodName)
                mut loweredReceiver := -1
                if receiverMode == "owned" {
                    match self.lowerExpression(con syntax, enumBase, con checked) {
                        case Ok(value) {
                            loweredReceiver = value
                        }
                        case Err(error) {
                            return Err(error)
                        }
                    }
                } else {
                    match self.lowerReadExpression(con syntax, enumBase, con checked) {
                        case Ok(value) {
                            loweredReceiver = value
                        }
                        case Err(error) {
                            return Err(error)
                        }
                    }
                }

                mut receiverArgumentKind := "Arg.Owned"
                if receiverMode == "con" {
                    receiverArgumentKind = "Arg.Con"
                } else if receiverMode == "mut" {
                    receiverArgumentKind = "Arg.Mut"
                }
                receiverArgument := self.addNode("A", receiverArgumentKind, "", token.CopyText(con receiverType), ast.Span(con syntax, enumBase), []int{loweredReceiver}, false)
                mut methodChildren := []int{receiverArgument,}
                for mut argumentIndex := 1; argumentIndex < ast.ChildCount(con syntax, expression); argumentIndex = argumentIndex + 1 {
                    argument := ast.Child(con syntax, expression, argumentIndex)
                    match self.lowerArgument(con syntax, argument, con checked) {
                        case Ok(loweredArgument) {
                            methodChildren = append(methodChildren, loweredArgument)
                        }
                        case Err(error) {
                            return Err(error)
                        }
                    }
                }
                methodIrName := strings.join(con []string{token.CopyText(con receiverType), ".", token.CopyText(con methodName),}, con "")
                return Ok(self.addNode("E", "Expr.Call", methodIrName, token.CopyText(con ty), ast.Span(con syntax, expression), methodChildren, cleanup))
            }
        }
        if ast.Kind(con syntax, callee) == "Expr.Var" &&(ast.Value(con syntax, callee) == "Some" || ast.Value(con syntax, callee) == "Ok" || ast.Value(con syntax, callee) == "Err") {
            if ast.ChildCount(con syntax, expression) != 2 {
                return Err(newError("checked built-in constructor argument count is invalid", ast.Span(con syntax, expression)))
            }
            argument := ast.Child(con syntax, expression, 1)
            if ast.Kind(con syntax, argument) != "Arg.Owned" || ast.ChildCount(con syntax, argument) != 1 {
                return Err(newError("checked built-in constructor argument mode is invalid", ast.Span(con syntax, argument)))
            }
            match self.lowerExpression(con syntax, ast.Child(con syntax, argument, 0), con checked) {
                case Ok(payload) {
                    return Ok(self.addNode("E", "Expr.VariantConstructor.Inline", ast.Value(con syntax, callee), token.CopyText(con ty), ast.Span(con syntax, expression), []int{payload}, cleanup))
                }
                case Err(error) {
                    return Err(error)
                }
            }
        }
        if ast.Kind(con syntax, callee) == "Expr.Var" && ast.Value(con syntax, callee) == "print" {
            if ast.ChildCount(con syntax, expression) != 2 {
                return Err(newError("checked print argument count is invalid", ast.Span(con syntax, expression)))
            }
            argument := ast.Child(con syntax, expression, 1)
            if ast.Kind(con syntax, argument) != "Arg.Owned" {
                return Err(newError("checked print argument mode is invalid", ast.Span(con syntax, expression)))
            }
            argumentExpression := ast.Child(con syntax, argument, 0)
            mut argumentType := ""
            match semantic.NodeType(con checked, argumentExpression) {
                case Ok(resolved) {
                    argumentType = resolved
                }
                case Err(_) {
                    return Err(newError("checked print argument type is missing", ast.Span(con syntax, argument)))
                }
            }
            match self.lowerExpression(con syntax, argumentExpression, con checked) {
                case Ok(loweredArgument) {
                    readArgument := self.addNode("A", "Arg.Con", "", token.CopyText(con argumentType), ast.Span(con syntax, argument), []int{loweredArgument}, false)
                    return Ok(self.addNode("E", "Expr.Call", "print", token.CopyText(con ty), ast.Span(con syntax, expression), []int{readArgument}, cleanup))
                }
                case Err(error) {
                    return Err(error)
                }
            }
        }
        if ast.Kind(con syntax, callee) == "Expr.Var" && ast.Value(con syntax, callee) == "len" {
            if ast.ChildCount(con syntax, expression) != 2 {
                return Err(newError("checked len argument count is invalid", ast.Span(con syntax, expression)))
            }
            argument := ast.Child(con syntax, expression, 1)
            if ast.Kind(con syntax, argument) != "Arg.Owned" {
                return Err(newError("checked len argument mode is invalid", ast.Span(con syntax, expression)))
            }
            match self.lowerReadExpression(con syntax, ast.Child(con syntax, argument, 0), con checked) {
                case Ok(loweredValue) {
                    return Ok(self.addNode("E", "Expr.ArrayLen", "", token.CopyText(con ty), ast.Span(con syntax, expression), []int{loweredValue}, cleanup))
                }
                case Err(error) {
                    return Err(error)
                }
            }
        }
        if ast.Kind(con syntax, callee) == "Expr.Var" && ast.Value(con syntax, callee) == "append" {
            if ast.ChildCount(con syntax, expression) != 3 {
                return Err(newError("checked append argument count is invalid", ast.Span(con syntax, expression)))
            }
            sliceArgument := ast.Child(con syntax, expression, 1)
            itemArgument := ast.Child(con syntax, expression, 2)
            if ast.Kind(con syntax, sliceArgument) != "Arg.Owned" || ast.Kind(con syntax, itemArgument) != "Arg.Owned" {
                return Err(newError("checked append argument mode is invalid", ast.Span(con syntax, expression)))
            }
            mut appendChildren := []int{}
            match self.lowerExpression(con syntax, ast.Child(con syntax, sliceArgument, 0), con checked) {
                case Ok(slice) {
                    appendChildren = append(appendChildren, slice)
                }
                case Err(error) {
                    return Err(error)
                }
            }
            match self.lowerExpression(con syntax, ast.Child(con syntax, itemArgument, 0), con checked) {
                case Ok(item) {
                    appendChildren = append(appendChildren, item)
                }
                case Err(error) {
                    return Err(error)
                }
            }
            return Ok(self.addNode("E", "Expr.SliceAppend", "", token.CopyText(con ty), ast.Span(con syntax, expression), appendChildren, cleanup))
        }
        mut children := []int{}
        mut callKind := "Expr.IndirectCall"
        mut callValue := ""
        if semantic.FunctionReferenceDirect(con checked, callee) {
            callKind = "Expr.Call"
            match semantic.FunctionReferenceName(con checked, callee) {
                case Ok(name) {
                    callValue = name
                }
                case Err(_) {
                    return Err(newError("checked direct function reference is missing", ast.Span(con syntax, callee)))
                }
            }
        } else {
            match self.lowerExpression(con syntax, callee, con checked) {
                case Ok(irCallee) {
                    children = append(children, irCallee)
                }
                case Err(error) {
                    return Err(error)
                }
            }
        }
        for mut child := 1; child < ast.ChildCount(con syntax, expression); child = child + 1 {
            argument := ast.Child(con syntax, expression, child)
            match self.lowerArgument(con syntax, argument, con checked) {
                case Ok(irArgument) {
                    children = append(children, irArgument)
                }
                case Err(error) {
                    return Err(error)
                }
            }
        }
        return Ok(self.addNode("E", callKind, callValue, token.CopyText(con ty), ast.Span(con syntax, expression), children, cleanup))
    }

    if kind == "Expr.Var" && value == "None" {
        return Ok(self.addNode("E", "Expr.VariantConstructor.Inline", "None", token.CopyText(con ty), ast.Span(con syntax, expression), []int{}, cleanup))
    }

    if kind == "Expr.FieldAccess" && ast.ChildCount(con syntax, expression) == 1 {
        enumBase := ast.Child(con syntax, expression, 0)
        if ast.Kind(con syntax, enumBase) == "Expr.Var" {
            enumName := ast.Value(con syntax, enumBase)
            payloadCount := semantic.EnumVariantPayloadCount(con checked, con enumName, con value)
            if payloadCount == 0 {
                storage := semantic.EnumStorage(con checked, con enumName)
                if storage == "" {
                    return Err(newError("checked enum constructor storage is missing", ast.Span(con syntax, expression)))
                }
                return Ok(self.addNode("E", variantConstructorKind(con storage), token.CopyText(con value), token.CopyText(con ty), ast.Span(con syntax, expression), []int{}, cleanup))
            }
        }
    }

    if kind == "Expr.Var" && semantic.FunctionReferenceDirect(con checked, expression) {
        return match semantic.FunctionReferenceName(con checked, expression) {
            case Ok(name) {
                Ok(self.addNode("E", "Expr.FunctionValue", name, token.CopyText(con ty), ast.Span(con syntax, expression), []int{}, cleanup))
            }
            case Err(_) {
                Err(newError("checked function value reference is missing", ast.Span(con syntax, expression)))
            }
        }
    }

    if kind == "Expr.StructLiteral" {
        fieldCount := semantic.StructFieldCount(con checked, con value)
        if fieldCount < 0 {
            return Err(newError("checked struct literal metadata is missing", ast.Span(con syntax, expression)))
        }
        mut fields := []int{}
        for mut signatureField := 0; signatureField < fieldCount; signatureField = signatureField + 1 {
            fieldName := semantic.StructFieldName(con checked, con value, signatureField)
            mut fieldNode := -1
            for mut child := 0; child < ast.ChildCount(con syntax, expression); child = child + 1 {
                candidate := ast.Child(con syntax, expression, child)
                if ast.Kind(con syntax, candidate) == "FieldInit" && ast.Value(con syntax, candidate) == fieldName {
                    fieldNode = candidate
                }
            }
            if fieldNode < 0 || ast.ChildCount(con syntax, fieldNode) != 1 {
                return Err(newError("checked struct literal field is missing", ast.Span(con syntax, expression)))
            }
            fieldExpression := ast.Child(con syntax, fieldNode, 0)
            mut fieldType := ""
            match semantic.NodeType(con checked, fieldExpression) {
                case Ok(resolved) {
                    fieldType = resolved
                }
                case Err(_) {
                    return Err(newError("checked struct literal field type is missing", ast.Span(con syntax, fieldNode)))
                }
            }
            match self.lowerExpression(con syntax, fieldExpression, con checked) {
                case Ok(loweredField) {
                    fields = append(fields, self.addNode("F", "Field.Value", token.CopyText(con fieldName), token.CopyText(con fieldType), ast.Span(con syntax, fieldNode), []int{loweredField}, false))
                }
                case Err(error) {
                    return Err(error)
                }
            }
        }
        return Ok(self.addNode("E", "Expr.StructLiteral", token.CopyText(con value), token.CopyText(con ty), ast.Span(con syntax, expression), fields, cleanup))
    }

    if kind == "Expr.ArrayLiteral" {
        mut elements := []int{}
        for mut child := 1; child < ast.ChildCount(con syntax, expression); child = child + 1 {
            match self.lowerExpression(con syntax, ast.Child(con syntax, expression, child), con checked) {
                case Ok(element) {
                    elements = append(elements, element)
                }
                case Err(error) {
                    return Err(error)
                }
            }
        }
        return Ok(self.addNode("E", "Expr.ArrayLiteral", "", token.CopyText(con ty), ast.Span(con syntax, expression), elements, cleanup))
    }

    if kind == "Expr.Match" {
        if ast.ChildCount(con syntax, expression) < 2 {
            return Err(newError("checked match expression has no arms", ast.Span(con syntax, expression)))
        }
        scrutinee := ast.Child(con syntax, expression, 0)
        mut matchChildren := []int{}
        match self.lowerExpression(con syntax, scrutinee, con checked) {
            case Ok(loweredScrutinee) {
                matchChildren = append(matchChildren, loweredScrutinee)
            }
            case Err(error) {
                return Err(error)
            }
        }
        for mut child := 1; child < ast.ChildCount(con syntax, expression); child = child + 1 {
            arm := ast.Child(con syntax, expression, child)
            if ast.Kind(con syntax, arm) != "MatchArm" || ast.ChildCount(con syntax, arm) != 2 {
                return Err(newError("checked match arm is malformed", ast.Span(con syntax, arm)))
            }
            pattern := ast.Child(con syntax, arm, 0)
            branch := ast.Child(con syntax, arm, 1)
            mut loweredPattern := LoweredMatchPattern{node: -1, cleanup: []CleanupBinding{}, nextDiscard: 0,}
            match self.lowerMatchPattern(con syntax, pattern, scrutinee, ast.Span(con syntax, branch), ast.Span(con syntax, arm), con checked) {
                case Ok(value) {
                    loweredPattern = value
                }
                case Err(error) {
                    return Err(error)
                }
            }
            match self.lowerExpression(con syntax, branch, con checked) {
                case Ok(loweredBranch) {
                    mut branchType := ""
                    match semantic.NodeType(con checked, branch) {
                        case Ok(resolved) {
                            branchType = resolved
                        }
                        case Err(_) {
                            return Err(newError("checked match arm type is missing", ast.Span(con syntax, branch)))
                        }
                    }
                    mut armChildren := []int{loweredPattern.node, loweredBranch}
                    movedBindings := self.movedCleanupRoots(loweredBranch, con loweredPattern.cleanup)
                    for mut binding := 0; binding < len(loweredPattern.cleanup); binding = binding + 1 {
                        if textIndex(con movedBindings, con loweredPattern.cleanup[binding].key) < 0 {
                            bindingValue := self.addNode("E", "Expr.Var", token.CopyText(con loweredPattern.cleanup[binding].name), token.CopyText(con loweredPattern.cleanup[binding].ty), source.Copy(con loweredPattern.cleanup[binding].span), []int{}, true)
                            armChildren = append(armChildren, self.addNode("S", "Stmt.Drop", "", "unit", ast.Span(con syntax, branch), []int{bindingValue}, false))
                        }
                    }
                    matchChildren = append(matchChildren, self.addNode("M", "Match.Arm", "", token.CopyText(con branchType), ast.Span(con syntax, branch), armChildren, false))
                }
                case Err(error) {
                    return Err(error)
                }
            }
        }
        return Ok(self.addNode("E", "Expr.Match", "", token.CopyText(con ty), ast.Span(con syntax, expression), matchChildren, cleanup))
    }

    if(kind == "Expr.Binary.Equal" || kind == "Expr.Binary.NotEqual") && ast.ChildCount(con syntax, expression) == 2 {
        left := ast.Child(con syntax, expression, 0)
        mut leftType := ""
        match semantic.NodeType(con checked, left) {
            case Ok(resolved) {
                leftType = resolved
            }
            case Err(_) {
                return Err(newError("checked equality operand type is missing", ast.Span(con syntax, left)))
            }
        }
        if leftType == "string" {
            mut equalityChildren := []int{}
            match self.lowerReadExpression(con syntax, left, con checked) {
                case Ok(loweredLeft) {
                    equalityChildren = append(equalityChildren, loweredLeft)
                }
                case Err(error) {
                    return Err(error)
                }
            }
            match self.lowerReadExpression(con syntax, ast.Child(con syntax, expression, 1), con checked) {
                case Ok(loweredRight) {
                    equalityChildren = append(equalityChildren, loweredRight)
                }
                case Err(error) {
                    return Err(error)
                }
            }
            return Ok(self.addNode("E", token.CopyText(con kind), "", token.CopyText(con ty), ast.Span(con syntax, expression), equalityChildren, cleanup))
        }
    }

    mut children := []int{}
    for mut child := 0; child < ast.ChildCount(con syntax, expression); child = child + 1 {
        syntaxChild := ast.Child(con syntax, expression, child)
        match self.lowerExpression(con syntax, syntaxChild, con checked) {
            case Ok(irChild) {
                children = append(children, irChild)
            }
            case Err(error) {
                return Err(error)
            }
        }
    }
    return Ok(self.addNode("E", kind, value, ty, ast.Span(con syntax, expression), children, cleanup))
}

func (mut self Lowerer) lowerArgument(con syntax ast.Program, argument int, con checked semantic.CheckedProgram) Result[int, Error] {
    expression := ast.Child(con syntax, argument, 0)
    mut ty := ""
    match semantic.NodeType(con checked, expression) {
        case Ok(resolved) {
            ty = resolved
        }
        case Err(_) {
            return Err(newError("checked argument expression type is missing", ast.Span(con syntax, argument)))
        }
    }
    return match self.lowerExpression(con syntax, expression, con checked) {
        case Ok(child) {
            Ok(self.addNode("A", ast.Kind(con syntax, argument), "", ty, ast.Span(con syntax, argument), []int{child}, false))
        }
        case Err(error) {
            Err(error)
        }
    }
}

func (mut self Lowerer) lowerReadExpression(con syntax ast.Program, expression int, con checked semantic.CheckedProgram) Result[int, Error] {
    if isDirectReadExpression(con syntax, expression) {
        return self.lowerExpression(con syntax, expression, con checked)
    }
    kind := ast.Kind(con syntax, expression)
    if kind == "Expr.FieldAccess" || kind == "Expr.Index" {
        return self.lowerTemporaryPlaceExpression(con syntax, expression, con checked)
    }

    mut lowered := -1
    match self.lowerExpression(con syntax, expression, con checked) {
        case Ok(value) {
            lowered = value
        }
        case Err(error) {
            return Err(error)
        }
    }
    return self.wrapFullExpressionTemporary(con syntax, expression, lowered, con checked)
}

func (mut self Lowerer) lowerTemporaryPlaceExpression(con syntax ast.Program, expression int, con checked semantic.CheckedProgram) Result[int, Error] {
    if isDirectReadExpression(con syntax, expression) {
        return self.lowerExpression(con syntax, expression, con checked)
    }

    kind := ast.Kind(con syntax, expression)
    if kind == "Expr.FieldAccess" {
        mut base := -1
        match self.lowerTemporaryPlaceExpression(con syntax, ast.Child(con syntax, expression, 0), con checked) {
            case Ok(value) {
                base = value
            }
            case Err(error) {
                return Err(error)
            }
        }
        mut ty := ""
        match semantic.NodeType(con checked, expression) {
            case Ok(resolved) {
                ty = resolved
            }
            case Err(_) {
                return Err(newError("checked temporary field type is missing", ast.Span(con syntax, expression)))
            }
        }
        return Ok(self.addNode("E", "Expr.FieldAccess", ast.Value(con syntax, expression), ty, ast.Span(con syntax, expression), []int{base}, semantic.NodeNeedsCleanup(con checked, expression)))
    }
    if kind == "Expr.Index" {
        mut base := -1
        match self.lowerTemporaryPlaceExpression(con syntax, ast.Child(con syntax, expression, 0), con checked) {
            case Ok(value) {
                base = value
            }
            case Err(error) {
                return Err(error)
            }
        }
        mut index := -1
        match self.lowerExpression(con syntax, ast.Child(con syntax, expression, 1), con checked) {
            case Ok(value) {
                index = value
            }
            case Err(error) {
                return Err(error)
            }
        }
        mut ty := ""
        match semantic.NodeType(con checked, expression) {
            case Ok(resolved) {
                ty = resolved
            }
            case Err(_) {
                return Err(newError("checked temporary index type is missing", ast.Span(con syntax, expression)))
            }
        }
        return Ok(self.addNode("E", "Expr.Index", "", ty, ast.Span(con syntax, expression), []int{base, index,}, semantic.NodeNeedsCleanup(con checked, expression)))
    }

    mut lowered := -1
    match self.lowerExpression(con syntax, expression, con checked) {
        case Ok(value) {
            lowered = value
        }
        case Err(error) {
            return Err(error)
        }
    }
    return self.wrapFullExpressionTemporary(con syntax, expression, lowered, con checked)
}

func (mut self Lowerer) wrapFullExpressionTemporary(con syntax ast.Program, expression int, lowered int, con checked semantic.CheckedProgram) Result[int, Error] {
    mut ty := ""
    match semantic.NodeType(con checked, expression) {
        case Ok(resolved) {
            ty = resolved
        }
        case Err(_) {
            return Err(newError("checked full-expression temporary type is missing", ast.Span(con syntax, expression)))
        }
    }
    span := ast.Span(con syntax, expression)
    name := strings.join(con []string{"mallang_full_expr_", strings.fromInt(source.Start(con span)), "_", strings.fromInt(source.End(con span)),}, con "")
    return Ok(self.addNode("E", "Expr.FullExprTemporary", name, token.CopyText(con ty), source.Copy(con span), []int{lowered}, semantic.NodeNeedsCleanup(con checked, expression)))
}

func (mut self Lowerer) lowerMatchPattern(con syntax ast.Program, pattern int, scrutinee int, span source.Span, discardSpan source.Span, con checked semantic.CheckedProgram) Result[LoweredMatchPattern, Error] {
    mut scrutineeType := ""
    match semantic.NodeType(con checked, scrutinee) {
        case Ok(resolved) {
            scrutineeType = resolved
        }
        case Err(_) {
            return Err(newError("checked match scrutinee type is missing", source.Copy(con span)))
        }
    }
    cleanup := semantic.NodeNeedsCleanup(con checked, scrutinee)
    return self.lowerMatchPatternForType(con syntax, pattern, con scrutineeType, cleanup, span, discardSpan, 0, con checked)
}

func (mut self Lowerer) lowerMatchPatternForType(con syntax ast.Program, pattern int, con expectedType string, expectedCleanup bool, span source.Span, discardSpan source.Span, discardIndex int, con checked semantic.CheckedProgram) Result[LoweredMatchPattern, Error] {
    kind := ast.Kind(con syntax, pattern)
    if kind == "Pattern.Wildcard" {
        if expectedCleanup {
            name := matchDiscardName(con discardSpan, discardIndex)
            node := self.addNode("P", "Pattern.Binding", token.CopyText(con name), token.CopyText(con expectedType), source.Copy(con span), []int{}, false)
            return Ok(LoweredMatchPattern{node: node, cleanup: []CleanupBinding{newCleanupBinding(con name, con expectedType, source.Copy(con span))}, nextDiscard: discardIndex + 1,})
        }
        node := self.addNode("P", "Pattern.Wildcard", "", token.CopyText(con expectedType), source.Copy(con span), []int{}, false)
        return Ok(LoweredMatchPattern{node: node, cleanup: []CleanupBinding{}, nextDiscard: discardIndex,})
    }
    if kind == "Pattern.Binding" {
        name := ast.Value(con syntax, pattern)
        node := self.addNode("P", "Pattern.Binding", token.CopyText(con name), token.CopyText(con expectedType), source.Copy(con span), []int{}, false)
        mut cleanupBindings := []CleanupBinding{}
        if expectedCleanup {
            cleanupBindings = append(cleanupBindings, newCleanupBinding(con name, con expectedType, source.Copy(con span)))
        }
        return Ok(LoweredMatchPattern{node: node, cleanup: cleanupBindings, nextDiscard: discardIndex,})
    }
    if kind == "Pattern.None" {
        node := self.addNode("P", "Pattern.Variant.Inline", "None", token.CopyText(con expectedType), source.Copy(con span), []int{}, false)
        return Ok(LoweredMatchPattern{node: node, cleanup: []CleanupBinding{}, nextDiscard: discardIndex,})
    }
    if kind == "Pattern.Some" || kind == "Pattern.Ok" || kind == "Pattern.Err" {
        mut argument := 0
        mut variant := "Some"
        if kind == "Pattern.Ok" {
            variant = "Ok"
        } else if kind == "Pattern.Err" {
            argument = 1
            variant = "Err"
        }
        mut payloadType := ""
        match semantic.TypeArgument(con checked, con expectedType, argument) {
            case Ok(resolved) {
                payloadType = resolved
            }
            case Err(_) {
                return Err(newError("checked built-in match payload type is missing", source.Copy(con span)))
            }
        }
        bindingName := ast.Value(con syntax, pattern)
        binding := self.addNode("P", "Pattern.Binding", token.CopyText(con bindingName), token.CopyText(con payloadType), source.Copy(con span), []int{}, false)
        node := self.addNode("P", "Pattern.Variant.Inline", variant, token.CopyText(con expectedType), source.Copy(con span), []int{binding}, false)
        mut cleanupBindings := []CleanupBinding{}
        if semantic.TypeArgumentNeedsCleanup(con checked, con expectedType, argument) {
            cleanupBindings = append(cleanupBindings, newCleanupBinding(con bindingName, con payloadType, source.Copy(con span)))
        }
        return Ok(LoweredMatchPattern{node: node, cleanup: cleanupBindings, nextDiscard: discardIndex,})
    }
    if kind == "Pattern.NestedBuiltin" {
        variant := ast.Value(con syntax, pattern)
        mut argument := 0
        if variant == "Err" {
            argument = 1
        } else if variant != "Some" && variant != "Ok" {
            return Err(newError("checked nested built-in match variant is invalid", source.Copy(con span)))
        }
        if ast.ChildCount(con syntax, pattern) != 1 {
            return Err(newError("checked nested built-in match payload count is invalid", source.Copy(con span)))
        }
        mut payloadType := ""
        match semantic.TypeArgument(con checked, con expectedType, argument) {
            case Ok(resolved) {
                payloadType = resolved
            }
            case Err(_) {
                return Err(newError("checked nested built-in match payload type is missing", source.Copy(con span)))
            }
        }
        payloadCleanup := semantic.TypeArgumentNeedsCleanup(con checked, con expectedType, argument)
        mut loweredPayload := LoweredMatchPattern{node: -1, cleanup: []CleanupBinding{}, nextDiscard: discardIndex,}
        match self.lowerMatchPatternForType(con syntax, ast.Child(con syntax, pattern, 0), con payloadType, payloadCleanup, source.Copy(con span), source.Copy(con discardSpan), discardIndex, con checked) {
            case Ok(value) {
                loweredPayload = value
            }
            case Err(error) {
                return Err(error)
            }
        }
        node := self.addNode("P", "Pattern.Variant.Inline", variant, token.CopyText(con expectedType), source.Copy(con span), []int{loweredPayload.node}, false)
        return Ok(LoweredMatchPattern{node: node, cleanup: copyCleanupBindings(con loweredPayload.cleanup), nextDiscard: loweredPayload.nextDiscard,})
    }
    if kind == "Pattern.Variant" {
        enumName := semantic.PatternVariantTypeName(con syntax, pattern)
        variantName := semantic.PatternVariantName(con syntax, pattern)
        if enumName == "" || variantName == "" {
            return Err(newError("checked user enum match pattern is malformed", source.Copy(con span)))
        }
        payloadCount := semantic.EnumVariantPayloadCount(con checked, con enumName, con variantName)
        if payloadCount < 0 || ast.ChildCount(con syntax, pattern) != payloadCount {
            return Err(newError("checked user enum match payload count is invalid", source.Copy(con span)))
        }
        storage := semantic.EnumStorage(con checked, con enumName)
        if storage == "" {
            return Err(newError("checked user enum match storage is missing", source.Copy(con span)))
        }
        mut payloads := []int{}
        mut cleanupBindings := []CleanupBinding{}
        mut nextDiscard := discardIndex
        for mut payload := 0; payload < payloadCount; payload = payload + 1 {
            mut payloadType := ""
            match semantic.EnumVariantPayloadType(con checked, con enumName, con variantName, payload) {
                case Ok(resolved) {
                    payloadType = resolved
                }
                case Err(_) {
                    return Err(newError("checked user enum match payload type is missing", source.Copy(con span)))
                }
            }
            payloadCleanup := semantic.EnumVariantPayloadNeedsCleanup(con checked, con enumName, con variantName, payload)
            mut loweredPayload := LoweredMatchPattern{node: -1, cleanup: []CleanupBinding{}, nextDiscard: nextDiscard,}
            match self.lowerMatchPatternForType(con syntax, ast.Child(con syntax, pattern, payload), con payloadType, payloadCleanup, source.Copy(con span), source.Copy(con discardSpan), nextDiscard, con checked) {
                case Ok(value) {
                    loweredPayload = value
                }
                case Err(error) {
                    return Err(error)
                }
            }
            payloads = append(payloads, loweredPayload.node)
            for mut binding := 0; binding < len(loweredPayload.cleanup); binding = binding + 1 {
                cleanupBindings = append(cleanupBindings, copyCleanupBinding(con loweredPayload.cleanup[binding]))
            }
            nextDiscard = loweredPayload.nextDiscard
        }
        node := self.addNode("P", variantPatternKind(con storage), variantName, token.CopyText(con expectedType), source.Copy(con span), payloads, false)
        return Ok(LoweredMatchPattern{node: node, cleanup: cleanupBindings, nextDiscard: nextDiscard,})
    }
    return Err(newError("B2e typed IR does not accept this match pattern", source.Copy(con span)))
}

func (mut self Lowerer) insertStraightLineCleanupDrops(con body []int, initial []CleanupBinding, external []CleanupBinding, fallback source.Span) []int {
    return self.insertCleanupDrops(con body, initial, external, fallback, con []string{}, con []string{}, con []string{})
}

func (mut self Lowerer) insertCleanupDrops(con body []int, initial []CleanupBinding, external []CleanupBinding, fallback source.Span, con tailExcluded []string, con breakExcluded []string, con continueExcluded []string) []int {
    if !self.supportsStraightLineCleanup(con body) {
        return copyInts(con body)
    }

    mut active := copyCleanupBindings(con initial)
    mut output := []int{}
    for mut statementIndex := 0; statementIndex < len(body); statementIndex = statementIndex + 1 {
        statement := body[statementIndex]
        self.insertStatementExpressionBranchCleanup(statement, con active)
        if self.nodes[statement].kind == "Stmt.If" {
            condition := self.nodes[statement].children[0]
            conditionMoved := self.movedCleanupRoots(condition, con active)
            active = removeCleanupRoots(active, con conditionMoved)
            thenBlock := self.nodes[statement].children[1]
            elseBlock := self.nodes[statement].children[2]
            thenSource := copyInts(con self.nodes[thenBlock].children)
            elseSource := copyInts(con self.nodes[elseBlock].children)
            thenFlow := self.analyzeCleanupFlow(con thenSource, con active)
            elseFlow := self.analyzeCleanupFlow(con elseSource, con active)
            persistentMoved := persistentBranchMoves(con active, con thenFlow, con elseFlow)
            remaining := removeCleanupRoots(copyCleanupBindings(con active), con persistentMoved)
            excluded := cleanupBindingKeys(con remaining)
            statementSpan := source.Copy(con self.nodes[statement].span)
            thenBody := self.insertCleanupDrops(con thenSource, copyCleanupBindings(con active), copyCleanupBindings(con external), source.Copy(con statementSpan), con excluded, con breakExcluded, con continueExcluded)
            elseBody := self.insertCleanupDrops(con elseSource, copyCleanupBindings(con active), copyCleanupBindings(con external), source.Copy(con statementSpan), con excluded, con breakExcluded, con continueExcluded)
            self.nodes[thenBlock].children = thenBody
            self.nodes[elseBlock].children = elseBody
            output = append(output, statement)
            active = remaining
            continue
        }
        if self.nodes[statement].kind == "Stmt.Match" {
            scrutinee := self.nodes[statement].children[0]
            scrutineeMoved := self.movedCleanupRoots(scrutinee, con active)
            active = removeCleanupRoots(active, con scrutineeMoved)
            mut armFlows := []CleanupFlow{}
            for mut child := 1; child < len(self.nodes[statement].children); child = child + 1 {
                arm := self.nodes[statement].children[child]
                block := self.nodes[arm].children[1]
                armFlows = append(armFlows, self.analyzeCleanupFlow(con self.nodes[block].children, con active))
            }
            persistentMoved := persistentMatchMoves(con active, con armFlows)
            remaining := removeCleanupRoots(copyCleanupBindings(con active), con persistentMoved)
            excluded := cleanupBindingKeys(con remaining)
            for mut child := 1; child < len(self.nodes[statement].children); child = child + 1 {
                arm := self.nodes[statement].children[child]
                block := self.nodes[arm].children[1]
                sourceBody := copyInts(con self.nodes[block].children)
                self.nodes[block].children = self.insertCleanupDrops(con sourceBody, copyCleanupBindings(con active), copyCleanupBindings(con external), source.Copy(con self.nodes[block].span), con excluded, con breakExcluded, con continueExcluded)
            }
            output = append(output, statement)
            active = remaining
            continue
        }
        if self.nodes[statement].kind == "Stmt.For" {
            bodyBlock := self.nodes[statement].children[len(self.nodes[statement].children) - 2]
            cleanupBlock := self.nodes[statement].children[len(self.nodes[statement].children) - 1]
            mut initMoved := []string{}
            mut loopActive := copyCleanupBindings(con active)
            preLoopKeys := cleanupBindingKeys(con loopActive)
            for mut child := 0; child < len(self.nodes[statement].children) - 2; child = child + 1 {
                control := self.nodes[statement].children[child]
                if self.nodes[control].kind == "ForInit.Let.Immutable" || self.nodes[control].kind == "ForInit.Let.Mutable" {
                    initMoved = appendUniqueTexts(initMoved, con self.movedCleanupRoots(control, con loopActive))
                    loopActive = removeCleanupRoots(loopActive, con initMoved)
                    if self.nodes[control].cleanup {
                        loopActive = append(loopActive, newCleanupBinding(con self.nodes[control].value, con self.nodes[control].ty, source.Copy(con self.nodes[control].span)))
                    }
                }
            }
            loopKeys := cleanupBindingKeys(con loopActive)
            sourceBody := copyInts(con self.nodes[bodyBlock].children)
            self.nodes[bodyBlock].children = self.insertCleanupDrops(con sourceBody, copyCleanupBindings(con loopActive), copyCleanupBindings(con external), source.Copy(con self.nodes[statement].span), con loopKeys, con loopKeys, con loopKeys)
            loopOwned := cleanupBindingsExcluding(con loopActive, con preLoopKeys)
            cleanupBody := copyInts(con self.nodes[cleanupBlock].children)
            loopSpan := source.Copy(con self.nodes[statement].span)
            self.nodes[cleanupBlock].children = self.pushCleanupDrops(cleanupBody, con loopOwned, con loopSpan)
            active = removeCleanupRoots(active, con initMoved)
            output = append(output, statement)
            continue
        }
        if self.nodes[statement].kind == "Stmt.RangeFor" {
            bodyBlock := self.nodes[statement].children[len(self.nodes[statement].children) - 2]
            cleanupBlock := self.nodes[statement].children[len(self.nodes[statement].children) - 1]
            rangeSource := self.nodes[statement].children[1]
            sourceMoved := self.movedPlaceCleanupRoots(rangeSource, con active)
            mut loopActive := removeCleanupRoots(copyCleanupBindings(con active), con sourceMoved)
            preLoopKeys := cleanupBindingKeys(con loopActive)
            owner := self.fullExpressionOwnerNode(rangeSource)
            if owner >= 0 {
                loopActive = append(loopActive, newCleanupBinding(con self.nodes[owner].value, con self.nodes[owner].ty, source.Copy(con self.nodes[owner].span)))
            }
            loopKeys := cleanupBindingKeys(con loopActive)
            sourceBody := copyInts(con self.nodes[bodyBlock].children)
            self.nodes[bodyBlock].children = self.insertCleanupDrops(con sourceBody, copyCleanupBindings(con loopActive), copyCleanupBindings(con external), source.Copy(con self.nodes[statement].span), con loopKeys, con loopKeys, con loopKeys)
            loopOwned := cleanupBindingsExcluding(con loopActive, con preLoopKeys)
            cleanupBody := copyInts(con self.nodes[cleanupBlock].children)
            loopSpan := source.Copy(con self.nodes[statement].span)
            self.nodes[cleanupBlock].children = self.pushCleanupDrops(cleanupBody, con loopOwned, con loopSpan)
            active = removeCleanupRoots(active, con sourceMoved)
            output = append(output, statement)
            continue
        }
        if self.nodes[statement].kind == "Stmt.Break" || self.nodes[statement].kind == "Stmt.Continue" {
            mut excluded := copyTexts(con breakExcluded)
            if self.nodes[statement].kind == "Stmt.Continue" {
                excluded = copyTexts(con continueExcluded)
            }
            droppable := cleanupBindingsExcluding(con active, con excluded)
            controlSpan := source.Copy(con self.nodes[statement].span)
            mut controlled := self.pushCleanupDrops(copyInts(con output), con droppable, con controlSpan)
            controlled = append(controlled, statement)
            for mut remainingStatement := statementIndex + 1; remainingStatement < len(body); remainingStatement = remainingStatement + 1 {
                controlled = append(controlled, body[remainingStatement])
            }
            return controlled
        }

        moved := self.movedCleanupRoots(statement, con active)
        remaining := removeCleanupRoots(copyCleanupBindings(con active), con moved)
        if self.nodes[statement].kind == "Stmt.Assign" && len(self.nodes[statement].children) == 1 {
            expression := self.nodes[statement].children[0]
            if self.nodes[expression].cleanup {
                binding := cleanupBindingIndex(con active, con self.nodes[statement].value)
                if binding >= 0 {
                    bindingKey := token.CopyText(con active[binding].key)
                    if textIndex(con moved, con bindingKey) < 0 {
                        target := self.addNode("E", "Expr.Var", token.CopyText(con active[binding].name), token.CopyText(con active[binding].ty), source.Copy(con active[binding].span), []int{}, true)
                        output = self.pushCleanupOverwrite(output, statement, target, expression)
                        active = copyCleanupBindings(con remaining)
                        continue
                    }

                    mut reactivated := copyCleanupBinding(con active[binding])
                    reactivated.span = source.Copy(con self.nodes[statement].span)
                    output = append(output, statement)
                    active = append(copyCleanupBindings(con remaining), reactivated)
                    continue
                }
                externalBinding := cleanupBindingIndex(con external, con self.nodes[statement].value)
                if externalBinding >= 0 {
                    target := self.addNode("E", "Expr.Var", token.CopyText(con external[externalBinding].name), token.CopyText(con external[externalBinding].ty), source.Copy(con external[externalBinding].span), []int{}, true)
                    output = self.pushCleanupOverwrite(output, statement, target, expression)
                    active = copyCleanupBindings(con remaining)
                    continue
                }
            }
        }
        if self.nodes[statement].kind == "Stmt.FieldAssign" && len(self.nodes[statement].children) == 2 {
            expression := self.nodes[statement].children[1]
            if self.nodes[expression].cleanup && !self.fieldAssignmentConsumesOverwrittenPlace(statement) {
                base := self.nodes[statement].children[0]
                target := self.addNode("E", "Expr.FieldAccess", token.CopyText(con self.nodes[statement].value), token.CopyText(con self.nodes[expression].ty), source.Copy(con self.nodes[statement].span), []int{base}, true)
                output = self.pushCleanupOverwrite(output, statement, target, expression)
                active = copyCleanupBindings(con remaining)
                continue
            }
        }
        if self.nodes[statement].kind == "Stmt.IndexAssign" && len(self.nodes[statement].children) == 3 {
            expression := self.nodes[statement].children[2]
            if self.nodes[expression].cleanup {
                base := self.nodes[statement].children[0]
                index := self.nodes[statement].children[1]
                target := self.addNode("E", "Expr.Index", "", token.CopyText(con self.nodes[expression].ty), source.Copy(con self.nodes[statement].span), []int{base, index}, true)
                output = self.pushCleanupOverwrite(output, statement, target, expression)
                active = copyCleanupBindings(con remaining)
                continue
            }
        }
        if self.nodes[statement].kind == "Stmt.Return" {
            expression := self.nodes[statement].children[0]
            statementSpan := source.Copy(con self.nodes[statement].span)
            expressionSpan := source.Copy(con self.nodes[expression].span)
            expressionType := token.CopyText(con self.nodes[expression].ty)
            expressionCleanup := self.nodes[expression].cleanup
            if expressionType != "unit" && len(remaining) > 0 {
                name := returnValueTempName(con statementSpan)
                temporary := self.addNode("S", "Stmt.Let.Immutable", token.CopyText(con name), token.CopyText(con expressionType), source.Copy(con statementSpan), []int{expression}, expressionCleanup)
                output = append(output, temporary)
                output = self.pushCleanupDrops(output, con remaining, con statementSpan)
                returned := self.addNode("E", "Expr.Var", token.CopyText(con name), token.CopyText(con expressionType), source.Copy(con expressionSpan), []int{}, expressionCleanup)
                output = append(output, self.addNode("S", "Stmt.Return", "", "unit", source.Copy(con statementSpan), []int{returned}, false))
            } else {
                output = self.pushCleanupDrops(output, con remaining, con statementSpan)
                output = append(output, statement)
            }
            return copyInts(con output)
        }

        active = remaining
        output = append(output, statement)
        letBinding := self.nodes[statement].kind == "Stmt.Let.Immutable" || self.nodes[statement].kind == "Stmt.Let.Mutable"
        if letBinding && self.nodes[statement].cleanup {
            active = append(active, newCleanupBinding(con self.nodes[statement].value, con self.nodes[statement].ty, source.Copy(con self.nodes[statement].span)))
        }
    }
    droppable := cleanupBindingsExcluding(con active, con tailExcluded)
    return self.pushCleanupDrops(output, con droppable, con fallback)
}

func (mut self Lowerer) insertStatementExpressionBranchCleanup(statement int, con active []CleanupBinding) bool {
    kind := token.CopyText(con self.nodes[statement].kind)
    if kind == "Stmt.Let.Immutable" || kind == "Stmt.Let.Mutable" || kind == "Stmt.Assign" || kind == "Stmt.Return" || kind == "Stmt.Expr" || kind == "Stmt.Assert" || kind == "Stmt.If" || kind == "Stmt.Match" {
        if len(self.nodes[statement].children) > 0 {
            self.insertExpressionBranchCleanup(self.nodes[statement].children[0], con active)
        }
        return true
    }
    if kind == "Stmt.FieldAssign" && len(self.nodes[statement].children) == 2 {
        self.insertExpressionBranchCleanup(self.nodes[statement].children[1], con active)
        return true
    }
    if kind == "Stmt.IndexAssign" && len(self.nodes[statement].children) == 3 {
        self.insertExpressionBranchCleanup(self.nodes[statement].children[2], con active)
        return true
    }
    if kind == "Stmt.RangeFor" && len(self.nodes[statement].children) == 4 {
        self.insertExpressionBranchCleanup(self.nodes[statement].children[1], con active)
    }
    return true
}

func (mut self Lowerer) insertExpressionBranchCleanup(node int, con active []CleanupBinding) bool {
    if self.nodes[node].category == "E" && self.nodes[node].kind == "Expr.Match" {
        if len(self.nodes[node].children) < 2 {
            return true
        }
        scrutinee := self.nodes[node].children[0]
        self.insertExpressionBranchCleanup(scrutinee, con active)
        scrutineeMoved := self.movedCleanupRoots(scrutinee, con active)
        armActive := removeCleanupRoots(copyCleanupBindings(con active), con scrutineeMoved)
        for mut child := 1; child < len(self.nodes[node].children); child = child + 1 {
            arm := self.nodes[node].children[child]
            if self.nodes[arm].kind == "Match.Arm" && len(self.nodes[arm].children) >= 2 {
                self.insertExpressionBranchCleanup(self.nodes[arm].children[1], con armActive)
            }
        }
        return true
    }
    if self.nodes[node].category == "E" && self.nodes[node].kind == "Expr.If" {
        if len(self.nodes[node].children) != 3 {
            return true
        }
        condition := self.nodes[node].children[0]
        thenBranch := self.nodes[node].children[1]
        elseBranch := self.nodes[node].children[2]
        self.insertExpressionBranchCleanup(condition, con active)
        conditionMoved := self.movedCleanupRoots(condition, con active)
        branchActive := removeCleanupRoots(copyCleanupBindings(con active), con conditionMoved)
        self.insertExpressionBranchCleanup(thenBranch, con branchActive)
        self.insertExpressionBranchCleanup(elseBranch, con branchActive)
        thenMoved := self.movedCleanupRoots(thenBranch, con branchActive)
        elseMoved := self.movedCleanupRoots(elseBranch, con branchActive)
        mergedMoved := appendUniqueTexts(copyTexts(con thenMoved), con elseMoved)
        thenCleanup := expressionBranchCleanupBindings(con branchActive, con mergedMoved, con thenMoved)
        elseCleanup := expressionBranchCleanupBindings(con branchActive, con mergedMoved, con elseMoved)
        branchSpan := source.Copy(con self.nodes[node].span)
        thenBlock := self.addNode("B", "Block.IfThenCleanup", "", "unit", source.Copy(con branchSpan), self.pushCleanupDrops([]int{}, con thenCleanup, con branchSpan), false)
        elseBlock := self.addNode("B", "Block.IfElseCleanup", "", "unit", source.Copy(con branchSpan), self.pushCleanupDrops([]int{}, con elseCleanup, con branchSpan), false)
        self.nodes[node].children = []int{condition, thenBranch, thenBlock, elseBranch, elseBlock,}
        return true
    }

    mut current := copyCleanupBindings(con active)
    for mut child := 0; child < len(self.nodes[node].children); child = child + 1 {
        nested := self.nodes[node].children[child]
        self.insertExpressionBranchCleanup(nested, con current)
        moved := self.movedCleanupRoots(nested, con current)
        current = removeCleanupRoots(current, con moved)
    }
    return true
}

func (con self Lowerer) supportsStraightLineCleanup(con body []int) bool {
    for mut index := 0; index < len(body); index = index + 1 {
        kind := token.CopyText(con self.nodes[body[index]].kind)
        if kind == "Stmt.If" {
            thenBlock := self.nodes[body[index]].children[1]
            elseBlock := self.nodes[body[index]].children[2]
            if !self.supportsStraightLineCleanup(con self.nodes[thenBlock].children) || !self.supportsStraightLineCleanup(con self.nodes[elseBlock].children) {
                return false
            }
        }
        if kind == "Stmt.Match" {
            for mut child := 1; child < len(self.nodes[body[index]].children); child = child + 1 {
                arm := self.nodes[body[index]].children[child]
                block := self.nodes[arm].children[1]
                if !self.supportsStraightLineCleanup(con self.nodes[block].children) {
                    return false
                }
            }
        }
        if kind == "Stmt.For" || kind == "Stmt.RangeFor" {
            bodyBlock := self.nodes[body[index]].children[len(self.nodes[body[index]].children) - 2]
            if !self.supportsStraightLineCleanup(con self.nodes[bodyBlock].children) {
                return false
            }
        }
    }
    return true
}

func (con self Lowerer) analyzeCleanupFlow(con body []int, con initial []CleanupBinding) CleanupFlow {
    mut active := copyCleanupBindings(con initial)
    mut movedInBody := []string{}
    for mut statementIndex := 0; statementIndex < len(body); statementIndex = statementIndex + 1 {
        statement := body[statementIndex]
        if self.nodes[statement].kind == "Stmt.If" {
            condition := self.nodes[statement].children[0]
            conditionMoved := self.movedCleanupRoots(condition, con active)
            movedInBody = appendUniqueTexts(movedInBody, con conditionMoved)
            active = removeCleanupRoots(active, con conditionMoved)
            thenBlock := self.nodes[statement].children[1]
            elseBlock := self.nodes[statement].children[2]
            thenFlow := self.analyzeCleanupFlow(con self.nodes[thenBlock].children, con active)
            elseFlow := self.analyzeCleanupFlow(con self.nodes[elseBlock].children, con active)
            persistentMoved := persistentBranchMoves(con active, con thenFlow, con elseFlow)
            movedInBody = appendUniqueTexts(movedInBody, con persistentMoved)
            active = removeCleanupRoots(active, con persistentMoved)
            if !thenFlow.continues && !elseFlow.continues {
                return CleanupFlow{moved: appendUniqueTexts([]string{}, con movedInBody), continues: false}
            }
            continue
        }
        if self.nodes[statement].kind == "Stmt.Match" {
            scrutinee := self.nodes[statement].children[0]
            scrutineeMoved := self.movedCleanupRoots(scrutinee, con active)
            movedInBody = appendUniqueTexts(movedInBody, con scrutineeMoved)
            active = removeCleanupRoots(active, con scrutineeMoved)
            mut armFlows := []CleanupFlow{}
            for mut child := 1; child < len(self.nodes[statement].children); child = child + 1 {
                arm := self.nodes[statement].children[child]
                block := self.nodes[arm].children[1]
                armFlows = append(armFlows, self.analyzeCleanupFlow(con self.nodes[block].children, con active))
            }
            persistentMoved := persistentMatchMoves(con active, con armFlows)
            movedInBody = appendUniqueTexts(movedInBody, con persistentMoved)
            active = removeCleanupRoots(active, con persistentMoved)
            continue
        }

        moved := self.movedCleanupRoots(statement, con active)
        movedInBody = appendUniqueTexts(movedInBody, con moved)
        active = removeCleanupRoots(active, con moved)
        if self.nodes[statement].kind == "Stmt.Return" || self.nodes[statement].kind == "Stmt.Break" || self.nodes[statement].kind == "Stmt.Continue" {
            return CleanupFlow{moved: appendUniqueTexts([]string{}, con movedInBody), continues: false}
        }
        letBinding := self.nodes[statement].kind == "Stmt.Let.Immutable" || self.nodes[statement].kind == "Stmt.Let.Mutable"
        if letBinding && self.nodes[statement].cleanup {
            active = append(active, newCleanupBinding(con self.nodes[statement].value, con self.nodes[statement].ty, source.Copy(con self.nodes[statement].span)))
        }
    }
    return CleanupFlow{moved: movedInBody, continues: true}
}

func (con self Lowerer) movedCleanupRoots(node int, con active []CleanupBinding) []string {
    if self.nodes[node].category == "S" && self.nodes[node].kind == "Stmt.RangeFor" {
        return self.movedPlaceCleanupRoots(self.nodes[node].children[1], con active)
    }
    if self.nodes[node].category == "S" && self.nodes[node].kind == "Stmt.For" {
        mut roots := []string{}
        for mut child := 0; child < len(self.nodes[node].children) - 2; child = child + 1 {
            control := self.nodes[node].children[child]
            if self.nodes[control].kind == "ForInit.Let.Immutable" || self.nodes[control].kind == "ForInit.Let.Mutable" {
                roots = appendUniqueTexts(roots, con self.movedCleanupRoots(control, con active))
            }
        }
        return roots
    }
    if self.nodes[node].category == "A" && self.nodes[node].kind != "Arg.Owned" {
        if len(self.nodes[node].children) == 1 {
            return self.movedPlaceCleanupRoots(self.nodes[node].children[0], con active)
        }
        return []string{}
    }
    if self.nodes[node].category == "S" && self.nodes[node].kind == "Stmt.FieldAssign" {
        return self.movedCleanupRoots(self.nodes[node].children[1], con active)
    }
    if self.nodes[node].category == "S" && self.nodes[node].kind == "Stmt.IndexAssign" {
        return self.movedCleanupRoots(self.nodes[node].children[2], con active)
    }
    if self.nodes[node].category == "E" && self.nodes[node].kind == "Expr.SliceAppend" && len(self.nodes[node].children) == 2 {
        slice := self.nodes[node].children[0]
        item := self.nodes[node].children[1]
        mut roots := self.movedCleanupRoots(item, con active)
        if self.nodes[slice].kind != "Expr.FieldAccess" {
            roots = appendUniqueTexts(roots, con self.movedCleanupRoots(slice, con active))
        }
        return roots
    }
    if self.nodes[node].category == "E" && self.nodes[node].kind == "Expr.ArrayLen" {
        return self.movedPlaceCleanupRoots(self.nodes[node].children[0], con active)
    }
    if self.nodes[node].category == "E" && self.nodes[node].kind == "Expr.Var" {
        binding := cleanupBindingIndex(con active, con self.nodes[node].value)
        if binding >= 0 {
            return []string{token.CopyText(con active[binding].key)}
        }
        return []string{}
    }
    equality := self.nodes[node].kind == "Expr.Binary.Equal" || self.nodes[node].kind == "Expr.Binary.NotEqual"
    readOnlyStringEquality := equality && len(self.nodes[node].children) > 0 && self.nodes[self.nodes[node].children[0]].ty == "string"
    if readOnlyStringEquality {
        return []string{}
    }

    mut roots := []string{}
    mut firstChild := 0
    if self.nodes[node].kind == "Expr.IndirectCall" {
        firstChild = 1
    }
    for mut child := firstChild; child < len(self.nodes[node].children); child = child + 1 {
        childRoots := self.movedCleanupRoots(self.nodes[node].children[child], con active)
        for mut root := 0; root < len(childRoots); root = root + 1 {
            if textIndex(con roots, con childRoots[root]) < 0 {
                roots = append(roots, token.CopyText(con childRoots[root]))
            }
        }
    }
    return roots
}

func (con self Lowerer) movedPlaceCleanupRoots(node int, con active []CleanupBinding) []string {
    if self.nodes[node].kind == "Expr.Var" {
        return []string{}
    }
    if self.nodes[node].kind == "Expr.FieldAccess" && len(self.nodes[node].children) == 1 {
        return self.movedPlaceCleanupRoots(self.nodes[node].children[0], con active)
    }
    if self.nodes[node].kind == "Expr.Index" && len(self.nodes[node].children) == 2 {
        mut roots := self.movedPlaceCleanupRoots(self.nodes[node].children[0], con active)
        roots = appendUniqueTexts(roots, con self.movedCleanupRoots(self.nodes[node].children[1], con active))
        return roots
    }
    return self.movedCleanupRoots(node, con active)
}

func (con self Lowerer) fullExpressionOwnerNode(node int) int {
    if self.nodes[node].kind == "Expr.FullExprTemporary" && self.nodes[node].cleanup {
        return node
    }
    if(self.nodes[node].kind == "Expr.FieldAccess" || self.nodes[node].kind == "Expr.Index") && len(self.nodes[node].children) > 0 {
        return self.fullExpressionOwnerNode(self.nodes[node].children[0])
    }
    return - 1
}

func (con self Lowerer) fieldAssignmentConsumesOverwrittenPlace(statement int) bool {
    if self.nodes[statement].kind != "Stmt.FieldAssign" || len(self.nodes[statement].children) != 2 {
        return false
    }
    base := self.nodes[statement].children[0]
    expression := self.nodes[statement].children[1]
    if self.nodes[expression].kind != "Expr.SliceAppend" || len(self.nodes[expression].children) != 2 {
        return false
    }
    slice := self.nodes[expression].children[0]
    if self.nodes[slice].kind != "Expr.FieldAccess" || len(self.nodes[slice].children) != 1 {
        return false
    }
    if self.nodes[slice].value != self.nodes[statement].value {
        return false
    }
    return self.sameDirectFieldPath(base, self.nodes[slice].children[0])
}

func (con self Lowerer) sameDirectFieldPath(left int, right int) bool {
    if self.nodes[left].kind != self.nodes[right].kind {
        return false
    }
    kind := token.CopyText(con self.nodes[left].kind)
    if kind == "Expr.Var" {
        return self.nodes[left].value == self.nodes[right].value
    }
    if kind == "Expr.FieldAccess" && len(self.nodes[left].children) == 1 && len(self.nodes[right].children) == 1 {
        return self.nodes[left].value == self.nodes[right].value && self.sameDirectFieldPath(self.nodes[left].children[0], self.nodes[right].children[0])
    }
    if kind == "Expr.Index" && len(self.nodes[left].children) == 2 && len(self.nodes[right].children) == 2 {
        return self.sameDirectFieldPath(self.nodes[left].children[0], self.nodes[right].children[0]) && self.sameStableExpression(self.nodes[left].children[1], self.nodes[right].children[1])
    }
    return false
}

func (con self Lowerer) sameStableExpression(left int, right int) bool {
    if self.nodes[left].kind != self.nodes[right].kind || self.nodes[left].value != self.nodes[right].value || len(self.nodes[left].children) != len(self.nodes[right].children) {
        return false
    }
    kind := token.CopyText(con self.nodes[left].kind)
    stable := kind == "Expr.Int" || kind == "Expr.String" || kind == "Expr.Bool" || kind == "Expr.Var" || kind == "Expr.Unary.Negate" || kind == "Expr.Unary.Not" || kind == "Expr.Binary.Add" || kind == "Expr.Binary.Subtract" || kind == "Expr.Binary.Multiply" || kind == "Expr.Binary.Divide" || kind == "Expr.Binary.Remainder" || kind == "Expr.Binary.Equal" || kind == "Expr.Binary.NotEqual" || kind == "Expr.Binary.LogicalAnd" || kind == "Expr.Binary.LogicalOr" || kind == "Expr.Binary.Less" || kind == "Expr.Binary.LessEqual" || kind == "Expr.Binary.Greater" || kind == "Expr.Binary.GreaterEqual" || kind == "Expr.FieldAccess" || kind == "Expr.Index"
    if !stable {
        return false
    }
    for mut child := 0; child < len(self.nodes[left].children); child = child + 1 {
        if !self.sameStableExpression(self.nodes[left].children[child], self.nodes[right].children[child]) {
            return false
        }
    }
    return true
}

func (mut self Lowerer) pushCleanupDrops(output []int, con active []CleanupBinding, con span source.Span) []int {
    mut result := output
    mut binding := len(active)
    for binding > 0 {
        binding = binding - 1
        variable := self.addNode("E", "Expr.Var", token.CopyText(con active[binding].name), token.CopyText(con active[binding].ty), source.Copy(con active[binding].span), []int{}, true)
        result = append(result, self.addNode("S", "Stmt.Drop", "", "unit", source.Copy(con span), []int{variable}, false))
    }
    return result
}

func (mut self Lowerer) pushCleanupOverwrite(output []int, statement int, target int, expression int) []int {
    mut result := output
    statementSpan := source.Copy(con self.nodes[statement].span)
    expressionSpan := source.Copy(con self.nodes[expression].span)
    expressionType := token.CopyText(con self.nodes[expression].ty)
    name := cleanupAssignmentRhsTempName(con statementSpan)
    temporary := self.addNode("S", "Stmt.Let.Immutable", token.CopyText(con name), token.CopyText(con expressionType), source.Copy(con statementSpan), []int{expression}, true)
    value := self.addNode("E", "Expr.Var", token.CopyText(con name), token.CopyText(con expressionType), source.Copy(con expressionSpan), []int{}, true)
    overwrite := self.addNode("S", "Stmt.Overwrite", "", "unit", source.Copy(con statementSpan), []int{target, value}, false)
    result = append(result, temporary)
    result = append(result, overwrite)
    return result
}

func (mut self Lowerer) addNode(category string, kind string, value string, ty string, span source.Span, children []int, cleanup bool) int {
    index := len(self.nodes)
    self.nodes = append(self.nodes, Node{category: category, kind: kind, value: value, ty: ty, span: span, children: children, cleanup: cleanup})
    return index
}

func cleanupBindingIndex(con active []CleanupBinding, con name string) int {
    mut index := len(active)
    for index > 0 {
        index = index - 1
        if active[index].name == name {
            return index
        }
    }
    return - 1
}

func persistentBranchMoves(con active []CleanupBinding, con thenFlow CleanupFlow, con elseFlow CleanupFlow) []string {
    mut moved := []string{}
    for mut index := 0; index < len(active); index = index + 1 {
        thenMoves := thenFlow.continues && textIndex(con thenFlow.moved, con active[index].key) >= 0
        elseMoves := elseFlow.continues && textIndex(con elseFlow.moved, con active[index].key) >= 0
        if thenMoves || elseMoves {
            moved = append(moved, token.CopyText(con active[index].key))
        }
    }
    return moved
}

func persistentMatchMoves(con active []CleanupBinding, con flows []CleanupFlow) []string {
    mut moved := []string{}
    for mut binding := 0; binding < len(active); binding = binding + 1 {
        mut persistent := false
        for mut flow := 0; flow < len(flows); flow = flow + 1 {
            if flows[flow].continues && textIndex(con flows[flow].moved, con active[binding].key) >= 0 {
                persistent = true
            }
        }
        if persistent {
            moved = append(moved, token.CopyText(con active[binding].key))
        }
    }
    return moved
}

func expressionBranchCleanupBindings(con active []CleanupBinding, con mergedMoved []string, con branchMoved []string) []CleanupBinding {
    mut cleanup := []CleanupBinding{}
    for mut binding := 0; binding < len(active); binding = binding + 1 {
        if textIndex(con mergedMoved, con active[binding].key) >= 0 && textIndex(con branchMoved, con active[binding].key) < 0 {
            cleanup = append(cleanup, copyCleanupBinding(con active[binding]))
        }
    }
    return cleanup
}

func newCleanupBinding(con name string, con ty string, span source.Span) CleanupBinding {
    copiedSpan := source.Copy(con span)
    key := strings.join(con []string{token.CopyText(con name), "@", strings.fromInt(source.Source(con copiedSpan)), "_", strings.fromInt(source.Start(con copiedSpan)), "_", strings.fromInt(source.End(con copiedSpan)),}, con "")
    return CleanupBinding{key: key, name: token.CopyText(con name), ty: token.CopyText(con ty), span: copiedSpan}
}

func copyCleanupBindings(con values []CleanupBinding) []CleanupBinding {
    mut copied := []CleanupBinding{}
    for mut index := 0; index < len(values); index = index + 1 {
        copied = append(copied, CleanupBinding{key: token.CopyText(con values[index].key), name: token.CopyText(con values[index].name), ty: token.CopyText(con values[index].ty), span: source.Copy(con values[index].span),})
    }
    return copied
}

func copyCleanupBinding(con value CleanupBinding) CleanupBinding {
    return CleanupBinding{key: token.CopyText(con value.key), name: token.CopyText(con value.name), ty: token.CopyText(con value.ty), span: source.Copy(con value.span),}
}

func cleanupBindingKeys(con values []CleanupBinding) []string {
    mut keys := []string{}
    for mut index := 0; index < len(values); index = index + 1 {
        keys = append(keys, token.CopyText(con values[index].key))
    }
    return keys
}

func cleanupBindingsExcluding(con values []CleanupBinding, con excluded []string) []CleanupBinding {
    mut kept := []CleanupBinding{}
    for mut index := 0; index < len(values); index = index + 1 {
        if textIndex(con excluded, con values[index].key) < 0 {
            kept = append(kept, CleanupBinding{key: token.CopyText(con values[index].key), name: token.CopyText(con values[index].name), ty: token.CopyText(con values[index].ty), span: source.Copy(con values[index].span),})
        }
    }
    return kept
}

func removeCleanupRoots(active []CleanupBinding, con moved []string) []CleanupBinding {
    mut remaining := []CleanupBinding{}
    for mut index := 0; index < len(active); index = index + 1 {
        if textIndex(con moved, con active[index].key) < 0 {
            remaining = append(remaining, CleanupBinding{key: token.CopyText(con active[index].key), name: token.CopyText(con active[index].name), ty: token.CopyText(con active[index].ty), span: source.Copy(con active[index].span),})
        }
    }
    return remaining
}

func textIndex(con values []string, con value string) int {
    for mut index := 0; index < len(values); index = index + 1 {
        if values[index]== value {
            return index
        }
    }
    return - 1
}

func appendUniqueTexts(values []string, con additions []string) []string {
    mut combined := values
    for mut index := 0; index < len(additions); index = index + 1 {
        if textIndex(con combined, con additions[index]) < 0 {
            combined = append(combined, token.CopyText(con additions[index]))
        }
    }
    return combined
}

func copyFunction(con function Function) Function {
    mut params := []Param{}
    for mut index := 0; index < len(function.params); index = index + 1 {
        params = append(params, Param{name: token.CopyText(con function.params[index].name), mode: token.CopyText(con function.params[index].mode), ty: token.CopyText(con function.params[index].ty),})
    }
    return Function{name: token.CopyText(con function.name), params: params, returnType: token.CopyText(con function.returnType), body: copyInts(con function.body),}
}

func copyTexts(con values []string) []string {
    mut copied := []string{}
    for mut index := 0; index < len(values); index = index + 1 {
        copied = append(copied, token.CopyText(con values[index]))
    }
    return copied
}

func copyInts(con values []int) []int {
    mut copied := []int{}
    for mut index := 0; index < len(values); index = index + 1 {
        copied = append(copied, values[index])
    }
    return copied
}

func normalizeNode(con program Program, node int, depth int) string {
    span := source.Copy(con program.nodes[node].span)
    mut output := strings.join(con []string{"I|", strings.fromInt(depth), "|", token.CopyText(con program.nodes[node].category), "|", token.CopyText(con program.nodes[node].kind), "|", strings.fromInt(source.Source(con span)), "|", strings.fromInt(source.Start(con span)), "|", strings.fromInt(source.End(con span)), "|", token.EncodeBytes(con program.nodes[node].value), "|", token.CopyText(con program.nodes[node].ty), "|", strings.fromInt(len(program.nodes[node].children)),}, con "")
    for mut child := 0; child < len(program.nodes[node].children); child = child + 1 {
        output = strings.join(con []string{output, "\n", normalizeNode(con program, program.nodes[node].children[child], depth + 1),}, con "")
    }
    return output
}

func closureName(span source.Span) string {
    return strings.join(con []string{"closure_", strings.fromInt(source.Source(con span)), "_", strings.fromInt(source.Start(con span)), "_", strings.fromInt(source.End(con span)),}, con "")
}

func returnValueTempName(con span source.Span) string {
    return strings.join(con []string{"mallang_return_value_", strings.fromInt(source.Start(con span)), "_", strings.fromInt(source.End(con span)),}, con "")
}

func cleanupAssignmentRhsTempName(con span source.Span) string {
    return strings.join(con []string{"mallang_cleanup_assign_rhs_", strings.fromInt(source.Start(con span)), "_", strings.fromInt(source.End(con span)),}, con "")
}

func variantConstructorKind(con storage string) string {
    if storage == "owned" {
        return "Expr.VariantConstructor.Owned"
    }
    return "Expr.VariantConstructor.Inline"
}

func variantPatternKind(con storage string) string {
    if storage == "owned" {
        return "Pattern.Variant.Owned"
    }
    return "Pattern.Variant.Inline"
}

func matchDiscardName(con span source.Span, index int) string {
    return strings.join(con []string{"mallang_match_discard_", strings.fromInt(source.Source(con span)), "_", strings.fromInt(source.Start(con span)), "_", strings.fromInt(source.End(con span)), "_", strings.fromInt(index),}, con "")
}

func isDirectReadExpression(con syntax ast.Program, expression int) bool {
    kind := ast.Kind(con syntax, expression)
    if kind == "Expr.Var" {
        return true
    }
    if(kind == "Expr.FieldAccess" || kind == "Expr.Index") && ast.ChildCount(con syntax, expression) > 0 {
        return isDirectReadExpression(con syntax, ast.Child(con syntax, expression, 0))
    }
    return false
}

func newError(message string, span source.Span) Error {
    return Error{message: message, span: span}
}
