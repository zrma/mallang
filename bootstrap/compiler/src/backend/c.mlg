    }
    tag := strings.fromInt(invalidData)
    return Ok([]string{strings.join(con []string{"static ", token.CopyText(con resultType), " MLG_UNUSED mallang_std_strings_parse_int(",}, con ""), "    const mlg_String *mlg_text", ") {", "    mallang_validate_string(*mlg_text);", "    if (mlg_text->mlg_len == 0) {", strings.join(con []string{"        return (", token.CopyText(con resultType), "){",}, con ""), "            .tag = 1,", strings.join(con []string{"            .", cField(con "payload"), " = {",}, con ""), strings.join(con []string{"                .", cField(con "Err"), " = mallang_std_strings_error(", token.CopyText(con tag), ", \"invalid integer text\")"}, con ""), "            }", "        };", "    }", "    size_t mlg_cursor = 0;", "    bool mlg_negative = false;", "    if (mlg_text->mlg_data[0] == '-') {", "        mlg_negative = true;", "        mlg_cursor = 1;", "        if (mlg_cursor == mlg_text->mlg_len) {", strings.join(con []string{"            return (", token.CopyText(con resultType), "){",}, con ""), "                .tag = 1,", strings.join(con []string{"                .", cField(con "payload"), " = {",}, con ""), strings.join(con []string{"                    .", cField(con "Err"), " = mallang_std_strings_error(", token.CopyText(con tag), ", \"invalid integer text\")"}, con ""), "                }", "            };", "        }", "    }", "    uint64_t mlg_limit = mlg_negative", "        ? (uint64_t)INT64_MAX + UINT64_C(1)", "        : (uint64_t)INT64_MAX;", "    uint64_t mlg_value = 0;", "    while (mlg_cursor < mlg_text->mlg_len) {", "        unsigned char mlg_byte = (unsigned char)mlg_text->mlg_data[mlg_cursor];", "        if (mlg_byte < '0' || mlg_byte > '9') {", strings.join(con []string{"            return (", token.CopyText(con resultType), "){",}, con ""), "                .tag = 1,", strings.join(con []string{"                .", cField(con "payload"), " = {",}, con ""), strings.join(con []string{"                    .", cField(con "Err"), " = mallang_std_strings_error(", token.CopyText(con tag), ", \"invalid integer text\")"}, con ""), "                }", "            };", "        }", "        uint64_t mlg_digit = (uint64_t)(mlg_byte - '0');", "        if (mlg_value > (mlg_limit - mlg_digit) / UINT64_C(10)) {", strings.join(con []string{"            return (", token.CopyText(con resultType), "){",}, con ""), "                .tag = 1,", strings.join(con []string{"                .", cField(con "payload"), " = {",}, con ""), strings.join(con []string{"                    .", cField(con "Err"), " = mallang_std_strings_error(", token.CopyText(con tag), ", \"integer value out of range\")"}, con ""), "                }", "            };", "        }", "        mlg_value = mlg_value * UINT64_C(10) + mlg_digit;", "        mlg_cursor = mlg_cursor + 1;", "    }", "    int64_t mlg_result;", "    if (mlg_negative && mlg_value == (uint64_t)INT64_MAX + UINT64_C(1)) {", "        mlg_result = INT64_MIN;", "    } else if (mlg_negative) {", "        mlg_result = -(int64_t)mlg_value;", "    } else {", "        mlg_result = (int64_t)mlg_value;", "    }", strings.join(con []string{"    return (", token.CopyText(con resultType), "){",}, con ""), "        .tag = 0,", strings.join(con []string{"        .", cField(con "payload"), " = { .", cField(con "Ok"), " = mlg_result }",}, con ""), "    };", "}", "",})
}

func platformErrorRuntime(con program ir.Program) Result[[]string, string] {
    structure := intrinsicStructIndex(con program, con "Error")
    enumeration := intrinsicEnumIndex(con program, con "ErrorKind")
    kindField := structFieldIndex(con program, structure, con "kind")
    messageField := structFieldIndex(con program, structure, con "message")
    if structure < 0 || enumeration < 0 || kindField < 0 || messageField < 0 {
        return Err("B3 C backend requires the standard platform Error IR metadata")
    }
    if ir.StructFieldType(con program, structure, kindField) != ir.EnumName(con program, enumeration) || ir.StructFieldType(con program, structure, messageField) != "string" {
        return Err("B3 C backend received malformed standard platform Error IR metadata")
    }
    names := []string{"NotFound", "PermissionDenied", "AlreadyExists", "InvalidInput", "InvalidData", "Interrupted", "Other",}
    mut tags := []string{}
    for mut index := 0; index < len(names); index = index + 1 {
        tag := enumVariantIndex(con program, enumeration, con names[index])
        if tag < 0 {
            return Err("B3 C backend received incomplete ErrorKind IR metadata")
        }
        tags = append(tags, strings.fromInt(tag))
    }
    errorType := cTypeFor(con program, con ir.StructName(con program, structure))
    kindType := cTypeFor(con program, con ir.EnumName(con program, enumeration))
    return Ok([]string{strings.join(con []string{"static ", token.CopyText(con errorType), " MLG_UNUSED mallang_std_error(",}, con ""), "    int32_t mlg_kind,", "    const char *mlg_message", ") {", strings.join(con []string{"    return (", token.CopyText(con errorType), "){",}, con ""), strings.join(con []string{"        .", cField(con "kind"), " = (", kindType, "){ .tag = mlg_kind },",}, con ""), strings.join(con []string{"        .", cField(con "message"), " = mallang_string_owned_from_bytes(",}, con ""), "            mlg_message,", "            strlen(mlg_message)", "        )", "    };", "}", "", "static int32_t MLG_UNUSED mallang_std_error_kind_from_errno(int mlg_error_number) {", "#if defined(ENOENT)", "    if (mlg_error_number == ENOENT) {", strings.join(con []string{"        return ", token.CopyText(con tags[0]), ";"}, con ""), "    }", "#endif", "#if defined(EACCES)", "    if (mlg_error_number == EACCES) {", strings.join(con []string{"        return ", token.CopyText(con tags[1]), ";"}, con ""), "    }", "#endif", "#if defined(EPERM)", "    if (mlg_error_number == EPERM) {", strings.join(con []string{"        return ", token.CopyText(con tags[1]), ";"}, con ""), "    }", "#endif", "#if defined(EEXIST)", "    if (mlg_error_number == EEXIST) {", strings.join(con []string{"        return ", token.CopyText(con tags[2]), ";"}, con ""), "    }", "#endif", "#if defined(EINVAL)", "    if (mlg_error_number == EINVAL) {", strings.join(con []string{"        return ", token.CopyText(con tags[3]), ";"}, con ""), "    }", "#endif", "#if defined(EILSEQ)", "    if (mlg_error_number == EILSEQ) {", strings.join(con []string{"        return ", token.CopyText(con tags[4]), ";"}, con ""), "    }", "#endif", "#if defined(EINTR)", "    if (mlg_error_number == EINTR) {", strings.join(con []string{"        return ", token.CopyText(con tags[5]), ";"}, con ""), "    }", "#endif", strings.join(con []string{"    return ", token.CopyText(con tags[6]), ";"}, con ""), "}", "", strings.join(con []string{"static ", token.CopyText(con errorType), " MLG_UNUSED mallang_std_errno_error("}, con ""), "    int mlg_error_number,", "    const char *mlg_message", ") {", "    return mallang_std_error(", "        mallang_std_error_kind_from_errno(mlg_error_number),", "        mlg_message", "    );", "}", "",})
}

func ioWriteRuntime(con program ir.Program) Result[[]string, string] {
    mut intrinsic := "IoWriteStdout"
    if !programUsesIntrinsic(con program, con intrinsic) {
        intrinsic = "IoWriteStderr"
    }
    resultType := cTypeFor(con program, con intrinsicResultType(con program, con intrinsic))
    enumeration := intrinsicEnumIndex(con program, con "ErrorKind")
    other := enumVariantIndex(con program, enumeration, con "Other")
    if resultType == "" || other < 0 {
        return Err("B3 C backend received malformed stream write IR metadata")
    }
    mut lines := []string{strings.join(con []string{"static ", token.CopyText(con resultType), " MLG_UNUSED mallang_std_io_write("}, con ""), "    FILE *mlg_stream,", "    const mlg_String *mlg_text,", "    const char *mlg_failure_message", ") {", "    mallang_validate_string(*mlg_text);", "    size_t mlg_written = 0;", "    while (mlg_written < mlg_text->mlg_len) {", "        errno = 0;", "        size_t mlg_step = fwrite(", "            mlg_text->mlg_data + mlg_written,", "            1,", "            mlg_text->mlg_len - mlg_written,", "            mlg_stream", "        );", "        mlg_written = mlg_written + mlg_step;", "        if (mlg_step > 0) {", "            continue;", "        }", "        int mlg_error_number = errno;", "        if (!ferror(mlg_stream)) {", strings.join(con []string{"            return (", token.CopyText(con resultType), "){",}, con ""), "                .tag = 1,", strings.join(con []string{"                .", cField(con "payload"), " = {",}, con ""), strings.join(con []string{"                    .", cField(con "Err"), " = mallang_std_error("}, con ""), strings.join(con []string{"                        ", strings.fromInt(other), ","}, con ""), "                        \"stream write made no progress\"", "                    )", "                }", "            };", "        }", strings.join(con []string{"        return (", token.CopyText(con resultType), "){",}, con ""), "            .tag = 1,", strings.join(con []string{"            .", cField(con "payload"), " = {",}, con ""), strings.join(con []string{"                .", cField(con "Err"), " = mallang_std_errno_error("}, con ""), "                    mlg_error_number,", "                    mlg_failure_message", "                )", "            }", "        };", "    }", "", "    errno = 0;", "    if (fflush(mlg_stream) != 0) {", strings.join(con []string{"        return (", token.CopyText(con resultType), "){",}, con ""), "            .tag = 1,", strings.join(con []string{"            .", cField(con "payload"), " = {",}, con ""), strings.join(con []string{"                .", cField(con "Err"), " = mallang_std_errno_error(errno, mlg_failure_message)"}, con ""), "            }", "        };", "    }", strings.join(con []string{"    return (", token.CopyText(con resultType), "){ .tag = 0 };"}, con ""), "}", "",}
    if programUsesIntrinsic(con program, con "IoWriteStdout") {
        lines = copyLines(lines, con []string{strings.join(con []string{"static ", token.CopyText(con resultType), " MLG_UNUSED mallang_std_io_write_stdout(const mlg_String *mlg_text) {"}, con ""), "    return mallang_std_io_write(stdout, mlg_text, \"standard output write failed\");", "}", "",})
    }
    if programUsesIntrinsic(con program, con "IoWriteStderr") {
        lines = copyLines(lines, con []string{strings.join(con []string{"static ", token.CopyText(con resultType), " MLG_UNUSED mallang_std_io_write_stderr(const mlg_String *mlg_text) {"}, con ""), "    return mallang_std_io_write(stderr, mlg_text, \"standard error write failed\");", "}", "",})
    }
    return Ok(lines)
}

func filePathRuntime() []string {
    return []string{"static bool MLG_UNUSED mallang_std_file_path(", "    const mlg_String *mlg_path,", "    char **mlg_path_out", ") {", "    mallang_validate_string(*mlg_path);", "    if (memchr(mlg_path->mlg_data, '\\0', mlg_path->mlg_len) != NULL) {", "        return false;", "    }", "    if (mlg_path->mlg_len == SIZE_MAX) {", "        mallang_runtime_error(\"file path allocation size overflow\");", "    }", "    char *mlg_path_data = mallang_alloc(", "        mlg_path->mlg_len + 1,", "        \"file path allocation failed\"", "    );", "    if (mlg_path->mlg_len > 0) {", "        memcpy(mlg_path_data, mlg_path->mlg_data, mlg_path->mlg_len);", "    }", "    mlg_path_data[mlg_path->mlg_len] = '\\0';", "    *mlg_path_out = mlg_path_data;", "    return true;", "}", "",}
}

func fsReadRuntime(con program ir.Program) Result[[]string, string] {
    resultType := cTypeFor(con program, con intrinsicResultType(con program, con "FsReadText"))
    enumeration := intrinsicEnumIndex(con program, con "ErrorKind")
    invalidInput := enumVariantIndex(con program, enumeration, con "InvalidInput")
    invalidData := enumVariantIndex(con program, enumeration, con "InvalidData")
    other := enumVariantIndex(con program, enumeration, con "Other")
    if resultType == "" || invalidInput < 0 || invalidData < 0 || other < 0 {
        return Err("B3 C backend received malformed FsReadText IR metadata")
    }
    return Ok([]string{strings.join(con []string{"static ", token.CopyText(con resultType), " MLG_UNUSED mallang_std_fs_read_text("}, con ""), "    const mlg_String *mlg_path", ") {", "    char *mlg_path_data = NULL;", "    if (!mallang_std_file_path(mlg_path, &mlg_path_data)) {", strings.join(con []string{"        return (", token.CopyText(con resultType), "){",}, con ""), "            .tag = 1,", strings.join(con []string{"            .", cField(con "payload"), " = {",}, con ""), strings.join(con []string{"                .", cField(con "Err"), " = mallang_std_error("}, con ""), strings.join(con []string{"                    ", strings.fromInt(invalidInput), ","}, con ""), "                    \"file path contains NUL\"", "                )", "            }", "        };", "    }", "", "    errno = 0;", "    FILE *mlg_file = fopen(mlg_path_data, \"rb\");", "    int mlg_open_error = errno;", "    mallang_dealloc(mlg_path_data);", "    if (mlg_file == NULL) {", strings.join(con []string{"        return (", token.CopyText(con resultType), "){",}, con ""), "            .tag = 1,", strings.join(con []string{"            .", cField(con "payload"), " = {",}, con ""), strings.join(con []string{"                .", cField(con "Err"), " = mallang_std_errno_error("}, con ""), "                    mlg_open_error,", "                    \"file open failed\"", "                )", "            }", "        };", "    }", "", "    size_t mlg_len = 0;", "    size_t mlg_cap = 4096;", "    char *mlg_data = mallang_alloc(mlg_cap, \"file read allocation failed\");", "    while (true) {", "        if (mlg_len == mlg_cap) {", "            if (mlg_cap > SIZE_MAX / 2) {", "                mallang_runtime_error(\"file read allocation size overflow\");", "            }", "            mlg_cap = mlg_cap * 2;", "            mlg_data = mallang_realloc(", "                mlg_data,", "                mlg_cap,", "                \"file read allocation failed\"", "            );", "        }", "", "        errno = 0;", "        size_t mlg_read = fread(mlg_data + mlg_len, 1, mlg_cap - mlg_len, mlg_file);", "        int mlg_read_error = errno;", "        mlg_len = mlg_len + mlg_read;", "        if (mlg_len > INT64_MAX) {", "            mallang_dealloc(mlg_data);", "            mallang_runtime_error(\"file content exceeds string size limit\");", "        }", "        if (mlg_read > 0) {", "            continue;", "        }", "        if (ferror(mlg_file) || mlg_read_error != 0) {", "            mallang_dealloc(mlg_data);", "            errno = 0;", "            int mlg_close_status = fclose(mlg_file);", "            if (mlg_read_error == 0 && mlg_close_status != 0) {", "                mlg_read_error = errno;", "            }", strings.join(con []string{"            return (", token.CopyText(con resultType), "){",}, con ""), "                .tag = 1,", strings.join(con []string{"                .", cField(con "payload"), " = {",}, con ""), strings.join(con []string{"                    .", cField(con "Err"), " = mallang_std_errno_error("}, con ""), "                        mlg_read_error,", "                        \"file read failed\"", "                    )", "                }", "            };", "        }", "        if (feof(mlg_file)) {", "            break;", "        }", "        mallang_dealloc(mlg_data);", "        (void)fclose(mlg_file);", strings.join(con []string{"        return (", token.CopyText(con resultType), "){",}, con ""), "            .tag = 1,", strings.join(con []string{"            .", cField(con "payload"), " = {",}, con ""), strings.join(con []string{"                .", cField(con "Err"), " = mallang_std_error("}, con ""), strings.join(con []string{"                    ", strings.fromInt(other), ","}, con ""), "                    \"file read made no progress\"", "                )", "            }", "        };", "    }", "", "    errno = 0;", "    if (fclose(mlg_file) != 0) {", "        int mlg_close_error = errno;", "        mallang_dealloc(mlg_data);", strings.join(con []string{"        return (", token.CopyText(con resultType), "){",}, con ""), "            .tag = 1,", strings.join(con []string{"            .", cField(con "payload"), " = {",}, con ""), strings.join(con []string{"                .", cField(con "Err"), " = mallang_std_errno_error("}, con ""), "                    mlg_close_error,", "                    \"file close failed\"", "                )", "            }", "        };", "    }", "    if (!mallang_utf8_scalar_count_bytes(mlg_data, mlg_len, NULL)) {", "        mallang_dealloc(mlg_data);", strings.join(con []string{"        return (", token.CopyText(con resultType), "){",}, con ""), "            .tag = 1,", strings.join(con []string{"            .", cField(con "payload"), " = {",}, con ""), strings.join(con []string{"                .", cField(con "Err"), " = mallang_std_error("}, con ""), strings.join(con []string{"                    ", strings.fromInt(invalidData), ","}, con ""), "                    \"file content is not valid UTF-8\"", "                )", "            }", "        };", "    }", "    mlg_data[mlg_len] = '\\0';", strings.join(con []string{"    return (", token.CopyText(con resultType), "){",}, con ""), "        .tag = 0,", strings.join(con []string{"        .", cField(con "payload"), " = {",}, con ""), strings.join(con []string{"            .", cField(con "Ok"), " = (mlg_String){"}, con ""), "                .mlg_data = mlg_data,", "                .mlg_len = mlg_len,", "                .mlg_storage = MLG_STRING_OWNED", "            }", "        }", "    };", "}", "",})
}

func osArgsRuntime(con program ir.Program) Result[[]string, string] {
    result := intrinsicResultType(con program, con "OsArgs")
    slice := typeArgument(con program, con result, 0)
    resultType := cTypeFor(con program, con result)
    sliceType := cTypeFor(con program, con slice)
    enumeration := intrinsicEnumIndex(con program, con "ErrorKind")
    invalidData := enumVariantIndex(con program, enumeration, con "InvalidData")
    if typeKind(con program, con result) != "result" || typeKind(con program, con slice) != "slice" || typeArgument(con program, con slice, 0) != "string" || resultType == "" || sliceType == "" || invalidData < 0 {
        return Err("B3 C backend received malformed OsArgs IR metadata")
    }
    return Ok([]string{"static int mallang_process_argc = 0;", "static char **mallang_process_argv = NULL;", "", "static void MLG_UNUSED mallang_process_init(int mlg_argc, char **mlg_argv) {", "    if (mlg_argc < 0 || (mlg_argc > 0 && mlg_argv == NULL)) {", "        mallang_runtime_error(\"invalid process argument storage\");", "    }", "    mallang_process_argc = mlg_argc;", "    mallang_process_argv = mlg_argv;", "}", "", "static void MLG_UNUSED mallang_std_drop_partial_strings(", "    mlg_String *mlg_values,", "    size_t mlg_initialized", ") {", "    for (size_t mlg_index = 0; mlg_index < mlg_initialized; mlg_index = mlg_index + 1) {", "        mallang_validate_string(mlg_values[mlg_index]);", "        mallang_dealloc((void *)mlg_values[mlg_index].mlg_data);", "    }", "    mallang_dealloc(mlg_values);", "}", "", strings.join(con []string{"static ", token.CopyText(con resultType), " MLG_UNUSED mallang_std_os_args(void) {"}, con ""), "    size_t mlg_count = (size_t)mallang_process_argc;", "    if (mlg_count > SIZE_MAX / sizeof(mlg_String)) {", "        mallang_runtime_error(\"process argument allocation size overflow\");", "    }", "    mlg_String *mlg_values = NULL;", "    if (mlg_count > 0) {", "        mlg_values = mallang_alloc(", "            mlg_count * sizeof(mlg_String),", "            \"process argument allocation failed\"", "        );", "    }", "", "    for (size_t mlg_index = 0; mlg_index < mlg_count; mlg_index = mlg_index + 1) {", "        const char *mlg_argument = mallang_process_argv[mlg_index];", "        if (mlg_argument == NULL) {", "            mallang_std_drop_partial_strings(mlg_values, mlg_index);", strings.join(con []string{"            return (", token.CopyText(con resultType), "){",}, con ""), "                .tag = 1,", strings.join(con []string{"                .", cField(con "payload"), " = {",}, con ""), strings.join(con []string{"                    .", cField(con "Err"), " = mallang_std_error("}, con ""), strings.join(con []string{"                        ", strings.fromInt(invalidData), ","}, con ""), "                        \"invalid process argument\"", "                    )", "                }", "            };", "        }", "        size_t mlg_len = strlen(mlg_argument);", "        if (mlg_len > INT64_MAX ||", "            !mallang_utf8_scalar_count_bytes(mlg_argument, mlg_len, NULL)) {", "            mallang_std_drop_partial_strings(mlg_values, mlg_index);", strings.join(con []string{"            return (", token.CopyText(con resultType), "){",}, con ""), "                .tag = 1,", strings.join(con []string{"                .", cField(con "payload"), " = {",}, con ""), strings.join(con []string{"                    .", cField(con "Err"), " = mallang_std_error("}, con ""), strings.join(con []string{"                        ", strings.fromInt(invalidData), ","}, con ""), "                        \"process argument is not valid UTF-8\"", "                    )", "                }", "            };", "        }", "        mlg_values[mlg_index] = mallang_string_owned_from_bytes(mlg_argument, mlg_len);", "    }", "", strings.join(con []string{"    return (", token.CopyText(con resultType), "){",}, con ""), "        .tag = 0,", strings.join(con []string{"        .", cField(con "payload"), " = {",}, con ""), strings.join(con []string{"            .", cField(con "Ok"), " = (", token.CopyText(con sliceType), "){",}, con ""), strings.join(con []string{"                .", cField(con "data"), " = mlg_values,"}, con ""), strings.join(con []string{"                .", cField(con "len"), " = (int64_t)mlg_count,"}, con ""), strings.join(con []string{"                .", cField(con "cap"), " = (int64_t)mlg_count"}, con ""), "            }", "        }", "    };", "}", "",})
}

func platformRuntime(con program ir.Program) Result[[]string, string] {
    usesIoWrite := programUsesIntrinsic(con program, con "IoWriteStdout") || programUsesIntrinsic(con program, con "IoWriteStderr")
    usesOsExit := programUsesIntrinsic(con program, con "OsExit")
    usesFsRead := programUsesIntrinsic(con program, con "FsReadText")
    usesOsArgs := programUsesIntrinsic(con program, con "OsArgs")
    if !usesIoWrite && !usesOsExit && !usesFsRead && !usesOsArgs {
        return Ok([]string{})
    }
    match platformErrorRuntime(con program) {
        case Ok(errorLines) {
            mut lines := copyLines([]string{}, con errorLines)
            if usesFsRead {
                lines = copyLines(lines, con filePathRuntime())
                match fsReadRuntime(con program) {
                    case Ok(fsLines) {
                        lines = copyLines(lines, con fsLines)
                    }
                    case Err(message) {
                        return Err(message)
                    }
                }
            }
            if usesOsArgs {
                match osArgsRuntime(con program) {
                    case Ok(osLines) {
                        lines = copyLines(lines, con osLines)
                    }
                    case Err(message) {
                        return Err(message)
                    }
                }
            }
            if usesOsExit {
                lines = copyLines(lines, con []string{"static _Noreturn void MLG_UNUSED mallang_std_os_exit(", "    int64_t mlg_code", ") {", "    if (mlg_code < 0 || mlg_code > 255) {", "        mallang_runtime_error(\"process exit code out of range\");", "    }", "    exit((int)mlg_code);", "}", "",})
            }
            if usesIoWrite {
                match ioWriteRuntime(con program) {
                    case Ok(ioLines) {
                        lines = copyLines(lines, con ioLines)
                    }
                    case Err(message) {
                        return Err(message)
                    }
                }
            }
            return Ok(lines)
        }
        case Err(message) {
            return Err(message)
        }
    }
}

func dynamicStringRuntime(con program ir.Program) Result[[]string, string] {
    mut lines := []string{}
    needsError := programUsesIntrinsic(con program, con "StringsByteAt") || programUsesIntrinsic(con program, con "StringsSlice") || programUsesIntrinsic(con program, con "StringsParseInt")
    if needsError {
        match stringErrorRuntime(con program) {
            case Ok(helper) {
                lines = copyLines(lines, con helper)
            }
            case Err(message) {
                return Err(message)
            }
        }
    }
    if programUsesIntrinsic(con program, con "StringsFind") {
        lines = copyLines(lines, con byteFindRuntime())
    }
    if programUsesIntrinsic(con program, con "StringsByteLen") {
        lines = copyLines(lines, con []string{"static int64_t MLG_UNUSED mallang_std_strings_byte_len(", "    const mlg_String *mlg_text", ") {", "    mallang_validate_string_layout(*mlg_text);", "    if (mlg_text->mlg_len > INT64_MAX) {", "        mallang_runtime_error(\"string byte length overflow\");", "    }", "    return (int64_t)mlg_text->mlg_len;", "}", "",})
    }
    if programUsesIntrinsic(con program, con "StringsByteAt") {
        match byteAtRuntime(con program) {
            case Ok(helper) {
                lines = copyLines(lines, con helper)
            }
            case Err(message) {
                return Err(message)
            }
        }
    }
    if programUsesIntrinsic(con program, con "StringsSlice") {
        match stringSliceRuntime(con program) {
            case Ok(helper) {
                lines = copyLines(lines, con helper)
            }
            case Err(message) {
                return Err(message)
            }
        }
    }
    if programUsesIntrinsic(con program, con "StringsFind") {
        match stringFindRuntime(con program) {
            case Ok(helper) {
                lines = copyLines(lines, con helper)
            }
            case Err(message) {
                return Err(message)
            }
        }
    }
    if programUsesIntrinsic(con program, con "StringsJoin") {
        match stringJoinRuntime(con program) {
            case Ok(helper) {
                lines = copyLines(lines, con helper)
            }
            case Err(message) {
                return Err(message)
            }
        }
    }
    if programUsesIntrinsic(con program, con "StringsFromInt") {
        lines = copyLines(lines, con []string{"static mlg_String MLG_UNUSED mallang_std_strings_from_int(", "    int64_t mlg_value", ") {", "    char mlg_buffer[32];", "    int mlg_written = snprintf(", "        mlg_buffer,", "        sizeof(mlg_buffer),", "        \"%lld\",", "        (long long)mlg_value", "    );", "    if (mlg_written < 0 || (size_t)mlg_written >= sizeof(mlg_buffer)) {", "        mallang_runtime_error(\"integer formatting failed\");", "    }", "    return mallang_string_owned_from_bytes(mlg_buffer, (size_t)mlg_written);", "}", "",})
    }
    if programUsesIntrinsic(con program, con "StringsFromBool") {
        lines = copyLines(lines, con []string{"static mlg_String MLG_UNUSED mallang_std_strings_from_bool(", "    bool mlg_value", ") {", "    const char *mlg_text = mlg_value ? \"true\" : \"false\";", "    size_t mlg_len = mlg_value ? 4 : 5;", "    return mallang_string_owned_from_bytes(mlg_text, mlg_len);", "}", "",})
    }
    if programUsesIntrinsic(con program, con "StringsParseInt") {
        match stringParseIntRuntime(con program) {
            case Ok(helper) {
                lines = copyLines(lines, con helper)
            }
            case Err(message) {
                return Err(message)
            }
        }
    }
    return Ok(lines)
}

func standardRuntime(con program ir.Program) Result[[]string, string] {
    match dynamicStringRuntime(con program) {
        case Ok(stringLines) {
            mut lines := copyLines([]string{}, con stringLines)
            match platformRuntime(con program) {
                case Ok(platformLines) {
                    lines = copyLines(lines, con platformLines)
                    return Ok(lines)
                }
                case Err(message) {
                    return Err(message)
                }
            }
        }
        case Err(message) {
            return Err(message)
        }
    }
}

func functionParams(con program ir.Program, function int, thunk bool) Result[string, string] {
    mut params := []string{}
    if thunk {
        params = append(params, "void *mlg_env")
    }
    for mut param := 0; param < ir.FunctionParamCount(con program, function); param = param + 1 {
        mode := ir.FunctionParamMode(con program, function, param)
        ty := cParamType(con program, con ir.FunctionParamType(con program, function, param), con mode)
        if ty == "" {
            return Err(unsupported(con ir.FunctionParamType(con program, function, param)))
        }
        mut name := cVariableName(con ir.FunctionParamName(con program, function, param))
        if thunk {
            name = strings.join(con []string{"mlg_arg_", strings.fromInt(param),}, con "")
        }
        params = append(params, strings.join(con []string{ty, " ", name,}, con ""))
    }
    if len(params) == 0 {
        return Ok("void")
    }
    return Ok(strings.join(con params, con ", "))
}

func functionSignature(con program ir.Program, function int) Result[string, string] {
    name := ir.FunctionName(con program, function)
    if name == "main" {
        if ir.FunctionParamCount(con program, function) != 0 || ir.FunctionReturnType(con program, function) != "unit" {
            return Err("B3 C backend requires func main()")
        }
        if programUsesIntrinsic(con program, con "OsArgs") {
            return Ok("int main(int argc, char **argv)")
        }
        return Ok("int main(void)")
    }
    returnType := cTypeFor(con program, con ir.FunctionReturnType(con program, function))
    if returnType == "" {
        return Err(unsupported(con ir.FunctionReturnType(con program, function)))
    }
    match functionParams(con program, function, false) {
        case Ok(params) {
            return Ok(strings.join(con []string{returnType, " ", cFunctionName(con name), "(", params, ")",}, con ""))
        }
        case Err(message) {
            return Err(message)
        }
    }
}

func spanSuffix(con program ir.Program, node int) string {
    span := ir.NodeSpan(con program, node)
    return strings.join(con []string{strings.fromInt(source.Start(con span)), "_", strings.fromInt(source.End(con span)),}, con "")
}

func emitCallArgument(con program ir.Program, argument int, con indent string, con env EmitEnv) Result[EmittedExpr, string] {
    if ir.NodeChildCount(con program, argument) != 1 {
        return Err("B3 C backend received malformed call argument IR")
    }
    kind := ir.NodeKind(con program, argument)
    expression := ir.NodeChild(con program, argument, 0)
    if kind == "Arg.Owned" ||((kind == "Arg.Con" || kind == "Arg.Mut") && ir.NodeKind(con program, expression) == "Expr.FullExprTemporary") {
        return emitExpression(con program, expression, con indent, con env)
    }
    if kind == "Arg.Con" || kind == "Arg.Mut" {
        return emitBorrowLvalue(con program, expression, con indent, con env)
    }
    return Err("B3 C backend received invalid call argument mode")
}

func callableTypeMatchesFunction(con program ir.Program, callable int, function int) bool {
    if callable < 0 || function < 0 || ir.CallableTypeMutable(con program, callable) {
        return false
    }
    if ir.CallableTypeReturn(con program, callable) != ir.FunctionReturnType(con program, function) {
        return false
    }
    if ir.CallableTypeParamCount(con program, callable) != ir.FunctionParamCount(con program, function) {
        return false
    }
    for mut param := 0; param < ir.CallableTypeParamCount(con program, callable); param = param + 1 {
        if ir.CallableTypeParamMode(con program, callable, param) != ir.FunctionParamMode(con program, function, param) {
            return false
        }
        if ir.CallableTypeParam(con program, callable, param) != ir.FunctionParamType(con program, function, param) {
            return false
        }
    }
    return true
}

func emitFunctionValue(con program ir.Program, node int) Result[EmittedExpr, string] {
    ty := ir.NodeType(con program, node)
    callable := callableTypeIndex(con program, con ty)
    name := ir.NodeValue(con program, node)
    function := functionIndex(con program, con name)
    if !callableTypeMatchesFunction(con program, callable, function) {
        return Err("B3 C backend received a mismatched named function value")
    }
    value := strings.join(con []string{"(", cTypeFor(con program, con ty), "){ .mlg_env = NULL, .mlg_drop = NULL, .mlg_call = mallang_callable_thunk_", cFunctionName(con name), " }",}, con "")
    return Ok(EmittedExpr{lines: []string{}, value: value, postLines: []string{},})
}

func callArgumentMode(con program ir.Program, argument int) string {
    kind := ir.NodeKind(con program, argument)
    if kind == "Arg.Owned" {
        return "owned"
    }
    if kind == "Arg.Con" {
        return "con"
    }
    if kind == "Arg.Mut" {
        return "mut"
    }
    return ""
}

func emitIndirectCall(con program ir.Program, node int, con indent string, con env EmitEnv) Result[EmittedExpr, string] {
    if ir.NodeChildCount(con program, node) < 1 {
        return Err("B3 C backend received malformed indirect call IR")
    }
    calleeNode := ir.NodeChild(con program, node, 0)
    calleeType := ir.NodeType(con program, calleeNode)
    callable := callableTypeIndex(con program, con calleeType)
    if callable < 0 {
        return Err("B3 C backend received an indirect call without a callable type")
    }
    if ir.NodeType(con program, node) != ir.CallableTypeReturn(con program, callable) || ir.NodeChildCount(con program, node) != ir.CallableTypeParamCount(con program, callable) + 1 {
        return Err("B3 C backend received a mismatched indirect call signature")
    }
    match emitExpression(con program, calleeNode, con indent, con env) {
        case Ok(callee) {
            temp := strings.join(con []string{"mallang_callable_tmp_", spanSuffix(con program, node),}, con "")
            mut lines := copyLines([]string{}, con callee.lines)
            lines = append(lines, strings.join(con []string{token.CopyText(con indent), cTypeFor(con program, con calleeType), " ", token.CopyText(con temp), " = ", token.CopyText(con callee.value), ";",}, con ""))
            mut postLines := copyLines([]string{}, con callee.postLines)
            mut args := []string{strings.join(con []string{token.CopyText(con temp), ".mlg_env",}, con ""),}
            for mut param := 0; param < ir.CallableTypeParamCount(con program, callable); param = param + 1 {
                argument := ir.NodeChild(con program, node, param + 1)
                mode := callArgumentMode(con program, argument)
                if mode != ir.CallableTypeParamMode(con program, callable, param) || ir.NodeType(con program, argument) != ir.CallableTypeParam(con program, callable, param) {
                    return Err("B3 C backend received a mismatched indirect call argument")
                }
                match emitCallArgument(con program, argument, con indent, con env) {
                    case Ok(emitted) {
                        lines = copyLines(lines, con emitted.lines)
                        mut value := token.CopyText(con emitted.value)
                        if mode == "con" || mode == "mut" {
                            value = strings.join(con []string{"&(", token.CopyText(con value), ")",}, con "")
                        }
                        args = append(args, value)
                        postLines = copyLines(emitted.postLines, con postLines)
                    }
                    case Err(message) {
                        return Err(message)
                    }
                }
            }
            value := strings.join(con []string{token.CopyText(con temp), ".mlg_call(", strings.join(con args, con ", "), ")",}, con "")
            return Ok(EmittedExpr{lines: lines, value: value, postLines: postLines,})
        }
        case Err(message) {
            return Err(message)
        }
    }
}

func emitCall(con program ir.Program, node int, con indent string, con env EmitEnv) Result[EmittedExpr, string] {
    name := ir.NodeValue(con program, node)
    if name == "print" {
        return Err("B3 C backend print is statement-only")
    }
    mut lines := []string{}
    mut args := []string{}
    mut postLines := []string{}
    for mut child := 0; child < ir.NodeChildCount(con program, node); child = child + 1 {
        argument := ir.NodeChild(con program, node, child)
        argumentKind := ir.NodeKind(con program, argument)
        match emitCallArgument(con program, argument, con indent, con env) {
            case Ok(emitted) {
                lines = copyLines(lines, con emitted.lines)
                mut value := token.CopyText(con emitted.value)
                if argumentKind == "Arg.Con" || argumentKind == "Arg.Mut" {
                    value = strings.join(con []string{"&(", token.CopyText(con value), ")",}, con "")
                }
                args = append(args, value)
                postLines = copyLines(emitted.postLines, con postLines)
            }
            case Err(message) {
                return Err(message)
            }
        }
    }
    return Ok(EmittedExpr{lines: lines, value: strings.join(con []string{cFunctionName(con name), "(", strings.join(con args, con ", "), ")",}, con ""), postLines: postLines,})
}

func intrinsicHelperName(con intrinsic string) string {
    if intrinsic == "StringsByteLen" {
        return "mallang_std_strings_byte_len"
    }
    if intrinsic == "StringsByteAt" {
        return "mallang_std_strings_byte_at"
    }
    if intrinsic == "StringsSlice" {
        return "mallang_std_strings_slice"
    }
    if intrinsic == "StringsFind" {
        return "mallang_std_strings_find"
    }
    if intrinsic == "StringsJoin" {
        return "mallang_std_strings_join"
    }
    if intrinsic == "StringsFromInt" {
        return "mallang_std_strings_from_int"
    }
    if intrinsic == "StringsFromBool" {
        return "mallang_std_strings_from_bool"
    }
    if intrinsic == "StringsParseInt" {
        return "mallang_std_strings_parse_int"
    }
    if intrinsic == "IoWriteStdout" {
        return "mallang_std_io_write_stdout"
    }
    if intrinsic == "IoWriteStderr" {
        return "mallang_std_io_write_stderr"
    }
    if intrinsic == "OsExit" {
        return "mallang_std_os_exit"
    }
    if intrinsic == "FsReadText" {
        return "mallang_std_fs_read_text"
    }
    if intrinsic == "OsArgs" {
        return "mallang_std_os_args"
    }
    return ""
}

func emitIntrinsicCall(con program ir.Program, node int, con indent string, con env EmitEnv) Result[EmittedExpr, string] {
    intrinsic := ir.NodeValue(con program, node)
    helper := intrinsicHelperName(con intrinsic)
    if helper == "" {
        return Err(unsupported(con strings.join(con []string{"intrinsic ", token.CopyText(con intrinsic),}, con "")))
    }
    mut lines := []string{}
    mut args := []string{}
    mut postLines := []string{}
    for mut child := 0; child < ir.NodeChildCount(con program, node); child = child + 1 {
        argument := ir.NodeChild(con program, node, child)
        mode := callArgumentMode(con program, argument)
        if mode == "" {
            return Err("B3 C backend received invalid intrinsic argument mode")
        }
        match emitCallArgument(con program, argument, con indent, con env) {
            case Ok(emitted) {
                lines = copyLines(lines, con emitted.lines)
                mut value := token.CopyText(con emitted.value)
                if mode == "con" || mode == "mut" {
                    value = strings.join(con []string{"&(", token.CopyText(con value), ")",}, con "")
                }
                args = append(args, value)
                postLines = copyLines(emitted.postLines, con postLines)
            }
            case Err(message) {
                return Err(message)
            }
        }
    }
    value := strings.join(con []string{helper, "(", strings.join(con args, con ", "), ")",}, con "")
    return Ok(EmittedExpr{lines: lines, value: value, postLines: postLines,})
}

func emitCheckedBinary(con program ir.Program, node int, con indent string, con builtin string, con env EmitEnv) Result[EmittedExpr, string] {
    if ir.NodeChildCount(con program, node) != 2 {
        return Err("B3 C backend received malformed checked binary IR")
    }
    match emitExpression(con program, ir.NodeChild(con program, node, 0), con indent, con env) {
        case Ok(left) {
            match emitExpression(con program, ir.NodeChild(con program, node, 1), con indent, con env) {
                case Ok(right) {
                    suffix := spanSuffix(con program, node)
                    leftName := strings.join(con []string{"mallang_checked_left_", token.CopyText(con suffix),}, con "")
                    rightName := strings.join(con []string{"mallang_checked_right_", token.CopyText(con suffix),}, con "")
                    resultName := strings.join(con []string{"mallang_checked_result_", token.CopyText(con suffix),}, con "")
                    mut lines := copyLines([]string{}, con left.lines)
                    lines = append(lines, strings.join(con []string{token.CopyText(con indent), "int64_t ", token.CopyText(con leftName), " = ", token.CopyText(con left.value), ";",}, con ""))
                    lines = copyLines(lines, con left.postLines)
                    lines = copyLines(lines, con right.lines)
                    lines = append(lines, strings.join(con []string{token.CopyText(con indent), "int64_t ", token.CopyText(con rightName), " = ", token.CopyText(con right.value), ";",}, con ""))
                    lines = copyLines(lines, con right.postLines)
                    lines = append(lines, strings.join(con []string{token.CopyText(con indent), "int64_t ", token.CopyText(con resultName), ";",}, con ""))
                    lines = append(lines, strings.join(con []string{token.CopyText(con indent), "if (", token.CopyText(con builtin), "(", token.CopyText(con leftName), ", ", token.CopyText(con rightName), ", &", token.CopyText(con resultName), ")) {",}, con ""))
                    lines = append(lines, strings.join(con []string{token.CopyText(con indent), "    mallang_runtime_error(\"integer overflow\");",}, con ""))
                    lines = append(lines, strings.join(con []string{token.CopyText(con indent), "}",}, con ""))
                    return Ok(EmittedExpr{lines: lines, value: resultName, postLines: []string{},})
                }
                case Err(message) {
                    return Err(message)
                }
            }
        }
        case Err(message) {
            return Err(message)
        }
    }
}

func emitCheckedNegate(con program ir.Program, node int, con indent string, con env EmitEnv) Result[EmittedExpr, string] {
    if ir.NodeChildCount(con program, node) != 1 {
        return Err("B3 C backend received malformed checked negate IR")
    }
    match emitExpression(con program, ir.NodeChild(con program, node, 0), con indent, con env) {
        case Ok(operand) {
            start := strings.fromInt(source.Start(con ir.NodeSpan(con program, node)))
            operandName := strings.join(con []string{"mallang_checked_unary_operand_", token.CopyText(con start),}, con "")
            resultName := strings.join(con []string{"mallang_checked_unary_result_", token.CopyText(con start),}, con "")
            mut lines := copyLines([]string{}, con operand.lines)
            lines = append(lines, strings.join(con []string{token.CopyText(con indent), "int64_t ", token.CopyText(con operandName), " = ", token.CopyText(con operand.value), ";",}, con ""))
            lines = append(lines, strings.join(con []string{token.CopyText(con indent), "int64_t ", token.CopyText(con resultName), ";",}, con ""))
            lines = append(lines, strings.join(con []string{token.CopyText(con indent), "if (__builtin_sub_overflow((int64_t)0, ", token.CopyText(con operandName), ", &", token.CopyText(con resultName), ")) {",}, con ""))
            lines = append(lines, strings.join(con []string{token.CopyText(con indent), "    mallang_runtime_error(\"integer overflow\");",}, con ""))
            lines = append(lines, strings.join(con []string{token.CopyText(con indent), "}",}, con ""))
            return Ok(EmittedExpr{lines: lines, value: resultName, postLines: operand.postLines,})
        }
        case Err(message) {
            return Err(message)
        }
    }
}

func emitCheckedDivision(con program ir.Program, node int, con indent string, con operator string, con env EmitEnv) Result[EmittedExpr, string] {
    if ir.NodeChildCount(con program, node) != 2 {
        return Err("B3 C backend received malformed checked division IR")
    }
    match emitExpression(con program, ir.NodeChild(con program, node, 0), con indent, con env) {
        case Ok(left) {
            match emitExpression(con program, ir.NodeChild(con program, node, 1), con indent, con env) {
                case Ok(right) {
                    suffix := spanSuffix(con program, node)
                    leftName := strings.join(con []string{"mallang_checked_left_", token.CopyText(con suffix),}, con "")
                    rightName := strings.join(con []string{"mallang_checked_right_", token.CopyText(con suffix),}, con "")
                    dividendName := strings.join(con []string{"mallang_dividend_", token.CopyText(con suffix),}, con "")
                    divisorName := strings.join(con []string{"mallang_divisor_", token.CopyText(con suffix),}, con "")
                    mut lines := copyLines([]string{}, con left.lines)
                    lines = append(lines, strings.join(con []string{token.CopyText(con indent), "int64_t ", token.CopyText(con leftName), " = ", token.CopyText(con left.value), ";",}, con ""))
                    lines = copyLines(lines, con left.postLines)
                    lines = copyLines(lines, con right.lines)
                    lines = append(lines, strings.join(con []string{token.CopyText(con indent), "int64_t ", token.CopyText(con rightName), " = ", token.CopyText(con right.value), ";",}, con ""))
                    lines = copyLines(lines, con right.postLines)
                    lines = append(lines, strings.join(con []string{token.CopyText(con indent), "int64_t ", token.CopyText(con dividendName), " = ", token.CopyText(con leftName), ";",}, con ""))
                    lines = append(lines, strings.join(con []string{token.CopyText(con indent), "int64_t ", token.CopyText(con divisorName), " = ", token.CopyText(con rightName), ";",}, con ""))
                    lines = append(lines, strings.join(con []string{token.CopyText(con indent), "if (", token.CopyText(con divisorName), " == 0) {",}, con ""))
                    lines = append(lines, strings.join(con []string{token.CopyText(con indent), "    mallang_runtime_error(\"division by zero\");",}, con ""))
                    lines = append(lines, strings.join(con []string{token.CopyText(con indent), "}",}, con ""))
                    lines = append(lines, strings.join(con []string{token.CopyText(con indent), "if (", token.CopyText(con dividendName), " == INT64_MIN && ", token.CopyText(con divisorName), " == -1) {",}, con ""))
                    lines = append(lines, strings.join(con []string{token.CopyText(con indent), "    mallang_runtime_error(\"integer overflow\");",}, con ""))
                    lines = append(lines, strings.join(con []string{token.CopyText(con indent), "}",}, con ""))
                    value := strings.join(con []string{"(", token.CopyText(con dividendName), " ", token.CopyText(con operator), " ", token.CopyText(con divisorName), ")",}, con "")
                    return Ok(EmittedExpr{lines: lines, value: value, postLines: []string{},})
                }
                case Err(message) {
                    return Err(message)
                }
            }
        }
        case Err(message) {
            return Err(message)
        }
    }
}

func emitStringEquality(con program ir.Program, node int, con indent string, con env EmitEnv) Result[EmittedExpr, string] {
    leftNode := ir.NodeChild(con program, node, 0)
    rightNode := ir.NodeChild(con program, node, 1)
    match emitExpression(con program, leftNode, con indent, con env) {
        case Ok(left) {
            match emitExpression(con program, rightNode, con indent, con env) {
                case Ok(right) {
                    suffix := spanSuffix(con program, node)
                    leftName := strings.join(con []string{"mallang_checked_left_", token.CopyText(con suffix),}, con "")
                    rightName := strings.join(con []string{"mallang_checked_right_", token.CopyText(con suffix),}, con "")
                    resultName := strings.join(con []string{"mallang_checked_result_", token.CopyText(con suffix),}, con "")
                    mut lines := copyLines([]string{}, con left.lines)
                    lines = append(lines, strings.join(con []string{token.CopyText(con indent), "mlg_String ", token.CopyText(con leftName), " = ", token.CopyText(con left.value), ";",}, con ""))
                    lines = copyLines(lines, con right.lines)
                    lines = append(lines, strings.join(con []string{token.CopyText(con indent), "mlg_String ", token.CopyText(con rightName), " = ", token.CopyText(con right.value), ";",}, con ""))
                    mut comparison := strings.join(con []string{"(mallang_string_equal(", token.CopyText(con leftName), ", ", token.CopyText(con rightName), "))",}, con "")
                    if ir.NodeKind(con program, node) == "Expr.Binary.NotEqual" {
                        comparison = strings.join(con []string{"(!mallang_string_equal(", token.CopyText(con leftName), ", ", token.CopyText(con rightName), "))",}, con "")
                    }
                    lines = append(lines, strings.join(con []string{token.CopyText(con indent), "bool ", token.CopyText(con resultName), " = ", comparison, ";",}, con ""))
                    lines = copyLines(lines, con right.postLines)
                    lines = copyLines(lines, con left.postLines)
                    return Ok(EmittedExpr{lines: lines, value: resultName, postLines: []string{},})
                }
                case Err(message) {
                    return Err(message)
                }
            }
        }
        case Err(message) {
            return Err(message)
        }
    }
}

func emitBinary(con program ir.Program, node int, con indent string, con env EmitEnv) Result[EmittedExpr, string] {
    kind := ir.NodeKind(con program, node)
    if kind == "Expr.Binary.Add" {
        return emitCheckedBinary(con program, node, con indent, con "__builtin_add_overflow", con env)
    }
    if kind == "Expr.Binary.Subtract" {
        return emitCheckedBinary(con program, node, con indent, con "__builtin_sub_overflow", con env)
    }
    if kind == "Expr.Binary.Multiply" {
        return emitCheckedBinary(con program, node, con indent, con "__builtin_mul_overflow", con env)
    }
    if kind == "Expr.Binary.Divide" {
        return emitCheckedDivision(con program, node, con indent, con "/", con env)
    }
    if kind == "Expr.Binary.Remainder" {
        return emitCheckedDivision(con program, node, con indent, con "%", con env)
    }
    if ir.NodeChildCount(con program, node) != 2 {
        return Err("B3 C backend received malformed binary IR")
    }
    if ir.NodeType(con program, ir.NodeChild(con program, node, 0)) == "string" &&(kind == "Expr.Binary.Equal" || kind == "Expr.Binary.NotEqual") {
        return emitStringEquality(con program, node, con indent, con env)
    }
    match emitExpression(con program, ir.NodeChild(con program, node, 0), con indent, con env) {
        case Ok(left) {
            match emitExpression(con program, ir.NodeChild(con program, node, 1), con indent, con env) {
                case Ok(right) {
                    mut operator := ""
                    if kind == "Expr.Binary.Equal" {
                        operator = "=="
                    } else if kind == "Expr.Binary.NotEqual" {
                        operator = "!="
                    } else if kind == "Expr.Binary.Less" {
                        operator = "<"
                    } else if kind == "Expr.Binary.LessEqual" {
                        operator = "<="
                    } else if kind == "Expr.Binary.Greater" {
                        operator = ">"
                    } else if kind == "Expr.Binary.GreaterEqual" {
                        operator = ">="
                    } else if kind == "Expr.Binary.LogicalAnd" {
                        operator = "&&"
                    } else if kind == "Expr.Binary.LogicalOr" {
                        operator = "||"
                    } else {
                        return Err(unsupported(con kind))
                    }
                    if len(left.lines) == 0 && len(left.postLines) == 0 && len(right.lines) == 0 && len(right.postLines) == 0 {
                        value := strings.join(con []string{"(", token.CopyText(con left.value), " ", token.CopyText(con operator), " ", token.CopyText(con right.value), ")",}, con "")
                        return Ok(EmittedExpr{lines: []string{}, value: value, postLines: []string{},})
                    }
                    operandType := cTypeFor(con program, con ir.NodeType(con program, ir.NodeChild(con program, node, 0)))
                    if operandType == "" || operandType == "void" {
                        return Err(unsupported(con ir.NodeType(con program, ir.NodeChild(con program, node, 0))))
                    }
                    suffix := spanSuffix(con program, node)
                    leftName := strings.join(con []string{"mallang_checked_left_", token.CopyText(con suffix),}, con "")
                    rightName := strings.join(con []string{"mallang_checked_right_", token.CopyText(con suffix),}, con "")
                    mut lines := copyLines([]string{}, con left.lines)
                    lines = append(lines, strings.join(con []string{token.CopyText(con indent), token.CopyText(con operandType), " ", token.CopyText(con leftName), " = ", token.CopyText(con left.value), ";",}, con ""))
                    lines = copyLines(lines, con left.postLines)
                    if kind == "Expr.Binary.LogicalAnd" || kind == "Expr.Binary.LogicalOr" {
                        resultName := strings.join(con []string{"mallang_logical_", token.CopyText(con suffix),}, con "")
                        lines = append(lines, strings.join(con []string{token.CopyText(con indent), "bool ", token.CopyText(con resultName), " = ", stripOuterParens(con leftName), ";",}, con ""))
                        mut condition := token.CopyText(con resultName)
                        if kind == "Expr.Binary.LogicalOr" {
                            condition = strings.join(con []string{"!", token.CopyText(con resultName),}, con "")
                        }
                        lines = append(lines, strings.join(con []string{token.CopyText(con indent), "if (", token.CopyText(con condition), ") {",}, con ""))
                        for mut line := 0; line < len(right.lines); line = line + 1 {
                            lines = append(lines, strings.join(con []string{"    ", token.CopyText(con right.lines[line]),}, con ""))
                        }
                        lines = append(lines, strings.join(con []string{token.CopyText(con indent), "    ", token.CopyText(con resultName), " = ", stripOuterParens(con right.value), ";",}, con ""))
                        for mut line := 0; line < len(right.postLines); line = line + 1 {
                            lines = append(lines, strings.join(con []string{"    ", token.CopyText(con right.postLines[line]),}, con ""))
                        }
                        lines = append(lines, strings.join(con []string{token.CopyText(con indent), "}",}, con ""))
                        return Ok(EmittedExpr{lines: copyLines([]string{}, con lines), value: resultName, postLines: []string{},})
                    }
                    lines = copyLines(lines, con right.lines)
                    lines = append(lines, strings.join(con []string{token.CopyText(con indent), token.CopyText(con operandType), " ", token.CopyText(con rightName), " = ", token.CopyText(con right.value), ";",}, con ""))
                    lines = copyLines(lines, con right.postLines)
                    value := strings.join(con []string{"(", token.CopyText(con leftName), " ", token.CopyText(con operator), " ", token.CopyText(con rightName), ")",}, con "")
                    return Ok(EmittedExpr{lines: lines, value: value, postLines: []string{},})
                }
                case Err(message) {
                    return Err(message)
                }
            }
        }
        case Err(message) {
            return Err(message)
        }
    }
}

func emitArrayLiteral(con program ir.Program, node int, con indent string, con env EmitEnv) Result[EmittedExpr, string] {
    ty := ir.NodeType(con program, node)
    kind := typeKind(con program, con ty)
    if kind == "array" {
        shape := typeShapeIndex(con program, con ty)
        length := ir.TypeShapeArrayLength(con program, shape)
        if ir.NodeChildCount(con program, node) != length {
            return Err("B3 C backend received an array literal length mismatch")
        }
        mut lines := []string{}
        mut values := []string{}
        mut postLines := []string{}
        for mut child := 0; child < ir.NodeChildCount(con program, node); child = child + 1 {
            match emitExpression(con program, ir.NodeChild(con program, node, child), con indent, con env) {
                case Ok(emitted) {
                    lines = copyLines(lines, con emitted.lines)
                    values = append(values, token.CopyText(con emitted.value))
                    postLines = copyLines(emitted.postLines, con postLines)
                }
                case Err(message) {
                    return Err(message)
                }
            }
        }
        mut value := strings.join(con []string{"(", cTypeFor(con program, con ty), "){ .mlg_empty = 0 }",}, con "")
        if length > 0 {
            value = strings.join(con []string{"(", cTypeFor(con program, con ty), "){ .mlg_data = { ", strings.join(con values, con ", "), " } }",}, con "")
        }
        return Ok(EmittedExpr{lines: copyLines([]string{}, con lines), value: value, postLines: copyLines([]string{}, con postLines),})
    }
    if kind == "slice" {
        temp := strings.join(con []string{"mallang_slice_tmp_", strings.fromInt(source.Start(con ir.NodeSpan(con program, node))),}, con "")
        element := typeArgument(con program, con ty, 0)
        elementType := cTypeFor(con program, con element)
        count := ir.NodeChildCount(con program, node)
        mut lines := []string{strings.join(con []string{token.CopyText(con indent), cTypeFor(con program, con ty), " ", token.CopyText(con temp), ";",}, con ""),}
        if count == 0 {
            lines = append(lines, strings.join(con []string{token.CopyText(con indent), token.CopyText(con temp), ".mlg_data = NULL;",}, con ""))
            lines = append(lines, strings.join(con []string{token.CopyText(con indent), token.CopyText(con temp), ".mlg_len = 0;",}, con ""))
            lines = append(lines, strings.join(con []string{token.CopyText(con indent), token.CopyText(con temp), ".mlg_cap = 0;",}, con ""))
            return Ok(EmittedExpr{lines: lines, value: temp, postLines: []string{},})
        } else {
            lines = append(lines, strings.join(con []string{token.CopyText(con indent), "if ((uint64_t)", strings.fromInt(count), " > UINT64_MAX / sizeof(", token.CopyText(con elementType), ")) {",}, con ""))
            lines = append(lines, strings.join(con []string{token.CopyText(con indent), "    mallang_runtime_error(\"slice allocation size overflow\");",}, con ""))
            lines = append(lines, strings.join(con []string{token.CopyText(con indent), "}",}, con ""))
            lines = append(lines, strings.join(con []string{token.CopyText(con indent), token.CopyText(con temp), ".mlg_data = mallang_alloc(sizeof(", token.CopyText(con elementType), ") * ", strings.fromInt(count), ", \"slice allocation failed\");",}, con ""))
            lines = append(lines, strings.join(con []string{token.CopyText(con indent), token.CopyText(con temp), ".mlg_len = ", strings.fromInt(count), ";",}, con ""))
            lines = append(lines, strings.join(con []string{token.CopyText(con indent), token.CopyText(con temp), ".mlg_cap = ", strings.fromInt(count), ";",}, con ""))
            mut postLines := []string{}
            for mut child := 0; child < count; child = child + 1 {
                match emitExpression(con program, ir.NodeChild(con program, node, child), con indent, con env) {
                    case Ok(emitted) {
                        lines = copyLines(lines, con emitted.lines)
                        lines = append(lines, strings.join(con []string{token.CopyText(con indent), token.CopyText(con temp), ".mlg_data[", strings.fromInt(child), "] = ", token.CopyText(con emitted.value), ";",}, con ""))
                        postLines = copyLines(emitted.postLines, con postLines)
                    }
                    case Err(message) {
                        return Err(message)
                    }
                }
            }
            return Ok(EmittedExpr{lines: lines, value: temp, postLines: postLines,})
        }
    }
    return Err("B3 C backend received an array literal without an array or slice type")
}

func emitStructLiteral(con program ir.Program, node int, con indent string, con env EmitEnv) Result[EmittedExpr, string] {
    mut lines := []string{}
    mut fields := []string{}
    mut postLines := []string{}
    for mut child := 0; child < ir.NodeChildCount(con program, node); child = child + 1 {
        field := ir.NodeChild(con program, node, child)
        if ir.NodeKind(con program, field) != "Field.Value" || ir.NodeChildCount(con program, field) != 1 {
            return Err("B3 C backend received malformed struct literal IR")
        }
        match emitExpression(con program, ir.NodeChild(con program, field, 0), con indent, con env) {
            case Ok(emitted) {
                lines = copyLines(lines, con emitted.lines)
                fields = append(fields, strings.join(con []string{".", cField(con ir.NodeValue(con program, field)), " = ", token.CopyText(con emitted.value),}, con ""))
                postLines = copyLines(emitted.postLines, con postLines)
            }
            case Err(message) {
                return Err(message)
            }
        }
    }
    value := strings.join(con []string{"(", cTypeFor(con program, con ir.NodeType(con program, node)), "){ ", strings.join(con fields, con ", "), " }",}, con "")
    return Ok(EmittedExpr{lines: lines, value: value, postLines: postLines,})
}

func emitVariantConstructor(con program ir.Program, node int, con indent string, con env EmitEnv) Result[EmittedExpr, string] {
    kind := ir.NodeKind(con program, node)
    mut storage := ""
    if kind == "Expr.VariantConstructor.Inline" {
        storage = "inline"
    } else if kind == "Expr.VariantConstructor.Owned" {
        storage = "owned"
    } else {
        return Err("B3 C backend received malformed ADT constructor IR")
    }
    ty := ir.NodeType(con program, node)
    variant := ir.NodeValue(con program, node)
    if adtStorage(con program, con ty) != storage {
        return Err("B3 C backend received an ADT constructor storage mismatch")
    }
    tag := adtVariantTag(con program, con ty, con variant)
    payloadCount := adtVariantPayloadCount(con program, con ty, con variant)
    if tag < 0 || payloadCount < 0 || payloadCount != ir.NodeChildCount(con program, node) {
        return Err("B3 C backend received an ADT constructor payload mismatch")
    }

    mut lines := []string{}
    mut payloads := []string{}
    mut postLines := []string{}
    for mut payload := 0; payload < payloadCount; payload = payload + 1 {
        child := ir.NodeChild(con program, node, payload)
        if ir.NodeType(con program, child) != adtVariantPayloadType(con program, con ty, con variant, payload) {
            return Err("B3 C backend received an ADT constructor payload type mismatch")
        }
        match emitExpression(con program, child, con indent, con env) {
            case Ok(emitted) {
                lines = copyLines(lines, con emitted.lines)
                temp := strings.join(con []string{"mallang_variant_payload_", spanSuffix(con program, node), "_", strings.fromInt(payload),}, con "")
                lines = append(lines, strings.join(con []string{token.CopyText(con indent), cTypeFor(con program, con ir.NodeType(con program, child)), " ", token.CopyText(con temp), " = ", token.CopyText(con emitted.value), ";",}, con ""))
                payloads = append(payloads, temp)
                postLines = copyLines(emitted.postLines, con postLines)
            }
            case Err(message) {
                return Err(message)
            }
        }
    }

    if storage == "inline" {
        mut payloadInitializer := ""
        if payloadCount == 1 {
            payloadInitializer = strings.join(con []string{", .", cField(con "payload"), " = { .", cField(con variant), " = ", token.CopyText(con payloads[0]), " }",}, con "")
        } else if payloadCount > 1 {
            mut fields := []string{}
            for mut payload := 0; payload < payloadCount; payload = payload + 1 {
                fields = append(fields, strings.join(con []string{".", variantPayloadField(payload), " = ", token.CopyText(con payloads[payload]),}, con ""))
            }
            payloadInitializer = strings.join(con []string{", .", cField(con "payload"), " = { .", cField(con variant), " = { ", strings.join(con fields, con ", "), " } }",}, con "")
        }
        value := strings.join(con []string{"(", cTypeFor(con program, con ty), "){ .tag = ", strings.fromInt(tag), token.CopyText(con payloadInitializer), " }",}, con "")
        return Ok(EmittedExpr{lines: copyLines([]string{}, con lines), value: value, postLines: copyLines([]string{}, con postLines),})
    }

    temp := strings.join(con []string{"mallang_variant_tmp_", spanSuffix(con program, node),}, con "")
    nodeValue := strings.join(con []string{token.CopyText(con temp), ".", cField(con "node"),}, con "")
    lines = append(lines, strings.join(con []string{token.CopyText(con indent), cTypeFor(con program, con ty), " ", token.CopyText(con temp), ";",}, con ""))
    lines = append(lines, strings.join(con []string{token.CopyText(con indent), token.CopyText(con nodeValue), " = mallang_alloc(sizeof(*", token.CopyText(con nodeValue), "), \"recursive enum allocation failed\");",}, con ""))
    lines = append(lines, strings.join(con []string{token.CopyText(con indent), token.CopyText(con nodeValue), "->tag = ", strings.fromInt(tag), ";",}, con ""))
    for mut payload := 0; payload < payloadCount; payload = payload + 1 {
        lines = append(lines, strings.join(con []string{token.CopyText(con indent), token.CopyText(con nodeValue), "->", variantPayloadMember(con variant, payloadCount, payload), " = ", token.CopyText(con payloads[payload]), ";",}, con ""))
    }
    return Ok(EmittedExpr{lines: lines, value: temp, postLines: postLines,})
}

func emitFieldAccess(con program ir.Program, node int, con indent string, con env EmitEnv) Result[EmittedExpr, string] {
    if ir.NodeChildCount(con program, node) != 1 {
        return Err("B3 C backend received malformed field access IR")
    }
    match emitExpression(con program, ir.NodeChild(con program, node, 0), con indent, con env) {
        case Ok(base) {
            return Ok(EmittedExpr{lines: base.lines, value: strings.join(con []string{"(", token.CopyText(con base.value), ").", cField(con ir.NodeValue(con program, node)),}, con ""), postLines: base.postLines,})
        }
        case Err(message) {
            return Err(message)
        }
    }
}

func emitIndex(con program ir.Program, node int, con indent string, con env EmitEnv) Result[EmittedExpr, string] {
    if ir.NodeChildCount(con program, node) != 2 {
        return Err("B3 C backend received malformed index IR")
    }
    baseNode := ir.NodeChild(con program, node, 0)
    indexNode := ir.NodeChild(con program, node, 1)
    match emitExpression(con program, baseNode, con indent, con env) {
        case Ok(base) {
            match emitExpression(con program, indexNode, con indent, con env) {
                case Ok(index) {
                    suffix := spanSuffix(con program, node)
                    sourceTemp := strings.join(con []string{"mallang_index_src_", token.CopyText(con suffix),}, con "")
                    indexTemp := strings.join(con []string{"mallang_index_value_", token.CopyText(con suffix),}, con "")
                    mut lines := copyLines([]string{}, con base.lines)
                    lines = append(lines, strings.join(con []string{token.CopyText(con indent), cTypeFor(con program, con ir.NodeType(con program, baseNode)), " ", token.CopyText(con sourceTemp), " = ", token.CopyText(con base.value), ";",}, con ""))
                    lines = copyLines(lines, con index.lines)
                    lines = append(lines, strings.join(con []string{token.CopyText(con indent), "int64_t ", token.CopyText(con indexTemp), " = ", token.CopyText(con index.value), ";",}, con ""))
                    kind := typeKind(con program, con ir.NodeType(con program, baseNode))
                    mut length := ""
                    mut message := ""
                    if kind == "array" {
                        shape := typeShapeIndex(con program, con ir.NodeType(con program, baseNode))
                        length = strings.fromInt(ir.TypeShapeArrayLength(con program, shape))
                        message = "array index out of bounds"
                    } else if kind == "slice" {
                        length = strings.join(con []string{"(", token.CopyText(con sourceTemp), ").mlg_len",}, con "")
                        message = "slice index out of bounds"
                    } else {
                        return Err("B3 C backend received an index base without an array or slice type")
                    }
                    lines = append(lines, strings.join(con []string{token.CopyText(con indent), "if (", token.CopyText(con indexTemp), " < 0 || ", token.CopyText(con indexTemp), " >= ", length, ") {",}, con ""))
                    lines = append(lines, strings.join(con []string{token.CopyText(con indent), "    mallang_runtime_error(\"", message, "\");",}, con ""))
                    lines = append(lines, strings.join(con []string{token.CopyText(con indent), "}",}, con ""))
                    mut postLines := copyLines([]string{}, con index.postLines)
                    postLines = copyLines(postLines, con base.postLines)
                    value := strings.join(con []string{"(", token.CopyText(con sourceTemp), ").mlg_data[", token.CopyText(con indexTemp), "]",}, con "")
                    return Ok(EmittedExpr{lines: lines, value: value, postLines: postLines,})
                }
                case Err(message) {
                    return Err(message)
                }
            }
        }
        case Err(message) {
            return Err(message)
        }
    }
}

func emitArrayLen(con program ir.Program, node int, con indent string, con env EmitEnv) Result[EmittedExpr, string] {
    if ir.NodeChildCount(con program, node) != 1 {
        return Err("B3 C backend received malformed len IR")
    }
    sourceNode := ir.NodeChild(con program, node, 0)
    match emitExpression(con program, sourceNode, con indent, con env) {
        case Ok(emitted) {
            kind := typeKind(con program, con ir.NodeType(con program, sourceNode))
            if kind == "array" {
                shape := typeShapeIndex(con program, con ir.NodeType(con program, sourceNode))
                mut lines := copyLines([]string{}, con emitted.lines)
                lines = append(lines, strings.join(con []string{token.CopyText(con indent), "(void)(", token.CopyText(con emitted.value), ");",}, con ""))
                return Ok(EmittedExpr{lines: lines, value: strings.fromInt(ir.TypeShapeArrayLength(con program, shape)), postLines: emitted.postLines,})
            }
            if kind == "slice" {
                return Ok(EmittedExpr{lines: emitted.lines, value: strings.join(con []string{"(", token.CopyText(con emitted.value), ").mlg_len",}, con ""), postLines: emitted.postLines,})
            }
            return Err("B3 C backend received len without an array or slice type")
        }
        case Err(message) {
            return Err(message)
        }
    }
}

func planPattern(con program ir.Program, pattern int, con expected string, con value string, bindingNode int, con current PatternPlan) Result[PatternPlan, string] {
    kind := ir.NodeKind(con program, pattern)
    if ir.NodeType(con program, pattern) != expected {
        return Err("B3 C backend received a match binding type mismatch")
    }
    mut plan := PatternPlan{conditions: copyLines([]string{}, con current.conditions), setup: copyLines([]string{}, con current.setup), env: copyEmitEnv(con current.env),}
    if kind == "Pattern.Wildcard" {
        return Ok(copyPatternPlan(con plan))
    }
    if kind == "Pattern.Binding" {
        name := ir.NodeValue(con program, pattern)
        binding := patternBindingName(con program, con name, bindingNode)
        plan.setup = append(plan.setup, strings.join(con []string{cTypeFor(con program, con expected), " ", token.CopyText(con binding), " = ", token.CopyText(con value), ";",}, con ""))
        plan.setup = append(plan.setup, strings.join(con []string{"(void)&", token.CopyText(con binding), ";",}, con ""))
        bindingEnv := envSet(con plan.env, con name, con binding)
        plan.env = envSet(con bindingEnv, con patternBindingEnvKey(con program, con name, bindingNode), con binding)
        return Ok(copyPatternPlan(con plan))
    }
    if kind != "Pattern.Variant.Inline" && kind != "Pattern.Variant.Owned" {
        return Err(unsupported(con kind))
    }
    mut storage := "inline"
    if kind == "Pattern.Variant.Owned" {
        storage = "owned"
    }
    if adtStorage(con program, con expected) != storage {
        return Err("B3 C backend received an ADT pattern storage mismatch")
    }
    variant := ir.NodeValue(con program, pattern)
    tag := adtVariantTag(con program, con expected, con variant)
    payloadCount := adtVariantPayloadCount(con program, con expected, con variant)
    if tag < 0 || payloadCount < 0 || payloadCount != ir.NodeChildCount(con program, pattern) {
        return Err("B3 C backend received an ADT pattern payload mismatch")
    }
    mut tagValue := strings.join(con []string{"(", token.CopyText(con value), ").tag",}, con "")
    mut ownedNode := ""
    if storage == "owned" {
        ownedNode = strings.join(con []string{"(", token.CopyText(con value), ").", cField(con "node"),}, con "")
        plan.conditions = append(plan.conditions, strings.join(con []string{"(", token.CopyText(con ownedNode), " != NULL || (mallang_runtime_error(\"invalid recursive enum handle\"), false))",}, con ""))
        tagValue = strings.join(con []string{token.CopyText(con ownedNode), "->tag",}, con "")
    }
    plan.conditions = append(plan.conditions, strings.join(con []string{token.CopyText(con tagValue), " == ", strings.fromInt(tag),}, con ""))
    for mut payload := 0; payload < payloadCount; payload = payload + 1 {
        payloadType := adtVariantPayloadType(con program, con expected, con variant, payload)
        mut payloadValue := strings.join(con []string{"(", token.CopyText(con value), ").", variantPayloadMember(con variant, payloadCount, payload),}, con "")
        if storage == "owned" {
            payloadValue = strings.join(con []string{token.CopyText(con ownedNode), "->", variantPayloadMember(con variant, payloadCount, payload),}, con "")
        }
        match planPattern(con program, ir.NodeChild(con program, pattern, payload), con payloadType, con payloadValue, bindingNode, con plan) {
            case Ok(nested) {
                plan = nested
            }
            case Err(message) {
                return Err(message)
            }
        }
    }
    if storage == "owned" {
        plan.setup = append(plan.setup, strings.join(con []string{"mallang_dealloc(", token.CopyText(con ownedNode), ");",}, con ""))
        plan.setup = append(plan.setup, strings.join(con []string{token.CopyText(con ownedNode), " = NULL;",}, con ""))
    }
    return Ok(plan)
}

func patternCondition(con plan PatternPlan) string {
    if len(plan.conditions) == 0 {
        return "true"
    }
    return strings.join(con plan.conditions, con " && ")
}

func emitMatchScrutinee(con program ir.Program, node int, con indent string, con env EmitEnv) Result[EmittedExpr, string] {
    if ir.NodeKind(con program, node) == "Expr.Var" {
        return Ok(EmittedExpr{lines: []string{}, value: envVariableName(con env, con ir.NodeValue(con program, node)), postLines: []string{},})
    }
    match emitExpression(con program, node, con indent, con env) {
        case Ok(emitted) {
            temp := strings.join(con []string{"mallang_match_tmp_", strings.fromInt(source.Start(con ir.NodeSpan(con program, node))),}, con "")
            mut lines := copyLines([]string{}, con emitted.lines)
            lines = append(lines, strings.join(con []string{token.CopyText(con indent), cTypeFor(con program, con ir.NodeType(con program, node)), " ", token.CopyText(con temp), " = ", token.CopyText(con emitted.value), ";",}, con ""))
            lines = copyLines(lines, con emitted.postLines)
            return Ok(EmittedExpr{lines: lines, value: temp, postLines: []string{},})
        }
        case Err(message) {
            return Err(message)
        }
    }
}

func emitMatchExpression(con program ir.Program, node int, con indent string, con env EmitEnv) Result[EmittedExpr, string] {
    if ir.NodeChildCount(con program, node) < 2 {
        return Err("B3 C backend received a match expression without arms")
    }
    scrutineeNode := ir.NodeChild(con program, node, 0)
    scrutineeType := ir.NodeType(con program, scrutineeNode)
    kind := typeKind(con program, con scrutineeType)
    if kind != "option" && kind != "result" && kind != "enum" {
        return Err("B3 C backend received a match on a non-ADT value")
    }
    match emitMatchScrutinee(con program, scrutineeNode, con indent, con env) {
        case Ok(scrutinee) {
            mut lines := copyLines([]string{}, con scrutinee.lines)
            temp := strings.join(con []string{"mallang_match_value_tmp_", strings.fromInt(source.Start(con ir.NodeSpan(con program, node))),}, con "")
            lines = append(lines, strings.join(con []string{token.CopyText(con indent), cTypeFor(con program, con ir.NodeType(con program, node)), " ", token.CopyText(con temp), ";",}, con ""))
            nestedIndent := strings.join(con []string{token.CopyText(con indent), "    ",}, con "")
            for mut armIndex := 1; armIndex < ir.NodeChildCount(con program, node); armIndex = armIndex + 1 {
                arm := ir.NodeChild(con program, node, armIndex)
                if ir.NodeKind(con program, arm) != "Match.Arm" || ir.NodeChildCount(con program, arm) < 2 {
                    return Err("B3 C backend received malformed match expression arm IR")
                }
                pattern := ir.NodeChild(con program, arm, 0)
                branch := ir.NodeChild(con program, arm, 1)
                initial := PatternPlan{conditions: []string{}, setup: []string{}, env: copyEmitEnv(con env),}
                match planPattern(con program, pattern, con scrutineeType, con scrutinee.value, arm, con initial) {
                    case Ok(plan) {
                        mut prefix := "if ("
                        if armIndex > 1 {
                            prefix = "} else if ("
                        }
                        lines = append(lines, strings.join(con []string{token.CopyText(con indent), prefix, patternCondition(con plan), ") {",}, con ""))
                        for mut setup := 0; setup < len(plan.setup); setup = setup + 1 {
                            lines = append(lines, strings.join(con []string{token.CopyText(con nestedIndent), token.CopyText(con plan.setup[setup]),}, con ""))
                        }
                        match emitExpression(con program, branch, con nestedIndent, con plan.env) {
                            case Ok(emitted) {
                                lines = copyLines(lines, con emitted.lines)
                                lines = append(lines, strings.join(con []string{token.CopyText(con nestedIndent), token.CopyText(con temp), " = ", token.CopyText(con emitted.value), ";",}, con ""))
                                lines = copyLines(lines, con emitted.postLines)
                            }
                            case Err(message) {
                                return Err(message)
                            }
                        }
                        for mut cleanup := 2; cleanup < ir.NodeChildCount(con program, arm); cleanup = cleanup + 1 {
                            match emitStatement(con program, ir.NodeChild(con program, arm, cleanup), con nestedIndent, con plan.env) {
                                case Ok(emitted) {
                                    lines = copyLines(lines, con emitted)
                                }
                                case Err(message) {
                                    return Err(message)
                                }
                            }
                        }
                    }
                    case Err(message) {
                        return Err(message)
                    }
                }
            }
            lines = append(lines, strings.join(con []string{token.CopyText(con indent), "} else {",}, con ""))
            lines = append(lines, strings.join(con []string{token.CopyText(con nestedIndent), "mallang_runtime_error(\"invalid enum tag\");",}, con ""))
            lines = append(lines, strings.join(con []string{token.CopyText(con indent), "}",}, con ""))
            return Ok(EmittedExpr{lines: lines, value: temp, postLines: []string{},})
        }
        case Err(message) {
            return Err(message)
        }
    }
}

func emitIfExpression(con program ir.Program, node int, con indent string, con env EmitEnv) Result[EmittedExpr, string] {
    childCount := ir.NodeChildCount(con program, node)
    if childCount != 3 && childCount != 5 {
        return Err("B3 C backend received malformed if expression IR")
    }
    conditionNode := ir.NodeChild(con program, node, 0)
    thenNode := ir.NodeChild(con program, node, 1)
    mut thenCleanup := -1
    mut elseNode := ir.NodeChild(con program, node, 2)
    mut elseCleanup := -1
    if childCount == 5 {
        thenCleanup = ir.NodeChild(con program, node, 2)
        elseNode = ir.NodeChild(con program, node, 3)
        elseCleanup = ir.NodeChild(con program, node, 4)
    }
    nestedIndent := strings.join(con []string{token.CopyText(con indent), "    ",}, con "")
    match emitExpression(con program, conditionNode, con indent, con env) {
        case Ok(condition) {
            match emitExpression(con program, thenNode, con nestedIndent, con env) {
                case Ok(thenBranch) {
                    match emitExpression(con program, elseNode, con nestedIndent, con env) {
                        case Ok(elseBranch) {
                            mut lines := copyLines([]string{}, con condition.lines)
                            mut conditionValue := token.CopyText(con condition.value)
                            if len(condition.postLines) > 0 {
                                conditionTemp := strings.join(con []string{"mallang_if_condition_", spanSuffix(con program, node),}, con "")
                                lines = append(lines, strings.join(con []string{token.CopyText(con indent), "bool ", token.CopyText(con conditionTemp), " = ", token.CopyText(con conditionValue), ";",}, con ""))
                                lines = copyLines(lines, con condition.postLines)
                                conditionValue = conditionTemp
                            }
                            mut thenCleanupCount := 0
                            mut elseCleanupCount := 0
                            if thenCleanup >= 0 {
                                thenCleanupCount = ir.NodeChildCount(con program, thenCleanup)
                            }
                            if elseCleanup >= 0 {
                                elseCleanupCount = ir.NodeChildCount(con program, elseCleanup)
                            }
                            if len(thenBranch.lines) == 0 && len(thenBranch.postLines) == 0 && len(elseBranch.lines) == 0 && len(elseBranch.postLines) == 0 && thenCleanupCount == 0 && elseCleanupCount == 0 {
                                value := strings.join(con []string{"((", token.CopyText(con conditionValue), ") ? (", token.CopyText(con thenBranch.value), ") : (", token.CopyText(con elseBranch.value), "))",}, con "")
                                return Ok(EmittedExpr{lines: copyLines([]string{}, con lines), value: value, postLines: []string{},})
                            }

                            temp := strings.join(con []string{"mallang_if_tmp_", strings.fromInt(source.Start(con ir.NodeSpan(con program, node))),}, con "")
                            lines = append(lines, strings.join(con []string{token.CopyText(con indent), cTypeFor(con program, con ir.NodeType(con program, node)), " ", token.CopyText(con temp), ";",}, con ""))
                            lines = append(lines, strings.join(con []string{token.CopyText(con indent), "if (", stripOuterParens(con conditionValue), ") {",}, con ""))
                            lines = copyLines(lines, con thenBranch.lines)
                            lines = append(lines, strings.join(con []string{token.CopyText(con nestedIndent), token.CopyText(con temp), " = ", token.CopyText(con thenBranch.value), ";",}, con ""))
                            lines = copyLines(lines, con thenBranch.postLines)
                            if thenCleanup >= 0 {
                                match emitBlock(con program, thenCleanup, con nestedIndent, con env) {
                                    case Ok(cleanup) {
                                        lines = copyLines(lines, con cleanup)
                                    }
                                    case Err(message) {
                                        return Err(message)
                                    }
                                }
                            }
                            lines = append(lines, strings.join(con []string{token.CopyText(con indent), "} else {",}, con ""))
                            lines = copyLines(lines, con elseBranch.lines)
                            lines = append(lines, strings.join(con []string{token.CopyText(con nestedIndent), token.CopyText(con temp), " = ", token.CopyText(con elseBranch.value), ";",}, con ""))
                            lines = copyLines(lines, con elseBranch.postLines)
                            if elseCleanup >= 0 {
                                match emitBlock(con program, elseCleanup, con nestedIndent, con env) {
                                    case Ok(cleanup) {
                                        lines = copyLines(lines, con cleanup)
                                    }
                                    case Err(message) {
                                        return Err(message)
                                    }
                                }
                            }
                            lines = append(lines, strings.join(con []string{token.CopyText(con indent), "}",}, con ""))
                            return Ok(EmittedExpr{lines: lines, value: temp, postLines: []string{},})
                        }
                        case Err(message) {
                            return Err(message)
                        }
                    }
                }
                case Err(message) {
                    return Err(message)
                }
            }
        }
        case Err(message) {
            return Err(message)
        }
    }
}

func emitExpression(con program ir.Program, node int, con indent string, con env EmitEnv) Result[EmittedExpr, string] {
    kind := ir.NodeKind(con program, node)
    if kind == "Expr.Int" || kind == "Expr.Bool" {
        return Ok(EmittedExpr{lines: []string{}, value: ir.NodeValue(con program, node), postLines: []string{},})
    }
    if kind == "Expr.String" {
        return Ok(EmittedExpr{lines: []string{}, value: cStringValue(con ir.NodeValue(con program, node)), postLines: []string{},})
    }
    if kind == "Expr.Var" {
        return Ok(EmittedExpr{lines: []string{}, value: envVariableName(con env, con ir.NodeValue(con program, node)), postLines: []string{},})
    }
    if kind == "Expr.FunctionValue" {
        return emitFunctionValue(con program, node)
    }
    if kind == "Expr.FullExprTemporary" {
        if ir.NodeChildCount(con program, node) != 1 {
            return Err("B3 C backend received malformed full-expression temporary IR")
        }
        match emitExpression(con program, ir.NodeChild(con program, node, 0), con indent, con env) {
            case Ok(emitted) {
                ty := cTypeFor(con program, con ir.NodeType(con program, node))
                if ty == "" || ty == "void" {
                    return Err(unsupported(con ir.NodeType(con program, node)))
                }
                name := cVariableName(con ir.NodeValue(con program, node))
                mut lines := copyLines([]string{}, con emitted.lines)
                lines = append(lines, strings.join(con []string{token.CopyText(con indent), ty, " ", token.CopyText(con name), " = ", token.CopyText(con emitted.value), ";",}, con ""))
                mut postLines := []string{}
                if ir.NodeNeedsCleanup(con program, node) {
                    match dropLine(con program, con ir.NodeType(con program, node), con name, con indent) {
                        case Ok(line) {
                            postLines = append(postLines, line)
                        }
                        case Err(message) {
                            return Err(message)
                        }
                    }
                }
                postLines = copyLines(postLines, con emitted.postLines)
                return Ok(EmittedExpr{lines: lines, value: name, postLines: postLines,})
            }
            case Err(message) {
                return Err(message)
            }
        }
    }
    if kind == "Expr.Call" {
        return emitCall(con program, node, con indent, con env)
    }
    if kind == "Expr.IndirectCall" {
        return emitIndirectCall(con program, node, con indent, con env)
    }
    if kind == "Expr.IntrinsicCall" {
        return emitIntrinsicCall(con program, node, con indent, con env)
    }
    if kind == "Expr.If" {
        return emitIfExpression(con program, node, con indent, con env)
    }
    if kind == "Expr.VariantConstructor.Inline" || kind == "Expr.VariantConstructor.Owned" {
        return emitVariantConstructor(con program, node, con indent, con env)
    }
    if kind == "Expr.Match" {
        return emitMatchExpression(con program, node, con indent, con env)
    }
    if kind == "Expr.ArrayLiteral" {
        return emitArrayLiteral(con program, node, con indent, con env)
    }
    if kind == "Expr.StructLiteral" {
        return emitStructLiteral(con program, node, con indent, con env)
    }
    if kind == "Expr.FieldAccess" {
        return emitFieldAccess(con program, node, con indent, con env)
    }
    if kind == "Expr.SliceFieldTake" {
        return emitSliceFieldTake(con program, node, con indent, con env)
    }
    if kind == "Expr.Index" {
        return emitIndex(con program, node, con indent, con env)
    }
    if kind == "Expr.ArrayLen" {
        return emitArrayLen(con program, node, con indent, con env)
    }
    if kind == "Expr.SliceAppend" {
        return emitSliceAppend(con program, node, con indent, con env)
    }
    if kind == "Expr.Unary.Negate" {
        return emitCheckedNegate(con program, node, con indent, con env)
    }
    if kind == "Expr.Unary.Not" {
        if ir.NodeChildCount(con program, node) != 1 {
            return Err("B3 C backend received malformed unary IR")
        }
        match emitExpression(con program, ir.NodeChild(con program, node, 0), con indent, con env) {
            case Ok(emitted) {
                return Ok(EmittedExpr{lines: emitted.lines, value: strings.join(con []string{"(!", token.CopyText(con emitted.value), ")",}, con ""), postLines: emitted.postLines,})
            }
            case Err(message) {
                return Err(message)
            }
        }
    }
    if kind == "Expr.Binary.Add" || kind == "Expr.Binary.Subtract" || kind == "Expr.Binary.Multiply" || kind == "Expr.Binary.Divide" || kind == "Expr.Binary.Remainder" || kind == "Expr.Binary.Equal" || kind == "Expr.Binary.NotEqual" || kind == "Expr.Binary.Less" || kind == "Expr.Binary.LessEqual" || kind == "Expr.Binary.Greater" || kind == "Expr.Binary.GreaterEqual" || kind == "Expr.Binary.LogicalAnd" || kind == "Expr.Binary.LogicalOr" {
        return emitBinary(con program, node, con indent, con env)
    }
    return Err(unsupported(con kind))
}

func emitPrint(con program ir.Program, call int, con indent string, con env EmitEnv) Result[[]string, string] {
    if ir.NodeChildCount(con program, call) != 1 {
        return Err("B3 C backend received malformed print IR")
    }
    argument := ir.NodeChild(con program, call, 0)
    if ir.NodeChildCount(con program, argument) != 1 {
        return Err("B3 C backend received malformed print argument IR")
    }
    match emitExpression(con program, ir.NodeChild(con program, argument, 0), con indent, con env) {
        case Ok(emitted) {
            mut lines := []string{}
            lines = copyLines(lines, con emitted.lines)
            ty := ir.NodeType(con program, argument)
            if ty == "int" {
                lines = append(lines, strings.join(con []string{token.CopyText(con indent), "printf(\"%lld\\n\", (long long)(", token.CopyText(con emitted.value), "));",}, con ""))
                lines = copyLines(lines, con emitted.postLines)
                return Ok(lines)
            } else if ty == "bool" {
                lines = append(lines, strings.join(con []string{token.CopyText(con indent), "printf(\"%s\\n\", (", token.CopyText(con emitted.value), ") ? \"true\" : \"false\");",}, con ""))
                lines = copyLines(lines, con emitted.postLines)
                return Ok(lines)
            } else if ty == "string" {
                lines = append(lines, strings.join(con []string{token.CopyText(con indent), "mallang_print_string(", token.CopyText(con emitted.value), ");",}, con ""))
                lines = append(lines, strings.join(con []string{token.CopyText(con indent), "printf(\"\\n\");",}, con ""))
                lines = copyLines(lines, con emitted.postLines)
                return Ok(lines)
            } else {
                return Err(unsupported(con strings.join(con []string{"print ", ty,}, con "")))
            }
        }
        case Err(message) {
            return Err(message)
        }
    }
}

func emitBlockWithContinue(con program ir.Program, block int, con indent string, con env EmitEnv, con continueLabel string) Result[[]string, string] {
    if ir.NodeCategory(con program, block) != "B" {
        return Err("B3 C backend received malformed block IR")
    }
    mut lines := []string{}
    for mut child := 0; child < ir.NodeChildCount(con program, block); child = child + 1 {
        match emitStatementWithContinue(con program, ir.NodeChild(con program, block, child), con indent, con env, con continueLabel) {
            case Ok(emitted) {
                lines = copyLines(lines, con emitted)
            }
            case Err(message) {
                return Err(message)
            }
        }
    }
    return Ok(lines)
}

func emitBlock(con program ir.Program, block int, con indent string, con env EmitEnv) Result[[]string, string] {
    return emitBlockWithContinue(con program, block, con indent, con env, con "")
}

func emitIfWithContinue(con program ir.Program, node int, con indent string, con env EmitEnv, con continueLabel string) Result[[]string, string] {
    if ir.NodeChildCount(con program, node) != 3 {
        return Err("B3 C backend received malformed if IR")
    }
    condition := ir.NodeChild(con program, node, 0)
    thenBlock := ir.NodeChild(con program, node, 1)
    elseBlock := ir.NodeChild(con program, node, 2)
    if ir.NodeKind(con program, thenBlock) != "Block.Then" || ir.NodeKind(con program, elseBlock) != "Block.Else" {
        return Err("B3 C backend received malformed if blocks")
    }
    match emitExpression(con program, condition, con indent, con env) {
        case Ok(emitted) {
            mut lines := copyLines([]string{}, con emitted.lines)
            mut value := stripOuterParens(con emitted.value)
            if len(emitted.postLines) > 0 {
                temp := strings.join(con []string{"mallang_condition_", spanSuffix(con program, condition),}, con "")
                lines = append(lines, strings.join(con []string{token.CopyText(con indent), "bool ", token.CopyText(con temp), " = ", token.CopyText(con value), ";",}, con ""))
                lines = copyLines(lines, con emitted.postLines)
                value = temp
            }
            lines = append(lines, strings.join(con []string{token.CopyText(con indent), "if (", token.CopyText(con value), ") {",}, con ""))
            match emitBlockWithContinue(con program, thenBlock, con strings.join(con []string {
                token.CopyText(con indent), "    ",
            }
            , con ""), con env, con continueLabel){case Ok(body) {
                    lines = copyLines(lines, con body)
                }
                case Err(message) {
                    return Err(message)
                }
            }
            if ir.NodeChildCount(con program, elseBlock) == 0 {
                lines = append(lines, strings.join(con []string{token.CopyText(con indent), "}",}, con ""))
            } else {
                lines = append(lines, strings.join(con []string{token.CopyText(con indent), "} else {",}, con ""))
                match emitBlockWithContinue(con program, elseBlock, con strings.join(con []string {
                    token.CopyText(con indent), "    ",
                }
                , con ""), con env, con continueLabel){case Ok(body) {
                        lines = copyLines(lines, con body)
                    }
                    case Err(message) {
                        return Err(message)
                    }
                }
                lines = append(lines, strings.join(con []string{token.CopyText(con indent), "}",}, con ""))
            }
            return Ok(lines)
        }
        case Err(message) {
            return Err(message)
        }
    }
}

func emitIf(con program ir.Program, node int, con indent string, con env EmitEnv) Result[[]string, string] {
    return emitIfWithContinue(con program, node, con indent, con env, con "")
}

func blockContainsOuterContinue(con program ir.Program, block int) bool {
    for mut child := 0; child < ir.NodeChildCount(con program, block); child = child + 1 {
        if statementContainsOuterContinue(con program, ir.NodeChild(con program, block, child)) {
            return true
        }
    }
    return false
}

func statementContainsOuterContinue(con program ir.Program, node int) bool {
    kind := ir.NodeKind(con program, node)
    if kind == "Stmt.Continue" {
        return true
    }
    if kind == "Stmt.If" {
        for mut child := 1; child < ir.NodeChildCount(con program, node); child = child + 1 {
            if blockContainsOuterContinue(con program, ir.NodeChild(con program, node, child)) {
                return true
            }
        }
    } else if kind == "Stmt.Match" {
        for mut child := 1; child < ir.NodeChildCount(con program, node); child = child + 1 {
            arm := ir.NodeChild(con program, node, child)
            if ir.NodeKind(con program, arm) == "Match.BlockArm" && ir.NodeChildCount(con program, arm) == 2 {
                if blockContainsOuterContinue(con program, ir.NodeChild(con program, arm, 1)) {
                    return true
                }
            }
        }
    }
    return false
}

func emitForInit(con program ir.Program, node int, con indent string, con env EmitEnv) Result[[]string, string] {
    kind := ir.NodeKind(con program, node)
    if(kind != "ForInit.Let.Immutable" && kind != "ForInit.Let.Mutable") || ir.NodeChildCount(con program, node) != 1 {
        return Err("B3 C backend received malformed for init IR")
    }
    match emitExpression(con program, ir.NodeChild(con program, node, 0), con indent, con env) {
        case Ok(emitted) {
            ty := cTypeFor(con program, con ir.NodeType(con program, node))
            if ty == "" || ty == "void" {
                return Err(unsupported(con ir.NodeType(con program, node)))
            }
            mut lines := copyLines([]string{}, con emitted.lines)
            lines = append(lines, strings.join(con []string{token.CopyText(con indent), ty, " ", cVariableName(con ir.NodeValue(con program, node)), " = ", token.CopyText(con emitted.value), ";",}, con ""))
            lines = copyLines(lines, con emitted.postLines)
            return Ok(lines)
        }
        case Err(message) {
            return Err(message)
        }
    }
}

func emitAssignmentTarget(con program ir.Program, node int, con indent string, con env EmitEnv) Result[EmittedExpr, string] {
    kind := ir.NodeKind(con program, node)
    if kind == "Expr.Var" {
        return Ok(EmittedExpr{lines: []string{}, value: envVariableName(con env, con ir.NodeValue(con program, node)), postLines: []string{},})
    }
    if kind == "Expr.FieldAccess" {
        if ir.NodeChildCount(con program, node) != 1 {
            return Err("B3 C backend received malformed assignment field target IR")
        }
        match emitExpression(con program, ir.NodeChild(con program, node, 0), con indent, con env) {
            case Ok(base) {
                return Ok(EmittedExpr{lines: base.lines, value: strings.join(con []string{"(", token.CopyText(con base.value), ").", cField(con ir.NodeValue(con program, node)),}, con ""), postLines: base.postLines,})
            }
            case Err(message) {
                return Err(message)
            }
        }
    }
    if kind == "Expr.Index" {
        if ir.NodeChildCount(con program, node) != 2 {
            return Err("B3 C backend received malformed assignment index target IR")
        }
        baseNode := ir.NodeChild(con program, node, 0)
        indexNode := ir.NodeChild(con program, node, 1)
        match emitExpression(con program, baseNode, con indent, con env) {
            case Ok(base) {
                match emitExpression(con program, indexNode, con indent, con env) {
                    case Ok(index) {
                        mut lines := copyLines([]string{}, con base.lines)
                        lines = copyLines(lines, con index.lines)
                        mut postLines := copyLines([]string{}, con index.postLines)
                        postLines = copyLines(postLines, con base.postLines)
                        kind := typeKind(con program, con ir.NodeType(con program, baseNode))
                        if kind == "array" {
                            shape := typeShapeIndex(con program, con ir.NodeType(con program, baseNode))
                            if shape < 0 {
                                return Err("B3 C backend received an unknown array assignment target type")
                            }
                            value := strings.join(con []string{"(", token.CopyText(con base.value), ").", cField(con "data"), "[mallang_check_index(", token.CopyText(con index.value), ", ", strings.fromInt(ir.TypeShapeArrayLength(con program, shape)), ")]",}, con "")
                            return Ok(EmittedExpr{lines: copyLines([]string{}, con lines), value: value, postLines: copyLines([]string{}, con postLines),})
                        }
                        if kind == "slice" {
                            temp := strings.join(con []string{"mallang_index_value_", spanSuffix(con program, node),}, con "")
                            lines = append(lines, strings.join(con []string{token.CopyText(con indent), "int64_t ", token.CopyText(con temp), " = ", token.CopyText(con index.value), ";",}, con ""))
                            lines = append(lines, strings.join(con []string{token.CopyText(con indent), "if (", token.CopyText(con temp), " < 0 || ", token.CopyText(con temp), " >= (", token.CopyText(con base.value), ").", cField(con "len"), ") {",}, con ""))
                            lines = append(lines, strings.join(con []string{token.CopyText(con indent), "    mallang_runtime_error(\"slice index out of bounds\");",}, con ""))
                            lines = append(lines, strings.join(con []string{token.CopyText(con indent), "}",}, con ""))
                            value := strings.join(con []string{"(", token.CopyText(con base.value), ").", cField(con "data"), "[", token.CopyText(con temp), "]",}, con "")
                            return Ok(EmittedExpr{lines: lines, value: value, postLines: postLines,})
                        }
                        return Err("B3 C backend received an index assignment target without an array or slice type")
                    }
                    case Err(message) {
                        return Err(message)
                    }
                }
            }
            case Err(message) {
                return Err(message)
            }
        }
    }
    return Err("B3 C backend received an invalid assignment target")
}

func emitBorrowLvalue(con program ir.Program, node int, con indent string, con env EmitEnv) Result[EmittedExpr, string] {
    kind := ir.NodeKind(con program, node)
    if kind == "Expr.FullExprTemporary" {
        return emitExpression(con program, node, con indent, con env)
    }
    if kind == "Expr.Var" {
        return Ok(EmittedExpr{lines: []string{}, value: envVariableName(con env, con ir.NodeValue(con program, node)), postLines: []string{},})
    }
    if kind == "Expr.FieldAccess" {
        if ir.NodeChildCount(con program, node) != 1 {
            return Err("B3 C backend received malformed borrow field IR")
        }
        match emitBorrowLvalue(con program, ir.NodeChild(con program, node, 0), con indent, con env) {
            case Ok(base) {
                return Ok(EmittedExpr{lines: base.lines, value: strings.join(con []string{"(", token.CopyText(con base.value), ").", cField(con ir.NodeValue(con program, node)),}, con ""), postLines: base.postLines,})
            }
            case Err(message) {
                return Err(message)
            }
        }
    }
    if kind == "Expr.Index" {
        if ir.NodeChildCount(con program, node) != 2 {
            return Err("B3 C backend received malformed borrow index IR")
        }
        baseNode := ir.NodeChild(con program, node, 0)
        indexNode := ir.NodeChild(con program, node, 1)
        match emitBorrowLvalue(con program, baseNode, con indent, con env) {
            case Ok(base) {
                match emitExpression(con program, indexNode, con indent, con env) {
                    case Ok(index) {
                        mut lines := copyLines([]string{}, con base.lines)
                        lines = copyLines(lines, con index.lines)
                        mut postLines := copyLines([]string{}, con index.postLines)
                        postLines = copyLines(postLines, con base.postLines)
                        baseKind := typeKind(con program, con ir.NodeType(con program, baseNode))
                        if baseKind == "array" {
                            shape := typeShapeIndex(con program, con ir.NodeType(con program, baseNode))
                            if shape < 0 {
                                return Err("B3 C backend received an unknown array borrow target type")
                            }
                            value := strings.join(con []string{"(", token.CopyText(con base.value), ").", cField(con "data"), "[mallang_check_index(", token.CopyText(con index.value), ", ", strings.fromInt(ir.TypeShapeArrayLength(con program, shape)), ")]",}, con "")
                            return Ok(EmittedExpr{lines: copyLines([]string{}, con lines), value: value, postLines: copyLines([]string{}, con postLines),})
                        }
                        if baseKind == "slice" {
                            indexTemp := strings.join(con []string{"mallang_index_value_", spanSuffix(con program, node),}, con "")
                            lines = append(lines, strings.join(con []string{token.CopyText(con indent), "int64_t ", token.CopyText(con indexTemp), " = ", token.CopyText(con index.value), ";",}, con ""))
                            lines = append(lines, strings.join(con []string{token.CopyText(con indent), "if (", token.CopyText(con indexTemp), " < 0 || ", token.CopyText(con indexTemp), " >= (", token.CopyText(con base.value), ").", cField(con "len"), ") {",}, con ""))
                            lines = append(lines, strings.join(con []string{token.CopyText(con indent), "    mallang_runtime_error(\"slice index out of bounds\");",}, con ""))
                            lines = append(lines, strings.join(con []string{token.CopyText(con indent), "}",}, con ""))
                            value := strings.join(con []string{"(", token.CopyText(con base.value), ").", cField(con "data"), "[", token.CopyText(con indexTemp), "]",}, con "")
                            return Ok(EmittedExpr{lines: lines, value: value, postLines: postLines,})
                        }
                        return Err("B3 C backend received a borrow index without an array or slice type")
                    }
                    case Err(message) {
                        return Err(message)
                    }
                }
            }
            case Err(message) {
                return Err(message)
            }
        }
    }
    return Err("B3 C backend received an invalid borrow lvalue")
}

func emitSliceFieldTake(con program ir.Program, node int, con indent string, con env EmitEnv) Result[EmittedExpr, string] {
    if ir.NodeChildCount(con program, node) != 1 || typeKind(con program, con ir.NodeType(con program, node)) != "slice" {
        return Err("B3 C backend received malformed slice field take IR")
    }
    sourceNode := ir.NodeChild(con program, node, 0)
    if ir.NodeType(con program, sourceNode) != ir.NodeType(con program, node) {
        return Err("B3 C backend received mismatched slice field take IR")
    }
    match emitBorrowLvalue(con program, sourceNode, con indent, con env) {
        case Ok(sourceValue) {
            mut lines := copyLines([]string{}, con sourceValue.lines)
            temp := strings.join(con []string{"mallang_slice_take_tmp_", strings.fromInt(source.Start(con ir.NodeSpan(con program, node))),}, con "")
            cType := cTypeFor(con program, con ir.NodeType(con program, node))
            empty := strings.join(con []string{"(", token.CopyText(con cType), "){ .mlg_data = NULL, .mlg_len = 0, .mlg_cap = 0 }",}, con "")
            lines = append(lines, strings.join(con []string{token.CopyText(con indent), cType, " ", token.CopyText(con temp), " = ", token.CopyText(con sourceValue.value), ";",}, con ""))
            lines = append(lines, strings.join(con []string{token.CopyText(con indent), token.CopyText(con sourceValue.value), " = ", empty, ";",}, con ""))
            return Ok(EmittedExpr{lines: lines, value: temp, postLines: sourceValue.postLines,})
        }
        case Err(message) {
            return Err(message)
        }
    }
}

func finishSliceAppend(con program ir.Program, node int, itemNode int, con indent string, con sourceValue EmittedExpr, clearSource bool, con env EmitEnv) Result[EmittedExpr, string] {
    resultType := ir.NodeType(con program, node)
    elementType := typeArgument(con program, con resultType, 0)
    elementCType := cTypeFor(con program, con elementType)
    resultCType := cTypeFor(con program, con resultType)
    if elementType == "" || elementCType == "" || elementCType == "void" || resultCType == "" || resultCType == "void" {
        return Err("B3 C backend received an append without a concrete slice element type")
    }
    match emitExpression(con program, itemNode, con indent, con env) {
        case Ok(item) {
            temp := strings.join(con []string{"mallang_slice_append_tmp_", strings.fromInt(source.Start(con ir.NodeSpan(con program, node))),}, con "")
            newLen := strings.join(con []string{token.CopyText(con temp), "_new_len",}, con "")
            newCap := strings.join(con []string{token.CopyText(con temp), "_new_cap",}, con "")
            dataTemp := strings.join(con []string{token.CopyText(con temp), "_data",}, con "")
            nestedIndent := strings.join(con []string{token.CopyText(con indent), "    ",}, con "")
            doubleIndent := strings.join(con []string{token.CopyText(con nestedIndent), "    ",}, con "")
            tripleIndent := strings.join(con []string{token.CopyText(con doubleIndent), "    ",}, con "")
            mut lines := copyLines([]string{}, con sourceValue.lines)
            lines = append(lines, strings.join(con []string{token.CopyText(con indent), token.CopyText(con resultCType), " ", token.CopyText(con temp), " = ", token.CopyText(con sourceValue.value), ";",}, con ""))
            lines = copyLines(lines, con item.lines)
            if clearSource {
                lines = append(lines, strings.join(con []string{token.CopyText(con indent), token.CopyText(con sourceValue.value), " = (", token.CopyText(con resultCType), "){ .", cField(con "data"), " = NULL, .", cField(con "len"), " = 0, .", cField(con "cap"), " = 0 };",}, con ""))
            }
            lines = append(lines, strings.join(con []string{token.CopyText(con indent), "if (", token.CopyText(con temp), ".", cField(con "len"), " == INT64_MAX) {",}, con ""))
            lines = append(lines, strings.join(con []string{token.CopyText(con nestedIndent), "mallang_runtime_error(\"slice length overflow\");",}, con ""))
            lines = append(lines, strings.join(con []string{token.CopyText(con indent), "}",}, con ""))
            lines = append(lines, strings.join(con []string{token.CopyText(con indent), "int64_t ", token.CopyText(con newLen), " = ", token.CopyText(con temp), ".", cField(con "len"), " + 1;",}, con ""))
            lines = append(lines, strings.join(con []string{token.CopyText(con indent), "if (", token.CopyText(con temp), ".", cField(con "cap"), " < ", token.CopyText(con newLen), ") {",}, con ""))
            lines = append(lines, strings.join(con []string{token.CopyText(con nestedIndent), "int64_t ", token.CopyText(con newCap), " = (", token.CopyText(con temp), ".", cField(con "cap"), " == 0) ? 1 : ", token.CopyText(con temp), ".", cField(con "cap"), ";",}, con ""))
            lines = append(lines, strings.join(con []string{token.CopyText(con nestedIndent), "while (", token.CopyText(con newCap), " < ", token.CopyText(con newLen), ") {",}, con ""))
            lines = append(lines, strings.join(con []string{token.CopyText(con doubleIndent), "if (", token.CopyText(con newCap), " > INT64_MAX / 2) {",}, con ""))
            lines = append(lines, strings.join(con []string{token.CopyText(con tripleIndent), token.CopyText(con newCap), " = ", token.CopyText(con newLen), ";",}, con ""))
            lines = append(lines, strings.join(con []string{token.CopyText(con tripleIndent), "break;",}, con ""))
            lines = append(lines, strings.join(con []string{token.CopyText(con doubleIndent), "}",}, con ""))
            lines = append(lines, strings.join(con []string{token.CopyText(con doubleIndent), token.CopyText(con newCap), " = ", token.CopyText(con newCap), " * 2;",}, con ""))
            lines = append(lines, strings.join(con []string{token.CopyText(con nestedIndent), "}",}, con ""))
            lines = append(lines, strings.join(con []string{token.CopyText(con nestedIndent), "if ((uint64_t)", token.CopyText(con newCap), " > UINT64_MAX / sizeof(", token.CopyText(con elementCType), ")) {",}, con ""))
            lines = append(lines, strings.join(con []string{token.CopyText(con doubleIndent), "mallang_runtime_error(\"slice allocation size overflow\");",}, con ""))
            lines = append(lines, strings.join(con []string{token.CopyText(con nestedIndent), "}",}, con ""))
            lines = append(lines, strings.join(con []string{token.CopyText(con nestedIndent), "void *", token.CopyText(con dataTemp), " = mallang_realloc(", token.CopyText(con temp), ".", cField(con "data"), ", sizeof(", token.CopyText(con elementCType), ") * (uint64_t)", token.CopyText(con newCap), ", \"slice allocation failed\");",}, con ""))
            lines = append(lines, strings.join(con []string{token.CopyText(con nestedIndent), token.CopyText(con temp), ".", cField(con "data"), " = ", token.CopyText(con dataTemp), ";",}, con ""))
            lines = append(lines, strings.join(con []string{token.CopyText(con nestedIndent), token.CopyText(con temp), ".", cField(con "cap"), " = ", token.CopyText(con newCap), ";",}, con ""))
            lines = append(lines, strings.join(con []string{token.CopyText(con indent), "}",}, con ""))
            lines = append(lines, strings.join(con []string{token.CopyText(con indent), token.CopyText(con temp), ".", cField(con "data"), "[", token.CopyText(con temp), ".", cField(con "len"), "] = ", token.CopyText(con item.value), ";",}, con ""))
            lines = append(lines, strings.join(con []string{token.CopyText(con indent), token.CopyText(con temp), ".", cField(con "len"), " = ", token.CopyText(con newLen), ";",}, con ""))
            mut postLines := copyLines([]string{}, con item.postLines)
            postLines = copyLines(postLines, con sourceValue.postLines)
            return Ok(EmittedExpr{lines: lines, value: temp, postLines: postLines,})
        }
        case Err(message) {
            return Err(message)
        }
    }
}

func emitSliceAppend(con program ir.Program, node int, con indent string, con env EmitEnv) Result[EmittedExpr, string] {
    if ir.NodeChildCount(con program, node) != 2 || typeKind(con program, con ir.NodeType(con program, node)) != "slice" {
        return Err("B3 C backend received malformed slice append IR")
    }
    sourceNode := ir.NodeChild(con program, node, 0)
    itemNode := ir.NodeChild(con program, node, 1)
    resultType := ir.NodeType(con program, node)
    if ir.NodeType(con program, sourceNode) != resultType || ir.NodeType(con program, itemNode) != typeArgument(con program, con resultType, 0) {
        return Err("B3 C backend received mismatched slice append operands")
    }
    if ir.NodeKind(con program, sourceNode) == "Expr.FieldAccess" {
        match emitBorrowLvalue(con program, sourceNode, con indent, con env) {
            case Ok(sourceValue) {
                return finishSliceAppend(con program, node, itemNode, con indent, con sourceValue, true, con env)
            }
            case Err(message) {
                return Err(message)
            }
        }
    }
    match emitExpression(con program, sourceNode, con indent, con env) {
        case Ok(sourceValue) {
            return finishSliceAppend(con program, node, itemNode, con indent, con sourceValue, false, con env)
        }
        case Err(message) {
            return Err(message)
        }
    }
}

func emitFieldAssign(con program ir.Program, node int, con indent string, con env EmitEnv) Result[[]string, string] {
    if ir.NodeChildCount(con program, node) != 2 {
        return Err("B3 C backend received malformed field assignment IR")
    }
    match emitAssignmentTarget(con program, ir.NodeChild(con program, node, 0), con indent, con env) {
        case Ok(base) {
            match emitExpression(con program, ir.NodeChild(con program, node, 1), con indent, con env) {
                case Ok(expression) {
                    mut lines := copyLines([]string{}, con base.lines)
                    lines = copyLines(lines, con expression.lines)
                    lines = append(lines, strings.join(con []string{token.CopyText(con indent), "(", token.CopyText(con base.value), ").", cField(con ir.NodeValue(con program, node)), " = ", token.CopyText(con expression.value), ";",}, con ""))
                    lines = copyLines(lines, con expression.postLines)
                    lines = copyLines(lines, con base.postLines)
                    return Ok(lines)
                }
                case Err(message) {
                    return Err(message)
                }
            }
        }
        case Err(message) {
            return Err(message)
        }
    }
}

func emitIndexAssign(con program ir.Program, node int, con indent string, con env EmitEnv) Result[[]string, string] {
    if ir.NodeChildCount(con program, node) != 3 {
        return Err("B3 C backend received malformed index assignment IR")
    }
    baseNode := ir.NodeChild(con program, node, 0)
    indexNode := ir.NodeChild(con program, node, 1)
    valueNode := ir.NodeChild(con program, node, 2)
    match emitAssignmentTarget(con program, baseNode, con indent, con env) {
        case Ok(base) {
            match emitExpression(con program, indexNode, con indent, con env) {
                case Ok(index) {
                    match emitExpression(con program, valueNode, con indent, con env) {
                        case Ok(value) {
                            indexTemp := strings.join(con []string{"mallang_index_assign_value_", spanSuffix(con program, indexNode),}, con "")
                            mut lines := copyLines([]string{}, con base.lines)
                            lines = copyLines(lines, con index.lines)
                            lines = append(lines, strings.join(con []string{token.CopyText(con indent), "int64_t ", token.CopyText(con indexTemp), " = ", token.CopyText(con index.value), ";",}, con ""))
                            baseKind := typeKind(con program, con ir.NodeType(con program, baseNode))
                            mut length := ""
                            mut message := ""
                            if baseKind == "array" {
                                shape := typeShapeIndex(con program, con ir.NodeType(con program, baseNode))
                                if shape < 0 {
                                    return Err("B3 C backend received an unknown array index assignment type")
                                }
                                length = strings.fromInt(ir.TypeShapeArrayLength(con program, shape))
                                message = "array index out of bounds"
                            } else if baseKind == "slice" {
                                length = strings.join(con []string{"(", token.CopyText(con base.value), ").", cField(con "len"),}, con "")
                                message = "slice index out of bounds"
                            } else {
                                return Err("B3 C backend received an index assignment without an array or slice type")
                            }
                            lines = append(lines, strings.join(con []string{token.CopyText(con indent), "if (", token.CopyText(con indexTemp), " < 0 || ", token.CopyText(con indexTemp), " >= ", token.CopyText(con length), ") {",}, con ""))
                            lines = append(lines, strings.join(con []string{token.CopyText(con indent), "    mallang_runtime_error(\"", token.CopyText(con message), "\");",}, con ""))
                            lines = append(lines, strings.join(con []string{token.CopyText(con indent), "}",}, con ""))
                            lines = copyLines(lines, con value.lines)
                            lines = append(lines, strings.join(con []string{token.CopyText(con indent), "(", token.CopyText(con base.value), ").", cField(con "data"), "[", token.CopyText(con indexTemp), "] = ", token.CopyText(con value.value), ";",}, con ""))
                            lines = copyLines(lines, con value.postLines)
                            lines = copyLines(lines, con index.postLines)
                            lines = copyLines(lines, con base.postLines)
                            return Ok(lines)
                        }
                        case Err(message) {
                            return Err(message)
                        }
                    }
                }
                case Err(message) {
                    return Err(message)
                }
            }
        }
        case Err(message) {
            return Err(message)
        }
    }
}

func emitForPost(con program ir.Program, node int, con indent string, con env EmitEnv) Result[[]string, string] {
    if ir.NodeKind(con program, node) != "ForPost.Assign" || ir.NodeChildCount(con program, node) != 2 {
        return Err("B3 C backend received malformed for post IR")
    }
    match emitAssignmentTarget(con program, ir.NodeChild(con program, node, 0), con indent, con env) {
        case Ok(target) {
            match emitExpression(con program, ir.NodeChild(con program, node, 1), con indent, con env) {
                case Ok(expression) {
                    mut lines := copyLines([]string{}, con target.lines)
                    lines = copyLines(lines, con expression.lines)
                    lines = append(lines, strings.join(con []string{token.CopyText(con indent), token.CopyText(con target.value), " = ", token.CopyText(con expression.value), ";",}, con ""))
                    lines = copyLines(lines, con expression.postLines)
                    lines = copyLines(lines, con target.postLines)
                    return Ok(lines)
                }
                case Err(message) {
                    return Err(message)
                }
            }
        }
        case Err(message) {
            return Err(message)
        }
    }
}

func emitOverwrite(con program ir.Program, node int, con indent string, con env EmitEnv) Result[[]string, string] {
    if ir.NodeChildCount(con program, node) != 2 {
        return Err("B3 C backend received malformed overwrite IR")
    }
    targetNode := ir.NodeChild(con program, node, 0)
    valueNode := ir.NodeChild(con program, node, 1)
    targetType := ir.NodeType(con program, targetNode)
    if !typeNeedsCleanup(con program, con targetType) || targetType != ir.NodeType(con program, valueNode) {
        return Err("B3 C backend received an overwrite without one cleanup type")
    }
    if ir.NodeKind(con program, valueNode) != "Expr.Var" {
        return Err("B3 C backend received an overwrite value without an evaluated temporary")
    }
    cType := cTypeFor(con program, con targetType)
    if cType == "" || cType == "void" {
        return Err(unsupported(con targetType))
    }
    match emitAssignmentTarget(con program, targetNode, con indent, con env) {
        case Ok(target) {
            match emitExpression(con program, valueNode, con indent, con env) {
                case Ok(value) {
                    if len(value.lines) != 0 || len(value.postLines) != 0 {
                        return Err("B3 C backend received an overwrite value temporary with cleanup code")
                    }
                    targetTemp := strings.join(con []string{"mallang_overwrite_target_", spanSuffix(con program, targetNode),}, con "")
                    mut lines := copyLines([]string{}, con target.lines)
                    lines = append(lines, strings.join(con []string{token.CopyText(con indent), cType, " *", token.CopyText(con targetTemp), " = &(", token.CopyText(con target.value), ");",}, con ""))
                    lines = append(lines, strings.join(con []string{token.CopyText(con indent), dropFunctionName(con program, con targetType), "(", token.CopyText(con targetTemp), ");",}, con ""))
                    lines = append(lines, strings.join(con []string{token.CopyText(con indent), "*", token.CopyText(con targetTemp), " = ", token.CopyText(con value.value), ";",}, con ""))
                    lines = copyLines(lines, con target.postLines)
                    return Ok(lines)
                }
                case Err(message) {
                    return Err(message)
                }
            }
        }
        case Err(message) {
            return Err(message)
        }
    }
}

func emitFor(con program ir.Program, node int, con indent string, con env EmitEnv) Result[[]string, string] {
    mut init := -1
    mut condition := -1
    mut post := -1
    mut body := -1
    mut cleanup := -1
    for mut child := 0; child < ir.NodeChildCount(con program, node); child = child + 1 {
        control := ir.NodeChild(con program, node, child)
        kind := ir.NodeKind(con program, control)
        if kind == "ForInit.Let.Immutable" || kind == "ForInit.Let.Mutable" {
            if init >= 0 {
                return Err("B3 C backend received duplicate for init IR")
            }
            init = control
        } else if kind == "ForCondition" {
            if ir.NodeChildCount(con program, control) != 1 {
                return Err("B3 C backend received malformed for condition IR")
            }
            condition = ir.NodeChild(con program, control, 0)
        } else if kind == "ForPost.Assign" {
            if post >= 0 {
                return Err("B3 C backend received duplicate for post IR")
            }
            post = control
        } else if kind == "Block.For" {
            body = control
        } else if kind == "Block.ForCleanup" {
            cleanup = control
        } else {
            return Err(unsupported(con kind))
        }
    }
    if body < 0 || cleanup < 0 {
        return Err("B3 C backend received malformed for blocks")
    }
    if init >= 0 || post >= 0 || ir.NodeChildCount(con program, cleanup) > 0 {
        nestedIndent := strings.join(con []string{token.CopyText(con indent), "    ",}, con "")
        loopIndent := strings.join(con []string{token.CopyText(con nestedIndent), "    ",}, con "")
        bodyIndent := strings.join(con []string{token.CopyText(con loopIndent), "    ",}, con "")
        mut lines := []string{strings.join(con []string{token.CopyText(con indent), "{",}, con ""),}
        if init >= 0 {
            match emitForInit(con program, init, con nestedIndent, con env) {
                case Ok(emitted) {
                    lines = copyLines(lines, con emitted)
                }
                case Err(message) {
                    return Err(message)
                }
            }
        }
        mut continueLabel := ""
        if post >= 0 && blockContainsOuterContinue(con program, body) {
            target := ir.NodeChild(con program, post, 0)
            continueLabel = strings.join(con []string{"mallang_for_post_", strings.fromInt(source.Start(con ir.NodeSpan(con program, target))),}, con "")
        }
        lines = append(lines, strings.join(con []string{token.CopyText(con nestedIndent), "while (true) {",}, con ""))
        if condition >= 0 {
            match emitExpression(con program, condition, con loopIndent, con env) {
                case Ok(emitted) {
                    lines = copyLines(lines, con emitted.lines)
                    mut value := stripOuterParens(con emitted.value)
                    if len(emitted.postLines) > 0 {
                        temp := strings.join(con []string{"mallang_condition_", spanSuffix(con program, condition),}, con "")
                        lines = append(lines, strings.join(con []string{token.CopyText(con loopIndent), "bool ", token.CopyText(con temp), " = ", token.CopyText(con value), ";",}, con ""))
                        lines = copyLines(lines, con emitted.postLines)
                        value = temp
                    }
                    lines = append(lines, strings.join(con []string{token.CopyText(con loopIndent), "if (!(", token.CopyText(con value), ")) {",}, con ""))
                    lines = append(lines, strings.join(con []string{token.CopyText(con bodyIndent), "break;",}, con ""))
                    lines = append(lines, strings.join(con []string{token.CopyText(con loopIndent), "}",}, con ""))
                }
                case Err(message) {
                    return Err(message)
                }
            }
        }
        lines = append(lines, strings.join(con []string{token.CopyText(con loopIndent), "{",}, con ""))
        match emitBlockWithContinue(con program, body, con bodyIndent, con env, con continueLabel) {
            case Ok(emitted) {
                lines = copyLines(lines, con emitted)
            }
            case Err(message) {
                return Err(message)
            }
        }
        lines = append(lines, strings.join(con []string{token.CopyText(con loopIndent), "}",}, con ""))
        if post >= 0 {
            if continueLabel == "" {
                lines = append(lines, strings.join(con []string{token.CopyText(con loopIndent), "{",}, con ""))
            } else {
                lines = append(lines, strings.join(con []string{token.CopyText(con loopIndent), token.CopyText(con continueLabel), ": {",}, con ""))
            }
            match emitForPost(con program, post, con bodyIndent, con env) {
                case Ok(emitted) {
                    lines = copyLines(lines, con emitted)
                }
                case Err(message) {
                    return Err(message)
                }
            }
            lines = append(lines, strings.join(con []string{token.CopyText(con loopIndent), "}",}, con ""))
        }
        lines = append(lines, strings.join(con []string{token.CopyText(con nestedIndent), "}",}, con ""))
        match emitBlock(con program, cleanup, con nestedIndent, con env) {
            case Ok(emitted) {
                lines = copyLines(lines, con emitted)
            }
            case Err(message) {
                return Err(message)
            }
        }
        lines = append(lines, strings.join(con []string{token.CopyText(con indent), "}",}, con ""))
        return Ok(lines)
    }
    nestedIndent := strings.join(con []string{token.CopyText(con indent), "    ",}, con "")
    mut emittedCondition := EmittedExpr{lines: []string{}, value: "true", postLines: []string{},}
    if condition >= 0 {
        match emitExpression(con program, condition, con nestedIndent, con env) {
            case Ok(emitted) {
                emittedCondition = emitted
            }
            case Err(message) {
                return Err(message)
            }
        }
    }
    mut lines := []string{}
    conditionValue := stripOuterParens(con emittedCondition.value)
    if len(emittedCondition.lines) == 0 && len(emittedCondition.postLines) == 0 {
        lines = append(lines, strings.join(con []string{token.CopyText(con indent), "while (", token.CopyText(con conditionValue), ") {",}, con ""))
    } else {
        lines = append(lines, strings.join(con []string{token.CopyText(con indent), "while (true) {",}, con ""))
        lines = copyLines(lines, con emittedCondition.lines)
        mut guardedValue := conditionValue
        if len(emittedCondition.postLines) > 0 {
            temp := strings.join(con []string{"mallang_condition_", spanSuffix(con program, condition),}, con "")
            lines = append(lines, strings.join(con []string{token.CopyText(con nestedIndent), "bool ", token.CopyText(con temp), " = ", token.CopyText(con guardedValue), ";",}, con ""))
            lines = copyLines(lines, con emittedCondition.postLines)
            guardedValue = temp
        }
        lines = append(lines, strings.join(con []string{token.CopyText(con nestedIndent), "if (!(", token.CopyText(con guardedValue), ")) {",}, con ""))
        lines = append(lines, strings.join(con []string{token.CopyText(con nestedIndent), "    break;",}, con ""))
        lines = append(lines, strings.join(con []string{token.CopyText(con nestedIndent), "}",}, con ""))
    }
    match emitBlock(con program, body, con strings.join(con []string {
        token.CopyText(con indent), "    ",
    }
    , con ""), con env){case Ok(emitted) {
            lines = copyLines(lines, con emitted)
        }
        case Err(message) {
            return Err(message)
        }
    }
    lines = append(lines, strings.join(con []string{token.CopyText(con indent), "}",}, con ""))
    return Ok(lines)
}

func rangeBindingPart(con value string, wantValue bool) string {
    mut comma := -1
    for mut index := 0; index < strings.byteLen(con value); index = index + 1 {
        match strings.byteAt(con value, index) {
            case Ok(byte) {
                if byte == 44 {
                    comma = index
                }
            }
            case Err(_) {}
        }
    }
    if comma < 0 {
        if wantValue {
            return "_"
        }
        return token.CopyText(con value)
    }
    mut start := 0
    mut end := comma
    if wantValue {
        start = comma + 1
        end = strings.byteLen(con value)
    }
    return match strings.slice(con value, start, end) {
        case Ok(part) {
            token.CopyText(con part)
        }
        case Err(_) {
            "_"
        }
    }
}

func fullExpressionOwnerNode(con program ir.Program, node int) int {
    kind := ir.NodeKind(con program, node)
    if kind == "Expr.FullExprTemporary" && ir.NodeNeedsCleanup(con program, node) {
        return node
    }
    if(kind == "Expr.FieldAccess" || kind == "Expr.Index") && ir.NodeChildCount(con program, node) > 0 {
        return fullExpressionOwnerNode(con program, ir.NodeChild(con program, node, 0))
    }
    return - 1
}

func removeFirstLine(con values []string, con target string) []string {
    mut removed := false
    mut output := []string{}
    for mut index := 0; index < len(values); index = index + 1 {
        if !removed && values[index]== target {
            removed = true
        } else {
            output = append(output, token.CopyText(con values[index]))
        }
    }
    return output
}

func emitRangeFor(con program ir.Program, node int, con indent string, con env EmitEnv) Result[[]string, string] {
    if ir.NodeChildCount(con program, node) != 4 {
        return Err("B3 C backend received malformed range-for IR")
    }
    bindings := ir.NodeChild(con program, node, 0)
    sourceNode := ir.NodeChild(con program, node, 1)
    body := ir.NodeChild(con program, node, 2)
    cleanup := ir.NodeChild(con program, node, 3)
    if ir.NodeKind(con program, bindings) != "RangeBindings" || ir.NodeKind(con program, body) != "Block.RangeFor" || ir.NodeKind(con program, cleanup) != "Block.RangeCleanup" {
        return Err("B3 C backend received malformed range-for blocks")
    }
    indexName := rangeBindingPart(con ir.NodeValue(con program, bindings), false)
    valueName := rangeBindingPart(con ir.NodeValue(con program, bindings), true)
    sourceType := ir.NodeType(con program, sourceNode)
    sourceKind := typeKind(con program, con sourceType)
    sourceTemp := strings.join(con []string{"mallang_range_src_", strings.fromInt(source.Start(con ir.NodeSpan(con program, sourceNode))),}, con "")
    mut length := ""
    mut arrayLength := -1
    if sourceKind == "array" {
        shape := typeShapeIndex(con program, con sourceType)
        if shape < 0 {
            return Err("B3 C backend received an unknown range array type")
        }
        arrayLength = ir.TypeShapeArrayLength(con program, shape)
        length = strings.fromInt(arrayLength)
    } else if sourceKind == "slice" {
        length = strings.join(con []string{"(", token.CopyText(con sourceTemp), ").", cField(con "len"),}, con "")
    } else {
        return Err("B3 C backend received a range source without an array or slice type")
    }
    match emitExpression(con program, sourceNode, con indent, con env) {
        case Ok(sourceExpression) {
            mut emittedSource := sourceExpression
            owner := fullExpressionOwnerNode(con program, sourceNode)
            if owner >= 0 {
                ownerType := ir.NodeType(con program, owner)
                ownerValue := ir.NodeValue(con program, owner)
                ownerName := cVariableName(con ownerValue)
                match dropLine(con program, con ownerType, con ownerName, con indent) {
                    case Ok(ownerDrop) {
                        if !containsText(con emittedSource.postLines, con ownerDrop) {
                            return Err("B3 C backend range full-expression owner is missing cleanup")
                        }
                        emittedSource.postLines = removeFirstLine(con emittedSource.postLines, con ownerDrop)
                    }
                    case Err(message) {
                        return Err(message)
                    }
                }
            }
            mut lines := copyLines([]string{}, con emittedSource.lines)
            lines = append(lines, strings.join(con []string{token.CopyText(con indent), cTypeFor(con program, con sourceType), " ", token.CopyText(con sourceTemp), " = ", token.CopyText(con emittedSource.value), ";",}, con ""))
            lines = append(lines, strings.join(con []string{token.CopyText(con indent), "(void)&", token.CopyText(con sourceTemp), ";",}, con ""))
            lines = copyLines(lines, con emittedSource.postLines)
            mut indexIdent := cVariableName(con indexName)
            if indexName == "_" {
                indexIdent = strings.join(con []string{"mallang_range_index_", strings.fromInt(source.Start(con ir.NodeSpan(con program, sourceNode))),}, con "")
            }
            lines = append(lines, strings.join(con []string{token.CopyText(con indent), "for (int64_t ", token.CopyText(con indexIdent), " = 0; ", token.CopyText(con indexIdent), " < ", token.CopyText(con length), "; ", token.CopyText(con indexIdent), " = (", token.CopyText(con indexIdent), " + 1)) {",}, con ""))
            nestedIndent := strings.join(con []string{token.CopyText(con indent), "    ",}, con "")
            mut valueIdent := ""
            if valueName != "_" {
                valueIdent = cVariableName(con valueName)
                valueType := cTypeFor(con program, con ir.NodeType(con program, bindings))
                if valueType == "" || valueType == "void" {
                    return Err(unsupported(con ir.NodeType(con program, bindings)))
                }
                if arrayLength == 0 {
                    lines = append(lines, strings.join(con []string{token.CopyText(con nestedIndent), valueType, " ", token.CopyText(con valueIdent), ";",}, con ""))
                } else {
                    lines = append(lines, strings.join(con []string{token.CopyText(con nestedIndent), valueType, " ", token.CopyText(con valueIdent), " = (", token.CopyText(con sourceTemp), ").", cField(con "data"), "[", token.CopyText(con indexIdent), "];",}, con ""))
                }
                lines = append(lines, strings.join(con []string{token.CopyText(con nestedIndent), "(void)&", token.CopyText(con valueIdent), ";",}, con ""))
            }
            mut bodyEnv := copyEmitEnv(con env)
            if indexName != "_" {
                bodyEnv = envSet(con bodyEnv, con indexName, con indexIdent)
            }
            if valueName != "_" {
                bodyEnv = envSet(con bodyEnv, con valueName, con valueIdent)
            }
            lines = append(lines, strings.join(con []string{token.CopyText(con nestedIndent), "{",}, con ""))
            match emitBlock(con program, body, con strings.join(con []string {
                token.CopyText(con nestedIndent), "    ",
            }
            , con ""), con bodyEnv){case Ok(emitted) {
                    lines = copyLines(lines, con emitted)
                }
                case Err(message) {
                    return Err(message)
                }
            }
            lines = append(lines, strings.join(con []string{token.CopyText(con nestedIndent), "}",}, con ""))
            lines = append(lines, strings.join(con []string{token.CopyText(con indent), "}",}, con ""))
            match emitBlock(con program, cleanup, con indent, con env) {
                case Ok(emitted) {
                    lines = copyLines(lines, con emitted)
                }
                case Err(message) {
                    return Err(message)
                }
            }
            return Ok(lines)
        }
        case Err(message) {
            return Err(message)
        }
    }
}

func emitMatchStatementWithContinue(con program ir.Program, node int, con indent string, con env EmitEnv, con continueLabel string) Result[[]string, string] {
    if ir.NodeChildCount(con program, node) < 2 {
        return Err("B3 C backend received a match statement without arms")
    }
    scrutineeNode := ir.NodeChild(con program, node, 0)
    scrutineeType := ir.NodeType(con program, scrutineeNode)
    kind := typeKind(con program, con scrutineeType)
    if kind != "option" && kind != "result" && kind != "enum" {
        return Err("B3 C backend received a match on a non-ADT value")
    }
    match emitMatchScrutinee(con program, scrutineeNode, con indent, con env) {
        case Ok(scrutinee) {
            mut lines := copyLines([]string{}, con scrutinee.lines)
            nestedIndent := strings.join(con []string{token.CopyText(con indent), "    ",}, con "")
            for mut armIndex := 1; armIndex < ir.NodeChildCount(con program, node); armIndex = armIndex + 1 {
                arm := ir.NodeChild(con program, node, armIndex)
                if ir.NodeKind(con program, arm) != "Match.BlockArm" || ir.NodeChildCount(con program, arm) != 2 {
                    return Err("B3 C backend received malformed match statement arm IR")
                }
                pattern := ir.NodeChild(con program, arm, 0)
                block := ir.NodeChild(con program, arm, 1)
                initial := PatternPlan{conditions: []string{}, setup: []string{}, env: copyEmitEnv(con env),}
                match planPattern(con program, pattern, con scrutineeType, con scrutinee.value, arm, con initial) {
                    case Ok(plan) {
                        mut prefix := "if ("
                        if armIndex > 1 {
                            prefix = "} else if ("
                        }
                        lines = append(lines, strings.join(con []string{token.CopyText(con indent), prefix, patternCondition(con plan), ") {",}, con ""))
                        for mut setup := 0; setup < len(plan.setup); setup = setup + 1 {
                            lines = append(lines, strings.join(con []string{token.CopyText(con nestedIndent), token.CopyText(con plan.setup[setup]),}, con ""))
                        }
                        match emitBlockWithContinue(con program, block, con nestedIndent, con plan.env, con continueLabel) {
                            case Ok(emitted) {
                                lines = copyLines(lines, con emitted)
                            }
                            case Err(message) {
                                return Err(message)
                            }
                        }
                    }
                    case Err(message) {
                        return Err(message)
                    }
                }
            }
            lines = append(lines, strings.join(con []string{token.CopyText(con indent), "} else {",}, con ""))
            lines = append(lines, strings.join(con []string{token.CopyText(con nestedIndent), "mallang_runtime_error(\"invalid enum tag\");",}, con ""))
            lines = append(lines, strings.join(con []string{token.CopyText(con indent), "}",}, con ""))
            return Ok(lines)
        }
        case Err(message) {
            return Err(message)
        }
    }
}

func emitMatchStatement(con program ir.Program, node int, con indent string, con env EmitEnv) Result[[]string, string] {
    return emitMatchStatementWithContinue(con program, node, con indent, con env, con "")
}

func emitStatementWithContinue(con program ir.Program, node int, con indent string, con env EmitEnv, con continueLabel string) Result[[]string, string] {
    kind := ir.NodeKind(con program, node)
    if kind == "Stmt.Let.Immutable" || kind == "Stmt.Let.Mutable" {
        if ir.NodeChildCount(con program, node) != 1 {
            return Err("B3 C backend received malformed let IR")
        }
        match emitExpression(con program, ir.NodeChild(con program, node, 0), con indent, con env) {
            case Ok(emitted) {
                mut lines := []string{}
                lines = copyLines(lines, con emitted.lines)
                ty := cTypeFor(con program, con ir.NodeType(con program, node))
                if ty == "" || ty == "void" {
                    return Err(unsupported(con ir.NodeType(con program, node)))
                }
                lines = append(lines, strings.join(con []string{token.CopyText(con indent), ty, " ", cVariableName(con ir.NodeValue(con program, node)), " = ", token.CopyText(con emitted.value), ";",}, con ""))
                lines = copyLines(lines, con emitted.postLines)
                return Ok(lines)
            }
            case Err(message) {
                return Err(message)
            }
        }
    }
    if kind == "Stmt.Assign" {
        if ir.NodeChildCount(con program, node) != 1 {
            return Err("B3 C backend received malformed assignment IR")
        }
        match emitExpression(con program, ir.NodeChild(con program, node, 0), con indent, con env) {
            case Ok(emitted) {
                mut lines := []string{}
                lines = copyLines(lines, con emitted.lines)
                lines = append(lines, strings.join(con []string{token.CopyText(con indent), envVariableName(con env, con ir.NodeValue(con program, node)), " = ", token.CopyText(con emitted.value), ";",}, con ""))
                lines = copyLines(lines, con emitted.postLines)
                return Ok(lines)
            }
            case Err(message) {
                return Err(message)
            }
        }
    }
    if kind == "Stmt.FieldAssign" {
        return emitFieldAssign(con program, node, con indent, con env)
    }
    if kind == "Stmt.IndexAssign" {
        return emitIndexAssign(con program, node, con indent, con env)
    }
    if kind == "Stmt.Return" {
        if ir.NodeChildCount(con program, node) == 0 {
            return Ok([]string{strings.join(con []string{token.CopyText(con indent), "return;",}, con ""),})
        }
        if ir.NodeChildCount(con program, node) != 1 {
            return Err("B3 C backend received malformed return IR")
        }
        match emitExpression(con program, ir.NodeChild(con program, node, 0), con indent, con env) {
            case Ok(emitted) {
                mut lines := []string{}
                lines = copyLines(lines, con emitted.lines)
                if len(emitted.postLines) == 0 {
                    lines = append(lines, strings.join(con []string{token.CopyText(con indent), "return ", token.CopyText(con emitted.value), ";",}, con ""))
                } else {
                    ty := cTypeFor(con program, con ir.NodeType(con program, ir.NodeChild(con program, node, 0)))
                    if ty == "" || ty == "void" {
                        return Err(unsupported(con ir.NodeType(con program, ir.NodeChild(con program, node, 0))))
                    }
                    temp := strings.join(con []string{"mallang_return_value_", spanSuffix(con program, ir.NodeChild(con program, node, 0)),}, con "")
                    lines = append(lines, strings.join(con []string{token.CopyText(con indent), ty, " ", token.CopyText(con temp), " = ", token.CopyText(con emitted.value), ";",}, con ""))
                    lines = copyLines(lines, con emitted.postLines)
                    lines = append(lines, strings.join(con []string{token.CopyText(con indent), "return ", token.CopyText(con temp), ";",}, con ""))
                }
                return Ok(lines)
            }
            case Err(message) {
                return Err(message)
            }
        }
    }
    if kind == "Stmt.If" {
        return emitIfWithContinue(con program, node, con indent, con env, con continueLabel)
    }
    if kind == "Stmt.For" {
        return emitFor(con program, node, con indent, con env)
    }
    if kind == "Stmt.RangeFor" {
        return emitRangeFor(con program, node, con indent, con env)
    }
    if kind == "Stmt.Match" {
        return emitMatchStatementWithContinue(con program, node, con indent, con env, con continueLabel)
    }
    if kind == "Stmt.Break" {
        return Ok([]string{strings.join(con []string{token.CopyText(con indent), "break;",}, con ""),})
    }
    if kind == "Stmt.Continue" {
        if continueLabel != "" {
            return Ok([]string{strings.join(con []string{token.CopyText(con indent), "goto ", token.CopyText(con continueLabel), ";",}, con ""),})
        }
        return Ok([]string{strings.join(con []string{token.CopyText(con indent), "continue;",}, con ""),})
    }
    if kind == "Stmt.Drop" {
        if ir.NodeChildCount(con program, node) != 1 {
            return Err("B3 C backend received malformed drop IR")
        }
        expression := ir.NodeChild(con program, node, 0)
        mut cleanupEnv := copyEmitEnv(con env)
        if ir.NodeKind(con program, expression) == "Expr.Var" {
            name := ir.NodeValue(con program, expression)
            identity := patternBindingEnvKey(con program, con name, expression)
            binding := envLookup(con env, con identity)
            if binding != "" {
                cleanupEnv = envSet(con cleanupEnv, con name, con binding)
            } else {
                current := envLookup(con env, con name)
                if startsWith(con current, con "mallang_pattern_") {
                    cleanupEnv = envRemove(con cleanupEnv, con name)
                }
            }
        }
        match emitExpression(con program, expression, con indent, con cleanupEnv) {
            case Ok(emitted) {
                mut lines := copyLines([]string{}, con emitted.lines)
                match dropLine(con program, con ir.NodeType(con program, expression), con emitted.value, con indent) {
                    case Ok(line) {
                        lines = append(lines, line)
                    }
                    case Err(message) {
                        return Err(message)
                    }
                }
                lines = copyLines(lines, con emitted.postLines)
                return Ok(lines)
            }
            case Err(message) {
                return Err(message)
            }
        }
    }
    if kind == "Stmt.Overwrite" {
        return emitOverwrite(con program, node, con indent, con env)
    }
    if kind == "Stmt.Expr" {
        if ir.NodeChildCount(con program, node) != 1 {
            return Err("B3 C backend received malformed expression statement IR")
        }
        expression := ir.NodeChild(con program, node, 0)
        if ir.NodeKind(con program, expression) == "Expr.Call" && ir.NodeValue(con program, expression) == "print" {
            return emitPrint(con program, expression, con indent, con env)
        }
        match emitExpression(con program, expression, con indent, con env) {
            case Ok(emitted) {
                mut lines := []string{}
                lines = copyLines(lines, con emitted.lines)
                mut value := token.CopyText(con emitted.value)
                if typeNeedsCleanup(con program, con ir.NodeType(con program, expression)) {
                    value = strings.join(con []string{"(void)(", token.CopyText(con value), ")",}, con "")
                }
                lines = append(lines, strings.join(con []string{token.CopyText(con indent), value, ";",}, con ""))
                lines = copyLines(lines, con emitted.postLines)
                return Ok(lines)
            }
            case Err(message) {
                return Err(message)
            }
        }
    }
    return Err(unsupported(con kind))
}

func emitStatement(con program ir.Program, node int, con indent string, con env EmitEnv) Result[[]string, string] {
    return emitStatementWithContinue(con program, node, con indent, con env, con "")
}

func emitThunk(con program ir.Program, function int) Result[[]string, string] {
    returnType := cTypeFor(con program, con ir.FunctionReturnType(con program, function))
    if returnType == "" {
        return Err(unsupported(con ir.FunctionReturnType(con program, function)))
    }
    match functionParams(con program, function, true) {
        case Ok(params) {
            name := cFunctionName(con ir.FunctionName(con program, function))
            mut args := []string{}
            for mut param := 0; param < ir.FunctionParamCount(con program, function); param = param + 1 {
                args = append(args, strings.join(con []string{"mlg_arg_", strings.fromInt(param),}, con ""))
            }
            mut lines := []string{strings.join(con []string{"static ", token.CopyText(con returnType), " MLG_UNUSED mallang_callable_thunk_", token.CopyText(con name), "(", params, ") {",}, con ""), "    (void)mlg_env;",}
            call := strings.join(con []string{name, "(", strings.join(con args, con ", "), ")",}, con "")
            if returnType == "void" {
                lines = append(lines, strings.join(con []string{"    ", call, ";",}, con ""))
            } else {
                lines = append(lines, strings.join(con []string{"    return ", call, ";",}, con ""))
            }
            lines = append(lines, "}")
            return Ok(lines)
        }
        case Err(message) {
            return Err(message)
        }
    }
}

func emitFunction(con program ir.Program, function int) Result[[]string, string] {
    match functionSignature(con program, function) {
        case Ok(signature) {
            mut lines := []string{strings.join(con []string{signature, " {",}, con ""),}
            mut env := EmitEnv{bindings: []EmitBinding{},}
            name := ir.FunctionName(con program, function)
            if name == "main" && programUsesIntrinsic(con program, con "OsArgs") {
                lines = append(lines, "    mallang_process_init(argc, argv);")
            }
            for mut param := 0; param < ir.FunctionParamCount(con program, function); param = param + 1 {
                paramName := ir.FunctionParamName(con program, function, param)
                cName := cVariableName(con paramName)
                lines = append(lines, strings.join(con []string{"    (void)", token.CopyText(con cName), ";",}, con ""))
                if ir.FunctionParamMode(con program, function, param) != "owned" {
                    env = envSet(con env, con paramName, con strings.join(con []string{"(*", token.CopyText(con cName), ")",}, con ""))
                }
            }
            for mut statement := 0; statement < ir.FunctionBodyCount(con program, function); statement = statement + 1 {
                match emitStatement(con program, ir.FunctionBodyNode(con program, function, statement), con "    ", con env) {
                    case Ok(emitted) {
                        lines = copyLines(lines, con emitted)
                    }
                    case Err(message) {
                        return Err(message)
                    }
                }
            }
            if name == "main" {
                lines = append(lines, "    return 0;")
            }
            lines = append(lines, "}")
            return Ok(lines)
        }
        case Err(message) {
            return Err(message)
        }
    }
}

pub func Generate(con program ir.Program) Result[string, string] {
    if ir.ClosureCount(con program) != 0 {
        return Err("B3 C backend does not yet support closures")
    }
    mut lines := runtimePrelude()
    types := collectDefinedTypes(con program)
    if containsText(con types, con "string") {
        lines = copyLines(lines, con stringRuntimeWithoutDrop())
    } else {
        lines = append(lines, "")
    }
    match emitTypeDefinitions(con program, con types) {
        case Ok(definitions) {
            if len(definitions) > 0 {
                lines = copyLines(lines, con definitions)
                lines = append(lines, "")
            }
        }
        case Err(message) {
            return Err(message)
        }
    }
    match emitDropHelpers(con program, con types) {
        case Ok(helpers) {
            if len(helpers) > 0 {
                lines = copyLines(lines, con helpers)
                lines = append(lines, "")
            }
        }
        case Err(message) {
            return Err(message)
        }
    }
    match standardRuntime(con program) {
        case Ok(helpers) {
            if len(helpers) > 0 {
                lines = copyLines(lines, con helpers)
                lines = append(lines, "")
            }
        }
        case Err(message) {
            return Err(message)
        }
    }
    for mut function := 0; function < ir.FunctionCount(con program); function = function + 1 {
        match functionSignature(con program, function) {
            case Ok(signature) {
                lines = append(lines, strings.join(con []string{signature, ";",}, con ""))
            }
            case Err(message) {
                return Err(message)
            }
        }
    }
    lines = append(lines, "")
    for mut function := 0; function < ir.FunctionCount(con program); function = function + 1 {
        if ir.FunctionName(con program, function) != "main" {
            match emitThunk(con program, function) {
                case Ok(emitted) {
                    lines = copyLines(lines, con emitted)
                    lines = append(lines, "")
                }
                case Err(message) {
                    return Err(message)
                }
            }
        }
    }
    for mut function := 0; function < ir.FunctionCount(con program); function = function + 1 {
        match emitFunction(con program, function) {
            case Ok(emitted) {
                lines = copyLines(lines, con emitted)
                lines = append(lines, "")
            }
            case Err(message) {
                return Err(message)
            }
        }
    }
    lines = append(lines, "")
    return Ok(strings.join(con lines, con "\n"))
}
