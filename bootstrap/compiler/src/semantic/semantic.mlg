package semantic

import "std/strings"
import "bootstrap_compiler/frontend/ast"
import "bootstrap_compiler/frontend/source"
import "bootstrap_compiler/frontend/token"

pub type ResolvedType struct {
    text string
    kind string
    copy bool
    cleanup bool
}

pub type TypeShape struct {
    text string
    kind string
    copy bool
    cleanup bool
    arguments []ResolvedType
    arrayLength int
}

pub type FieldSig struct {
    name string
    ty ResolvedType
}

pub type StructSig struct {
    name string
    intrinsic string
    intrinsicArgs []ResolvedType
    fields []FieldSig
}

pub type EnumVariantSig struct {
    name string
    payloads []ResolvedType
}

pub type EnumSig struct {
    name string
    intrinsic string
    patternName string
    variants []EnumVariantSig
}

pub type ParamSig struct {
    name string
    mode string
    ty ResolvedType
}

pub type FunctionSig struct {
    name string
    intrinsic string
    mutable bool
    params []ParamSig
    returnType ResolvedType
}

pub type MethodSig struct {
    name string
    receiver ParamSig
    params []ParamSig
    returnType ResolvedType
}

pub type TypedNode struct {
    node int
    ty ResolvedType
}

pub type FunctionReference struct {
    node int
    function int
    direct bool
}

pub type ClosureCapture struct {
    name string
    ty ResolvedType
    mutable bool
}

pub type CheckedClosure struct {
    node int
    function int
    captures []ClosureCapture
}

pub type CaptureUse struct {
    name string
    mutable bool
}

pub type Local struct {
    name string
    mutable bool
    borrowed bool
    moved bool
    rangeSource bool
    capture bool
    ty ResolvedType
    function int
    scopeDepth int
}

pub type BorrowPlace struct {
    root string
    segments []string
    ty ResolvedType
    exclusive bool
}

type RangeBindings struct {
    indexName string
    valueName string
    valid bool
}

type PatternVariantParts struct {
    typeName string
    variantName string
    valid bool
}

type PatternBinding struct {
    name string
    ty ResolvedType
}

type PatternCoverage struct {
    bindings []PatternBinding
    leaves [][]string
}

type AdtPatternPayload struct {
    kind string
    node int
    name string
}

pub type CheckedProgram struct {
    typeShapes []TypeShape
    structs []StructSig
    enums []EnumSig
    functions []FunctionSig
    functionTypes []FunctionSig
    methods []MethodSig
    typedNodes []TypedNode
    functionReferences []FunctionReference
    closures []CheckedClosure
    captureUses []CaptureUse
    closureMutable bool
    closureNode int
    recursiveBindings []string
    locals []Local
    scopeDepth int
    loopDepth int
}

pub type SemanticError struct {
    message string
    span source.Span
}

pub func Check(con program ast.Program) Result[CheckedProgram, SemanticError] {
    mut checked := CheckedProgram{typeShapes: []TypeShape{}, structs: []StructSig{}, enums: []EnumSig{}, functions: []FunctionSig{}, functionTypes: []FunctionSig{}, methods: []MethodSig{}, typedNodes: []TypedNode{}, functionReferences: []FunctionReference{}, closures: []CheckedClosure{}, captureUses: []CaptureUse{}, closureMutable: false, closureNode: -1, recursiveBindings: []string{}, locals: []Local{}, scopeDepth: 0, loopDepth: 0,}

    match checked.collectEnumNames(con program) {
        case Ok(_) {}
        case Err(error) {
            return Err(error)
        }
    }
    match checked.collectStructNames(con program) {
        case Ok(_) {}
        case Err(error) {
            return Err(error)
        }
    }
    match checked.collectStructFields(con program) {
        case Ok(_) {}
        case Err(error) {
            return Err(error)
        }
    }
    match checked.collectEnumVariants(con program) {
        case Ok(_) {}
        case Err(error) {
            return Err(error)
        }
    }
    match checked.collectFunctionSignatures(con program) {
        case Ok(_) {}
        case Err(error) {
            return Err(error)
        }
    }
    if !checked.hasFunction(con "main") {
        root := ast.Root(con program)
        return Err(newError("program must declare `func main()`", ast.Span(con program, root)))
    }
    match checked.checkFunctionBodies(con program) {
        case Ok(_) {}
        case Err(error) {
            return Err(error)
        }
    }
    match checked.checkTestBodies(con program) {
        case Ok(_) {}
        case Err(error) {
            return Err(error)
        }
    }

    return Ok(checked)
}

pub func NodeType(con checked CheckedProgram, node int) Result[string, bool] {
    for mut index := 0; index < len(checked.typedNodes); index = index + 1 {
        if checked.typedNodes[index].node == node {
            return Ok(token.CopyText(con checked.typedNodes[index].ty.text))
        }
    }
    return Err(false)
}

pub func NodeTypeKind(con checked CheckedProgram, node int) Result[string, bool] {
    for mut index := 0; index < len(checked.typedNodes); index = index + 1 {
        if checked.typedNodes[index].node == node {
            return Ok(token.CopyText(con checked.typedNodes[index].ty.kind))
        }
    }
    return Err(false)
}

pub func NodeNeedsCleanup(con checked CheckedProgram, node int) bool {
    for mut index := 0; index < len(checked.typedNodes); index = index + 1 {
        if checked.typedNodes[index].node == node {
            return checked.typedNodes[index].ty.cleanup
        }
    }
    return false
}

pub func NodeTypeArgument(con checked CheckedProgram, node int, argument int) Result[string, bool] {
    for mut index := 0; index < len(checked.typedNodes); index = index + 1 {
        if checked.typedNodes[index].node == node {
            return match checked.typeArgument(con checked.typedNodes[index].ty, argument) {
                case Ok(ty) {
                    Ok(token.CopyText(con ty.text))
                }
                case Err(_) {
                    Err(false)
                }
            }
        }
    }
    return Err(false)
}

pub func NodeTypeArgumentNeedsCleanup(con checked CheckedProgram, node int, argument int) bool {
    for mut index := 0; index < len(checked.typedNodes); index = index + 1 {
        if checked.typedNodes[index].node == node {
            return match checked.typeArgument(con checked.typedNodes[index].ty, argument) {
                case Ok(ty) {
                    ty.cleanup
                }
                case Err(_) {
                    false
                }
            }
        }
    }
    return false
}

pub func TypeArgument(con checked CheckedProgram, con name string, argument int) Result[string, bool] {
    for mut shape := 0; shape < len(checked.typeShapes); shape = shape + 1 {
        if checked.typeShapes[shape].text == name {
            if argument < 0 || argument >= len(checked.typeShapes[shape].arguments) {
                return Err(false)
            }
            return Ok(token.CopyText(con checked.typeShapes[shape].arguments[argument].text))
        }
    }
    return Err(false)
}

pub func TypeArgumentNeedsCleanup(con checked CheckedProgram, con name string, argument int) bool {
    for mut shape := 0; shape < len(checked.typeShapes); shape = shape + 1 {
        if checked.typeShapes[shape].text == name {
            if argument < 0 || argument >= len(checked.typeShapes[shape].arguments) {
                return false
            }
            return checked.typeShapes[shape].arguments[argument].cleanup
        }
    }
    return false
}

