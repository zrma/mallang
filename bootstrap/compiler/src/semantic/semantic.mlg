pub func ClosureIndexForNode(con checked CheckedProgram, node int) int {
    for mut index := 0; index < len(checked.closures); index = index + 1 {
        if checked.closures[index].node == node {
            return index
        }
    }
    return - 1
}

pub func ClosureNode(con checked CheckedProgram, closure int) int {
    return checked.closures[closure].node
