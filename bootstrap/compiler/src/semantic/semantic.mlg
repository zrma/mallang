pub func StructFieldCount(con checked CheckedProgram, con name string) int {
    structure := checked.structIndex(con name)
    if structure < 0 {
        return - 1
    }
    return len(checked.structs[structure].fields)
}

pub func StructFieldName(con checked CheckedProgram, con name string, field int) string {
    structure := checked.structIndex(con name)
    if structure < 0 || field < 0 || field >= len(checked.structs[structure].fields) {
        return ""
    }
    return token.CopyText(con checked.structs[structure].fields[field].name)
}

pub func StructFieldType(con checked CheckedProgram, con name string, field int) string {
