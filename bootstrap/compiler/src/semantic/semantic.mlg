pub func ErrorMessage(con error SemanticError) string {
    return token.CopyText(con error.message)
}

pub func ErrorSpan(con error SemanticError) source.Span {
    return source.Copy(con error.span)
}

pub func NormalizeError(con error SemanticError) string {
    span := source.Copy(con error.span)
    parts := []string{"SERR|", strings.fromInt(source.Source(con span)), "|", strings.fromInt(source.Start(con span)), "|", strings.fromInt(source.End(con span)), "|", token.EncodeBytes(con error.message),}
    return strings.join(con parts, con "")
}

pub func Normalize(con checked CheckedProgram) string {
    lines := []string{strings.join(con []string{"CHECKED|", strings.fromInt(len(checked.structs)), "|", strings.fromInt(len(checked.enums)), "|", strings.fromInt(len(checked.functions)), "|", strings.fromInt(len(checked.methods)),}, con ""),}

    mut output := lines
    for mut structIndex := 0; structIndex < len(checked.structs); structIndex = structIndex + 1 {
        output = append(output, strings.join(con []string{"STRUCT|", token.CopyText(con checked.structs[structIndex].name), "|", strings.fromInt(len(checked.structs[structIndex].fields)),}, con ""))
        for mut fieldIndex := 0; fieldIndex < len(checked.structs[structIndex].fields); fieldIndex = fieldIndex + 1 {
            output = append(output, strings.join(con []string{"FIELD|", token.CopyText(con checked.structs[structIndex].name), "|", token.CopyText(con checked.structs[structIndex].fields[fieldIndex].name), "|", token.CopyText(con checked.structs[structIndex].fields[fieldIndex].ty.text),}, con ""))
        }
    }
    for mut enumIndex := 0; enumIndex < len(checked.enums); enumIndex = enumIndex + 1 {
        output = append(output, strings.join(con []string{"ENUM|", token.CopyText(con checked.enums[enumIndex].name), "|", strings.fromInt(len(checked.enums[enumIndex].variants)),}, con ""))
        for mut variantIndex := 0; variantIndex < len(checked.enums[enumIndex].variants); variantIndex = variantIndex + 1 {
            mut line := strings.join(con []string{"VARIANT|", token.CopyText(con checked.enums[enumIndex].name), "|", token.CopyText(con checked.enums[enumIndex].variants[variantIndex].name), "|", strings.fromInt(len(checked.enums[enumIndex].variants[variantIndex].payloads)),}, con "")
            for mut payloadIndex := 0; payloadIndex < len(checked.enums[enumIndex].variants[variantIndex].payloads); payloadIndex = payloadIndex + 1 {
                line = strings.join(con []string{line, "|", token.CopyText(con checked.enums[enumIndex].variants[variantIndex].payloads[payloadIndex].text),}, con "")
            }
            output = append(output, line)
        }
    }
    for mut functionIndex := 0; functionIndex < len(checked.functions); functionIndex = functionIndex + 1 {
        output = append(output, strings.join(con []string{"FUNC|", token.CopyText(con checked.functions[functionIndex].name), "|", token.CopyText(con checked.functions[functionIndex].returnType.text), "|", strings.fromInt(len(checked.functions[functionIndex].params)),}, con ""))
        for mut paramIndex := 0; paramIndex < len(checked.functions[functionIndex].params); paramIndex = paramIndex + 1 {
            output = append(output, strings.join(con []string{"PARAM|", token.CopyText(con checked.functions[functionIndex].name), "|", token.CopyText(con checked.functions[functionIndex].params[paramIndex].mode), "|", token.CopyText(con checked.functions[functionIndex].params[paramIndex].name), "|", token.CopyText(con checked.functions[functionIndex].params[paramIndex].ty.text),}, con ""))
        }
    }
    for mut methodIndex := 0; methodIndex < len(checked.methods); methodIndex = methodIndex + 1 {
        output = append(output, strings.join(con []string{"METHOD|", token.CopyText(con checked.methods[methodIndex].receiver.ty.text), "|", token.CopyText(con checked.methods[methodIndex].name), "|", token.CopyText(con checked.methods[methodIndex].receiver.mode), "|", token.CopyText(con checked.methods[methodIndex].receiver.name), "|", token.CopyText(con checked.methods[methodIndex].returnType.text), "|", strings.fromInt(len(checked.methods[methodIndex].params)),}, con ""))
        for mut paramIndex := 0; paramIndex < len(checked.methods[methodIndex].params); paramIndex = paramIndex + 1 {
            output = append(output, strings.join(con []string{"MPARAM|", token.CopyText(con checked.methods[methodIndex].receiver.ty.text), "|", token.CopyText(con checked.methods[methodIndex].name), "|", token.CopyText(con checked.methods[methodIndex].params[paramIndex].mode), "|", token.CopyText(con checked.methods[methodIndex].params[paramIndex].name), "|", token.CopyText(con checked.methods[methodIndex].params[paramIndex].ty.text),}, con ""))
        }
    }

    return strings.join(con output, con "\n")
}

func (mut self CheckedProgram) collectEnumNames(con program ast.Program) Result[bool, SemanticError] {
    root := ast.Root(con program)
    for mut child := 0; child < ast.ChildCount(con program, root); child = child + 1 {
        declaration := ast.Child(con program, root, child)
        kind := ast.Kind(con program, declaration)
        if isEnumKind(con kind) {
            name := ast.Value(con program, declaration)
            if isBuiltinTypeName(con name) {
                return Err(newError(strings.join(con []string{"`", token.CopyText(con name), "` is a built-in type name",}, con ""), ast.Span(con program, declaration)))
            }
            if isBuiltinValueName(con name) {
                return Err(newError(strings.join(con []string{"`", token.CopyText(con name), "` is a built-in value name",}, con ""), ast.Span(con program, declaration)))
            }
            if self.hasEnum(con name) {
                return Err(newError(strings.join(con []string{"duplicate enum `", token.CopyText(con name), "`",}, con ""), ast.Span(con program, declaration)))
            }
            mut patternName := token.CopyText(con name)
            for mut item := 0; item < ast.ChildCount(con program, declaration); item = item + 1 {
                metadata := ast.Child(con program, declaration, item)
                if ast.Kind(con program, metadata) == "SpecializationOrigin" {
                    patternName = ast.Value(con program, metadata)
                }
            }
            intrinsic := declarationMetadata(con program, declaration, con "Intrinsic.Type")
            self.enums = append(self.enums, EnumSig{name: name, intrinsic: intrinsic, patternName: patternName, variants: []EnumVariantSig{}})
        }
    }
    return Ok(true)
}

func (mut self CheckedProgram) collectStructNames(con program ast.Program) Result[bool, SemanticError] {
    root := ast.Root(con program)
    for mut child := 0; child < ast.ChildCount(con program, root); child = child + 1 {
        declaration := ast.Child(con program, root, child)
        kind := ast.Kind(con program, declaration)
        if isStructKind(con kind) {
            name := ast.Value(con program, declaration)
            if isBuiltinTypeName(con name) {
                return Err(newError(strings.join(con []string{"`", token.CopyText(con name), "` is a built-in type name",}, con ""), ast.Span(con program, declaration)))
            }
            if isBuiltinValueName(con name) {
                return Err(newError(strings.join(con []string{"`", token.CopyText(con name), "` is a built-in value name",}, con ""), ast.Span(con program, declaration)))
            }
            if self.hasEnum(con name) {
                return Err(newError(strings.join(con []string{"type `", token.CopyText(con name), "` is declared as both a struct and an enum",}, con ""), ast.Span(con program, declaration)))
            }
            if self.hasStruct(con name) {
                return Err(newError(strings.join(con []string{"duplicate struct `", token.CopyText(con name), "`",}, con ""), ast.Span(con program, declaration)))
            }
            intrinsic := declarationMetadata(con program, declaration, con "Intrinsic.Type")
            self.structs = append(self.structs, StructSig{name: name, intrinsic: intrinsic, intrinsicArgs: []ResolvedType{}, fields: []FieldSig{}})
        }
    }
    return Ok(true)
}

func (mut self CheckedProgram) collectStructFields(con program ast.Program) Result[bool, SemanticError] {
    root := ast.Root(con program)
    mut structIndex := 0
    for mut child := 0; child < ast.ChildCount(con program, root); child = child + 1 {
        declaration := ast.Child(con program, root, child)
        kind := ast.Kind(con program, declaration)
        if isStructKind(con kind) {
            mut intrinsicArgs := []ResolvedType{}
            for mut item := 0; item < ast.ChildCount(con program, declaration); item = item + 1 {
                fieldNode := ast.Child(con program, declaration, item)
                fieldKind := ast.Kind(con program, fieldNode)
                if fieldKind == "TypeParam" {
                    return Err(newError("B2a semantic checker does not yet accept generic declarations", ast.Span(con program, declaration)))
                }
                if fieldKind == "FieldDecl" {
                    name := ast.Value(con program, fieldNode)
                    if hasField(con self.structs[structIndex], con name) {
                        message := strings.join(con []string{"duplicate field `", token.CopyText(con name), "` in `", token.CopyText(con self.structs[structIndex].name), "`",}, con "")
                        return Err(newError(message, ast.Span(con program, fieldNode)))
                    }
                    typeNode := ast.Child(con program, fieldNode, 0)
                    match self.resolveType(con program, typeNode) {
                        case Ok(ty) {
                            self.structs[structIndex].fields = append(self.structs[structIndex].fields, FieldSig{name: name, ty: ty})
                        }
                        case Err(error) {
                            return Err(error)
                        }
                    }
                } else if fieldKind == "Intrinsic.Type" {
                    for mut argument := 0; argument < ast.ChildCount(con program, fieldNode); argument = argument + 1 {
                        match self.resolveType(con program, ast.Child(con program, fieldNode, argument)) {
                            case Ok(ty) {
                                intrinsicArgs = append(intrinsicArgs, ty)
                            }
                            case Err(error) {
                                return Err(error)
                            }
                        }
                    }
                }
            }
            self.structs[structIndex].intrinsicArgs = intrinsicArgs
            if self.structs[structIndex].intrinsic == "Map" {
                if len(self.structs[structIndex].intrinsicArgs) != 2 {
                    return Err(newError("compiler-owned collections.Map must have two type arguments", ast.Span(con program, declaration)))
                }
                key := copyType(con self.structs[structIndex].intrinsicArgs[0])
                if key.kind != "int" && key.kind != "bool" && key.kind != "string" && !startsWith(con key.text, con "__mlg_symbolic_type_") {
                    message := strings.join(con []string{"collections.Map key type must be `int`, `bool`, or `string`, got `", token.CopyText(con key.text), "`",}, con "")
                    return Err(newError(message, ast.Span(con program, declaration)))
                }
            }
            structIndex = structIndex + 1
        }
    }
    return Ok(true)
}

func (mut self CheckedProgram) collectEnumVariants(con program ast.Program) Result[bool, SemanticError] {
    root := ast.Root(con program)
    mut enumIndex := 0
    for mut child := 0; child < ast.ChildCount(con program, root); child = child + 1 {
        declaration := ast.Child(con program, root, child)
        kind := ast.Kind(con program, declaration)
        if isEnumKind(con kind) {
            mut variantCount := 0
            for mut item := 0; item < ast.ChildCount(con program, declaration); item = item + 1 {
                variantNode := ast.Child(con program, declaration, item)
                variantKind := ast.Kind(con program, variantNode)
                if variantKind == "TypeParam" {
                    return Err(newError("B2a semantic checker does not yet accept generic declarations", ast.Span(con program, declaration)))
                }
                if variantKind == "EnumVariant" {
                    variantCount = variantCount + 1
                    name := ast.Value(con program, variantNode)
                    if hasVariant(con self.enums[enumIndex], con name) {
                        message := strings.join(con []string{"duplicate variant `", token.CopyText(con name), "` in enum `", token.CopyText(con self.enums[enumIndex].name), "`",}, con "")
                        return Err(newError(message, ast.Span(con program, variantNode)))
                    }
                    mut payloads := []ResolvedType{}
                    for mut payload := 0; payload < ast.ChildCount(con program, variantNode); payload = payload + 1 {
                        typeNode := ast.Child(con program, variantNode, payload)
                        match self.resolveType(con program, typeNode) {
                            case Ok(ty) {
                                payloads = append(payloads, ty)
                            }
                            case Err(error) {
                                return Err(error)
                            }
                        }
                    }
                    self.enums[enumIndex].variants = append(self.enums[enumIndex].variants, EnumVariantSig{name: name, payloads: payloads})
                }
            }
            if variantCount == 0 {
                message := strings.join(con []string{"enum `", token.CopyText(con self.enums[enumIndex].name), "` must declare at least one variant",}, con "")
                return Err(newError(message, ast.Span(con program, declaration)))
            }
            enumIndex = enumIndex + 1
        }
    }
    return Ok(true)
}

func (mut self CheckedProgram) collectFunctionSignatures(con program ast.Program) Result[bool, SemanticError] {
    root := ast.Root(con program)
    for mut child := 0; child < ast.ChildCount(con program, root); child = child + 1 {
        declaration := ast.Child(con program, root, child)
        kind := ast.Kind(con program, declaration)
        if isFunctionKind(con kind) {
            name := ast.Value(con program, declaration)
            mut receiverNode := -1
            mut returnNode := -1
            mut paramNodes := []int{}
            for mut item := 0; item < ast.ChildCount(con program, declaration); item = item + 1 {
                node := ast.Child(con program, declaration, item)
                nodeKind := ast.Kind(con program, node)
                if nodeKind == "TypeParam" {
                    return Err(newError("B2a semantic checker does not yet accept generic declarations", ast.Span(con program, declaration)))
                } else if nodeKind == "Receiver" {
                    receiverNode = ast.Child(con program, node, 0)
                } else if nodeKind == "ReturnType" {
                    returnNode = ast.Child(con program, node, 0)
                } else if isParamKind(con nodeKind) {
                    paramNodes = append(paramNodes, node)
                }
            }

            if name == "main" {
                if receiverNode >= 0 {
                    return Err(newError("`main` must not declare a method receiver", ast.Span(con program, declaration)))
                }
                if len(paramNodes) > 0 {
                    return Err(newError("`main` must not take parameters", ast.Span(con program, paramNodes[0])))
                }
                if returnNode >= 0 {
                    return Err(newError("`main` must not declare a return type in v0", ast.Span(con program, returnNode)))
                }
            }

            mut params := []ParamSig{}
            for mut paramIndex := 0; paramIndex < len(paramNodes); paramIndex = paramIndex + 1 {
                match self.resolveParam(con program, paramNodes[paramIndex]) {
                    case Ok(param) {
                        if hasParam(con params, con param.name) {
                            return Err(newError(strings.join(con []string{"duplicate parameter `", token.CopyText(con param.name), "`",}, con ""), ast.Span(con program, declaration)))
                        }
                        params = append(params, param)
                    }
                    case Err(error) {
                        return Err(error)
                    }
                }
            }

            mut returnType := unitType()
            if returnNode >= 0 {
                match self.resolveType(con program, returnNode) {
                    case Ok(ty) {
                        returnType = ty
                    }
                    case Err(error) {
                        return Err(error)
                    }
                }
            }

            if receiverNode >= 0 {
                match self.resolveParam(con program, receiverNode) {
                    case Ok(receiver) {
                        if receiver.ty.kind != "struct" {
                            return Err(newError("method receiver must be a struct type in v0", ast.Span(con program, receiverNode)))
                        }
                        if self.hasMethod(con receiver.ty.text, con name) {
                            return Err(newError(strings.join(con []string{"duplicate method `", token.CopyText(con name), "`",}, con ""), ast.Span(con program, declaration)))
                        }
                        self.methods = append(self.methods, MethodSig{name: name, receiver: receiver, params: params, returnType: returnType})
                    }
                    case Err(error) {
                        return Err(error)
                    }
                }
            } else {
                if isBuiltinTypeName(con name) {
                    return Err(newError(strings.join(con []string{"`", token.CopyText(con name), "` is a built-in type name",}, con ""), ast.Span(con program, declaration)))
                }
                if isBuiltinValueName(con name) {
                    return Err(newError(strings.join(con []string{"`", token.CopyText(con name), "` is a built-in value name",}, con ""), ast.Span(con program, declaration)))
                }
                if self.hasStruct(con name) {
                    return Err(newError(strings.join(con []string{"top-level function `", token.CopyText(con name), "` conflicts with struct `", token.CopyText(con name), "`",}, con ""), ast.Span(con program, declaration)))
                }
                if self.hasEnum(con name) {
                    return Err(newError(strings.join(con []string{"top-level function `", token.CopyText(con name), "` conflicts with enum `", token.CopyText(con name), "`",}, con ""), ast.Span(con program, declaration)))
                }
                if self.hasFunction(con name) {
                    return Err(newError(strings.join(con []string{"duplicate function `", token.CopyText(con name), "`",}, con ""), ast.Span(con program, declaration)))
                }
                intrinsic := declarationMetadata(con program, declaration, con "Intrinsic.Function")
                self.functions = append(self.functions, FunctionSig{name: name, intrinsic: intrinsic, mutable: false, params: params, returnType: returnType})
            }
        }
    }
    return Ok(true)
}

func (mut self CheckedProgram) checkFunctionBodies(con program ast.Program) Result[bool, SemanticError] {
    root := ast.Root(con program)
    for mut child := 0; child < ast.ChildCount(con program, root); child = child + 1 {
        declaration := ast.Child(con program, root, child)
        declarationKind := ast.Kind(con program, declaration)
        if isFunctionKind(con declarationKind) {
            name := ast.Value(con program, declaration)
            mut receiverNode := -1
            mut blockNode := -1
            for mut item := 0; item < ast.ChildCount(con program, declaration); item = item + 1 {
                node := ast.Child(con program, declaration, item)
                nodeKind := ast.Kind(con program, node)
                if nodeKind == "Receiver" {
                    receiverNode = ast.Child(con program, node, 0)
                } else if nodeKind == "Block" {
                    blockNode = node
                }
            }

            mut locals := []Local{}
            mut returnType := unitType()
            if receiverNode >= 0 {
                receiverTypeNode := ast.Child(con program, receiverNode, 0)
                mut receiverTypeName := ""
                match self.resolveType(con program, receiverTypeNode) {
                    case Ok(receiverType) {
                        receiverTypeName = token.CopyText(con receiverType.text)
                    }
                    case Err(error) {
                        return Err(error)
                    }
                }
                methodIndex := self.methodIndex(con receiverTypeName, con name)
                if methodIndex < 0 {
                    return Err(newError("checked method signature is missing", ast.Span(con program, declaration)))
                }
                mut receiverLocal := localFromParam(con self.methods[methodIndex].receiver)
                receiverLocal.function = self.functionIndexForType(con receiverLocal.ty)
                locals = append(locals, receiverLocal)
                for mut param := 0; param < len(self.methods[methodIndex].params); param = param + 1 {
                    mut local := localFromParam(con self.methods[methodIndex].params[param])
                    local.function = self.functionIndexForType(con local.ty)
                    locals = append(locals, local)
                }
                returnType = copyType(con self.methods[methodIndex].returnType)
            } else {
                functionIndex := self.functionIndex(con name)
                if functionIndex < 0 {
                    return Err(newError("checked function signature is missing", ast.Span(con program, declaration)))
                }
                if self.functions[functionIndex].intrinsic != "" {
                    continue
                }
                for mut param := 0; param < len(self.functions[functionIndex].params); param = param + 1 {
                    mut local := localFromParam(con self.functions[functionIndex].params[param])
                    local.function = self.functionIndexForType(con local.ty)
                    locals = append(locals, local)
                }
                returnType = copyType(con self.functions[functionIndex].returnType)
            }

            self.locals = locals
            self.scopeDepth = 0
            self.loopDepth = 0
            match self.checkBlock(con program, blockNode, con returnType) {
                case Ok(returned) {
                    if returnType.kind != "unit" && !returned {
                        message := strings.join(con []string{"function `", token.CopyText(con name), "` must return `", token.CopyText(con returnType.text), "`",}, con "")
                        return Err(newError(message, ast.Span(con program, declaration)))
                    }
                }
                case Err(error) {
                    return Err(error)
                }
            }
        }
    }
    return Ok(true)
}

func (mut self CheckedProgram) checkTestBodies(con program ast.Program) Result[bool, SemanticError] {
    root := ast.Root(con program)
    for mut child := 0; child < ast.ChildCount(con program, root); child = child + 1 {
        declaration := ast.Child(con program, root, child)
        if ast.Kind(con program, declaration) == "TestDecl" {
            if ast.ChildCount(con program, declaration) != 1 {
                return Err(newError("checked test declaration body is missing", ast.Span(con program, declaration)))
            }
            self.locals = []Local{}
            self.scopeDepth = 0
            self.loopDepth = 0
            match self.checkBlock(con program, ast.Child(con program, declaration, 0), con unitType()) {
                case Ok(_) {}
                case Err(error) {
                    return Err(error)
                }
            }
        }
    }
    return Ok(true)
}

func (mut self CheckedProgram) checkBlock(con program ast.Program, block int, con returnType ResolvedType) Result[bool, SemanticError] {
    mut returned := false
    for mut statementIndex := 0; statementIndex < ast.ChildCount(con program, block); statementIndex = statementIndex + 1 {
        statement := ast.Child(con program, block, statementIndex)
        match self.checkStatement(con program, statement, con returnType) {
            case Ok(statementReturned) {
                if statementReturned {
                    returned = true
                }
            }
            case Err(error) {
                return Err(error)
            }
        }
    }
    return Ok(returned)
}

func (mut self CheckedProgram) checkStatement(con program ast.Program, statement int, con returnType ResolvedType) Result[bool, SemanticError] {
    kind := ast.Kind(con program, statement)
    if kind == "Stmt.Let.Immutable" || kind == "Stmt.Let.Mutable" {
        name := ast.Value(con program, statement)
        if isBuiltinValueName(con name) {
            return Err(newError(strings.join(con []string{"`", token.CopyText(con name), "` is a built-in value name",}, con ""), ast.Span(con program, statement)))
        }
        expression := ast.Child(con program, statement, 0)
        existingBefore := localIndex(con self.locals, con name)
        outerRecursiveBindings := copyTexts(con self.recursiveBindings)
        expressionKind := ast.Kind(con program, expression)
        if(expressionKind == "Expr.FunctionLiteral.Immutable" || expressionKind == "Expr.FunctionLiteral.Mutable") && existingBefore < 0 {
            self.recursiveBindings = append(self.recursiveBindings, token.CopyText(con name))
        }
        match self.checkExpression(con program, expression) {
            case Ok(ty) {
                self.recursiveBindings = copyTexts(con outerRecursiveBindings)
                existing := localIndex(con self.locals, con name)
                if existing >= 0 && self.locals[existing].scopeDepth == self.scopeDepth {
                    message := strings.join(con []string{"binding `", token.CopyText(con name), "` already exists in this block",}, con "")
                    return Err(newError(message, ast.Span(con program, statement)))
                }
                mut function := -1
                reference := self.functionReferenceIndex(expression)
                if reference >= 0 {
                    function = self.functionReferences[reference].function
                }
                if function == -1 && ty.kind == "function" {
                    function = self.functionIndexForType(con ty)
                }
                self.locals = append(self.locals, Local{name: name, mutable: kind == "Stmt.Let.Mutable", borrowed: false, moved: false, rangeSource: false, capture: false, ty: ty, function: function, scopeDepth: self.scopeDepth})
                return Ok(false)
            }
            case Err(error) {
                self.recursiveBindings = copyTexts(con outerRecursiveBindings)
                return Err(error)
            }
        }
    }
    if kind == "Stmt.Assign" {
        name := ast.Value(con program, statement)
        index := localIndex(con self.locals, con name)
        if index < 0 {
            return Err(newError(strings.join(con []string{"unknown variable `", token.CopyText(con name), "`",}, con ""), ast.Span(con program, statement)))
        }
        match self.checkCaptureMutation(con program, index) {
            case Ok(_) {}
            case Err(error) {
                return Err(error)
            }
        }
        if !self.locals[index].mutable {
            return Err(newError(strings.join(con []string{"cannot assign to immutable binding `", token.CopyText(con name), "`",}, con ""), ast.Span(con program, statement)))
        }
        if self.locals[index].rangeSource {
            return Err(newError(strings.join(con []string{"cannot assign to active range source `", token.CopyText(con name), "` in v0",}, con ""), ast.Span(con program, statement)))
        }
        expression := ast.Child(con program, statement, 0)
        expectedType := copyType(con self.locals[index].ty)
        match self.checkExpressionExpected(con program, expression, con "owned", con expectedType, true) {
            case Ok(valueType) {
                if valueType.text != self.locals[index].ty.text {
                    message := strings.join(con []string{"assignment type mismatch for `", token.CopyText(con name), "`: expected `", token.CopyText(con self.locals[index].ty.text), "`, got `", token.CopyText(con valueType.text), "`",}, con "")
                    return Err(newError(message, ast.Span(con program, statement)))
                }
                self.locals[index].function = -1
                reference := self.functionReferenceIndex(expression)
                if reference >= 0 {
                    self.locals[index].function = self.functionReferences[reference].function
                }
                if self.locals[index].function == -1 && valueType.kind == "function" {
                    self.locals[index].function = self.functionIndexForType(con valueType)
                }
                self.locals[index].moved = false
                return Ok(false)
            }
            case Err(error) {
                return Err(error)
            }
        }
    }
    if kind == "Stmt.FieldAssign" {
        return match self.checkFieldAssign(con program, statement) {
            case Ok(_) {
                Ok(false)
            }
            case Err(error) {
                Err(error)
            }
        }
    }
    if kind == "Stmt.IndexAssign" {
        return match self.checkIndexAssign(con program, statement) {
            case Ok(_) {
                Ok(false)
            }
            case Err(error) {
                Err(error)
            }
        }
    }
    if kind == "Stmt.If" {
        return self.checkIfStatement(con program, statement, con returnType)
    }
    if kind == "Stmt.Match" {
        return self.checkFlatMatchStatement(con program, statement, con returnType)
    }
    if kind == "Stmt.For" {
        return self.checkForStatement(con program, statement, con returnType)
    }
    if kind == "Stmt.RangeFor" {
        return self.checkRangeStatement(con program, statement, con returnType)
    }
    if kind == "Stmt.Break" || kind == "Stmt.Continue" {
        if self.loopDepth == 0 {
            mut keyword := "break"
            if kind == "Stmt.Continue" {
                keyword = "continue"
            }
            message := strings.join(con []string{"`", keyword, "` can only be used inside a loop",}, con "")
            return Err(newError(message, ast.Span(con program, statement)))
        }
        return Ok(false)
    }
    if kind == "Stmt.Assert" {
        if ast.ChildCount(con program, statement) != 1 {
            return Err(newError("checked assertion condition is missing", ast.Span(con program, statement)))
        }
        condition := ast.Child(con program, statement, 0)
        match self.checkExpression(con program, condition) {
            case Ok(conditionType) {
                if conditionType.kind != "bool" {
                    return Err(newError("assertion condition must have type `bool`", ast.Span(con program, condition)))
                }
                return Ok(false)
            }
            case Err(error) {
                return Err(error)
            }
        }
    }
    if kind == "Stmt.Return" {
        expression := ast.Child(con program, statement, 0)
        match self.checkExpressionExpected(con program, expression, con "owned", con returnType, true) {
            case Ok(valueType) {
                if valueType.text != returnType.text {
                    message := strings.join(con []string{"return type mismatch: expected `", token.CopyText(con returnType.text), "`, got `", token.CopyText(con valueType.text), "`",}, con "")
                    return Err(newError(message, ast.Span(con program, statement)))
                }
                return Ok(true)
            }
            case Err(error) {
                return Err(error)
            }
        }
    }
    if kind == "Stmt.Expr" {
        expression := ast.Child(con program, statement, 0)
        if isPrintCall(con program, expression) {
            return match self.checkPrintCall(con program, expression) {
                case Ok(_) {
                    Ok(false)
                }
                case Err(error) {
                    Err(error)
                }
            }
        }
        return match self.checkExpression(con program, expression) {
            case Ok(_) {
                Ok(false)
            }
            case Err(error) {
                Err(error)
            }
        }
    }
    return Err(newError("B2b semantic checker does not yet accept this statement", ast.Span(con program, statement)))
}

func (mut self CheckedProgram) checkIfStatement(con program ast.Program, statement int, con returnType ResolvedType) Result[bool, SemanticError] {
    condition := ast.Child(con program, statement, 0)
    match self.checkExpression(con program, condition) {
        case Ok(conditionType) {
            if conditionType.kind != "bool" {
                return Err(newError("if condition must have type `bool`", ast.Span(con program, condition)))
            }
        }
        case Err(error) {
            return Err(error)
        }
    }

    baseLocals := copyLocals(con self.locals)
    baseDepth := self.scopeDepth
    thenBlock := ast.Child(con program, statement, 1)
    self.scopeDepth = baseDepth + 1
    mut thenReturns := false
    match self.checkBlock(con program, thenBlock, con returnType) {
        case Ok(returned) {
            thenReturns = returned
        }
        case Err(error) {
            self.locals = copyLocals(con baseLocals)
            self.scopeDepth = baseDepth
            return Err(error)
        }
    }
    thenLocals := copyLocals(con self.locals)

    self.locals = copyLocals(con baseLocals)
    self.scopeDepth = baseDepth
    mut elseReturns := false
    mut elseLocals := copyLocals(con baseLocals)
    if ast.ChildCount(con program, statement) > 2 {
        elseBlock := ast.Child(con program, statement, 2)
        self.scopeDepth = baseDepth + 1
        match self.checkBlock(con program, elseBlock, con returnType) {
            case Ok(returned) {
                elseReturns = returned
            }
            case Err(error) {
                self.locals = copyLocals(con baseLocals)
                self.scopeDepth = baseDepth
                return Err(error)
            }
        }
        elseLocals = copyLocals(con self.locals)
    }
    self.locals = mergeBranchMoves(con baseLocals, con thenLocals, con elseLocals)
    self.scopeDepth = baseDepth
    return Ok(thenReturns && elseReturns)
}

func (mut self CheckedProgram) checkFlatMatchStatement(con program ast.Program, statement int, con returnType ResolvedType) Result[bool, SemanticError] {
    if ast.ChildCount(con program, statement) < 2 {
        return Err(newError("match requires at least one arm", ast.Span(con program, statement)))
    }

    scrutinee := ast.Child(con program, statement, 0)
    mut scrutineeType := unitType()
    match self.checkExpression(con program, scrutinee) {
        case Ok(ty) {
            scrutineeType = ty
        }
        case Err(error) {
            return Err(error)
        }
    }
    if scrutineeType.kind != "option" && scrutineeType.kind != "result" && scrutineeType.kind != "enum" {
        message := strings.join(con []string{"match scrutinee must be an enum, `Option`, or `Result`, got `", token.CopyText(con scrutineeType.text), "`",}, con "")
        return Err(newError(message, ast.Span(con program, statement)))
    }
    match self.checkMatchPatterns(con program, statement, con scrutineeType) {
        case Ok(_) {}
        case Err(error) {
            return Err(error)
        }
    }

    baseLocals := copyLocals(con self.locals)
    baseDepth := self.scopeDepth
    mut mergedLocals := copyLocals(con baseLocals)
    mut allReturn := true
    for mut armIndex := 1; armIndex < ast.ChildCount(con program, statement); armIndex = armIndex + 1 {
        arm := ast.Child(con program, statement, armIndex)
        self.locals = copyLocals(con baseLocals)
        self.scopeDepth = baseDepth + 1
        match self.addMatchBindings(con program, arm, con scrutineeType) {
            case Ok(_) {}
            case Err(error) {
                self.locals = copyLocals(con baseLocals)
                self.scopeDepth = baseDepth
                return Err(error)
            }
        }
        block := ast.Child(con program, arm, 1)
        match self.checkBlock(con program, block, con returnType) {
            case Ok(returned) {
                allReturn = allReturn && returned
                armLocals := copyLocals(con self.locals)
                mergedLocals = mergeBranchMoves(con baseLocals, con mergedLocals, con armLocals)
            }
            case Err(error) {
                self.locals = copyLocals(con baseLocals)
                self.scopeDepth = baseDepth
                return Err(error)
            }
        }
    }
    self.locals = mergedLocals
    self.scopeDepth = baseDepth
    return Ok(allReturn)
}

func (mut self CheckedProgram) checkForStatement(con program ast.Program, statement int, con returnType ResolvedType) Result[bool, SemanticError] {
    childCount := ast.ChildCount(con program, statement)
    if childCount < 1 {
        return Err(newError("malformed for statement", ast.Span(con program, statement)))
    }
    body := ast.Child(con program, statement, childCount - 1)
    if ast.Kind(con program, body) != "Block" {
        return Err(newError("B2c3b checker does not yet accept three-clause for statements", ast.Span(con program, statement)))
    }

    baseLocals := copyLocals(con self.locals)
    baseDepth := self.scopeDepth
    baseLoopDepth := self.loopDepth
    loopScopeDepth := baseDepth + 1
    mut loopLocals := copyLocals(con baseLocals)
    mut initNode := -1
    mut conditionNode := -1
    mut postNode := -1

    for mut childIndex := 0; childIndex < childCount - 1; childIndex = childIndex + 1 {
        child := ast.Child(con program, statement, childIndex)
        childKind := ast.Kind(con program, child)
        if childKind == "ForInit.Let.Immutable" || childKind == "ForInit.Let.Mutable" {
            initNode = child
        } else if childKind == "ForCondition" {
            conditionNode = child
        } else if childKind == "ForPost.Assign" {
            postNode = child
        } else {
            return Err(newError("malformed for statement child", ast.Span(con program, child)))
        }
    }

    if initNode >= 0 {
        self.locals = copyLocals(con loopLocals)
        self.scopeDepth = loopScopeDepth
        match self.checkForInit(con program, initNode, con ast.Span(con program, statement)) {
            case Ok(_) {
                loopLocals = copyLocals(con self.locals)
            }
            case Err(error) {
                self.locals = copyLocals(con baseLocals)
                self.scopeDepth = baseDepth
                return Err(error)
            }
        }
    }

    if conditionNode >= 0 {
        condition := ast.Child(con program, conditionNode, 0)
        self.locals = copyLocals(con loopLocals)
        match self.checkExpression(con program, condition) {
            case Ok(conditionType) {
                if conditionType.kind != "bool" {
                    self.locals = copyLocals(con baseLocals)
                    return Err(newError("for condition must have type `bool`", ast.Span(con program, condition)))
                }
            }
            case Err(error) {
                self.locals = copyLocals(con baseLocals)
                return Err(error)
            }
        }
        conditionLocals := copyLocals(con self.locals)
        match rejectLoopPersistentMoves(con loopLocals, con conditionLocals, loopScopeDepth, con ast.Span(con program, condition)) {
            case Ok(_) {
                loopLocals = conditionLocals
            }
            case Err(error) {
                self.locals = copyLocals(con baseLocals)
                return Err(error)
            }
        }
    }

    self.locals = copyLocals(con loopLocals)
    self.scopeDepth = loopScopeDepth + 1
    self.loopDepth = baseLoopDepth + 1
    match self.checkBlock(con program, body, con returnType) {
        case Ok(_) {}
        case Err(error) {
            self.locals = copyLocals(con baseLocals)
            self.scopeDepth = baseDepth
            self.loopDepth = baseLoopDepth
            return Err(error)
        }
    }
    bodyLocals := copyLocals(con self.locals)
    match rejectLoopPersistentMoves(con loopLocals, con bodyLocals, loopScopeDepth, con ast.Span(con program, body)) {
        case Ok(_) {}
        case Err(error) {
            self.locals = copyLocals(con baseLocals)
            self.scopeDepth = baseDepth
            self.loopDepth = baseLoopDepth
            return Err(error)
        }
    }

    mut postLocals := mergeLoopMoves(con loopLocals, con bodyLocals, con bodyLocals)
    if postNode >= 0 {
        postStartLocals := copyLocals(con postLocals)
        self.locals = copyLocals(con postLocals)
        self.scopeDepth = loopScopeDepth
        match self.checkForPost(con program, postNode, con ast.Span(con program, statement)) {
            case Ok(_) {}
            case Err(error) {
                self.locals = copyLocals(con baseLocals)
                self.scopeDepth = baseDepth
                self.loopDepth = baseLoopDepth
                return Err(error)
            }
        }
        checkedPostLocals := copyLocals(con self.locals)
        match rejectLoopPersistentMoves(con postStartLocals, con checkedPostLocals, loopScopeDepth, con ast.Span(con program, statement)) {
            case Ok(_) {
                postLocals = checkedPostLocals
            }
            case Err(error) {
                self.locals = copyLocals(con baseLocals)
                self.scopeDepth = baseDepth
                self.loopDepth = baseLoopDepth
                return Err(error)
            }
        }
    }

    mergedLocals := mergeLoopMoves(con baseLocals, con loopLocals, con bodyLocals)
    self.locals = mergeLoopMoves(con mergedLocals, con postLocals, con postLocals)
    self.scopeDepth = baseDepth
    self.loopDepth = baseLoopDepth
    return Ok(false)
}

func (mut self CheckedProgram) checkRangeStatement(con program ast.Program, statement int, con returnType ResolvedType) Result[bool, SemanticError] {
    if ast.ChildCount(con program, statement) != 2 {
        return Err(newError("malformed range statement", ast.Span(con program, statement)))
    }
    bindings := parseRangeBindings(con ast.Value(con program, statement))
    if !bindings.valid {
        return Err(newError("malformed range bindings", ast.Span(con program, statement)))
    }
    if bindings.indexName != "_" && isBuiltinValueName(con bindings.indexName) {
        return Err(newError(strings.join(con []string{"`", token.CopyText(con bindings.indexName), "` is a built-in value name",}, con ""), ast.Span(con program, statement)))
    }
    if bindings.valueName != "_" && isBuiltinValueName(con bindings.valueName) {
        return Err(newError(strings.join(con []string{"`", token.CopyText(con bindings.valueName), "` is a built-in value name",}, con ""), ast.Span(con program, statement)))
    }
    if bindings.indexName != "_" && bindings.indexName == bindings.valueName {
        return Err(newError("range index and value bindings must use different names", ast.Span(con program, statement)))
    }

    rangeSource := ast.Child(con program, statement, 0)
    body := ast.Child(con program, statement, 1)
    mut sourceType := unitType()
    match self.checkExpressionUse(con program, rangeSource, con "read") {
        case Ok(ty) {
            sourceType = ty
        }
        case Err(error) {
            return Err(error)
        }
    }
    if sourceType.kind != "array" && sourceType.kind != "slice" {
        message := strings.join(con []string{"range source must be a fixed-size array or slice, got `", token.CopyText(con sourceType.text), "`",}, con "")
        return Err(newError(message, ast.Span(con program, rangeSource)))
    }
    mut elementType := unitType()
    match self.typeArgument(con sourceType, 0) {
        case Ok(ty) {
            elementType = ty
        }
        case Err(_) {
            return Err(newError("checked range element type is missing", ast.Span(con program, rangeSource)))
        }
    }
    if bindings.valueName != "_" && !elementType.copy {
        message := strings.join(con []string{"range value binding requires a Copy element type in v0, got `", token.CopyText(con elementType.text), "`",}, con "")
        return Err(newError(message, ast.Span(con program, rangeSource)))
    }

    baseLocals := copyLocals(con self.locals)
    baseDepth := self.scopeDepth
    baseLoopDepth := self.loopDepth
    rangeScopeDepth := baseDepth + 1
    mut bodyLocals := copyLocals(con baseLocals)
    if bindings.indexName != "_" {
        bodyLocals = append(bodyLocals, Local{name: token.CopyText(con bindings.indexName), mutable: false, borrowed: false, moved: false, rangeSource: false, capture: false, ty: intType(), function: -1, scopeDepth: rangeScopeDepth,})
    }
    if bindings.valueName != "_" {
        bodyLocals = append(bodyLocals, Local{name: token.CopyText(con bindings.valueName), mutable: false, borrowed: false, moved: false, rangeSource: false, capture: false, ty: copyType(con elementType), function: -1, scopeDepth: rangeScopeDepth,})
    }
    if ast.Kind(con program, rangeSource) == "Expr.Var" {
        sourceName := ast.Value(con program, rangeSource)
        sourceLocal := localIndex(con bodyLocals, con sourceName)
        if sourceLocal >= 0 {
            bodyLocals[sourceLocal].rangeSource = true
        }
    }

    self.locals = bodyLocals
    self.scopeDepth = rangeScopeDepth + 1
    self.loopDepth = baseLoopDepth + 1
    match self.checkBlock(con program, body, con returnType) {
        case Ok(_) {}
        case Err(error) {
            self.locals = copyLocals(con baseLocals)
            self.scopeDepth = baseDepth
            self.loopDepth = baseLoopDepth
            return Err(error)
        }
    }
    checkedBodyLocals := copyLocals(con self.locals)
    match rejectLoopPersistentMoves(con baseLocals, con checkedBodyLocals, rangeScopeDepth, con ast.Span(con program, body)) {
        case Ok(_) {}
        case Err(error) {
            self.locals = copyLocals(con baseLocals)
            self.scopeDepth = baseDepth
            self.loopDepth = baseLoopDepth
            return Err(error)
        }
    }

    self.locals = mergeLoopMoves(con baseLocals, con checkedBodyLocals, con checkedBodyLocals)
    self.scopeDepth = baseDepth
    self.loopDepth = baseLoopDepth
    return Ok(false)
}

func (mut self CheckedProgram) checkForInit(con program ast.Program, init int, con span source.Span) Result[bool, SemanticError] {
    name := ast.Value(con program, init)
    if isBuiltinValueName(con name) {
        return Err(newError(strings.join(con []string{"`", token.CopyText(con name), "` is a built-in value name",}, con ""), source.Copy(con span)))
    }
    expression := ast.Child(con program, init, 0)
    match self.checkExpression(con program, expression) {
        case Ok(ty) {
            existing := localIndex(con self.locals, con name)
            if existing >= 0 && self.locals[existing].scopeDepth == self.scopeDepth {
                message := strings.join(con []string{"binding `", token.CopyText(con name), "` already exists in this block",}, con "")
                return Err(newError(message, source.Copy(con span)))
            }
            mut function := -1
            reference := self.functionReferenceIndex(expression)
            if reference >= 0 {
                function = self.functionReferences[reference].function
            }
            mutable := ast.Kind(con program, init) == "ForInit.Let.Mutable"
            self.locals = append(self.locals, Local{name: name, mutable: mutable, borrowed: false, moved: false, rangeSource: false, capture: false, ty: ty, function: function, scopeDepth: self.scopeDepth})
            return Ok(true)
        }
        case Err(error) {
            return Err(error)
        }
    }
}

func (mut self CheckedProgram) checkForPost(con program ast.Program, post int, con span source.Span) Result[bool, SemanticError] {
    target := ast.Child(con program, post, 0)
    value := ast.Child(con program, post, 1)
    targetKind := ast.Kind(con program, target)
    if targetKind == "Expr.FieldAccess" {
        base := ast.Child(con program, target, 0)
        return self.checkFieldPlaceAssign(con program, base, con ast.Value(con program, target), value)
    }
    if targetKind == "Expr.Index" {
        base := ast.Child(con program, target, 0)
        index := ast.Child(con program, target, 1)
        return self.checkIndexPlaceAssign(con program, base, index, value, con span)
    }
    if targetKind != "Expr.Var" {
        return Err(newError("for post target must be a variable, field access, or index expression", ast.Span(con program, target)))
    }
    name := ast.Value(con program, target)
    local := localIndex(con self.locals, con name)
    if local < 0 {
        return Err(newError(strings.join(con []string{"unknown variable `", token.CopyText(con name), "`",}, con ""), source.Copy(con span)))
    }
    match self.checkCaptureMutation(con program, local) {
        case Ok(_) {}
        case Err(error) {
            return Err(error)
        }
    }
    if !self.locals[local].mutable {
        return Err(newError(strings.join(con []string{"cannot assign to immutable binding `", token.CopyText(con name), "`",}, con ""), source.Copy(con span)))
    }
    if self.locals[local].rangeSource {
        return Err(newError(strings.join(con []string{"cannot assign to active range source `", token.CopyText(con name), "` in v0",}, con ""), source.Copy(con span)))
    }
    expectedType := copyType(con self.locals[local].ty)
    self.recordType(target, con expectedType)
    match self.checkExpressionExpected(con program, value, con "owned", con expectedType, true) {
        case Ok(valueType) {
            if valueType.text != self.locals[local].ty.text {
                message := strings.join(con []string{"assignment type mismatch for `", token.CopyText(con name), "`: expected `", token.CopyText(con self.locals[local].ty.text), "`, got `", token.CopyText(con valueType.text), "`",}, con "")
                return Err(newError(message, source.Copy(con span)))
            }
            self.locals[local].function = -1
            reference := self.functionReferenceIndex(value)
            if reference >= 0 {
                self.locals[local].function = self.functionReferences[reference].function
            }
            self.locals[local].moved = false
            return Ok(true)
        }
        case Err(error) {
            return Err(error)
        }
    }
}

func (mut self CheckedProgram) checkFieldAssign(con program ast.Program, statement int) Result[bool, SemanticError] {
    base := ast.Child(con program, statement, 0)
    value := ast.Child(con program, statement, 1)
    field := ast.Value(con program, statement)
    return self.checkFieldPlaceAssign(con program, base, con field, value)
}

func (mut self CheckedProgram) checkFieldPlaceAssign(con program ast.Program, base int, con field string, value int) Result[bool, SemanticError] {
    mut root := ""
    match assignmentRoot(con program, base) {
        case Ok(name) {
            root = name
        }
        case Err(_) {
            return Err(newError("field assignment target must be a direct local variable, field, or indexed element in v0", ast.Span(con program, base)))
        }
    }
    local := localIndex(con self.locals, con root)
    if local < 0 {
        return Err(newError(strings.join(con []string{"unknown variable `", token.CopyText(con root), "`",}, con ""), ast.Span(con program, base)))
    }
    match self.checkCaptureMutation(con program, local) {
        case Ok(_) {}
        case Err(error) {
            return Err(error)
        }
    }
    if !self.locals[local].mutable {
        message := strings.join(con []string{"cannot assign field of immutable binding `", token.CopyText(con root), "`",}, con "")
        return Err(newError(message, ast.Span(con program, base)))
    }

    mut baseType := unitType()
    match self.resolveAssignmentPlaceType(con program, base) {
        case Ok(ty) {
            baseType = ty
        }
        case Err(error) {
            return Err(error)
        }
    }
    mut fieldType := unitType()
    match self.resolveStructField(con baseType, con field, ast.Span(con program, base), con "field assignment") {
        case Ok(ty) {
            fieldType = ty
        }
        case Err(error) {
            return Err(error)
        }
    }
    match self.checkExpressionExpected(con program, value, con "owned", con fieldType, true) {
        case Ok(valueType) {
            if valueType.text != fieldType.text {
                message := strings.join(con []string{"field `", token.CopyText(con field), "` assignment type mismatch: expected `", token.CopyText(con fieldType.text), "`, got `", token.CopyText(con valueType.text), "`",}, con "")
                return Err(newError(message, ast.Span(con program, value)))
            }
        }
        case Err(error) {
            return Err(error)
        }
    }
    return Ok(true)
}

func (mut self CheckedProgram) checkIndexAssign(con program ast.Program, statement int) Result[bool, SemanticError] {
    base := ast.Child(con program, statement, 0)
    index := ast.Child(con program, statement, 1)
    value := ast.Child(con program, statement, 2)
    return self.checkIndexPlaceAssign(con program, base, index, value, con ast.Span(con program, statement))
}

func (mut self CheckedProgram) checkIndexPlaceAssign(con program ast.Program, base int, index int, value int, con span source.Span) Result[bool, SemanticError] {
    mut root := ""
    match assignmentRoot(con program, base) {
        case Ok(name) {
            root = name
        }
        case Err(_) {
            return Err(newError("indexed assignment target must be a local-rooted mutable array or slice in v0", ast.Span(con program, base)))
        }
    }
    local := localIndex(con self.locals, con root)
    if local < 0 {
        return Err(newError(strings.join(con []string{"unknown variable `", token.CopyText(con root), "`",}, con ""), ast.Span(con program, base)))
    }
    match self.checkCaptureMutation(con program, local) {
        case Ok(_) {}
        case Err(error) {
            return Err(error)
        }
    }
    if !self.locals[local].mutable {
        mut target := "binding"
        if assignmentHasField(con program, base) {
            target = "place of binding"
        }
        message := strings.join(con []string{"cannot assign through immutable indexed ", target, " `", token.CopyText(con root), "`",}, con "")
        return Err(newError(message, ast.Span(con program, base)))
    }

    mut baseType := unitType()
    match self.resolveAssignmentPlaceType(con program, base) {
        case Ok(ty) {
            baseType = ty
        }
        case Err(error) {
            return Err(error)
        }
    }
    if baseType.kind != "array" && baseType.kind != "slice" {
        message := strings.join(con []string{"indexed assignment target must be a fixed-size array or slice, got `", token.CopyText(con baseType.text), "`",}, con "")
        return Err(newError(message, ast.Span(con program, base)))
    }
    mut indexType := unitType()
    match self.checkExpression(con program, index) {
        case Ok(ty) {
            indexType = ty
        }
        case Err(error) {
            return Err(error)
        }
    }
    match self.validateIndex(con program, index, con indexType, con baseType) {
        case Ok(_) {}
        case Err(error) {
            return Err(error)
        }
    }
    mut element := unitType()
    match self.typeArgument(con baseType, 0) {
        case Ok(ty) {
            element = ty
        }
        case Err(_) {
            return Err(newError("checked indexed assignment element type is missing", source.Copy(con span)))
        }
    }
    match self.checkExpressionExpected(con program, value, con "owned", con element, true) {
        case Ok(valueType) {
            if valueType.text != element.text {
                message := strings.join(con []string{"indexed assignment type mismatch: expected `", token.CopyText(con element.text), "`, got `", token.CopyText(con valueType.text), "`",}, con "")
                return Err(newError(message, source.Copy(con span)))
            }
        }
        case Err(error) {
            return Err(error)
        }
    }
    return Ok(true)
}

func (mut self CheckedProgram) checkExpression(con program ast.Program, expression int) Result[ResolvedType, SemanticError] {
    return self.checkExpressionUse(con program, expression, con "owned")
}

func (mut self CheckedProgram) checkExpressionUse(con program ast.Program, expression int, con valueUse string) Result[ResolvedType, SemanticError] {
    expectedType := unitType()
    return self.checkExpressionExpected(con program, expression, con valueUse, con expectedType, false)
}

func (mut self CheckedProgram) checkExpressionExpected(con program ast.Program, expression int, con valueUse string, con expectedType ResolvedType, hasExpected bool) Result[ResolvedType, SemanticError] {
    kind := ast.Kind(con program, expression)
    if kind == "Expr.Int" {
        ty := intType()
        self.recordType(expression, con ty)
        return Ok(ty)
    }
    if kind == "Expr.String" {
        ty := stringType()
        self.recordType(expression, con ty)
        return Ok(ty)
    }
    if kind == "Expr.Bool" {
        ty := boolType()
        self.recordType(expression, con ty)
        return Ok(ty)
    }
    if kind == "Expr.Var" {
        name := ast.Value(con program, expression)
        if name == "None" {
            return self.checkNoneConstructor(con program, expression, con expectedType, hasExpected)
        }
        index := localIndex(con self.locals, con name)
        if index < 0 {
            if containsText(con self.recursiveBindings, con name) {
                message := strings.join(con []string{"recursive closure `", token.CopyText(con name), "` is not supported in v0.3",}, con "")
                return Err(newError(message, ast.Span(con program, expression)))
            }
            if name == "main" {
                return Err(newError("`main` cannot be used as a function value", ast.Span(con program, expression)))
            }
            function := self.functionIndex(con name)
            if function < 0 {
                return Err(newError(strings.join(con []string{"unknown variable `", token.CopyText(con name), "`",}, con ""), ast.Span(con program, expression)))
            }
            ty := self.functionType(function)
            self.recordType(expression, con ty)
            self.recordFunctionReference(expression, function, true)
            return Ok(ty)
        }
        if self.locals[index].moved {
            return Err(newError(strings.join(con []string{"use of moved value `", token.CopyText(con name), "`",}, con ""), ast.Span(con program, expression)))
        }
        self.markCapture(index, false)
        ty := copyType(con self.locals[index].ty)
        if valueUse == "owned" && !ty.copy {
            if self.locals[index].borrowed {
                return Err(newError(strings.join(con []string{"cannot move borrowed value `", token.CopyText(con name), "`",}, con ""), ast.Span(con program, expression)))
            }
            self.locals[index].moved = true
        }
        self.recordType(expression, con ty)
        if ty.kind == "function" {
            self.recordFunctionReference(expression, self.locals[index].function, false)
        }
        return Ok(ty)
    }
    if kind == "Expr.Call" {
        return self.checkCall(con program, expression, con expectedType, hasExpected)
    }
    if kind == "Expr.StructLiteral" {
        return self.checkStructLiteral(con program, expression, con expectedType, hasExpected)
    }
    if kind == "Expr.ArrayLiteral" {
        return self.checkArrayLiteral(con program, expression, con expectedType, hasExpected)
    }
    if kind == "Expr.FieldAccess" {
        enumIndex := self.enumSelectionIndex(con program, expression)
        if enumIndex >= 0 {
            return self.checkEnumConstructor(con program, expression, expression, enumIndex, con expectedType, hasExpected, false)
        }
        return self.checkFieldAccess(con program, expression, con valueUse)
    }
    if kind == "Expr.Index" {
        return self.checkIndexAccess(con program, expression, con valueUse)
    }
    if kind == "Expr.FunctionLiteral.Immutable" || kind == "Expr.FunctionLiteral.Mutable" {
        return self.checkFunctionLiteral(con program, expression)
    }
    if kind == "Expr.If" {
        return self.checkIfExpression(con program, expression, con valueUse, con expectedType, hasExpected)
    }
    if kind == "Expr.Match" {
        return self.checkMatchExpression(con program, expression, con valueUse, con expectedType, hasExpected)
    }
    if kind == "Expr.Unary.Negate" || kind == "Expr.Unary.Not" {
        operand := ast.Child(con program, expression, 0)
        match self.checkExpression(con program, operand) {
            case Ok(operandType) {
                if kind == "Expr.Unary.Negate" && operandType.kind != "int" {
                    return Err(newError("`-` expects an `int` operand", ast.Span(con program, operand)))
                }
                if kind == "Expr.Unary.Not" && operandType.kind != "bool" {
                    return Err(newError("`!` expects a `bool` operand", ast.Span(con program, operand)))
                }
                mut ty := intType()
                if kind == "Expr.Unary.Not" {
                    ty = boolType()
                }
                self.recordType(expression, con ty)
                return Ok(ty)
            }
            case Err(error) {
                return Err(error)
            }
        }
    }
    if isBinaryKind(con kind) {
        left := ast.Child(con program, expression, 0)
        right := ast.Child(con program, expression, 1)
        mut leftType := unitType()
        mut operandUse := "owned"
        if isEqualityKind(con kind) {
            operandUse = "read"
        }
        match self.checkExpressionUse(con program, left, con operandUse) {
            case Ok(ty) {
                leftType = ty
            }
            case Err(error) {
                return Err(error)
            }
        }
        match self.checkExpressionUse(con program, right, con operandUse) {
            case Ok(rightType) {
                combinedSpan := source.Join(ast.Span(con program, left), ast.Span(con program, right))
                if leftType.text != rightType.text {
                    return Err(newError("binary operands must have the same type", source.Copy(con combinedSpan)))
                }
                mut resultType := boolType()
                if isArithmeticKind(con kind) {
                    if leftType.kind != "int" {
                        return Err(newError("arithmetic operators currently require `int` operands", source.Copy(con combinedSpan)))
                    }
                    resultType = intType()
                } else if isEqualityKind(con kind) {
                    if leftType.kind != "int" && leftType.kind != "bool" && leftType.kind != "string" {
                        return Err(newError("equality currently supports `int`, `bool`, and `string` operands", source.Copy(con combinedSpan)))
                    }
                } else if isLogicalKind(con kind) {
                    if leftType.kind != "bool" {
                        return Err(newError("logical operators require `bool` operands", source.Copy(con combinedSpan)))
                    }
                } else if leftType.kind != "int" {
                    return Err(newError("ordering comparisons currently require `int` operands", source.Copy(con combinedSpan)))
                }
                self.recordType(expression, con resultType)
                return Ok(resultType)
            }
            case Err(error) {
                return Err(error)
            }
        }
    }
    return Err(newError("B2b semantic checker does not yet accept this expression", ast.Span(con program, expression)))
}

func (mut self CheckedProgram) checkFunctionLiteral(con program ast.Program, expression int) Result[ResolvedType, SemanticError] {
    mut params := []ParamSig{}
    mut returnType := unitType()
    mut block := -1
    for mut child := 0; child < ast.ChildCount(con program, expression); child = child + 1 {
        node := ast.Child(con program, expression, child)
        kind := ast.Kind(con program, node)
        if isParamKind(con kind) {
            match self.resolveParam(con program, node) {
                case Ok(param) {
                    if hasParam(con params, con param.name) {
                        message := strings.join(con []string{"duplicate closure parameter `", token.CopyText(con param.name), "`",}, con "")
                        return Err(newError(message, ast.Span(con program, expression)))
                    }
                    params = append(params, param)
                }
                case Err(error) {
                    return Err(error)
                }
            }
        } else if kind == "ReturnType" {
            match self.resolveType(con program, ast.Child(con program, node, 0)) {
                case Ok(ty) {
                    returnType = ty
                }
                case Err(error) {
                    return Err(error)
                }
            }
        } else if kind == "Block" {
            block = node
        }
    }
    if block < 0 {
        return Err(newError("function literal body is missing", ast.Span(con program, expression)))
    }

    mutable := ast.Kind(con program, expression) == "Expr.FunctionLiteral.Mutable"
    outerLocals := copyLocals(con self.locals)
    outerCaptureUses := copyCaptureUses(con self.captureUses)
    outerClosureMutable := self.closureMutable
    outerClosureNode := self.closureNode
    outerDepth := self.scopeDepth
    outerLoopDepth := self.loopDepth
    mut closureLocals := []Local{}
    for mut outer := 0; outer < len(outerLocals); outer = outer + 1 {
        if localIndex(con outerLocals, con outerLocals[outer].name) == outer {
            closureLocals = append(closureLocals, Local{name: token.CopyText(con outerLocals[outer].name), mutable: mutable && outerLocals[outer].mutable, borrowed: true, moved: false, rangeSource: false, capture: true, ty: copyType(con outerLocals[outer].ty), function: outerLocals[outer].function, scopeDepth: -1,})
        }
    }
    for mut param := 0; param < len(params); param = param + 1 {
        mut local := localFromParam(con params[param])
        local.function = self.functionIndexForType(con local.ty)
        closureLocals = append(closureLocals, local)
    }
    self.captureUses = []CaptureUse{}
    self.closureMutable = mutable
    self.closureNode = expression
    self.locals = closureLocals
    self.scopeDepth = 0
    self.loopDepth = 0
    mut returned := false
    match self.checkBlock(con program, block, con returnType) {
        case Ok(value) {
            returned = value
        }
        case Err(error) {
            self.locals = copyLocals(con outerLocals)
            self.captureUses = copyCaptureUses(con outerCaptureUses)
            self.closureMutable = outerClosureMutable
            self.closureNode = outerClosureNode
            self.scopeDepth = outerDepth
            self.loopDepth = outerLoopDepth
            return Err(error)
        }
    }
    closureCaptureUses := copyCaptureUses(con self.captureUses)
    self.locals = copyLocals(con outerLocals)
    self.captureUses = copyCaptureUses(con outerCaptureUses)
    self.closureMutable = outerClosureMutable
    self.closureNode = outerClosureNode
    self.scopeDepth = outerDepth
    self.loopDepth = outerLoopDepth
    if returnType.kind != "unit" && !returned {
        message := strings.join(con []string{"function literal must return `", token.CopyText(con returnType.text), "`",}, con "")
        return Err(newError(message, ast.Span(con program, expression)))
    }

    mut captures := []ClosureCapture{}
    for mut capture := 0; capture < len(closureCaptureUses); capture = capture + 1 {
        name := token.CopyText(con closureCaptureUses[capture].name)
        outer := localIndex(con self.locals, con name)
        if outer < 0 {
            return Err(newError("checked closure capture is missing", ast.Span(con program, expression)))
        }
        if self.locals[outer].moved {
            message := strings.join(con []string{"cannot capture moved value `", token.CopyText(con name), "`",}, con "")
            return Err(newError(message, ast.Span(con program, expression)))
        }
        if self.locals[outer].rangeSource {
            message := strings.join(con []string{"cannot capture active range source `", token.CopyText(con name), "`",}, con "")
            return Err(newError(message, ast.Span(con program, expression)))
        }
        if self.locals[outer].borrowed && !self.locals[outer].ty.copy {
            message := strings.join(con []string{"cannot capture borrowed non-Copy value `", token.CopyText(con name), "`",}, con "")
            return Err(newError(message, ast.Span(con program, expression)))
        }
        if mutable && closureCaptureUses[capture].mutable && !self.locals[outer].mutable {
            message := strings.join(con []string{"mutable closure capture `", token.CopyText(con name), "` requires a mutable source binding",}, con "")
            return Err(newError(message, ast.Span(con program, expression)))
        }
        captures = append(captures, ClosureCapture{name: token.CopyText(con name), ty: copyType(con self.locals[outer].ty), mutable: closureCaptureUses[capture].mutable,})
    }
    for mut capture := 0; capture < len(captures); capture = capture + 1 {
        outer := localIndex(con self.locals, con captures[capture].name)
        if self.locals[outer].capture {
            self.markCapture(outer, captures[capture].mutable)
        }
        if !captures[capture].ty.copy {
            self.locals[outer].moved = true
        }
    }

    syntheticName := strings.join(con []string{"__mlg_closure_", strings.fromInt(len(self.functionTypes)),}, con "")
    self.functionTypes = append(self.functionTypes, FunctionSig{name: syntheticName, intrinsic: "", mutable: mutable, params: copyParams(con params), returnType: copyType(con returnType),})
    function := encodeFunctionTypeIndex(len(self.functionTypes) - 1)
    ty := self.functionType(function)
    self.recordType(expression, con ty)
    self.recordFunctionReference(expression, function, false)
    self.closures = append(self.closures, CheckedClosure{node: expression, function: function, captures: captures,})
    return Ok(ty)
}

func (mut self CheckedProgram) checkStructLiteral(con program ast.Program, expression int, con expectedType ResolvedType, hasExpected bool) Result[ResolvedType, SemanticError] {
    typeName := ast.Value(con program, expression)
    ty := ResolvedType{text: token.CopyText(con typeName), kind: "struct", copy: false, cleanup: true,}
    if hasExpected && expectedType.text != ty.text {
        message := strings.join(con []string{"struct literal type mismatch: expected `", token.CopyText(con expectedType.text), "`, got `", token.CopyText(con ty.text), "`",}, con "")
        return Err(newError(message, ast.Span(con program, expression)))
    }
    structure := self.structIndex(con typeName)
    if structure < 0 {
        return Err(newError(strings.join(con []string{"unknown struct `", token.CopyText(con typeName), "`",}, con ""), ast.Span(con program, expression)))
    }

    for mut child := 0; child < ast.ChildCount(con program, expression); child = child + 1 {
        field := ast.Child(con program, expression, child)
        if ast.Kind(con program, field) != "FieldInit" {
            return Err(newError("generic struct literals require v0.4 specialization", ast.Span(con program, expression)))
        }
        fieldName := ast.Value(con program, field)
        for mut previous := 0; previous < child; previous = previous + 1 {
            previousField := ast.Child(con program, expression, previous)
            if ast.Kind(con program, previousField) == "FieldInit" && ast.Value(con program, previousField) == fieldName {
                message := strings.join(con []string{"duplicate field `", token.CopyText(con fieldName), "` in `", token.CopyText(con typeName), "` literal",}, con "")
                return Err(newError(message, ast.Span(con program, field)))
            }
        }

        mut signatureField := -1
        for mut index := 0; index < len(self.structs[structure].fields); index = index + 1 {
            if self.structs[structure].fields[index].name == fieldName {
                signatureField = index
            }
        }
        if signatureField < 0 {
            message := strings.join(con []string{"unknown field `", token.CopyText(con fieldName), "` in `", token.CopyText(con typeName), "` literal",}, con "")
            return Err(newError(message, ast.Span(con program, field)))
        }

        value := ast.Child(con program, field, 0)
        expectedFieldType := copyType(con self.structs[structure].fields[signatureField].ty)
        match self.checkExpressionExpected(con program, value, con "owned", con expectedFieldType, true) {
            case Ok(valueType) {
                if valueType.text != expectedFieldType.text {
                    message := strings.join(con []string{"field `", token.CopyText(con fieldName), "` type mismatch: expected `", token.CopyText(con expectedFieldType.text), "`, got `", token.CopyText(con valueType.text), "`",}, con "")
                    return Err(newError(message, ast.Span(con program, field)))
                }
            }
            case Err(error) {
                return Err(error)
            }
        }
    }

    for mut field := 0; field < len(self.structs[structure].fields); field = field + 1 {
        mut found := false
        for mut child := 0; child < ast.ChildCount(con program, expression); child = child + 1 {
            fieldNode := ast.Child(con program, expression, child)
            if ast.Kind(con program, fieldNode) == "FieldInit" && ast.Value(con program, fieldNode) == self.structs[structure].fields[field].name {
                found = true
            }
        }
        if !found {
            message := strings.join(con []string{"missing field `", token.CopyText(con self.structs[structure].fields[field].name), "` in `", token.CopyText(con typeName), "` literal",}, con "")
            return Err(newError(message, ast.Span(con program, expression)))
        }
    }

    self.recordType(expression, con ty)
    return Ok(ty)
}

func (mut self CheckedProgram) checkArrayLiteral(con program ast.Program, expression int, con expectedType ResolvedType, hasExpected bool) Result[ResolvedType, SemanticError] {
    typeNode := ast.Child(con program, expression, 0)
    mut collectionType := unitType()
    match self.resolveType(con program, typeNode) {
        case Ok(ty) {
            collectionType = ty
        }
        case Err(error) {
            return Err(error)
        }
    }
    if hasExpected && expectedType.text != collectionType.text {
        message := strings.join(con []string{"array literal type mismatch: expected `", token.CopyText(con expectedType.text), "`, got `", token.CopyText(con collectionType.text), "`",}, con "")
        return Err(newError(message, ast.Span(con program, expression)))
    }
    if collectionType.kind != "array" && collectionType.kind != "slice" {
        return Err(newError("array literal requires a fixed-size array or slice type", ast.Span(con program, typeNode)))
    }

    elementCount := ast.ChildCount(con program, expression) - 1
    if collectionType.kind == "array" {
        expectedLength := self.arrayLength(con collectionType)
        if elementCount != expectedLength {
            message := strings.join(con []string{"array literal length mismatch: expected ", strings.fromInt(expectedLength), " elements, got ", strings.fromInt(elementCount),}, con "")
            return Err(newError(message, ast.Span(con program, expression)))
        }
    }

    mut elementType := unitType()
    match self.typeArgument(con collectionType, 0) {
        case Ok(ty) {
            elementType = ty
        }
        case Err(_) {
            return Err(newError("checked array literal element type is missing", ast.Span(con program, expression)))
        }
    }
    for mut index := 0; index < elementCount; index = index + 1 {
        value := ast.Child(con program, expression, index + 1)
        match self.checkExpressionExpected(con program, value, con "owned", con elementType, true) {
            case Ok(valueType) {
                if valueType.text != elementType.text {
                    message := strings.join(con []string{"array literal element ", strings.fromInt(index), " type mismatch: expected `", token.CopyText(con elementType.text), "`, got `", token.CopyText(con valueType.text), "`",}, con "")
                    return Err(newError(message, ast.Span(con program, value)))
                }
            }
            case Err(error) {
                return Err(error)
            }
        }
    }

    self.recordType(expression, con collectionType)
    return Ok(collectionType)
}

func (mut self CheckedProgram) checkIfExpression(con program ast.Program, expression int, con valueUse string, con expectedType ResolvedType, hasExpected bool) Result[ResolvedType, SemanticError] {
    condition := ast.Child(con program, expression, 0)
    match self.checkExpression(con program, condition) {
        case Ok(conditionType) {
            if conditionType.kind != "bool" {
                return Err(newError("if condition must have type `bool`", ast.Span(con program, condition)))
            }
        }
        case Err(error) {
            return Err(error)
        }
    }

    baseLocals := copyLocals(con self.locals)
    thenBranch := ast.Child(con program, expression, 1)
    mut thenType := unitType()
    match self.checkExpressionExpected(con program, thenBranch, con valueUse, con expectedType, hasExpected) {
        case Ok(ty) {
            thenType = ty
        }
        case Err(error) {
            self.locals = copyLocals(con baseLocals)
            return Err(error)
        }
    }
    thenLocals := copyLocals(con self.locals)

    self.locals = copyLocals(con baseLocals)
    elseBranch := ast.Child(con program, expression, 2)
    mut elseType := unitType()
    match self.checkExpressionExpected(con program, elseBranch, con valueUse, con expectedType, hasExpected) {
        case Ok(ty) {
            elseType = ty
        }
        case Err(error) {
            self.locals = copyLocals(con baseLocals)
            return Err(error)
        }
    }
    elseLocals := copyLocals(con self.locals)
    self.locals = baseLocals

    if thenType.text != elseType.text {
        message := strings.join(con []string{"if branches must have the same type: got `", token.CopyText(con thenType.text), "` and `", token.CopyText(con elseType.text), "`",}, con "")
        return Err(newError(message, ast.Span(con program, expression)))
    }
    if thenType.kind == "unit" {
        return Err(newError("if expression branches must produce a value in v0", ast.Span(con program, expression)))
    }
    self.locals = mergeBranchMoves(con self.locals, con thenLocals, con elseLocals)
    self.recordType(expression, con thenType)
    return Ok(thenType)
}

func (mut self CheckedProgram) checkMatchExpression(con program ast.Program, expression int, con valueUse string, con expectedType ResolvedType, hasExpected bool) Result[ResolvedType, SemanticError] {
    if ast.ChildCount(con program, expression) < 2 {
        return Err(newError("match requires at least one arm", ast.Span(con program, expression)))
    }

    scrutinee := ast.Child(con program, expression, 0)
    mut scrutineeType := unitType()
    match self.checkExpression(con program, scrutinee) {
        case Ok(ty) {
            scrutineeType = ty
        }
        case Err(error) {
            return Err(error)
        }
    }
    if scrutineeType.kind != "option" && scrutineeType.kind != "result" && scrutineeType.kind != "enum" {
        message := strings.join(con []string{"match scrutinee must be an enum, `Option`, or `Result`, got `", token.CopyText(con scrutineeType.text), "`",}, con "")
        return Err(newError(message, ast.Span(con program, expression)))
    }
    match self.checkMatchPatterns(con program, expression, con scrutineeType) {
        case Ok(_) {}
        case Err(error) {
            return Err(error)
        }
    }

    baseLocals := copyLocals(con self.locals)
    baseDepth := self.scopeDepth
    mut branchExpected := copyType(con expectedType)
    if !hasExpected {
        mut inferred := false
        mut firstError := newError("match arm type inference failed", ast.Span(con program, expression))
        mut hasFirstError := false
        for mut armIndex := 1; armIndex < ast.ChildCount(con program, expression); armIndex = armIndex + 1 {
            arm := ast.Child(con program, expression, armIndex)
            self.locals = copyLocals(con baseLocals)
            self.scopeDepth = baseDepth + 1
            match self.addMatchBindings(con program, arm, con scrutineeType) {
                case Ok(_) {}
                case Err(error) {
                    self.locals = copyLocals(con baseLocals)
                    self.scopeDepth = baseDepth
                    return Err(error)
                }
            }
            branch := ast.Child(con program, arm, 1)
            match self.checkExpressionExpected(con program, branch, con valueUse, con branchExpected, false) {
                case Ok(ty) {
                    branchExpected = ty
                    inferred = true
                    break
                }
                case Err(error) {
                    if !hasFirstError {
                        firstError = error
                        hasFirstError = true
                    }
                }
            }
        }
        self.locals = copyLocals(con baseLocals)
        self.scopeDepth = baseDepth
        if !inferred {
            return Err(firstError)
        }
    }

    mut mergedLocals := copyLocals(con baseLocals)
    mut firstType := unitType()
    mut hasFirstType := false
    for mut armIndex := 1; armIndex < ast.ChildCount(con program, expression); armIndex = armIndex + 1 {
        arm := ast.Child(con program, expression, armIndex)
        self.locals = copyLocals(con baseLocals)
        self.scopeDepth = baseDepth + 1
        match self.addMatchBindings(con program, arm, con scrutineeType) {
            case Ok(_) {}
            case Err(error) {
                self.locals = copyLocals(con baseLocals)
                self.scopeDepth = baseDepth
                return Err(error)
            }
        }
        branch := ast.Child(con program, arm, 1)
        match self.checkExpressionExpected(con program, branch, con valueUse, con branchExpected, true) {
            case Ok(ty) {
                if !hasFirstType {
                    firstType = ty
                    hasFirstType = true
                } else if firstType.text != ty.text {
                    message := strings.join(con []string{"match arms must have the same type: got `", token.CopyText(con firstType.text), "` and `", token.CopyText(con ty.text), "`",}, con "")
                    self.locals = copyLocals(con baseLocals)
                    self.scopeDepth = baseDepth
                    return Err(newError(message, ast.Span(con program, expression)))
                }
                armLocals := copyLocals(con self.locals)
                mergedLocals = mergeBranchMoves(con baseLocals, con mergedLocals, con armLocals)
            }
            case Err(error) {
                self.locals = copyLocals(con baseLocals)
                self.scopeDepth = baseDepth
                return Err(error)
            }
        }
    }

    self.locals = mergedLocals
    self.scopeDepth = baseDepth
    if firstType.kind == "unit" {
        return Err(newError("match expression arms must produce a value in v0", ast.Span(con program, expression)))
    }
    self.recordType(expression, con firstType)
    return Ok(firstType)
}

func (con self CheckedProgram) checkMatchPatterns(con program ast.Program, expression int, con scrutineeType ResolvedType) Result[bool, SemanticError] {
    if matchUsesRecursiveCoverage(con program, expression) {
        return self.checkRecursiveMatchPatterns(con program, expression, con scrutineeType)
    }
    if scrutineeType.kind == "enum" {
        return self.checkUserEnumMatchPatterns(con program, expression, con scrutineeType)
    }
    return self.checkBuiltinMatchPatterns(con program, expression, con scrutineeType)
}

func (con self CheckedProgram) checkBuiltinMatchPatterns(con program ast.Program, expression int, con scrutineeType ResolvedType) Result[bool, SemanticError] {
    mut seenFirst := false
    mut seenSecond := false
    for mut armIndex := 1; armIndex < ast.ChildCount(con program, expression); armIndex = armIndex + 1 {
        arm := ast.Child(con program, expression, armIndex)
        pattern := ast.Child(con program, arm, 0)
        patternKind := ast.Kind(con program, pattern)
        if patternKind == "Pattern.Some" || patternKind == "Pattern.Ok" || patternKind == "Pattern.Err" {
            name := ast.Value(con program, pattern)
            if isBuiltinValueName(con name) {
                message := strings.join(con []string{"`", token.CopyText(con name), "` is a built-in value name",}, con "")
                return Err(newError(message, ast.Span(con program, arm)))
            }
        }
        mut coverage := 0
        match self.flatMatchCoverage(con program, pattern, con scrutineeType) {
            case Ok(value) {
                coverage = value
            }
            case Err(error) {
                return Err(error)
            }
        }
        duplicate := coverage == 1 && seenFirst || coverage == 2 && seenSecond || coverage == 3 && seenFirst && seenSecond
        if duplicate {
            return Err(newError("match pattern is duplicate or unreachable", ast.Span(con program, arm)))
        }
        if coverage == 1 || coverage == 3 {
            seenFirst = true
        }
        if coverage == 2 || coverage == 3 {
            seenSecond = true
        }
    }

    if seenFirst && seenSecond {
        return Ok(true)
    }
    mut missing := ""
    if scrutineeType.kind == "option" {
        if !seenSecond {
            missing = "Option.None"
        }
        if !seenFirst {
            if missing == "" {
                missing = "Option.Some"
            } else {
                missing = strings.join(con []string{missing, ", Option.Some",}, con "")
            }
        }
    } else {
        if !seenSecond {
            missing = "Result.Err"
        }
        if !seenFirst {
            if missing == "" {
                missing = "Result.Ok"
            } else {
                missing = strings.join(con []string{missing, ", Result.Ok",}, con "")
            }
        }
    }
    message := strings.join(con []string{"match is not exhaustive; missing ", missing,}, con "")
    return Err(newError(message, ast.Span(con program, expression)))
}

func (con self CheckedProgram) checkUserEnumMatchPatterns(con program ast.Program, expression int, con scrutineeType ResolvedType) Result[bool, SemanticError] {
    enumIndex := self.enumIndex(con scrutineeType.text)
    if enumIndex < 0 {
        return Err(newError("checked enum signature is missing", ast.Span(con program, expression)))
    }
    mut seen := []bool{}
    for mut variant := 0; variant < len(self.enums[enumIndex].variants); variant = variant + 1 {
        seen = append(seen, false)
    }

    for mut armIndex := 1; armIndex < ast.ChildCount(con program, expression); armIndex = armIndex + 1 {
        arm := ast.Child(con program, expression, armIndex)
        pattern := ast.Child(con program, arm, 0)
        if ast.Kind(con program, pattern) == "Pattern.Wildcard" {
            mut complete := true
            for mut variant := 0; variant < len(seen); variant = variant + 1 {
                complete = complete && seen[variant]
            }
            if complete {
                return Err(newError("match pattern is duplicate or unreachable", ast.Span(con program, arm)))
            }
            for mut variant := 0; variant < len(seen); variant = variant + 1 {
                seen[variant]= true
            }
        } else {
            mut variantIndex := -1
            match self.validateUserEnumPattern(con program, pattern, enumIndex) {
                case Ok(index) {
                    variantIndex = index
                }
                case Err(error) {
                    return Err(error)
                }
            }
            if seen[variantIndex] {
                return Err(newError("match pattern is duplicate or unreachable", ast.Span(con program, arm)))
            }
            seen[variantIndex]= true
        }
    }

    mut missing := []string{}
    for mut variant := 0; variant < len(seen); variant = variant + 1 {
        if !seen[variant] {
            missing = append(missing, strings.join(con []string{token.CopyText(con self.enums[enumIndex].patternName), ".", token.CopyText(con self.enums[enumIndex].variants[variant].name),}, con ""))
        }
    }
    if len(missing) == 0 {
        return Ok(true)
    }
    sorted := sortTexts(missing)
    message := strings.join(con []string{"match is not exhaustive; missing ", strings.join(con sorted, con ", "),}, con "")
    return Err(newError(message, ast.Span(con program, expression)))
}

func (con self CheckedProgram) validateUserEnumPattern(con program ast.Program, pattern int, enumIndex int) Result[int, SemanticError] {
    kind := ast.Kind(con program, pattern)
    if kind != "Pattern.Variant" {
        mut patternName := "match pattern"
        if kind == "Pattern.Some" {
            patternName = "Some"
        } else if kind == "Pattern.None" {
            patternName = "None"
        } else if kind == "Pattern.Ok" {
            patternName = "Ok"
        } else if kind == "Pattern.Err" {
            patternName = "Err"
        } else if kind == "Pattern.NestedBuiltin" {
            patternName = ast.Value(con program, pattern)
        } else {
            return Err(newError("B2d1b2c2b1 semantic checker does not yet accept this enum match pattern", ast.Span(con program, pattern)))
        }
        message := strings.join(con []string{"pattern `", patternName, "` does not match payload type `", token.CopyText(con self.enums[enumIndex].name), "`",}, con "")
        return Err(newError(message, ast.Span(con program, pattern)))
    }

    parts := splitPatternVariant(con ast.Value(con program, pattern))
    if !parts.valid {
        return Err(newError("malformed user enum match pattern", ast.Span(con program, pattern)))
    }
    if parts.typeName != self.enums[enumIndex].patternName {
        message := strings.join(con []string{"pattern type `", token.CopyText(con parts.typeName), "` does not match `", token.CopyText(con self.enums[enumIndex].patternName), "`",}, con "")
        return Err(newError(message, ast.Span(con program, pattern)))
    }
    variantIndex := enumVariantIndex(con self.enums[enumIndex], con parts.variantName)
    if variantIndex < 0 {
        message := strings.join(con []string{"enum `", token.CopyText(con parts.typeName), "` has no variant `", token.CopyText(con parts.variantName), "`",}, con "")
        return Err(newError(message, ast.Span(con program, pattern)))
    }

    expectedCount := len(self.enums[enumIndex].variants[variantIndex].payloads)
    actualCount := ast.ChildCount(con program, pattern)
    prefix := strings.join(con []string{token.CopyText(con parts.typeName), ".", token.CopyText(con parts.variantName),}, con "")
    if expectedCount == 0 && actualCount > 0 {
        message := strings.join(con []string{"zero-payload variant `", token.CopyText(con prefix), "` cannot destructure a payload",}, con "")
        return Err(newError(message, ast.Span(con program, pattern)))
    }
    if expectedCount == 1 && actualCount == 0 {
        message := strings.join(con []string{"variant `", token.CopyText(con prefix), "` requires a payload pattern",}, con "")
        return Err(newError(message, ast.Span(con program, pattern)))
    }
    if expectedCount != actualCount {
        message := strings.join(con []string{"variant `", token.CopyText(con prefix), "` requires ", strings.fromInt(expectedCount), " payload patterns, got ", strings.fromInt(actualCount),}, con "")
        return Err(newError(message, ast.Span(con program, pattern)))
    }

    mut bindings := []string{}
    for mut payload := 0; payload < actualCount; payload = payload + 1 {
        payloadPattern := ast.Child(con program, pattern, payload)
        payloadKind := ast.Kind(con program, payloadPattern)
        if payloadKind == "Pattern.Binding" {
            name := ast.Value(con program, payloadPattern)
            if isBuiltinValueName(con name) {
                message := strings.join(con []string{"`", token.CopyText(con name), "` is a built-in value name",}, con "")
                return Err(newError(message, ast.Span(con program, pattern)))
            }
            if containsText(con bindings, con name) {
                message := strings.join(con []string{"duplicate pattern binding `", token.CopyText(con name), "`",}, con "")
                return Err(newError(message, ast.Span(con program, pattern)))
            }
            bindings = append(bindings, name)
        } else if payloadKind != "Pattern.Wildcard" {
            return Err(newError("B2d1b2c2b1 semantic checker does not yet accept nested enum payload patterns", ast.Span(con program, pattern)))
        }
    }
    return Ok(variantIndex)
}

func (con self CheckedProgram) checkRecursiveMatchPatterns(con program ast.Program, expression int, con scrutineeType ResolvedType) Result[bool, SemanticError] {
    mut all := [][]string{}
    match self.coverageLeaves(con scrutineeType, []string {}
    , ast.Span(con program, expression)){case Ok(leaves) {
            all = leaves
        }
        case Err(error) {
            return Err(error)
        }
    }

    mut seen := [][]string{}
    for mut armIndex := 1; armIndex < ast.ChildCount(con program, expression); armIndex = armIndex + 1 {
        arm := ast.Child(con program, expression, armIndex)
        pattern := ast.Child(con program, arm, 0)
        mut coverage := PatternCoverage{bindings: []PatternBinding{}, leaves: [][]string{},}
        match self.patternCoverage(con program, pattern, con scrutineeType, arm, []string {}
        ){case Ok(value) {
                coverage = value
            }
            case Err(error) {
                return Err(error)
            }
        }
        if coverageIsSubset(con coverage.leaves, con seen) {
            return Err(newError("match pattern is duplicate or unreachable", ast.Span(con program, arm)))
        }
        seen = extendCoverage(seen, con coverage.leaves)
    }

    if coverageIsSubset(con all, con seen) {
        return Ok(true)
    }
    mut missing := []string{}
    for mut leaf := 0; leaf < len(all); leaf = leaf + 1 {
        if !coveragePathIsCovered(con all[leaf], con seen) {
            missing = append(missing, strings.join(con all[leaf], con " -> "))
        }
    }
    sorted := sortTexts(missing)
    message := strings.join(con []string{"match is not exhaustive; missing ", strings.join(con sorted, con ", "),}, con "")
    return Err(newError(message, ast.Span(con program, expression)))
}

func (con self CheckedProgram) patternCoverage(con program ast.Program, pattern int, con expected ResolvedType, spanNode int, visiting []string) Result[PatternCoverage, SemanticError] {
    kind := ast.Kind(con program, pattern)
    if kind == "Pattern.Wildcard" {
        return match self.coverageLeaves(con expected, copySegments(con visiting), ast.Span(con program, spanNode)) {
            case Ok(leaves) {
                Ok(PatternCoverage{bindings: []PatternBinding{}, leaves: leaves,})
            }
            case Err(error) {
                Err(error)
            }
        }
    }
    if kind == "Pattern.Binding" {
        name := ast.Value(con program, pattern)
        if isBuiltinValueName(con name) {
            message := strings.join(con []string{"`", token.CopyText(con name), "` is a built-in value name",}, con "")
            return Err(newError(message, ast.Span(con program, spanNode)))
        }
        match self.coverageLeaves(con expected, copySegments(con visiting), ast.Span(con program, spanNode)) {
            case Ok(leaves) {
                return Ok(PatternCoverage{bindings: []PatternBinding{PatternBinding{name: name, ty: copyType(con expected),},}, leaves: leaves,})
            }
            case Err(error) {
                return Err(error)
            }
        }
    }

    mut sourceTypeName := ""
    mut variantName := ""
    mut hasSourceType := false
    mut payloads := []AdtPatternPayload{}
    if kind == "Pattern.Variant" {
        parts := splitPatternVariant(con ast.Value(con program, pattern))
        if !parts.valid {
            return Err(newError("malformed user enum match pattern", ast.Span(con program, spanNode)))
        }
        if expected.kind != "enum" {
            patternName := strings.join(con []string{token.CopyText(con parts.typeName), ".", token.CopyText(con parts.variantName),}, con "")
            message := strings.join(con []string{"pattern `", patternName, "` requires an enum payload, got `", token.CopyText(con expected.text), "`",}, con "")
            return Err(newError(message, ast.Span(con program, spanNode)))
        }
        sourceTypeName = token.CopyText(con parts.typeName)
        variantName = token.CopyText(con parts.variantName)
        hasSourceType = true
        for mut child := 0; child < ast.ChildCount(con program, pattern); child = child + 1 {
            payloads = append(payloads, AdtPatternPayload{kind: "nested", node: ast.Child(con program, pattern, child), name: "",})
        }
    } else if kind == "Pattern.Some" || kind == "Pattern.Ok" || kind == "Pattern.Err" {
        if kind == "Pattern.Some" {
            variantName = "Some"
        } else if kind == "Pattern.Ok" {
            variantName = "Ok"
        } else {
            variantName = "Err"
        }
        payloads = append(payloads, AdtPatternPayload{kind: "binding", node: -1, name: ast.Value(con program, pattern),})
    } else if kind == "Pattern.None" {
        variantName = "None"
    } else if kind == "Pattern.NestedBuiltin" {
        variantName = ast.Value(con program, pattern)
        if ast.ChildCount(con program, pattern) != 1 {
            return Err(newError("malformed nested built-in match pattern", ast.Span(con program, spanNode)))
        }
        payloads = append(payloads, AdtPatternPayload{kind: "nested", node: ast.Child(con program, pattern, 0), name: "",})
    } else {
        return Err(newError("B2d1b2c2b2 semantic checker does not accept this match pattern", ast.Span(con program, spanNode)))
    }

    return self.adtVariantPatternCoverage(con program, con expected, con sourceTypeName, hasSourceType, con variantName, con payloads, spanNode, visiting)
}

func (con self CheckedProgram) adtVariantPatternCoverage(con program ast.Program, con expected ResolvedType, con sourceTypeName string, hasSourceType bool, con variantName string, con payloads []AdtPatternPayload, spanNode int, visiting []string) Result[PatternCoverage, SemanticError] {
    variantCount := self.adtVariantCount(con expected)
    if variantCount < 0 {
        message := strings.join(con []string{"pattern `", token.CopyText(con variantName), "` does not match payload type `", token.CopyText(con expected.text), "`",}, con "")
        return Err(newError(message, ast.Span(con program, spanNode)))
    }
    patternName := self.adtPatternName(con expected)
    if hasSourceType && sourceTypeName != patternName {
        message := strings.join(con []string{"pattern type `", token.CopyText(con sourceTypeName), "` does not match `", token.CopyText(con patternName), "`",}, con "")
        return Err(newError(message, ast.Span(con program, spanNode)))
    }
    variantIndex := self.adtVariantIndex(con expected, con variantName)
    if variantIndex < 0 {
        if hasSourceType {
            message := strings.join(con []string{"enum `", token.CopyText(con sourceTypeName), "` has no variant `", token.CopyText(con variantName), "`",}, con "")
            return Err(newError(message, ast.Span(con program, spanNode)))
        }
        message := strings.join(con []string{"pattern `", token.CopyText(con variantName), "` does not match payload type `", token.CopyText(con expected.text), "`",}, con "")
        return Err(newError(message, ast.Span(con program, spanNode)))
    }

    expectedCount := self.adtVariantPayloadCount(con expected, variantIndex)
    actualCount := len(payloads)
    prefix := strings.join(con []string{token.CopyText(con patternName), ".", token.CopyText(con variantName),}, con "")
    if expectedCount == 0 && actualCount > 0 {
        message := strings.join(con []string{"zero-payload variant `", token.CopyText(con prefix), "` cannot destructure a payload",}, con "")
        return Err(newError(message, ast.Span(con program, spanNode)))
    }
    if expectedCount == 1 && actualCount == 0 {
        message := strings.join(con []string{"variant `", token.CopyText(con prefix), "` requires a payload pattern",}, con "")
        return Err(newError(message, ast.Span(con program, spanNode)))
    }
    if expectedCount != actualCount {
        message := strings.join(con []string{"variant `", token.CopyText(con prefix), "` requires ", strings.fromInt(expectedCount), " payload patterns, got ", strings.fromInt(actualCount),}, con "")
        return Err(newError(message, ast.Span(con program, spanNode)))
    }

    mut nestedVisiting := copySegments(con visiting)
    if !containsText(con nestedVisiting, con expected.text) {
        nestedVisiting = append(nestedVisiting, token.CopyText(con expected.text))
    }
    mut bindings := []PatternBinding{}
    mut payloadCoverages := [][][]string{}
    for mut payload := 0; payload < actualCount; payload = payload + 1 {
        mut payloadType := unitType()
        match self.adtVariantPayloadType(con expected, variantIndex, payload) {
            case Ok(ty) {
                payloadType = ty
            }
            case Err(_) {
                return Err(newError("checked match payload type is missing", ast.Span(con program, spanNode)))
            }
        }
        mut coverage := PatternCoverage{bindings: []PatternBinding{}, leaves: [][]string{},}
        if payloads[payload].kind == "binding" {
            name := token.CopyText(con payloads[payload].name)
            if isBuiltinValueName(con name) {
                message := strings.join(con []string{"`", token.CopyText(con name), "` is a built-in value name",}, con "")
                return Err(newError(message, ast.Span(con program, spanNode)))
            }
            match self.coverageLeaves(con payloadType, copySegments(con nestedVisiting), ast.Span(con program, spanNode)) {
                case Ok(leaves) {
                    coverage = PatternCoverage{bindings: []PatternBinding{PatternBinding{name: name, ty: copyType(con payloadType),},}, leaves: leaves,}
                }
                case Err(error) {
                    return Err(error)
                }
            }
        } else {
            match self.patternCoverage(con program, payloads[payload].node, con payloadType, spanNode, copySegments(con nestedVisiting)) {
                case Ok(value) {
                    coverage = value
                }
                case Err(error) {
                    return Err(error)
                }
            }
        }
        for mut binding := 0; binding < len(coverage.bindings); binding = binding + 1 {
            name := token.CopyText(con coverage.bindings[binding].name)
            if containsPatternBinding(con bindings, con name) {
                message := strings.join(con []string{"duplicate pattern binding `", token.CopyText(con name), "`",}, con "")
                return Err(newError(message, ast.Span(con program, spanNode)))
            }
            bindings = append(bindings, PatternBinding{name: name, ty: copyType(con coverage.bindings[binding].ty),})
        }
        payloadCoverages = append(payloadCoverages, copyCoverageSet(con coverage.leaves))
    }
    return Ok(PatternCoverage{bindings: bindings, leaves: variantCoverage(con prefix, payloadCoverages),})
}

func (con self CheckedProgram) coverageLeaves(con expected ResolvedType, visiting []string, span source.Span) Result[[][]string, SemanticError] {
    if containsText(con visiting, con expected.text) {
        mut name := self.adtPatternName(con expected)
        if name == "" {
            name = token.CopyText(con expected.text)
        }
        recursive := strings.join(con []string{"<recursive ", name, ">",}, con "")
        return Ok([][]string{[]string{recursive,},})
    }

    variantCount := self.adtVariantCount(con expected)
    if variantCount < 0 {
        return Ok([][]string{[]string{},})
    }
    mut nestedVisiting := copySegments(con visiting)
    nestedVisiting = append(nestedVisiting, token.CopyText(con expected.text))
    mut leaves := [][]string{}
    for mut variant := 0; variant < variantCount; variant = variant + 1 {
        variantName := self.adtVariantName(con expected, variant)
        prefix := strings.join(con []string{self.adtPatternName(con expected), ".", variantName,}, con "")
        mut payloadCoverages := [][][]string{}
        payloadCount := self.adtVariantPayloadCount(con expected, variant)
        for mut payload := 0; payload < payloadCount; payload = payload + 1 {
            match self.adtVariantPayloadType(con expected, variant, payload) {
                case Ok(payloadType) {
                    match self.coverageLeaves(con payloadType, copySegments(con nestedVisiting), source.Copy(con span)) {
                        case Ok(coverage) {
                            payloadCoverages = append(payloadCoverages, coverage)
                        }
                        case Err(error) {
                            return Err(error)
                        }
                    }
                }
                case Err(_) {
                    return Err(newError("checked match payload type is missing", source.Copy(con span)))
                }
            }
        }
        variantLeaves := variantCoverage(con prefix, payloadCoverages)
        leaves = extendCoverage(leaves, con variantLeaves)
    }
    return Ok(leaves)
}

func (con self CheckedProgram) flatMatchCoverage(con program ast.Program, pattern int, con scrutineeType ResolvedType) Result[int, SemanticError] {
    kind := ast.Kind(con program, pattern)
    if kind == "Pattern.Wildcard" {
        return Ok(3)
    }
    if scrutineeType.kind == "option" {
        if kind == "Pattern.Some" {
            return Ok(1)
        }
        if kind == "Pattern.None" {
            return Ok(2)
        }
    } else {
        if kind == "Pattern.Ok" {
            return Ok(1)
        }
        if kind == "Pattern.Err" {
            return Ok(2)
        }
    }

    mut patternName := "match pattern"
    if kind == "Pattern.Some" {
        patternName = "Some"
    } else if kind == "Pattern.None" {
        patternName = "None"
    } else if kind == "Pattern.Ok" {
        patternName = "Ok"
    } else if kind == "Pattern.Err" {
        patternName = "Err"
    } else {
        return Err(newError("B2d1b2c1 semantic checker does not yet accept nested or user enum match patterns", ast.Span(con program, pattern)))
    }
    message := strings.join(con []string{"pattern `", patternName, "` does not match payload type `", token.CopyText(con scrutineeType.text), "`",}, con "")
    return Err(newError(message, ast.Span(con program, pattern)))
}

func (mut self CheckedProgram) addMatchBindings(con program ast.Program, arm int, con scrutineeType ResolvedType) Result[bool, SemanticError] {
    pattern := ast.Child(con program, arm, 0)
    if patternUsesRecursiveCoverage(con program, pattern) {
        return self.addRecursiveMatchBindings(con program, arm, con scrutineeType)
    }
    if scrutineeType.kind == "enum" {
        return self.addUserEnumMatchBindings(con program, arm, con scrutineeType)
    }
    return self.addBuiltinMatchBinding(con program, arm, con scrutineeType)
}

func (mut self CheckedProgram) addBuiltinMatchBinding(con program ast.Program, arm int, con scrutineeType ResolvedType) Result[bool, SemanticError] {
    pattern := ast.Child(con program, arm, 0)
    kind := ast.Kind(con program, pattern)
    mut argument := -1
    if kind == "Pattern.Some" || kind == "Pattern.Ok" {
        argument = 0
    } else if kind == "Pattern.Err" {
        argument = 1
    } else {
        return Ok(false)
    }

    name := ast.Value(con program, pattern)
    if isBuiltinValueName(con name) {
        message := strings.join(con []string{"`", token.CopyText(con name), "` is a built-in value name",}, con "")
        return Err(newError(message, ast.Span(con program, arm)))
    }
    match self.typeArgument(con scrutineeType, argument) {
        case Ok(ty) {
            self.locals = append(self.locals, Local{name: name, mutable: false, borrowed: false, moved: false, rangeSource: false, capture: false, ty: ty, function: -1, scopeDepth: self.scopeDepth,})
            return Ok(true)
        }
        case Err(_) {
            return Err(newError("checked match payload type is missing", ast.Span(con program, arm)))
        }
    }
}

func (mut self CheckedProgram) addUserEnumMatchBindings(con program ast.Program, arm int, con scrutineeType ResolvedType) Result[bool, SemanticError] {
    pattern := ast.Child(con program, arm, 0)
    if ast.Kind(con program, pattern) == "Pattern.Wildcard" {
        return Ok(false)
    }
    parts := splitPatternVariant(con ast.Value(con program, pattern))
    enumIndex := self.enumIndex(con scrutineeType.text)
    if !parts.valid || enumIndex < 0 {
        return Err(newError("checked enum match pattern is missing", ast.Span(con program, arm)))
    }
    variantIndex := enumVariantIndex(con self.enums[enumIndex], con parts.variantName)
    if variantIndex < 0 {
        return Err(newError("checked enum match variant is missing", ast.Span(con program, arm)))
    }
    mut added := false
    for mut payload := 0; payload < ast.ChildCount(con program, pattern); payload = payload + 1 {
        payloadPattern := ast.Child(con program, pattern, payload)
        if ast.Kind(con program, payloadPattern) == "Pattern.Binding" {
            name := ast.Value(con program, payloadPattern)
            ty := copyType(con self.enums[enumIndex].variants[variantIndex].payloads[payload])
            self.locals = append(self.locals, Local{name: name, mutable: false, borrowed: false, moved: false, rangeSource: false, capture: false, ty: ty, function: -1, scopeDepth: self.scopeDepth,})
            added = true
        }
    }
    return Ok(added)
}

func (mut self CheckedProgram) addRecursiveMatchBindings(con program ast.Program, arm int, con scrutineeType ResolvedType) Result[bool, SemanticError] {
    pattern := ast.Child(con program, arm, 0)
    match self.patternCoverage(con program, pattern, con scrutineeType, arm, []string {}
    ){case Ok(coverage) {
            for mut binding := 0; binding < len(coverage.bindings); binding = binding + 1 {
                self.locals = append(self.locals, Local{name: token.CopyText(con coverage.bindings[binding].name), mutable: false, borrowed: false, moved: false, rangeSource: false, capture: false, ty: copyType(con coverage.bindings[binding].ty), function: -1, scopeDepth: self.scopeDepth,})
            }
            return Ok(len(coverage.bindings) > 0)
        }
        case Err(error) {
            return Err(error)
        }
    }
}

func (mut self CheckedProgram) checkFieldAccess(con program ast.Program, expression int, con valueUse string) Result[ResolvedType, SemanticError] {
    base := ast.Child(con program, expression, 0)
    match self.checkExpressionUse(con program, base, con "read") {
        case Ok(baseType) {
            if baseType.kind != "struct" {
                message := strings.join(con []string{"field access requires a struct value, got `", token.CopyText(con baseType.text), "`",}, con "")
                return Err(newError(message, ast.Span(con program, base)))
            }
            structure := self.structIndex(con baseType.text)
            if structure < 0 {
                return Err(newError("checked struct signature is missing", ast.Span(con program, expression)))
            }
            field := ast.Value(con program, expression)
            for mut index := 0; index < len(self.structs[structure].fields); index = index + 1 {
                if self.structs[structure].fields[index].name == field {
                    ty := copyType(con self.structs[structure].fields[index].ty)
                    if valueUse == "owned" && !ty.copy {
                        if ty.kind != "slice" || !isDirectBorrowExpression(con program, base) {
                            if !isDirectBorrowExpression(con program, base) {
                                return Err(newError("moving a non-copy field out of a computed struct value is not supported without destructuring", ast.Span(con program, expression)))
                            }
                            match rejectFieldBaseMove(con program, base) {
                                case Ok(_) {}
                                case Err(error) {
                                    return Err(error)
                                }
                            }
                        }
                    }
                    self.recordType(expression, con ty)
                    return Ok(ty)
                }
            }
            message := strings.join(con []string{"unknown field `", token.CopyText(con field), "` on `", token.CopyText(con baseType.text), "`",}, con "")
            return Err(newError(message, ast.Span(con program, expression)))
        }
        case Err(error) {
            return Err(error)
        }
    }
}

func (mut self CheckedProgram) checkIndexAccess(con program ast.Program, expression int, con valueUse string) Result[ResolvedType, SemanticError] {
    base := ast.Child(con program, expression, 0)
    index := ast.Child(con program, expression, 1)
    mut baseType := unitType()
    match self.checkExpressionUse(con program, base, con "read") {
        case Ok(ty) {
            baseType = ty
        }
        case Err(error) {
            return Err(error)
        }
    }
    mut indexType := unitType()
    match self.checkExpression(con program, index) {
        case Ok(ty) {
            indexType = ty
        }
        case Err(error) {
            return Err(error)
        }
    }

    if baseType.kind != "array" && baseType.kind != "slice" {
        message := strings.join(con []string{"indexing requires a fixed-size array or slice, got `", token.CopyText(con baseType.text), "`",}, con "")
        return Err(newError(message, ast.Span(con program, base)))
    }
    mut element := unitType()
    match self.typeArgument(con baseType, 0) {
        case Ok(ty) {
            element = ty
        }
        case Err(_) {
            return Err(newError("checked index element type is missing", ast.Span(con program, expression)))
        }
    }
    match self.validateIndex(con program, index, con indexType, con baseType) {
        case Ok(_) {}
        case Err(error) {
            return Err(error)
        }
    }
    if valueUse == "owned" && !element.copy {
        mut collection := "slice"
        if baseType.kind == "array" {
            collection = "array"
        }
        message := strings.join(con []string{collection, " indexing requires a Copy element type in v0, got `", token.CopyText(con element.text), "`",}, con "")
        return Err(newError(message, ast.Span(con program, expression)))
    }
    self.recordType(expression, con element)
    return Ok(element)
}

func (con self CheckedProgram) validateIndex(con program ast.Program, index int, con indexType ResolvedType, con baseType ResolvedType) Result[bool, SemanticError] {
    mut collection := "slice"
    if baseType.kind == "array" {
        collection = "array"
    }
    if indexType.kind != "int" {
        message := strings.join(con []string{token.CopyText(con collection), " index must have type `int`, got `", token.CopyText(con indexType.text), "`",}, con "")
        return Err(newError(message, ast.Span(con program, index)))
    }
    match constInt(con program, index) {
        case Ok(value) {
            if value < 0 {
                message := strings.join(con []string{collection, " index ", strings.fromInt(value), " must be non-negative",}, con "")
                return Err(newError(message, ast.Span(con program, index)))
            }
            if baseType.kind == "array" {
                length := self.arrayLength(con baseType)
                if value >= length {
                    message := strings.join(con []string{"array index ", strings.fromInt(value), " is out of bounds for length ", strings.fromInt(length),}, con "")
                    return Err(newError(message, ast.Span(con program, index)))
                }
            }
        }
        case Err(_) {}
    }
    return Ok(true)
}

func (mut self CheckedProgram) resolveAssignmentPlaceType(con program ast.Program, expression int) Result[ResolvedType, SemanticError] {
    kind := ast.Kind(con program, expression)
    if kind == "Expr.Var" {
        name := ast.Value(con program, expression)
        local := localIndex(con self.locals, con name)
        if local < 0 {
            return Err(newError(strings.join(con []string{"unknown variable `", token.CopyText(con name), "`",}, con ""), ast.Span(con program, expression)))
        }
        self.markCapture(local, false)
        ty := copyType(con self.locals[local].ty)
        self.recordType(expression, con ty)
        return Ok(ty)
    }
    if kind == "Expr.FieldAccess" {
        base := ast.Child(con program, expression, 0)
        match self.resolveAssignmentPlaceType(con program, base) {
            case Ok(baseType) {
                field := ast.Value(con program, expression)
                match self.resolveStructField(con baseType, con field, ast.Span(con program, expression), con "field assignment") {
                    case Ok(ty) {
                        self.recordType(expression, con ty)
                        return Ok(ty)
                    }
                    case Err(error) {
                        return Err(error)
                    }
                }
            }
            case Err(error) {
                return Err(error)
            }
        }
    }
    if kind == "Expr.Index" {
        base := ast.Child(con program, expression, 0)
        index := ast.Child(con program, expression, 1)
        mut baseType := unitType()
        match self.resolveAssignmentPlaceType(con program, base) {
            case Ok(ty) {
                baseType = ty
            }
            case Err(error) {
                return Err(error)
            }
        }
        if baseType.kind != "array" && baseType.kind != "slice" {
            message := strings.join(con []string{"indexed field assignment target must be a fixed-size array or slice, got `", token.CopyText(con baseType.text), "`",}, con "")
            return Err(newError(message, ast.Span(con program, base)))
        }
        mut indexType := unitType()
        match self.checkExpression(con program, index) {
            case Ok(ty) {
                indexType = ty
            }
            case Err(error) {
                return Err(error)
            }
        }
        match self.validateIndex(con program, index, con indexType, con baseType) {
            case Ok(_) {}
            case Err(error) {
                return Err(error)
            }
        }
        match self.typeArgument(con baseType, 0) {
            case Ok(ty) {
                self.recordType(expression, con ty)
                return Ok(ty)
            }
            case Err(_) {
                return Err(newError("checked assignment place element type is missing", ast.Span(con program, expression)))
            }
        }
    }
    return Err(newError("field assignment target must be a direct local variable, field, or indexed element in v0", ast.Span(con program, expression)))
}

func (con self CheckedProgram) resolveStructField(con baseType ResolvedType, con field string, span source.Span, con context string) Result[ResolvedType, SemanticError] {
    if baseType.kind != "struct" {
        message := strings.join(con []string{token.CopyText(con context), " requires a struct value, got `", token.CopyText(con baseType.text), "`",}, con "")
        return Err(newError(message, source.Copy(con span)))
    }
    structure := self.structIndex(con baseType.text)
    if structure < 0 {
        return Err(newError("checked struct signature is missing", source.Copy(con span)))
    }
    for mut index := 0; index < len(self.structs[structure].fields); index = index + 1 {
        if self.structs[structure].fields[index].name == field {
            return Ok(copyType(con self.structs[structure].fields[index].ty))
        }
    }
    message := strings.join(con []string{"unknown field `", token.CopyText(con field), "` on `", token.CopyText(con baseType.text), "`",}, con "")
    return Err(newError(message, source.Copy(con span)))
}

func (mut self CheckedProgram) checkCall(con program ast.Program, expression int, con expectedType ResolvedType, hasExpected bool) Result[ResolvedType, SemanticError] {
    callee := ast.Child(con program, expression, 0)
    if ast.Kind(con program, callee) == "Expr.FieldAccess" {
        enumIndex := self.enumSelectionIndex(con program, callee)
        if enumIndex >= 0 {
            return self.checkEnumConstructor(con program, expression, callee, enumIndex, con expectedType, hasExpected, true)
        }
        return self.checkMethodCall(con program, expression, callee)
    }
    if ast.Kind(con program, callee) != "Expr.Var" {
        return Err(newError("only direct function and method calls are supported in v0", ast.Span(con program, callee)))
    }

    name := ast.Value(con program, callee)
    if name == "Some" {
        return self.checkSomeConstructor(con program, expression, con expectedType, hasExpected)
    }
    if name == "Ok" {
        return self.checkResultConstructor(con program, expression, con expectedType, hasExpected, true)
    }
    if name == "Err" {
        return self.checkResultConstructor(con program, expression, con expectedType, hasExpected, false)
    }
    if name == "print" {
        return Err(newError("`print` is only supported as a statement", ast.Span(con program, expression)))
    }
    if name == "len" {
        return self.checkLenCall(con program, expression)
    }
    if name == "append" {
        return self.checkAppendCall(con program, expression)
    }
    local := localIndex(con self.locals, con name)
    mut function := -1
    mut indirect := false
    if local >= 0 {
        if self.locals[local].ty.kind != "function" {
            return Err(newError(strings.join(con []string{"`", token.CopyText(con name), "` is not callable",}, con ""), ast.Span(con program, expression)))
        }
        if self.locals[local].moved {
            return Err(newError(strings.join(con []string{"use of moved value `", token.CopyText(con name), "`",}, con ""), ast.Span(con program, expression)))
        }
        function = self.locals[local].function
        indirect = true
        if function == -1 {
            return Err(newError("B2b semantic checker cannot yet resolve this function value signature", ast.Span(con program, expression)))
        }
        if self.callableMutable(function) {
            match self.checkCaptureMutation(con program, local) {
                case Ok(_) {}
                case Err(error) {
                    return Err(error)
                }
            }
        } else {
            self.markCapture(local, false)
        }
        if self.callableMutable(function) && !self.locals[local].mutable {
            message := strings.join(con []string{"mutable function value `", token.CopyText(con name), "` requires mutable access",}, con "")
            return Err(newError(message, ast.Span(con program, expression)))
        }
        calleeType := copyType(con self.locals[local].ty)
        self.recordType(callee, con calleeType)
        self.recordFunctionReference(callee, function, false)
    } else {
        if containsText(con self.recursiveBindings, con name) {
            message := strings.join(con []string{"recursive closure `", token.CopyText(con name), "` is not supported in v0.3",}, con "")
            return Err(newError(message, ast.Span(con program, callee)))
        }
        function = self.functionIndex(con name)
        if function < 0 {
            return Err(newError(strings.join(con []string{"unknown function `", token.CopyText(con name), "`",}, con ""), ast.Span(con program, callee)))
        }
        calleeType := self.functionType(function)
        self.recordType(callee, con calleeType)
        self.recordFunctionReference(callee, function, true)
    }

    match self.checkCallArguments(con program, expression, function, con name, indirect) {
        case Ok(_) {
            resultType := self.callableReturnType(function)
            self.recordType(expression, con resultType)
            return Ok(resultType)
        }
        case Err(error) {
            return Err(error)
        }
    }
}

func (mut self CheckedProgram) checkPrintCall(con program ast.Program, expression int) Result[ResolvedType, SemanticError] {
    argumentCount := ast.ChildCount(con program, expression) - 1
    if argumentCount != 1 {
        return Err(newError("`print` expects exactly one argument", ast.Span(con program, expression)))
    }
    argument := ast.Child(con program, expression, 1)
    if argModeFromKind(con ast.Kind(con program, argument)) != "owned" {
        return Err(newError("`print` arguments do not take `con` or `mut` mode markers", ast.Span(con program, argument)))
    }

    value := ast.Child(con program, argument, 0)
    mut valueType := unitType()
    match self.checkFullExpressionRead(con program, value) {
        case Ok(ty) {
            valueType = ty
        }
        case Err(error) {
            return Err(error)
        }
    }
    if valueType.kind != "int" && valueType.kind != "bool" && valueType.kind != "string" {
        message := strings.join(con []string{"cannot print value of type `", token.CopyText(con valueType.text), "` in v0",}, con "")
        return Err(newError(message, ast.Span(con program, argument)))
    }

    ty := unitType()
    self.recordType(expression, con ty)
    return Ok(ty)
}

func (mut self CheckedProgram) checkLenCall(con program ast.Program, expression int) Result[ResolvedType, SemanticError] {
    argumentCount := ast.ChildCount(con program, expression) - 1
    if argumentCount != 1 {
        return Err(newError("`len` expects exactly one argument", ast.Span(con program, expression)))
    }
    argument := ast.Child(con program, expression, 1)
    if argModeFromKind(con ast.Kind(con program, argument)) != "owned" {
        return Err(newError("`len` arguments do not take `con` or `mut` mode markers", ast.Span(con program, argument)))
    }

    value := ast.Child(con program, argument, 0)
    mut valueType := unitType()
    match self.checkFullExpressionRead(con program, value) {
        case Ok(ty) {
            valueType = ty
        }
        case Err(error) {
            return Err(error)
        }
    }
    if valueType.kind != "array" && valueType.kind != "slice" {
        message := strings.join(con []string{"`len` expects a fixed-size array or slice, got `", token.CopyText(con valueType.text), "`",}, con "")
        return Err(newError(message, ast.Span(con program, argument)))
    }

    ty := intType()
    self.recordType(expression, con ty)
    return Ok(ty)
}

func (mut self CheckedProgram) checkAppendCall(con program ast.Program, expression int) Result[ResolvedType, SemanticError] {
    argumentCount := ast.ChildCount(con program, expression) - 1
    if argumentCount != 2 {
        return Err(newError("`append` expects exactly two arguments", ast.Span(con program, expression)))
    }
    sliceArgument := ast.Child(con program, expression, 1)
    itemArgument := ast.Child(con program, expression, 2)
    if argModeFromKind(con ast.Kind(con program, sliceArgument)) != "owned" || argModeFromKind(con ast.Kind(con program, itemArgument)) != "owned" {
        return Err(newError("`append` arguments do not take `con` or `mut` mode markers", ast.Span(con program, expression)))
    }

    sliceExpression := ast.Child(con program, sliceArgument, 0)
    mut sliceType := unitType()
    if ast.Kind(con program, sliceExpression) == "Expr.FieldAccess" && isDirectBorrowExpression(con program, sliceExpression) {
        match self.checkExpressionUse(con program, sliceExpression, con "read") {
            case Ok(ty) {
                sliceType = ty
            }
            case Err(error) {
                return Err(error)
            }
        }
    } else {
        match self.checkExpression(con program, sliceExpression) {
            case Ok(ty) {
                sliceType = ty
            }
            case Err(error) {
                return Err(error)
            }
        }
    }
    if sliceType.kind != "slice" {
        message := strings.join(con []string{"`append` first argument must be a slice, got `", token.CopyText(con sliceType.text), "`",}, con "")
        return Err(newError(message, ast.Span(con program, sliceArgument)))
    }

    mut elementType := unitType()
    match self.typeArgument(con sliceType, 0) {
        case Ok(ty) {
            elementType = ty
        }
        case Err(_) {
            return Err(newError("checked append element type is missing", ast.Span(con program, sliceArgument)))
        }
    }
    itemExpression := ast.Child(con program, itemArgument, 0)
    match self.checkExpressionExpected(con program, itemExpression, con "owned", con elementType, true) {
        case Ok(itemType) {
            if itemType.text != elementType.text {
                message := strings.join(con []string{"`append` item type mismatch: expected `", token.CopyText(con elementType.text), "`, got `", token.CopyText(con itemType.text), "`",}, con "")
                return Err(newError(message, ast.Span(con program, itemArgument)))
            }
        }
        case Err(error) {
            return Err(error)
        }
    }

    self.recordType(expression, con sliceType)
    return Ok(sliceType)
}

func (mut self CheckedProgram) checkNoneConstructor(con program ast.Program, expression int, con expectedType ResolvedType, hasExpected bool) Result[ResolvedType, SemanticError] {
    if !hasExpected || expectedType.kind != "option" {
        return Err(newError("`None` requires expected `Option[T]` context", ast.Span(con program, expression)))
    }
    ty := copyType(con expectedType)
    self.recordType(expression, con ty)
    return Ok(ty)
}

func (mut self CheckedProgram) checkSomeConstructor(con program ast.Program, expression int, con expectedType ResolvedType, hasExpected bool) Result[ResolvedType, SemanticError] {
    mut value := -1
    match constructorArgument(con program, expression, con "Some") {
        case Ok(argument) {
            value = argument
        }
        case Err(error) {
            return Err(error)
        }
    }

    mut expectedPayload := unitType()
    mut hasExpectedPayload := false
    if hasExpected && expectedType.kind == "option" {
        match self.typeArgument(con expectedType, 0) {
            case Ok(payload) {
                expectedPayload = payload
                hasExpectedPayload = true
            }
            case Err(_) {
                return Err(newError("checked Option payload type is missing", ast.Span(con program, expression)))
            }
        }
    }

    match self.checkExpressionExpected(con program, value, con "owned", con expectedPayload, hasExpectedPayload) {
        case Ok(payloadType) {
            ty := self.makeOptionType(con payloadType)
            self.recordType(expression, con ty)
            return Ok(ty)
        }
        case Err(error) {
            return Err(error)
        }
    }
}

func (mut self CheckedProgram) checkResultConstructor(con program ast.Program, expression int, con expectedType ResolvedType, hasExpected bool, ok bool) Result[ResolvedType, SemanticError] {
    mut constructor := "Err"
    if ok {
        constructor = "Ok"
    }
    mut value := -1
    match constructorArgument(con program, expression, con constructor) {
        case Ok(argument) {
            value = argument
        }
        case Err(error) {
            return Err(error)
        }
    }
    if !hasExpected || expectedType.kind != "result" {
        message := strings.join(con []string{"`", constructor, "` requires expected `Result[T, E]` context",}, con "")
        return Err(newError(message, ast.Span(con program, expression)))
    }

    mut okType := unitType()
    match self.typeArgument(con expectedType, 0) {
        case Ok(ty) {
            okType = ty
        }
        case Err(_) {
            return Err(newError("checked Result success type is missing", ast.Span(con program, expression)))
        }
    }
    mut errorType := unitType()
    match self.typeArgument(con expectedType, 1) {
        case Ok(ty) {
            errorType = ty
        }
        case Err(_) {
            return Err(newError("checked Result error type is missing", ast.Span(con program, expression)))
        }
    }

    mut expectedPayload := copyType(con errorType)
    if ok {
        expectedPayload = copyType(con okType)
    }
    match self.checkExpressionExpected(con program, value, con "owned", con expectedPayload, true) {
        case Ok(payloadType) {
            if ok {
                okType = payloadType
            } else {
                errorType = payloadType
            }
            ty := self.makeResultType(con okType, con errorType)
            self.recordType(expression, con ty)
            return Ok(ty)
        }
        case Err(error) {
            return Err(error)
        }
    }
}

func (mut self CheckedProgram) checkEnumConstructor(con program ast.Program, expression int, selection int, enumIndex int, con expectedType ResolvedType, hasExpected bool, called bool) Result[ResolvedType, SemanticError] {
    enumName := token.CopyText(con self.enums[enumIndex].name)
    enumType := makeType(token.CopyText(con enumName), "enum", false, true)
    if hasExpected && expectedType.text != enumType.text {
        message := strings.join(con []string{"enum constructor type mismatch: expected `", token.CopyText(con expectedType.text), "`, got `", token.CopyText(con enumType.text), "`",}, con "")
        return Err(newError(message, ast.Span(con program, expression)))
    }

    variantName := ast.Value(con program, selection)
    variantIndex := enumVariantIndex(con self.enums[enumIndex], con variantName)
    if variantIndex < 0 {
        message := strings.join(con []string{"enum `", token.CopyText(con enumName), "` has no variant `", token.CopyText(con variantName), "`",}, con "")
        return Err(newError(message, ast.Span(con program, expression)))
    }
    payloadCount := len(self.enums[enumIndex].variants[variantIndex].payloads)
    prefix := strings.join(con []string{token.CopyText(con enumName), ".", token.CopyText(con variantName)}, con "")
    if !called {
        if payloadCount == 1 {
            message := strings.join(con []string{"variant `", token.CopyText(con prefix), "` requires one payload argument",}, con "")
            return Err(newError(message, ast.Span(con program, expression)))
        }
        if payloadCount > 1 {
            message := strings.join(con []string{"variant `", token.CopyText(con prefix), "` requires ", strings.fromInt(payloadCount), " payload arguments",}, con "")
            return Err(newError(message, ast.Span(con program, expression)))
        }
        self.recordType(expression, con enumType)
        return Ok(copyType(con enumType))
    }

    if payloadCount == 0 {
        message := strings.join(con []string{"zero-payload variant `", token.CopyText(con prefix), "` is not callable",}, con "")
        return Err(newError(message, ast.Span(con program, expression)))
    }
    argumentCount := ast.ChildCount(con program, expression) - 1
    if argumentCount != payloadCount {
        message := strings.join(con []string{"variant `", token.CopyText(con prefix), "` requires ", strings.fromInt(payloadCount), " payload arguments, got ", strings.fromInt(argumentCount),}, con "")
        return Err(newError(message, ast.Span(con program, expression)))
    }

    for mut index := 0; index < payloadCount; index = index + 1 {
        argument := ast.Child(con program, expression, index + 1)
        if argModeFromKind(con ast.Kind(con program, argument)) != "owned" {
            message := strings.join(con []string{"payload argument ", strings.fromInt(index + 1), " for `", token.CopyText(con prefix), "` must be owned",}, con "")
            return Err(newError(message, ast.Span(con program, argument)))
        }
        value := ast.Child(con program, argument, 0)
        payloadType := copyType(con self.enums[enumIndex].variants[variantIndex].payloads[index])
        match self.checkExpressionExpected(con program, value, con "owned", con payloadType, true) {
            case Ok(actualType) {
                if actualType.text != payloadType.text {
                    mut message := strings.join(con []string{"payload type mismatch for `", token.CopyText(con prefix), "`: expected `", token.CopyText(con payloadType.text), "`, got `", token.CopyText(con actualType.text), "`",}, con "")
                    if payloadCount > 1 {
                        message = strings.join(con []string{"payload ", strings.fromInt(index + 1), " type mismatch for `", token.CopyText(con prefix), "`: expected `", token.CopyText(con payloadType.text), "`, got `", token.CopyText(con actualType.text), "`",}, con "")
                    }
                    return Err(newError(message, ast.Span(con program, argument)))
                }
            }
            case Err(error) {
                return Err(error)
            }
        }
    }
    self.recordType(expression, con enumType)
    return Ok(enumType)
}

func (mut self CheckedProgram) checkMethodCall(con program ast.Program, expression int, callee int) Result[ResolvedType, SemanticError] {
    receiver := ast.Child(con program, callee, 0)
    mut receiverType := unitType()
    match self.checkReceiverProbeType(con program, receiver) {
        case Ok(ty) {
            receiverType = ty
        }
        case Err(error) {
            return Err(error)
        }
    }
    if receiverType.kind != "struct" {
        message := strings.join(con []string{"method call requires a struct receiver, got `", token.CopyText(con receiverType.text), "`",}, con "")
        return Err(newError(message, ast.Span(con program, receiver)))
    }

    methodName := ast.Value(con program, callee)
    method := self.methodIndex(con receiverType.text, con methodName)
    if method < 0 {
        message := strings.join(con []string{"unknown method `", token.CopyText(con methodName), "` on `", token.CopyText(con receiverType.text), "`",}, con "")
        return Err(newError(message, ast.Span(con program, expression)))
    }

    receiverMode := token.CopyText(con self.methods[method].receiver.mode)
    mut receiverBorrow := BorrowPlace{root: "", segments: []string{}, ty: unitType(), exclusive: false,}
    mut checkedReceiverType := unitType()
    if receiverMode == "owned" {
        match self.checkExpression(con program, receiver) {
            case Ok(ty) {
                checkedReceiverType = copyType(con ty)
            }
            case Err(error) {
                return Err(error)
            }
        }
    } else {
        if isDirectBorrowExpression(con program, receiver) {
            match self.checkReceiverBorrow(con program, receiver, receiverMode == "mut") {
                case Ok(place) {
                    checkedReceiverType = copyType(con place.ty)
                    receiverBorrow = place
                }
                case Err(error) {
                    return Err(error)
                }
            }
        } else {
            match self.checkFullExpressionRead(con program, receiver) {
                case Ok(ty) {
                    checkedReceiverType = ty
                }
                case Err(error) {
                    return Err(error)
                }
            }
        }
    }
    expectedReceiverType := copyType(con self.methods[method].receiver.ty)
    if checkedReceiverType.text != expectedReceiverType.text {
        message := strings.join(con []string{"receiver type mismatch for `", token.CopyText(con methodName), "`: expected `", token.CopyText(con expectedReceiverType.text), "`, got `", token.CopyText(con checkedReceiverType.text), "`",}, con "")
        return Err(newError(message, ast.Span(con program, receiver)))
    }

    match self.checkMethodArguments(con program, expression, method, con methodName, con receiverBorrow) {
        case Ok(_) {
            resultType := copyType(con self.methods[method].returnType)
            self.recordType(expression, con resultType)
            return Ok(resultType)
        }
        case Err(error) {
            return Err(error)
        }
    }
}

func (mut self CheckedProgram) checkReceiverProbeType(con program ast.Program, receiver int) Result[ResolvedType, SemanticError] {
    if isDirectBorrowExpression(con program, receiver) {
        match self.resolveBorrowPlace(con program, receiver) {
            case Ok(place) {
                local := localIndex(con self.locals, con place.root)
                if local < 0 {
                    return Err(newError(strings.join(con []string{"unknown variable `", token.CopyText(con place.root), "`",}, con ""), ast.Span(con program, receiver)))
                }
                if self.locals[local].moved {
                    root := directBorrowRootExpression(con program, receiver)
                    return Err(newError(strings.join(con []string{"borrow of moved value `", token.CopyText(con place.root), "`",}, con ""), ast.Span(con program, root)))
                }
                return Ok(copyType(con place.ty))
            }
            case Err(error) {
                return Err(error)
            }
        }
    }

    baseLocals := copyLocals(con self.locals)
    match self.checkFullExpressionRead(con program, receiver) {
        case Ok(ty) {
            self.locals = baseLocals
            return Ok(ty)
        }
        case Err(error) {
            self.locals = baseLocals
            return Err(error)
        }
    }
}

func (mut self CheckedProgram) checkReceiverBorrow(con program ast.Program, receiver int, mutable bool) Result[BorrowPlace, SemanticError] {
    match self.resolveBorrowPlace(con program, receiver) {
        case Ok(place) {
            local := localIndex(con self.locals, con place.root)
            if local < 0 {
                return Err(newError(strings.join(con []string{"unknown variable `", token.CopyText(con place.root), "`",}, con ""), ast.Span(con program, receiver)))
            }
            if self.locals[local].moved {
                return Err(newError(strings.join(con []string{"borrow of moved value `", token.CopyText(con place.root), "`",}, con ""), ast.Span(con program, receiver)))
            }
            if mutable {
                match self.checkCaptureMutation(con program, local) {
                    case Ok(_) {}
                    case Err(error) {
                        return Err(error)
                    }
                }
            }
            if mutable && !self.locals[local].mutable {
                mut subject := ""
                if hasIndexSegment(con place.segments) {
                    subject = "place of"
                } else if len(place.segments) > 0 {
                    subject = "field of"
                }
                mut separator := ""
                if subject != "" {
                    separator = " "
                }
                message := strings.join(con []string{"cannot mutably borrow ", subject, separator, "immutable binding `", token.CopyText(con place.root), "`",}, con "")
                return Err(newError(message, ast.Span(con program, receiver)))
            }
            return Ok(BorrowPlace{root: token.CopyText(con place.root), segments: copySegments(con place.segments), ty: copyType(con place.ty), exclusive: mutable,})
        }
        case Err(error) {
            return Err(error)
        }
    }
}

func (mut self CheckedProgram) checkFullExpressionRead(con program ast.Program, expression int) Result[ResolvedType, SemanticError] {
    expectedType := unitType()
    return self.checkFullExpressionReadExpected(con program, expression, con expectedType, false)
}

func (mut self CheckedProgram) checkFullExpressionReadExpected(con program ast.Program, expression int, con expectedType ResolvedType, hasExpected bool) Result[ResolvedType, SemanticError] {
    if isDirectBorrowExpression(con program, expression) {
        return self.checkExpressionExpected(con program, expression, con "read", con expectedType, hasExpected)
    }
    kind := ast.Kind(con program, expression)
    if kind == "Expr.FieldAccess" {
        base := ast.Child(con program, expression, 0)
        match self.checkFullExpressionRead(con program, base) {
            case Ok(baseType) {
                field := ast.Value(con program, expression)
                match self.resolveStructField(con baseType, con field, ast.Span(con program, expression), con "field access") {
                    case Ok(ty) {
                        self.recordType(expression, con ty)
                        return Ok(ty)
                    }
                    case Err(error) {
                        return Err(error)
                    }
                }
            }
            case Err(error) {
                return Err(error)
            }
        }
    }
    if kind == "Expr.Index" {
        base := ast.Child(con program, expression, 0)
        index := ast.Child(con program, expression, 1)
        mut baseType := unitType()
        match self.checkFullExpressionRead(con program, base) {
            case Ok(ty) {
                baseType = ty
            }
            case Err(error) {
                return Err(error)
            }
        }
        mut indexType := unitType()
        match self.checkExpression(con program, index) {
            case Ok(ty) {
                indexType = ty
            }
            case Err(error) {
                return Err(error)
            }
        }
        if baseType.kind != "array" && baseType.kind != "slice" {
            message := strings.join(con []string{"indexing requires a fixed-size array or slice, got `", token.CopyText(con baseType.text), "`",}, con "")
            return Err(newError(message, ast.Span(con program, base)))
        }
        match self.validateIndex(con program, index, con indexType, con baseType) {
            case Ok(_) {}
            case Err(error) {
                return Err(error)
            }
        }
        match self.typeArgument(con baseType, 0) {
            case Ok(ty) {
                self.recordType(expression, con ty)
                return Ok(ty)
            }
            case Err(_) {
                return Err(newError("checked index element type is missing", ast.Span(con program, expression)))
            }
        }
    }
    return self.checkExpressionExpected(con program, expression, con "owned", con expectedType, hasExpected)
}

func (mut self CheckedProgram) checkCallArguments(con program ast.Program, expression int, function int, con name string, indirect bool) Result[bool, SemanticError] {
    argumentCount := ast.ChildCount(con program, expression) - 1
    parameterCount := self.callableParamCount(function)
    if argumentCount != parameterCount {
        message := strings.join(con []string{"function `", token.CopyText(con name), "` expects ", strings.fromInt(parameterCount), " arguments, got ", strings.fromInt(argumentCount),}, con "")
        return Err(newError(message, ast.Span(con program, expression)))
    }

    for mut index := 0; index < argumentCount; index = index + 1 {
        argument := ast.Child(con program, expression, index + 1)
        argumentMode := argModeFromKind(con ast.Kind(con program, argument))
        parameterMode := self.callableParamMode(function, index)
        mut parameterName := self.callableParamName(function, index)
        if indirect {
            parameterName = strings.join(con []string{"argument ", strings.fromInt(index + 1),}, con "")
        }
        if argumentMode != parameterMode {
            mut expectation := "expects an owned argument"
            if parameterMode == "con" {
                expectation = "expects `con` argument"
            } else if parameterMode == "mut" {
                expectation = "expects `mut` argument"
            }
            message := strings.join(con []string{"parameter `", parameterName, "` ", expectation,}, con "")
            return Err(newError(message, ast.Span(con program, argument)))
        }

        value := ast.Child(con program, argument, 0)
        parameterType := self.callableParamType(function, index)
        mut argumentType := unitType()
        if argumentMode == "con" || argumentMode == "mut" {
            emptyReceiver := BorrowPlace{root: "", segments: []string{}, ty: unitType(), exclusive: false,}
            match self.checkBorrowArgument(con program, expression, index, argumentMode == "mut", con emptyReceiver, con parameterType) {
                case Ok(ty) {
                    argumentType = ty
                }
                case Err(error) {
                    return Err(error)
                }
            }
        } else {
            match self.checkExpressionExpected(con program, value, con "owned", con parameterType, true) {
                case Ok(ty) {
                    argumentType = ty
                }
                case Err(error) {
                    return Err(error)
                }
            }
        }
        if argumentType.text != parameterType.text {
            message := strings.join(con []string{"argument type mismatch for `", token.CopyText(con name), "`: expected `", token.CopyText(con parameterType.text), "`, got `", token.CopyText(con argumentType.text), "`",}, con "")
            return Err(newError(message, ast.Span(con program, argument)))
        }
    }
    return Ok(true)
}

func (mut self CheckedProgram) checkMethodArguments(con program ast.Program, expression int, method int, con name string, con receiverBorrow BorrowPlace) Result[bool, SemanticError] {
    argumentCount := ast.ChildCount(con program, expression) - 1
    parameterCount := len(self.methods[method].params)
    if argumentCount != parameterCount {
        message := strings.join(con []string{"function `", token.CopyText(con name), "` expects ", strings.fromInt(parameterCount), " arguments, got ", strings.fromInt(argumentCount),}, con "")
        return Err(newError(message, ast.Span(con program, expression)))
    }

    for mut index := 0; index < argumentCount; index = index + 1 {
        argument := ast.Child(con program, expression, index + 1)
        argumentMode := argModeFromKind(con ast.Kind(con program, argument))
        parameterMode := token.CopyText(con self.methods[method].params[index].mode)
        parameterName := token.CopyText(con self.methods[method].params[index].name)
        if argumentMode != parameterMode {
            mut expectation := "expects an owned argument"
            if parameterMode == "con" {
                expectation = "expects `con` argument"
            } else if parameterMode == "mut" {
                expectation = "expects `mut` argument"
            }
            message := strings.join(con []string{"parameter `", parameterName, "` ", expectation,}, con "")
            return Err(newError(message, ast.Span(con program, argument)))
        }

        value := ast.Child(con program, argument, 0)
        parameterType := copyType(con self.methods[method].params[index].ty)
        mut argumentType := unitType()
        if argumentMode == "con" || argumentMode == "mut" {
            match self.checkBorrowArgument(con program, expression, index, argumentMode == "mut", con receiverBorrow, con parameterType) {
                case Ok(ty) {
                    argumentType = ty
                }
                case Err(error) {
                    return Err(error)
                }
            }
        } else {
            match self.checkExpressionExpected(con program, value, con "owned", con parameterType, true) {
                case Ok(ty) {
                    argumentType = ty
                }
                case Err(error) {
                    return Err(error)
                }
            }
        }
        if argumentType.text != parameterType.text {
            message := strings.join(con []string{"argument type mismatch for `", token.CopyText(con name), "`: expected `", token.CopyText(con parameterType.text), "`, got `", token.CopyText(con argumentType.text), "`",}, con "")
            return Err(newError(message, ast.Span(con program, argument)))
        }
    }
    return Ok(true)
}

func (mut self CheckedProgram) checkBorrowArgument(con program ast.Program, call int, argumentIndex int, mutable bool, con receiverBorrow BorrowPlace, con parameterType ResolvedType) Result[ResolvedType, SemanticError] {
    argument := ast.Child(con program, call, argumentIndex + 1)
    value := ast.Child(con program, argument, 0)
    if !isDirectBorrowExpression(con program, value) {
        return self.checkFullExpressionReadExpected(con program, value, con parameterType, true)
    }
    match self.resolveBorrowPlace(con program, value) {
        case Ok(place) {
            local := localIndex(con self.locals, con place.root)
            if local < 0 {
                return Err(newError(strings.join(con []string{"unknown variable `", token.CopyText(con place.root), "`",}, con ""), ast.Span(con program, value)))
            }
            if self.locals[local].moved {
                return Err(newError(strings.join(con []string{"borrow of moved value `", token.CopyText(con place.root), "`",}, con ""), ast.Span(con program, value)))
            }
            if mutable {
                match self.checkCaptureMutation(con program, local) {
                    case Ok(_) {}
                    case Err(error) {
                        return Err(error)
                    }
                }
            }
            if mutable && !self.locals[local].mutable {
                mut subject := ""
                if hasIndexSegment(con place.segments) {
                    subject = "place of"
                } else if len(place.segments) > 0 {
                    subject = "field of"
                }
                mut separator := ""
                if subject != "" {
                    separator = " "
                }
                message := strings.join(con []string{"cannot mutably borrow ", subject, separator, "immutable binding `", token.CopyText(con place.root), "`",}, con "")
                return Err(newError(message, ast.Span(con program, argument)))
            }

            current := BorrowPlace{root: token.CopyText(con place.root), segments: copySegments(con place.segments), ty: copyType(con place.ty), exclusive: mutable,}
            if receiverBorrow.root != "" && borrowPlacesOverlap(con current, con receiverBorrow) &&(current.exclusive || receiverBorrow.exclusive) {
                message := strings.join(con []string{"borrow of `", borrowPlaceText(con current), "` overlaps with an active borrow in this call",}, con "")
                return Err(newError(message, ast.Span(con program, argument)))
            }
            for mut index := 0; index < argumentIndex; index = index + 1 {
                previousArgument := ast.Child(con program, call, index + 1)
                previousMode := argModeFromKind(con ast.Kind(con program, previousArgument))
                if previousMode == "con" || previousMode == "mut" {
                    previousValue := ast.Child(con program, previousArgument, 0)
                    if isDirectBorrowExpression(con program, previousValue) {
                        match self.resolveBorrowPlace(con program, previousValue) {
                            case Ok(previousPlace) {
                                previous := BorrowPlace{root: token.CopyText(con previousPlace.root), segments: copySegments(con previousPlace.segments), ty: copyType(con previousPlace.ty), exclusive: previousMode == "mut",}
                                if borrowPlacesOverlap(con current, con previous) &&(current.exclusive || previous.exclusive) {
                                    message := strings.join(con []string{"borrow of `", borrowPlaceText(con current), "` overlaps with an active borrow in this call",}, con "")
                                    return Err(newError(message, ast.Span(con program, argument)))
                                }
                            }
                            case Err(error) {
                                return Err(error)
                            }
                        }
                    }
                }
            }
            ty := copyType(con current.ty)
            return Ok(ty)
        }
        case Err(error) {
            return Err(error)
        }
    }
}

func (mut self CheckedProgram) resolveBorrowPlace(con program ast.Program, expression int) Result[BorrowPlace, SemanticError] {
    kind := ast.Kind(con program, expression)
    if kind == "Expr.Var" {
        name := ast.Value(con program, expression)
        local := localIndex(con self.locals, con name)
        if local < 0 {
            return Err(newError(strings.join(con []string{"unknown variable `", token.CopyText(con name), "`",}, con ""), ast.Span(con program, expression)))
        }
        self.markCapture(local, false)
        ty := copyType(con self.locals[local].ty)
        self.recordType(expression, con ty)
        if ty.kind == "function" {
            self.recordFunctionReference(expression, self.locals[local].function, false)
        }
        return Ok(BorrowPlace{root: name, segments: []string{}, ty: ty, exclusive: false,})
    }
    if kind == "Expr.FieldAccess" {
        base := ast.Child(con program, expression, 0)
        match self.resolveBorrowPlace(con program, base) {
            case Ok(place) {
                field := ast.Value(con program, expression)
                match self.resolveStructField(con place.ty, con field, ast.Span(con program, expression), con "field borrow") {
                    case Ok(ty) {
                        mut segments := copySegments(con place.segments)
                        segments = append(segments, token.CopyText(con field))
                        self.recordType(expression, con ty)
                        return Ok(BorrowPlace{root: token.CopyText(con place.root), segments: segments, ty: ty, exclusive: false,})
                    }
                    case Err(error) {
                        return Err(error)
                    }
                }
            }
            case Err(error) {
                return Err(error)
            }
        }
    }
    if kind == "Expr.Index" {
        base := ast.Child(con program, expression, 0)
        index := ast.Child(con program, expression, 1)
        match self.resolveBorrowPlace(con program, base) {
            case Ok(place) {
                if place.ty.kind != "array" && place.ty.kind != "slice" {
                    message := strings.join(con []string{"element borrow target must be a fixed-size array or slice, got `", token.CopyText(con place.ty.text), "`",}, con "")
                    return Err(newError(message, ast.Span(con program, base)))
                }
                mut indexType := unitType()
                match self.checkExpression(con program, index) {
                    case Ok(ty) {
                        indexType = ty
                    }
                    case Err(error) {
                        return Err(error)
                    }
                }
                match self.validateIndex(con program, index, con indexType, con place.ty) {
                    case Ok(_) {}
                    case Err(error) {
                        return Err(error)
                    }
                }
                match self.typeArgument(con place.ty, 0) {
                    case Ok(ty) {
                        mut segments := copySegments(con place.segments)
                        segments = append(segments, "?")
                        self.recordType(expression, con ty)
                        return Ok(BorrowPlace{root: token.CopyText(con place.root), segments: segments, ty: ty, exclusive: false,})
                    }
                    case Err(_) {
                        return Err(newError("checked borrow place element type is missing", ast.Span(con program, expression)))
                    }
                }
            }
            case Err(error) {
                return Err(error)
            }
        }
    }
    return Err(newError("direct borrow arguments must use a stable local variable, field, or array/slice element", ast.Span(con program, expression)))
}

func copySegments(con segments []string) []string {
    mut copied := []string{}
    for mut index := 0; index < len(segments); index = index + 1 {
        copied = append(copied, token.CopyText(con segments[index]))
    }
    return copied
}

func copyTexts(con values []string) []string {
    mut copied := []string{}
    for mut index := 0; index < len(values); index = index + 1 {
        copied = append(copied, token.CopyText(con values[index]))
    }
    return copied
}

func hasIndexSegment(con segments []string) bool {
    for mut index := 0; index < len(segments); index = index + 1 {
        if segments[index]== "?" {
            return true
        }
    }
    return false
}

func isDirectBorrowExpression(con program ast.Program, expression int) bool {
    kind := ast.Kind(con program, expression)
    if kind == "Expr.Var" {
        return true
    }
    if kind == "Expr.FieldAccess" || kind == "Expr.Index" {
        return isDirectBorrowExpression(con program, ast.Child(con program, expression, 0))
    }
    return false
}

func directBorrowRootExpression(con program ast.Program, expression int) int {
    kind := ast.Kind(con program, expression)
    if kind == "Expr.FieldAccess" || kind == "Expr.Index" {
        return directBorrowRootExpression(con program, ast.Child(con program, expression, 0))
    }
    return expression
}

func rejectFieldBaseMove(con program ast.Program, base int) Result[bool, SemanticError] {
    kind := ast.Kind(con program, base)
    if kind == "Expr.Var" {
        name := ast.Value(con program, base)
        message := strings.join(con []string{"moving non-copy field out of `", token.CopyText(con name), "` is not supported without destructuring",}, con "")
        return Err(newError(message, ast.Span(con program, base)))
    }
    if kind == "Expr.Index" {
        return Err(newError("moving non-copy field out of indexed element is not supported without destructuring", ast.Span(con program, base)))
    }
    if kind == "Expr.FieldAccess" {
        return rejectFieldBaseMove(con program, ast.Child(con program, base, 0))
    }
    return Ok(true)
}

func borrowPlacesOverlap(con left BorrowPlace, con right BorrowPlace) bool {
    if left.root != right.root {
        return false
    }
    mut common := len(left.segments)
    if len(right.segments) < common {
        common = len(right.segments)
    }
    for mut index := 0; index < common; index = index + 1 {
        if left.segments[index]!= right.segments[index] {
            return false
        }
    }
    return true
}

func borrowPlaceText(con place BorrowPlace) string {
    mut output := token.CopyText(con place.root)
    for mut index := 0; index < len(place.segments); index = index + 1 {
        if place.segments[index]== "?" {
            output = strings.join(con []string{output, "[?]",}, con "")
        } else {
            output = strings.join(con []string{output, ".", token.CopyText(con place.segments[index]),}, con "")
        }
    }
    return output
}

func (mut self CheckedProgram) recordType(node int, con ty ResolvedType) {
    self.typedNodes = append(self.typedNodes, TypedNode{node: node, ty: copyType(con ty)})
}

func (mut self CheckedProgram) recordTypeShape(con ty ResolvedType, con arguments []ResolvedType, arrayLength int) {
    if self.typeShapeIndex(con ty) < 0 {
        mut copiedArguments := []ResolvedType{}
        for mut index := 0; index < len(arguments); index = index + 1 {
            copiedArguments = append(copiedArguments, copyType(con arguments[index]))
        }
        self.typeShapes = append(self.typeShapes, TypeShape{text: token.CopyText(con ty.text), kind: token.CopyText(con ty.kind), copy: ty.copy, cleanup: ty.cleanup, arguments: copiedArguments, arrayLength: arrayLength,})
    }
}

func (mut self CheckedProgram) makeOptionType(con payload ResolvedType) ResolvedType {
    ty := makeType(strings.join(con []string{"Option[", token.CopyText(con payload.text), "]",}, con ""), "option", payload.copy, payload.cleanup)
    self.recordTypeShape(con ty, con []ResolvedType{copyType(con payload)}, -1)
    return ty
}

func (mut self CheckedProgram) makeResultType(con okType ResolvedType, con errorType ResolvedType) ResolvedType {
    ty := makeType(strings.join(con []string{"Result[", token.CopyText(con okType.text), ", ", token.CopyText(con errorType.text), "]",}, con ""), "result", okType.copy && errorType.copy, okType.cleanup || errorType.cleanup)
    self.recordTypeShape(con ty, con []ResolvedType{copyType(con okType), copyType(con errorType)}, -1)
    return ty
}

func (con self CheckedProgram) typeShapeIndex(con ty ResolvedType) int {
    for mut index := 0; index < len(self.typeShapes); index = index + 1 {
        if self.typeShapes[index].text == ty.text {
            return index
        }
    }
    return - 1
}

func (con self CheckedProgram) typeArgument(con ty ResolvedType, argument int) Result[ResolvedType, bool] {
    shape := self.typeShapeIndex(con ty)
    if shape < 0 || argument < 0 || argument >= len(self.typeShapes[shape].arguments) {
        return Err(false)
    }
    return Ok(copyType(con self.typeShapes[shape].arguments[argument]))
}

func (con self CheckedProgram) arrayLength(con ty ResolvedType) int {
    shape := self.typeShapeIndex(con ty)
    if shape < 0 {
        return - 1
    }
    return self.typeShapes[shape].arrayLength
}

func (mut self CheckedProgram) recordFunctionReference(node int, function int, direct bool) {
    self.functionReferences = append(self.functionReferences, FunctionReference{node: node, function: function, direct: direct})
}

func (mut self CheckedProgram) markCapture(local int, mutable bool) {
    if local >= 0 && self.locals[local].capture {
        name := token.CopyText(con self.locals[local].name)
        mut found := false
        for mut capture := 0; capture < len(self.captureUses); capture = capture + 1 {
            if self.captureUses[capture].name == name {
                self.captureUses[capture].mutable = self.captureUses[capture].mutable || mutable
                found = true
            }
        }
        if !found {
            self.captureUses = append(self.captureUses, CaptureUse{name: token.CopyText(con name), mutable: mutable,})
        }
    }
}

func (mut self CheckedProgram) checkCaptureMutation(con program ast.Program, local int) Result[bool, SemanticError] {
    self.markCapture(local, true)
    if local >= 0 && self.locals[local].capture && self.closureMutable && !self.locals[local].mutable {
        name := token.CopyText(con self.locals[local].name)
        message := strings.join(con []string{"mutable closure capture `", name, "` requires a mutable source binding",}, con "")
        return Err(newError(message, ast.Span(con program, self.closureNode)))
    }
    return Ok(true)
}

func (con self CheckedProgram) functionReferenceIndex(node int) int {
    for mut index := 0; index < len(self.functionReferences); index = index + 1 {
        if self.functionReferences[index].node == node {
            return index
        }
    }
    return - 1
}

func (con self CheckedProgram) functionIndex(con name string) int {
    for mut index := 0; index < len(self.functions); index = index + 1 {
        if self.functions[index].name == name {
            return index
        }
    }
    return - 1
}

func (con self CheckedProgram) structIndex(con name string) int {
    for mut index := 0; index < len(self.structs); index = index + 1 {
        if self.structs[index].name == name {
            return index
        }
    }
    return - 1
}

func (con self CheckedProgram) enumIndex(con name string) int {
    for mut index := 0; index < len(self.enums); index = index + 1 {
        if self.enums[index].name == name {
            return index
        }
    }
    return - 1
}

func (con self CheckedProgram) enumNeedsOwnedStorage(con name string) bool {
    enumeration := self.enumIndex(con name)
    if enumeration < 0 {
        return false
    }
    for mut variant := 0; variant < len(self.enums[enumeration].variants); variant = variant + 1 {
        for mut payload := 0; payload < len(self.enums[enumeration].variants[variant].payloads); payload = payload + 1 {
            visited := []string{token.CopyText(con name)}
            if self.typeReachesEnum(con self.enums[enumeration].variants[variant].payloads[payload], con name, con visited) {
                return true
            }
        }
    }
    return false
}

func (con self CheckedProgram) typeReachesEnum(con ty ResolvedType, con target string, con visiting []string) bool {
    if ty.kind == "enum" || ty.kind == "struct" {
        if ty.text == target {
            return true
        }
        if containsText(con visiting, con ty.text) {
            return false
        }
        mut nestedVisiting := copyTexts(con visiting)
        nestedVisiting = append(nestedVisiting, token.CopyText(con ty.text))
        if ty.kind == "enum" {
            enumeration := self.enumIndex(con ty.text)
            if enumeration >= 0 {
                for mut variant := 0; variant < len(self.enums[enumeration].variants); variant = variant + 1 {
                    for mut payload := 0; payload < len(self.enums[enumeration].variants[variant].payloads); payload = payload + 1 {
                        if self.typeReachesEnum(con self.enums[enumeration].variants[variant].payloads[payload], con target, con nestedVisiting) {
                            return true
                        }
                    }
                }
            }
        } else {
            structure := self.structIndex(con ty.text)
            if structure >= 0 {
                for mut field := 0; field < len(self.structs[structure].fields); field = field + 1 {
                    if self.typeReachesEnum(con self.structs[structure].fields[field].ty, con target, con nestedVisiting) {
                        return true
                    }
                }
            }
        }
        return false
    }

    shape := self.typeShapeIndex(con ty)
    if shape >= 0 {
        for mut argument := 0; argument < len(self.typeShapes[shape].arguments); argument = argument + 1 {
            if self.typeReachesEnum(con self.typeShapes[shape].arguments[argument], con target, con visiting) {
                return true
            }
        }
    }
    return false
}

func (con self CheckedProgram) adtPatternName(con ty ResolvedType) string {
    if ty.kind == "option" {
        return "Option"
    }
    if ty.kind == "result" {
        return "Result"
    }
    if ty.kind == "enum" {
        index := self.enumIndex(con ty.text)
        if index >= 0 {
            return token.CopyText(con self.enums[index].patternName)
        }
        return token.CopyText(con ty.text)
    }
    return ""
}

func (con self CheckedProgram) adtVariantCount(con ty ResolvedType) int {
    if ty.kind == "option" || ty.kind == "result" {
        return 2
    }
    if ty.kind == "enum" {
        index := self.enumIndex(con ty.text)
        if index >= 0 {
            return len(self.enums[index].variants)
        }
    }
    return - 1
}

func (con self CheckedProgram) adtVariantName(con ty ResolvedType, variant int) string {
    if ty.kind == "option" {
        if variant == 0 {
            return "None"
        }
        if variant == 1 {
            return "Some"
        }
    } else if ty.kind == "result" {
        if variant == 0 {
            return "Ok"
        }
        if variant == 1 {
            return "Err"
        }
    } else if ty.kind == "enum" {
        index := self.enumIndex(con ty.text)
        if index >= 0 && variant >= 0 && variant < len(self.enums[index].variants) {
            return token.CopyText(con self.enums[index].variants[variant].name)
        }
    }
    return ""
}

func (con self CheckedProgram) adtVariantIndex(con ty ResolvedType, con name string) int {
    count := self.adtVariantCount(con ty)
    for mut variant := 0; variant < count; variant = variant + 1 {
        if self.adtVariantName(con ty, variant) == name {
            return variant
        }
    }
    return - 1
}

func (con self CheckedProgram) adtVariantPayloadCount(con ty ResolvedType, variant int) int {
    if ty.kind == "option" {
        if variant == 0 {
            return 0
        }
        if variant == 1 {
            return 1
        }
    } else if ty.kind == "result" {
        if variant == 0 || variant == 1 {
            return 1
        }
    } else if ty.kind == "enum" {
        index := self.enumIndex(con ty.text)
        if index >= 0 && variant >= 0 && variant < len(self.enums[index].variants) {
            return len(self.enums[index].variants[variant].payloads)
        }
    }
    return - 1
}

func (con self CheckedProgram) adtVariantPayloadType(con ty ResolvedType, variant int, payload int) Result[ResolvedType, bool] {
    if ty.kind == "option" && variant == 1 && payload == 0 {
        return self.typeArgument(con ty, 0)
    }
    if ty.kind == "result" && payload == 0 {
        if variant == 0 {
            return self.typeArgument(con ty, 0)
        }
        if variant == 1 {
            return self.typeArgument(con ty, 1)
        }
    }
    if ty.kind == "enum" {
        index := self.enumIndex(con ty.text)
        if index >= 0 && variant >= 0 && variant < len(self.enums[index].variants) && payload >= 0 && payload < len(self.enums[index].variants[variant].payloads) {
            return Ok(copyType(con self.enums[index].variants[variant].payloads[payload]))
        }
    }
    return Err(false)
}

func (con self CheckedProgram) enumSelectionIndex(con program ast.Program, expression int) int {
    if ast.Kind(con program, expression) != "Expr.FieldAccess" {
        return - 1
    }
    base := ast.Child(con program, expression, 0)
    if ast.Kind(con program, base) != "Expr.Var" {
        return - 1
    }
    enumName := ast.Value(con program, base)
    return self.enumIndex(con enumName)
}

func (con self CheckedProgram) functionIndexForType(con ty ResolvedType) int {
    if ty.kind != "function" {
        return - 1
    }
    for mut index := 0; index < len(self.functions); index = index + 1 {
        functionType := self.functionType(index)
        if functionType.text == ty.text {
            return index
        }
    }
    for mut index := 0; index < len(self.functionTypes); index = index + 1 {
        function := encodeFunctionTypeIndex(index)
        functionType := self.functionType(function)
        if functionType.text == ty.text {
            return function
        }
    }
    return - 1
}

func (con self CheckedProgram) callableMutable(function int) bool {
    if function >= 0 {
        return self.functions[function].mutable
    }
    return self.functionTypes[decodeFunctionTypeIndex(function)].mutable
}

func (con self CheckedProgram) callableParamCount(function int) int {
    if function >= 0 {
        return len(self.functions[function].params)
    }
    return len(self.functionTypes[decodeFunctionTypeIndex(function)].params)
}

func (con self CheckedProgram) callableParamName(function int, param int) string {
    if function >= 0 {
        return token.CopyText(con self.functions[function].params[param].name)
    }
    return token.CopyText(con self.functionTypes[decodeFunctionTypeIndex(function)].params[param].name)
}

func (con self CheckedProgram) callableParamMode(function int, param int) string {
    if function >= 0 {
        return token.CopyText(con self.functions[function].params[param].mode)
    }
    return token.CopyText(con self.functionTypes[decodeFunctionTypeIndex(function)].params[param].mode)
}

func (con self CheckedProgram) callableParamType(function int, param int) ResolvedType {
    if function >= 0 {
        return copyType(con self.functions[function].params[param].ty)
    }
    return copyType(con self.functionTypes[decodeFunctionTypeIndex(function)].params[param].ty)
}

func (con self CheckedProgram) callableReturnType(function int) ResolvedType {
    if function >= 0 {
        return copyType(con self.functions[function].returnType)
    }
    return copyType(con self.functionTypes[decodeFunctionTypeIndex(function)].returnType)
}

func (con self CheckedProgram) functionType(function int) ResolvedType {
    mut params := []string{}
    for mut param := 0; param < self.callableParamCount(function); param = param + 1 {
        mut prefix := ""
        mode := self.callableParamMode(function, param)
        if mode != "owned" {
            prefix = strings.join(con []string{token.CopyText(con mode), " ",}, con "")
        }
        paramType := self.callableParamType(function, param)
        params = append(params, strings.join(con []string{prefix, token.CopyText(con paramType.text),}, con ""))
    }
    mut mutable := ""
    if self.callableMutable(function) {
        mutable = " mut"
    }
    returnType := self.callableReturnType(function)
    return ResolvedType{text: strings.join(con []string{"func", mutable, "(", strings.join(con params, con ", "), ") ", token.CopyText(con returnType.text),}, con ""), kind: "function", copy: false, cleanup: true,}
}

func (con self CheckedProgram) methodIndex(con receiver string, con name string) int {
    for mut index := 0; index < len(self.methods); index = index + 1 {
        if self.methods[index].receiver.ty.text == receiver && self.methods[index].name == name {
            return index
        }
    }
    return - 1
}

func (mut self CheckedProgram) resolveParam(con program ast.Program, node int) Result[ParamSig, SemanticError] {
    name := ast.Value(con program, node)
    if isBuiltinValueName(con name) {
        return Err(newError(strings.join(con []string{"`", token.CopyText(con name), "` is a built-in value name",}, con ""), ast.Span(con program, node)))
    }
    kind := ast.Kind(con program, node)
    mode := modeFromKind(con kind)
    typeNode := ast.Child(con program, node, 0)
    return match self.resolveType(con program, typeNode) {
        case Ok(ty) {
            Ok(ParamSig{name: name, mode: mode, ty: ty})
        }
        case Err(error) {
            Err(error)
        }
    }
}

func (mut self CheckedProgram) resolveType(con program ast.Program, node int) Result[ResolvedType, SemanticError] {
    kind := ast.Kind(con program, node)
    name := ast.Value(con program, node)
    span := ast.Span(con program, node)
    childCount := ast.ChildCount(con program, node)

    if kind == "Type.Slice" {
        if childCount != 1 {
            return Err(newError("malformed slice type reference", source.Copy(con span)))
        }
        match self.resolveType(con program, ast.Child(con program, node, 0)) {
            case Ok(element) {
                ty := makeType(strings.join(con []string{"[]", token.CopyText(con element.text),}, con ""), "slice", false, true)
                self.recordTypeShape(con ty, con []ResolvedType{copyType(con element)}, -1)
                return Ok(ty)
            }
            case Err(error) {
                return Err(error)
            }
        }
    }
    if kind == "Type.Array" {
        if childCount != 1 {
            return Err(newError("malformed fixed-size array type reference", source.Copy(con span)))
        }
        match self.resolveType(con program, ast.Child(con program, node, 0)) {
            case Ok(element) {
                mut length := 0
                match strings.parseInt(con name) {
                    case Ok(value) {
                        length = value
                    }
                    case Err(_) {
                        return Err(newError("malformed fixed-size array length", source.Copy(con span)))
                    }
                }
                ty := makeType(strings.join(con []string{"[", token.CopyText(con name), "]", token.CopyText(con element.text),}, con ""), "array", false, element.cleanup)
                self.recordTypeShape(con ty, con []ResolvedType{copyType(con element)}, length)
                return Ok(ty)
            }
            case Err(error) {
                return Err(error)
            }
        }
    }
    if kind == "Type.Function.Immutable" || kind == "Type.Function.Mutable" {
        if childCount == 0 {
            return Err(newError("malformed function type reference", source.Copy(con span)))
        }
        mut params := []string{}
        mut signatureParams := []ParamSig{}
        for mut child := 0; child < childCount - 1; child = child + 1 {
            paramNode := ast.Child(con program, node, child)
            paramKind := ast.Kind(con program, paramNode)
            mode := modeFromKind(con paramKind)
            match self.resolveType(con program, ast.Child(con program, paramNode, 0)) {
                case Ok(paramType) {
                    mut prefix := ""
                    if mode != "owned" {
                        prefix = strings.join(con []string{token.CopyText(con mode), " ",}, con "")
                    }
                    params = append(params, strings.join(con []string{prefix, token.CopyText(con paramType.text),}, con ""))
                    signatureParams = append(signatureParams, ParamSig{name: strings.join(con []string{"argument ", strings.fromInt(child + 1),}, con ""), mode: mode, ty: copyType(con paramType),})
                }
                case Err(error) {
                    return Err(error)
                }
            }
        }
        returnWrapper := ast.Child(con program, node, childCount - 1)
        returnNode := ast.Child(con program, returnWrapper, 0)
        mut mutable := ""
        mut functionMutable := false
        if kind == "Type.Function.Mutable" {
            mutable = " mut"
            functionMutable = true
        }
        match self.resolveType(con program, returnNode) {
            case Ok(returnType) {
                ty := ResolvedType{text: strings.join(con []string{"func", mutable, "(", strings.join(con params, con ", "), ") ", token.CopyText(con returnType.text),}, con ""), kind: "function", copy: false, cleanup: true,}
                self.functionTypes = append(self.functionTypes, FunctionSig{name: "", intrinsic: "", mutable: functionMutable, params: signatureParams, returnType: copyType(con returnType),})
                return Ok(ty)
            }
            case Err(error) {
                return Err(error)
            }
        }
    }
    if kind != "Type.Named" {
        return Err(newError("malformed type reference", source.Copy(con span)))
    }

    if name == "int" || name == "bool" || name == "string" || name == "unit" {
        if childCount != 0 {
            return Err(newError(strings.join(con []string{"primitive type `", token.CopyText(con name), "` does not take type arguments",}, con ""), source.Copy(con span)))
        }
        if name == "string" {
            return Ok(ResolvedType{text: token.CopyText(con name), kind: "string", copy: false, cleanup: true,})
        }
        return Ok(ResolvedType{text: token.CopyText(con name), kind: token.CopyText(con name), copy: true, cleanup: false,})
    }
    if name == "Option" {
        if childCount != 1 {
            return Err(newError("`Option` expects exactly 1 type argument", source.Copy(con span)))
        }
        match self.resolveType(con program, ast.Child(con program, node, 0)) {
            case Ok(inner) {
                ty := makeType(strings.join(con []string{"Option[", token.CopyText(con inner.text), "]",}, con ""), "option", inner.copy, inner.cleanup)
                self.recordTypeShape(con ty, con []ResolvedType{copyType(con inner)}, -1)
                return Ok(ty)
            }
            case Err(error) {
                return Err(error)
            }
        }
    }
    if name == "Result" {
        if childCount != 2 {
            return Err(newError("`Result` expects exactly 2 type arguments", source.Copy(con span)))
        }
        match self.resolveType(con program, ast.Child(con program, node, 0)) {
            case Ok(okType) {
                match self.resolveType(con program, ast.Child(con program, node, 1)) {
                    case Ok(errorType) {
                        ty := makeType(strings.join(con []string{"Result[", token.CopyText(con okType.text), ", ", token.CopyText(con errorType.text), "]",}, con ""), "result", okType.copy && errorType.copy, okType.cleanup || errorType.cleanup)
                        self.recordTypeShape(con ty, con []ResolvedType{copyType(con okType), copyType(con errorType)}, -1)
                        return Ok(ty)
                    }
                    case Err(error) {
                        return Err(error)
                    }
                }
            }
            case Err(error) {
                return Err(error)
            }
        }
    }
    if self.hasStruct(con name) {
        if childCount != 0 {
            return Err(newError(strings.join(con []string{"struct type `", token.CopyText(con name), "` does not take type arguments",}, con ""), source.Copy(con span)))
        }
        return Ok(ResolvedType{text: token.CopyText(con name), kind: "struct", copy: false, cleanup: true,})
    }
    if self.hasEnum(con name) {
        if childCount != 0 {
            return Err(newError(strings.join(con []string{"enum type `", token.CopyText(con name), "` does not take type arguments",}, con ""), source.Copy(con span)))
        }
        enumeration := self.enumIndex(con name)
        if enumeration >= 0 && self.enums[enumeration].intrinsic == "ErrorKind" {
            return Ok(ResolvedType{text: token.CopyText(con name), kind: "enum", copy: true, cleanup: false,})
        }
        return Ok(ResolvedType{text: token.CopyText(con name), kind: "enum", copy: false, cleanup: true,})
    }
    return Err(newError(strings.join(con []string{"unknown type `", token.CopyText(con name), "`",}, con ""), source.Copy(con span)))
}

func (con self CheckedProgram) hasStruct(con name string) bool {
    for mut index := 0; index < len(self.structs); index = index + 1 {
        if self.structs[index].name == name {
            return true
        }
    }
    return false
}

func (con self CheckedProgram) hasEnum(con name string) bool {
    for mut index := 0; index < len(self.enums); index = index + 1 {
        if self.enums[index].name == name {
            return true
        }
    }
    return false
}

func (con self CheckedProgram) hasFunction(con name string) bool {
    for mut index := 0; index < len(self.functions); index = index + 1 {
        if self.functions[index].name == name {
            return true
        }
    }
    return false
}

func (con self CheckedProgram) hasMethod(con receiver string, con name string) bool {
    for mut index := 0; index < len(self.methods); index = index + 1 {
        if self.methods[index].receiver.ty.text == receiver && self.methods[index].name == name {
            return true
        }
    }
    return false
}

func hasField(con value StructSig, con name string) bool {
    for mut index := 0; index < len(value.fields); index = index + 1 {
        if value.fields[index].name == name {
            return true
        }
    }
    return false
}

func hasVariant(con value EnumSig, con name string) bool {
    for mut index := 0; index < len(value.variants); index = index + 1 {
        if value.variants[index].name == name {
            return true
        }
    }
    return false
}

func enumVariantIndex(con value EnumSig, con name string) int {
    for mut index := 0; index < len(value.variants); index = index + 1 {
        if value.variants[index].name == name {
            return index
        }
    }
    return - 1
}

func encodeFunctionTypeIndex(index int) int {
    return - 2 - index
}

func decodeFunctionTypeIndex(function int) int {
    return - 2 - function
}

func matchUsesRecursiveCoverage(con program ast.Program, expression int) bool {
    for mut arm := 1; arm < ast.ChildCount(con program, expression); arm = arm + 1 {
        pattern := ast.Child(con program, ast.Child(con program, expression, arm), 0)
        if patternUsesRecursiveCoverage(con program, pattern) {
            return true
        }
    }
    return false
}

func patternUsesRecursiveCoverage(con program ast.Program, pattern int) bool {
    kind := ast.Kind(con program, pattern)
    if kind == "Pattern.NestedBuiltin" {
        return true
    }
    if kind != "Pattern.Variant" {
        return false
    }
    for mut child := 0; child < ast.ChildCount(con program, pattern); child = child + 1 {
        payload := ast.Child(con program, pattern, child)
        payloadKind := ast.Kind(con program, payload)
        if payloadKind != "Pattern.Binding" && payloadKind != "Pattern.Wildcard" {
            return true
        }
        if patternUsesRecursiveCoverage(con program, payload) {
            return true
        }
    }
    return false
}

func containsPatternBinding(con bindings []PatternBinding, con name string) bool {
    for mut index := 0; index < len(bindings); index = index + 1 {
        if bindings[index].name == name {
            return true
        }
    }
    return false
}

func copyCoverageSet(con coverage [][]string) [][]string {
    mut copied := [][]string{}
    for mut leaf := 0; leaf < len(coverage); leaf = leaf + 1 {
        copied = append(copied, copySegments(con coverage[leaf]))
    }
    return copied
}

func containsCoveragePath(con coverage [][]string, con expected []string) bool {
    for mut leaf := 0; leaf < len(coverage); leaf = leaf + 1 {
        if len(coverage[leaf]) == len(expected) {
            mut equal := true
            for mut segment := 0; segment < len(expected); segment = segment + 1 {
                equal = equal && coverage[leaf][segment]== expected[segment]
            }
            if equal {
                return true
            }
        }
    }
    return false
}

func extendCoverage(coverage [][]string, con additions [][]string) [][]string {
    mut extended := coverage
    for mut leaf := 0; leaf < len(additions); leaf = leaf + 1 {
        if !containsCoveragePath(con extended, con additions[leaf]) {
            extended = append(extended, copySegments(con additions[leaf]))
        }
    }
    return extended
}

func variantCoverage(con prefix string, payloads [][][]string) [][]string {
    if len(payloads) == 0 {
        return [][]string{[]string{token.CopyText(con prefix),},}
    }
    if len(payloads) == 1 {
        mut prefixed := [][]string{}
        for mut leaf := 0; leaf < len(payloads[0]); leaf = leaf + 1 {
            mut path := []string{token.CopyText(con prefix),}
            for mut segment := 0; segment < len(payloads[0][leaf]); segment = segment + 1 {
                path = append(path, token.CopyText(con payloads[0][leaf][segment]))
            }
            prefixed = extendCoverage(prefixed, con [][]string{path,})
        }
        return prefixed
    }

    mut combined := [][]string{[]string{token.CopyText(con prefix),},}
    for mut payload := 0; payload < len(payloads); payload = payload + 1 {
        mut next := [][]string{}
        for mut pathIndex := 0; pathIndex < len(combined); pathIndex = pathIndex + 1 {
            for mut leaf := 0; leaf < len(payloads[payload]); leaf = leaf + 1 {
                mut joined := copySegments(con combined[pathIndex])
                joined = append(joined, strings.join(con []string{"payload ", strings.fromInt(payload + 1),}, con ""))
                for mut segment := 0; segment < len(payloads[payload][leaf]); segment = segment + 1 {
                    joined = append(joined, token.CopyText(con payloads[payload][leaf][segment]))
                }
                next = extendCoverage(next, con [][]string{joined,})
            }
        }
        combined = next
    }
    return combined
}

func coverageIsSubset(con required [][]string, con available [][]string) bool {
    for mut leaf := 0; leaf < len(required); leaf = leaf + 1 {
        if !coveragePathIsCovered(con required[leaf], con available) {
            return false
        }
    }
    return true
}

func coveragePathIsCovered(con path []string, con available [][]string) bool {
    for mut candidate := 0; candidate < len(available); candidate = candidate + 1 {
        if coveragePathCovers(con available[candidate], con path) {
            return true
        }
    }
    return false
}

func coveragePathCovers(con covering []string, con path []string) bool {
    for mut segment := 0; segment < len(covering); segment = segment + 1 {
        if segment >= len(path) {
            return false
        }
        if isRecursiveCoverageSegment(con covering[segment]) {
            return !isRecursiveCoverageSegment(con path[segment]) || covering[segment]== path[segment]
        }
        if covering[segment]!= path[segment] {
            return false
        }
    }
    return len(covering) == len(path)
}

func isRecursiveCoverageSegment(con value string) bool {
    return match strings.find(con value, con "<recursive ") {
        case Some(offset) {
            offset == 0
        }
        case None {
            false
        }
    }
}

func containsText(con values []string, con expected string) bool {
    for mut index := 0; index < len(values); index = index + 1 {
        if values[index]== expected {
            return true
        }
    }
    return false
}

func hasParam(con params []ParamSig, con name string) bool {
    for mut index := 0; index < len(params); index = index + 1 {
        if params[index].name == name {
            return true
        }
    }
    return false
}

func localIndex(con locals []Local, con name string) int {
    for mut index := len(locals) - 1; index >= 0; index = index - 1 {
        if locals[index].name == name {
            return index
        }
    }
    return - 1
}

func localFromParam(con param ParamSig) Local {
    return Local{name: token.CopyText(con param.name), mutable: param.mode == "mut", borrowed: param.mode != "owned", moved: false, rangeSource: false, capture: false, ty: copyType(con param.ty), function: -1, scopeDepth: 0,}
}

func copyParams(con params []ParamSig) []ParamSig {
    mut copied := []ParamSig{}
    for mut index := 0; index < len(params); index = index + 1 {
        copied = append(copied, ParamSig{name: token.CopyText(con params[index].name), mode: token.CopyText(con params[index].mode), ty: copyType(con params[index].ty),})
    }
    return copied
}

func copyLocals(con locals []Local) []Local {
    mut copied := []Local{}
    for mut index := 0; index < len(locals); index = index + 1 {
        copied = append(copied, Local{name: token.CopyText(con locals[index].name), mutable: locals[index].mutable, borrowed: locals[index].borrowed, moved: locals[index].moved, rangeSource: locals[index].rangeSource, capture: locals[index].capture, ty: copyType(con locals[index].ty), function: locals[index].function, scopeDepth: locals[index].scopeDepth,})
    }
    return copied
}

func copyCaptureUses(con captures []CaptureUse) []CaptureUse {
    mut copied := []CaptureUse{}
    for mut index := 0; index < len(captures); index = index + 1 {
        copied = append(copied, CaptureUse{name: token.CopyText(con captures[index].name), mutable: captures[index].mutable,})
    }
    return copied
}

func parseRangeBindings(con value string) RangeBindings {
    separator := ","
    mut result := RangeBindings{indexName: "", valueName: "", valid: false,}
    match strings.find(con value, con separator) {
        case Some(offset) {
            mut indexName := ""
            match strings.slice(con value, 0, offset) {
                case Ok(text) {
                    indexName = text
                }
                case Err(_) {}
            }
            mut valueName := ""
            match strings.slice(con value, offset + 1, strings.byteLen(con value)) {
                case Ok(text) {
                    valueName = text
                }
                case Err(_) {}
            }
            valid := indexName != "" && valueName != ""
            result = RangeBindings{indexName: indexName, valueName: valueName, valid: valid,}
        }
        case None {}
    }
    return result
}

func splitPatternVariant(con value string) PatternVariantParts {
    mut result := PatternVariantParts{typeName: "", variantName: "", valid: false,}
    match strings.find(con value, con ".") {
        case Some(offset) {
            mut typeName := ""
            match strings.slice(con value, 0, offset) {
                case Ok(text) {
                    typeName = text
                }
                case Err(_) {}
            }
            mut variantName := ""
            match strings.slice(con value, offset + 1, strings.byteLen(con value)) {
                case Ok(text) {
                    variantName = text
                }
                case Err(_) {}
            }
            valid := typeName != "" && variantName != ""
            result = PatternVariantParts{typeName: typeName, variantName: variantName, valid: valid,}
        }
        case None {}
    }
    return result
}

func sortTexts(values []string) []string {
    mut used := []bool{}
    for mut index := 0; index < len(values); index = index + 1 {
        used = append(used, false)
    }

    mut sorted := []string{}
    for len(sorted) < len(values) {
        mut best := -1
        for mut index := 0; index < len(values); index = index + 1 {
            if !used[index]&&(best < 0 || textPrecedes(con values[index], con values[best])) {
                best = index
            }
        }
        if best < 0 {
            break
        }
        used[best]= true
        sorted = append(sorted, token.CopyText(con values[best]))
    }
    return sorted
}

func textPrecedes(con left string, con right string) bool {
    mut limit := strings.byteLen(con left)
    if strings.byteLen(con right) < limit {
        limit = strings.byteLen(con right)
    }
    for mut index := 0; index < limit; index = index + 1 {
        mut leftByte := 0
        match strings.byteAt(con left, index) {
            case Ok(value) {
                leftByte = value
            }
            case Err(_) {
                return false
            }
        }
        mut rightByte := 0
        match strings.byteAt(con right, index) {
            case Ok(value) {
                rightByte = value
            }
            case Err(_) {
                return false
            }
        }
        if leftByte != rightByte {
            return leftByte < rightByte
        }
    }
    return strings.byteLen(con left) < strings.byteLen(con right)
}

func mergeBranchMoves(con baseLocals []Local, con thenLocals []Local, con elseLocals []Local) []Local {
    mut merged := copyLocals(con baseLocals)
    for mut index := 0; index < len(merged); index = index + 1 {
        movedInThen := index < len(thenLocals) && thenLocals[index].moved
        movedInElse := index < len(elseLocals) && elseLocals[index].moved
        merged[index].moved = merged[index].moved || movedInThen || movedInElse
    }
    return merged
}

func mergeLoopMoves(con baseLocals []Local, con loopLocals []Local, con bodyLocals []Local) []Local {
    mut merged := copyLocals(con baseLocals)
    for mut index := 0; index < len(merged); index = index + 1 {
        movedInLoop := index < len(loopLocals) && loopLocals[index].moved
        movedInBody := index < len(bodyLocals) && bodyLocals[index].moved
        merged[index].moved = merged[index].moved || movedInLoop || movedInBody
    }
    return merged
}

func rejectLoopPersistentMoves(con beforeLocals []Local, con afterLocals []Local, loopScopeDepth int, con span source.Span) Result[bool, SemanticError] {
    mut limit := len(beforeLocals)
    if len(afterLocals) < limit {
        limit = len(afterLocals)
    }
    for mut index := 0; index < limit; index = index + 1 {
        if afterLocals[index].moved && !beforeLocals[index].moved && afterLocals[index].scopeDepth <= loopScopeDepth && !afterLocals[index].ty.copy {
            message := strings.join(con []string{"loop cannot move persistent value `", token.CopyText(con afterLocals[index].name), "` in v0",}, con "")
            return Err(newError(message, source.Copy(con span)))
        }
    }
    return Ok(true)
}

func copyType(con ty ResolvedType) ResolvedType {
    return ResolvedType{text: token.CopyText(con ty.text), kind: token.CopyText(con ty.kind), copy: ty.copy, cleanup: ty.cleanup,}
}

func makeType(text string, kind string, copy bool, cleanup bool) ResolvedType {
    return ResolvedType{text: text, kind: kind, copy: copy, cleanup: cleanup,}
}

func intType() ResolvedType {
    return ResolvedType{text: "int", kind: "int", copy: true, cleanup: false,}
}

func boolType() ResolvedType {
    return ResolvedType{text: "bool", kind: "bool", copy: true, cleanup: false,}
}

func stringType() ResolvedType {
    return ResolvedType{text: "string", kind: "string", copy: false, cleanup: true,}
}

func constInt(con program ast.Program, expression int) Result[int, bool] {
    kind := ast.Kind(con program, expression)
    if kind == "Expr.Int" {
        return match strings.parseInt(con ast.Value(con program, expression)) {
            case Ok(value) {
                Ok(value)
            }
            case Err(_) {
                Err(false)
            }
        }
    }
    if kind == "Expr.Unary.Negate" {
        return match constInt(con program, ast.Child(con program, expression, 0)) {
            case Ok(value) {
                Ok(-value)
            }
            case Err(_) {
                Err(false)
            }
        }
    }
    return Err(false)
}

func assignmentRoot(con program ast.Program, expression int) Result[string, bool] {
    kind := ast.Kind(con program, expression)
    if kind == "Expr.Var" {
        return Ok(ast.Value(con program, expression))
    }
    if kind == "Expr.FieldAccess" || kind == "Expr.Index" {
        return assignmentRoot(con program, ast.Child(con program, expression, 0))
    }
    return Err(false)
}

func assignmentHasField(con program ast.Program, expression int) bool {
    kind := ast.Kind(con program, expression)
    if kind == "Expr.FieldAccess" {
        return true
    }
    if kind == "Expr.Index" {
        return assignmentHasField(con program, ast.Child(con program, expression, 0))
    }
    return false
}

func isPrintCall(con program ast.Program, expression int) bool {
    if ast.Kind(con program, expression) != "Expr.Call" || ast.ChildCount(con program, expression) == 0 {
        return false
    }
    callee := ast.Child(con program, expression, 0)
    return ast.Kind(con program, callee) == "Expr.Var" && ast.Value(con program, callee) == "print"
}

func isBinaryKind(con kind string) bool {
    return isArithmeticKind(con kind) || isEqualityKind(con kind) || isLogicalKind(con kind) || kind == "Expr.Binary.Less" || kind == "Expr.Binary.LessEqual" || kind == "Expr.Binary.Greater" || kind == "Expr.Binary.GreaterEqual"
}

func isArithmeticKind(con kind string) bool {
    return kind == "Expr.Binary.Add" || kind == "Expr.Binary.Subtract" || kind == "Expr.Binary.Multiply" || kind == "Expr.Binary.Divide" || kind == "Expr.Binary.Remainder"
}

func isEqualityKind(con kind string) bool {
    return kind == "Expr.Binary.Equal" || kind == "Expr.Binary.NotEqual"
}

func isLogicalKind(con kind string) bool {
    return kind == "Expr.Binary.LogicalAnd" || kind == "Expr.Binary.LogicalOr"
}

func isStructKind(con kind string) bool {
    return kind == "StructDecl.Package" || kind == "StructDecl.Public"
}

func isEnumKind(con kind string) bool {
    return kind == "EnumDecl.Package" || kind == "EnumDecl.Public"
}

func isFunctionKind(con kind string) bool {
    return kind == "FunctionDecl.Package" || kind == "FunctionDecl.Public"
}

func isParamKind(con kind string) bool {
    return kind == "Param.Owned" || kind == "Param.Con" || kind == "Param.Mut"
}

func modeFromKind(con kind string) string {
    if kind == "Param.Con" || kind == "ReceiverParam.Con" || kind == "FunctionTypeParam.Con" {
        return "con"
    }
    if kind == "Param.Mut" || kind == "ReceiverParam.Mut" || kind == "FunctionTypeParam.Mut" {
        return "mut"
    }
    return "owned"
}

func argModeFromKind(con kind string) string {
    if kind == "Arg.Con" {
        return "con"
    }
    if kind == "Arg.Mut" {
        return "mut"
    }
    return "owned"
}

func constructorArgument(con program ast.Program, expression int, con constructor string) Result[int, SemanticError] {
    if ast.ChildCount(con program, expression) != 2 {
        message := strings.join(con []string{"`", token.CopyText(con constructor), "` expects exactly one argument",}, con "")
        return Err(newError(message, ast.Span(con program, expression)))
    }
    argument := ast.Child(con program, expression, 1)
    if argModeFromKind(con ast.Kind(con program, argument)) != "owned" {
        message := strings.join(con []string{"`", token.CopyText(con constructor), "` expects an owned argument",}, con "")
        return Err(newError(message, ast.Span(con program, argument)))
    }
    return Ok(ast.Child(con program, argument, 0))
}

func isBuiltinTypeName(con name string) bool {
    return name == "int" || name == "bool" || name == "string" || name == "unit" || name == "Option" || name == "Result" || name == "Slice"
}

func isBuiltinValueName(con name string) bool {
    return name == "print" || name == "len" || name == "append" || name == "Some" || name == "None" || name == "Ok" || name == "Err"
}

func declarationMetadata(con program ast.Program, declaration int, con kind string) string {
    for mut child := 0; child < ast.ChildCount(con program, declaration); child = child + 1 {
        node := ast.Child(con program, declaration, child)
        if ast.Kind(con program, node) == kind {
            return ast.Value(con program, node)
        }
    }
    return ""
}

func startsWith(con value string, con prefix string) bool {
    if strings.byteLen(con value) < strings.byteLen(con prefix) {
        return false
    }
    return match strings.slice(con value, 0, strings.byteLen(con prefix)) {
        case Ok(head) {
            head == prefix
        }
        case Err(_) {
            false
        }
    }
}

func unitType() ResolvedType {
    return ResolvedType{text: "unit", kind: "unit", copy: true, cleanup: false,}
}

func newError(message string, span source.Span) SemanticError {
    return SemanticError{message: message, span: span}
}
