pub func TypeShapeArgumentNeedsCleanup(con checked CheckedProgram, shape int, argument int) bool {
    return checked.typeShapes[shape].arguments[argument].cleanup
}

pub func TypeShapeArrayLength(con checked CheckedProgram, shape int) int {
    return checked.typeShapes[shape].arrayLength
