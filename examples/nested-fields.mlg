type Name struct {
    first string
    last string
}

type User struct {
    name Name
    age int
}

func main() {
    mut user := User{name: Name{first: "kim", last: "min"}, age: 30}
    printName(con user.name.first)
    user.name.last = "lee"
    printName(con user.name.last)
    printAge(con user.age)
}

func printName(con name string) {
    print(name)
}

func printAge(con age int) {
    print(age)
}
