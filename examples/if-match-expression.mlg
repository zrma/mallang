func main() {
    print(pick(true))
    print(pick(false))
}

func pick(flag bool) int {
    return if flag {
        match maybe(true) {
            case Some(inner) { inner }
            case None { 0 }
        }
    } else {
        match maybe(false) {
            case Some(inner) { inner }
            case None { 0 }
        }
    }
}

func maybe(flag bool) Option[int] {
    return if flag { Some(7) } else { None }
}
